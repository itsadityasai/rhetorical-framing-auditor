{"article_id":"s83RXhJb42nRJ2v0","edus":[{"id":0,"text":"WASHINGTON ( ) -","depth":1},{"id":1,"text":"President Donald Trump on Tuesday scrapped an Obama-era program","depth":8},{"id":2,"text":"that protects from deportation immigrants","depth":9},{"id":3,"text":"brought illegally into the United States as children ,","depth":9},{"id":4,"text":"delaying implementation until March","depth":8},{"id":5,"text":"and giving a gridlocked Congress six months","depth":9},{"id":6,"text":"to decide the fate of almost 800,000 young people .","depth":9},{"id":7,"text":"As the so-called Dreamers","depth":9},{"id":8,"text":"who have benefited from the five-year-old program","depth":9},{"id":9,"text":"were plunged into uncertainty ,","depth":8},{"id":10,"text":"business and religious leaders , mayors , governors , Democratic lawmakers , unions , civil liberties advocates and former Democratic President Barack Obama all condemned Trump ' s move .","depth":7},{"id":11,"text":"The action was announced not by Trump","depth":8},{"id":12,"text":"but by Jeff Sessions , his attorney general ,","depth":10},{"id":13,"text":"who called the Deferred Action for Childhood Arrivals","depth":12},{"id":14,"text":"( DACA )","depth":12},{"id":15,"text":"program an unconstitutional overreach by Obama .","depth":11},{"id":16,"text":"There will be an \" orderly , lawful wind-down , \"","depth":10},{"id":17,"text":"Sessions said .","depth":10},{"id":18,"text":"Trump later issued a written statement","depth":10},{"id":19,"text":"saying","depth":11},{"id":20,"text":"that \" I do not favor punishing children ,","depth":14},{"id":21,"text":"most of whom are now adults ,","depth":14},{"id":22,"text":"for the actions of their parents .","depth":13},{"id":23,"text":"But we must also recognize","depth":13},{"id":24,"text":"that we are ( a ) nation of opportunity","depth":14},{"id":25,"text":"because we are a nation of laws . \"","depth":14},{"id":26,"text":"He denounced Obama ' s program as an \" amnesty-first approach \" toward illegal immigrants","depth":10},{"id":27,"text":"and pressed his nationalist \" America First \" message ,","depth":11},{"id":28,"text":"saying","depth":12},{"id":29,"text":"that","depth":13},{"id":30,"text":"despite concerns","depth":15},{"id":31,"text":"voiced by his critics about the fate of the Dreamers ,","depth":15},{"id":32,"text":"\" Above all else , we must remember","depth":15},{"id":33,"text":"that young Americans have dreams too . \"","depth":15},{"id":34,"text":"On Tuesday evening , the Republican president tweeted","depth":9},{"id":35,"text":"that lawmakers now had six months","depth":11},{"id":36,"text":"to \" legalize DACA \"","depth":11},{"id":37,"text":"and that","depth":11},{"id":38,"text":"if they did not ,","depth":12},{"id":39,"text":"he would \" revisit this issue ! \"","depth":12},{"id":40,"text":"Obama issued his own statement","depth":9},{"id":41,"text":"calling Trump ' s action a political decision ,","depth":9},{"id":42,"text":"defending DACA ' s legality","depth":9},{"id":43,"text":"and urging Congress to protect Dreamers .","depth":9},{"id":44,"text":"\" This is about young people","depth":11},{"id":45,"text":"who grew up in America -","depth":11},{"id":46,"text":"kids","depth":12},{"id":47,"text":"who study in our schools ,","depth":12},{"id":48,"text":"young adults","depth":13},{"id":49,"text":"who are starting careers ,","depth":13},{"id":50,"text":"patriots","depth":13},{"id":51,"text":"who pledge allegiance to our flag .","depth":13},{"id":52,"text":"These Dreamers are Americans in their hearts , in their minds , in every single way but one :","depth":10},{"id":53,"text":"on paper , \"","depth":10},{"id":54,"text":"Obama said .","depth":8},{"id":55,"text":"The Trump administration said","depth":7},{"id":56,"text":"nobody","depth":9},{"id":57,"text":"covered by the program ,","depth":10},{"id":58,"text":"which provided work permits in addition to deportation protection","depth":11},{"id":59,"text":"and primarily benefits Hispanics ,","depth":11},{"id":60,"text":"would be affected before March 5 .","depth":8},{"id":61,"text":"Most people","depth":8},{"id":62,"text":"covered by DACA","depth":8},{"id":63,"text":"are in their 20s .","depth":7},{"id":64,"text":"Trump shifted responsibility to a Congress","depth":8},{"id":65,"text":"controlled by his fellow Republicans","depth":8},{"id":66,"text":"and said","depth":8},{"id":67,"text":"it was now up to lawmakers to pass immigration legislation","depth":9},{"id":68,"text":"that could address the fate of those","depth":11},{"id":69,"text":"protected by DACA","depth":11},{"id":70,"text":"who would be in danger of deportation .","depth":10},{"id":71,"text":"Trump and Sessions offered no details of the type of legislation","depth":9},{"id":72,"text":"they would want to see ,","depth":9},{"id":73,"text":"and Trump ' s spokeswoman offered only a broad outline .","depth":8},{"id":74,"text":"\" I have a love for these people","depth":11},{"id":75,"text":"( DACA recipients ) ,","depth":11},{"id":76,"text":"and hopefully now Congress will be able to help them","depth":11},{"id":77,"text":"and do it properly , \"","depth":11},{"id":78,"text":"Trump later told reporters at the White House ,","depth":9},{"id":79,"text":"adding :","depth":9},{"id":80,"text":"\" I think","depth":10},{"id":81,"text":"it ' s going to work out very well . \"","depth":10},{"id":82,"text":"Since Trump took office in January ,","depth":6},{"id":83,"text":"Congress has been unable to pass any major legislation ,","depth":8},{"id":84,"text":"most notably failing on a healthcare overhaul ,","depth":8},{"id":85,"text":"and lawmakers have been bitterly divided over immigration in the past .","depth":7},{"id":86,"text":"\" President Trump ' s decision","depth":9},{"id":87,"text":"to end DACA","depth":9},{"id":88,"text":"is a deeply shameful act of political cowardice and a despicable assault on innocent young people in communities across America , \"","depth":8},{"id":89,"text":"said Nancy Pelosi , the top Democrat in the House of Representatives .","depth":7},{"id":90,"text":"The Democratic attorney general of Massachusetts , Maura Healey , said","depth":8},{"id":91,"text":"a coalition of states planned to file suit in the coming days","depth":10},{"id":92,"text":"to defend DACA ,","depth":10},{"id":93,"text":"and one advocacy group announced its own legal action .","depth":9},{"id":94,"text":"\" This is a sad day for our country , \"","depth":10},{"id":95,"text":"added Facebook Inc","depth":12},{"id":96,"text":"( FB.O )","depth":12},{"id":97,"text":"founder Mark Zuckerberg .","depth":11},{"id":98,"text":"\" The decision","depth":12},{"id":99,"text":"to end DACA","depth":12},{"id":100,"text":"is not just wrong .","depth":11},{"id":101,"text":"It is particularly cruel to offer young people the American Dream ,","depth":11},{"id":102,"text":"encourage them to come out of the shadows and trust our government ,","depth":12},{"id":103,"text":"and then punish them for it . \"","depth":12},{"id":104,"text":"Brad Smith , president of Microsoft Corp","depth":11},{"id":105,"text":"( MSFT.O ) ,","depth":11},{"id":106,"text":"urged Congress to \" put the humanitarian needs of these 800,000 people on the legislative calendar \"","depth":10},{"id":107,"text":"before tax-cut legislation","depth":10},{"id":108,"text":"sought by Trump .","depth":10},{"id":109,"text":"Nearly 800,000 people stepped forward ,","depth":7},{"id":110,"text":"admitted their illegal immigrant status","depth":9},{"id":111,"text":"and provided personal information to the government","depth":9},{"id":112,"text":"to apply for the DACA program .","depth":8},{"id":113,"text":"They now face the prospect","depth":7},{"id":114,"text":"of being deported","depth":8},{"id":115,"text":"starting in March .","depth":8},{"id":116,"text":"Dreamers are a fraction of the roughly 11 million illegal immigrants in the United States .","depth":5},{"id":117,"text":"Demonstrators chant during a rally against the rescindment of DACA","depth":8},{"id":118,"text":"( Deferred Action for Childhood Arrivals )","depth":8},{"id":119,"text":"program outside the San Francisco Federal Building in San Francisco , California , U.S. , September 5 , 2017 .","depth":7},{"id":120,"text":"/Stephen Lam","depth":6},{"id":121,"text":"\" The cancellation of the DACA program is reprehensible , \"","depth":8},{"id":122,"text":"the U.S. Conference of Catholic Bishops said in a statement .","depth":8},{"id":123,"text":"But White House spokeswoman Sarah Sanders said :","depth":8},{"id":124,"text":"\" It ' s not cold hearted for the president to uphold the law . \"","depth":8},{"id":125,"text":"Trump said","depth":7},{"id":126,"text":"DACA recipients would not be deportation priorities","depth":8},{"id":127,"text":"unless they were criminals or gang members .","depth":8},{"id":128,"text":"Ending DACA was the latest action by Trump","depth":7},{"id":129,"text":"sure to alienate Hispanic Americans , a growing segment of the U.S. population and an increasingly important voting bloc .","depth":7},{"id":130,"text":"Most of the immigrants","depth":10},{"id":131,"text":"protected by DACA","depth":10},{"id":132,"text":"came from Mexico and other Latin American countries .","depth":9},{"id":133,"text":"The Mexican government said","depth":9},{"id":134,"text":"it \" profoundly laments \" Trump ' s decision","depth":11},{"id":135,"text":"to end DACA","depth":11},{"id":136,"text":"and pledged to strengthen efforts","depth":11},{"id":137,"text":"to guarantee consular protections for affected Mexican citizens .","depth":11},{"id":138,"text":"The Homeland Security Department will provide a limited window","depth":11},{"id":139,"text":"- until Oct. 5 -","depth":11},{"id":140,"text":"for some DACA recipients","depth":12},{"id":141,"text":"whose work permits expire before March 5","depth":12},{"id":142,"text":"to apply","depth":12},{"id":143,"text":"to renew those permits .","depth":12},{"id":144,"text":"In addition , the department will adjudicate any new DACA requests , or renewal requests ,","depth":10},{"id":145,"text":"accepted as of Tuesday .","depth":10},{"id":146,"text":"That would mean that some beneficiaries of DACA could work legally in the country through 2019 .","depth":8},{"id":147,"text":"The administration said","depth":7},{"id":148,"text":"the president ' s decision was prompted in part by a threat from several Republican state attorneys general ,","depth":10},{"id":149,"text":"led by Texas ,","depth":10},{"id":150,"text":"to file legal challenges in federal court","depth":9},{"id":151,"text":"if Trump did not act to end DACA .","depth":8},{"id":152,"text":"Late on Tuesday , Texas state Attorney General Ken Paxton said","depth":7},{"id":153,"text":"he withdrew the 10-state suit after Trump ' s decision .","depth":7},{"id":154,"text":"House Speaker Paul Ryan called on lawmakers to find a long-term solution for the young people","depth":6},{"id":155,"text":"affected by the reversal of the program .","depth":6},{"id":156,"text":"Republican Senate Majority Leader Mitch McConnell said","depth":7},{"id":157,"text":"Congress \" will continue working on securing our border","depth":8},{"id":158,"text":"and ensuring a lawful system of immigration","depth":9},{"id":159,"text":"that works . \"","depth":9},{"id":160,"text":"Republican Senator Lindsey Graham said","depth":7},{"id":161,"text":"there could be a winning formula","depth":9},{"id":162,"text":"by coupling legislation","depth":11},{"id":163,"text":"to provide legal status for Dreamers","depth":11},{"id":164,"text":"with additional border security measures ,","depth":10},{"id":165,"text":"although he said","depth":9},{"id":166,"text":"support was lacking in Congress for Trump ' s proposed border wall .","depth":9},{"id":167,"text":"Trump made a crackdown on illegal immigrants a centerpiece of his 2016 election campaign ,","depth":6},{"id":168,"text":"promising to deport every illegal immigrant .","depth":6},{"id":169,"text":"The decision","depth":9},{"id":170,"text":"to end DACA","depth":9},{"id":171,"text":"is the latest action by Trump","depth":8},{"id":172,"text":"to erase key parts of his Democratic predecessor ' s legacy .","depth":7},{"id":173,"text":"That includes pulling the United States out of the Paris climate accord ,","depth":7},{"id":174,"text":"abandoning a 12-nation Pacific trade deal ,","depth":8},{"id":175,"text":"seeking to dismantle the Obamacare healthcare law ,","depth":9},{"id":176,"text":"rolling back environmental protections ,","depth":10},{"id":177,"text":"reversing parts of Obama ' s opening to Cuba","depth":11},{"id":178,"text":"and removing protections for transgender people .","depth":11}],"relations":[{"parent":357,"left":0,"right":356,"relation":"organization","nuclearity":"SN"},{"parent":356,"left":294,"right":355,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":259,"right":293,"relation":"elaboration","nuclearity":"NS"},{"parent":259,"left":232,"right":258,"relation":"elaboration","nuclearity":"NS"},{"parent":232,"left":188,"right":231,"relation":"elaboration","nuclearity":"NS"},{"parent":188,"left":184,"right":187,"relation":"causal","nuclearity":"NS"},{"parent":184,"left":181,"right":183,"relation":"causal","nuclearity":"NS"},{"parent":181,"left":1,"right":180,"relation":"elaboration","nuclearity":"NS"},{"parent":180,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":183,"left":4,"right":182,"relation":"joint","nuclearity":"NN"},{"parent":182,"left":5,"right":6,"relation":"purpose","nuclearity":"NS"},{"parent":187,"left":186,"right":10,"relation":"same-unit","nuclearity":"NN"},{"parent":186,"left":185,"right":9,"relation":"same-unit","nuclearity":"NN"},{"parent":185,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":231,"left":216,"right":230,"relation":"joint","nuclearity":"NN"},{"parent":216,"left":194,"right":215,"relation":"joint","nuclearity":"NN"},{"parent":194,"lef