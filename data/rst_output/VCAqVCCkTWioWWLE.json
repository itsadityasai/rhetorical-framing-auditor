{"article_id":"VCAqVCCkTWioWWLE","edus":[{"id":0,"text":"Story highlights","depth":1},{"id":1,"text":"A Russian lawmaker says","depth":4},{"id":2,"text":"Russia will not push Snowden out","depth":4},{"id":3,"text":"Snowden wants to return home ,","depth":4},{"id":4,"text":"but he wants protection from prosecution","depth":4},{"id":5,"text":"Edward Snowden may stay in Russia longer","depth":6},{"id":6,"text":"than first thought .","depth":6},{"id":7,"text":"Snowden has said","depth":6},{"id":8,"text":"the time is n't right","depth":8},{"id":9,"text":"for him to return to the United States ,","depth":8},{"id":10,"text":"where he could face criminal charges","depth":8},{"id":11,"text":"for leaking classified information .","depth":8},{"id":12,"text":"Russia gave him asylum for a year .","depth":5},{"id":13,"text":"Now Russia says","depth":8},{"id":14,"text":"it will continue to extend asylum protections to Snowden","depth":9},{"id":15,"text":"and wo n't send him back home .","depth":9},{"id":16,"text":"That word came Friday from Alexy Pushkov , a legislator","depth":9},{"id":17,"text":"who is head of the Foreign Affairs Committee in the Duma , Russia 's lower house .","depth":9},{"id":18,"text":"He spoke about Snowden at the World Economic Forum in Davos , Switzerland .","depth":8},{"id":19,"text":"Russia 's position basically buys Snowden more time","depth":7},{"id":20,"text":"as he mulls his next move .","depth":7},{"id":21,"text":"JUST WATCHED","depth":10},{"id":22,"text":"Edward Snowden responds to CNN","depth":10},{"id":23,"text":"Replay More Videos ...","depth":9},{"id":24,"text":"MUST WATCH","depth":10},{"id":25,"text":"Edward Snowden responds to CNN","depth":10},{"id":26,"text":"01:45","depth":9},{"id":27,"text":"JUST WATCHED A DOJ deal for Edward Snowden ?","depth":11},{"id":28,"text":"Replay More Videos ...","depth":11},{"id":29,"text":"MUST WATCH A DOJ deal for Edward Snowden ?","depth":10},{"id":30,"text":"04:56","depth":9},{"id":31,"text":"JUST WATCHED","depth":10},{"id":32,"text":"Atty Gen. Holder discusses Snowden case","depth":10},{"id":33,"text":"Replay More Videos ...","depth":10},{"id":34,"text":"MUST WATCH","depth":12},{"id":35,"text":"Atty Gen. Holder discusses Snowden case","depth":12},{"id":36,"text":"01:36","depth":11},{"id":37,"text":"Snowden has said","depth":9},{"id":38,"text":"he wants to return home","depth":10},{"id":39,"text":"but also wants whistle-blower protection .","depth":10},{"id":40,"text":"The U.S. government , meanwhile , says","depth":9},{"id":41,"text":"it will not offer clemency .","depth":9},{"id":42,"text":"In an online chat Thursday , Snowden said","depth":10},{"id":43,"text":"that returning to the U.S. `` is the best resolution for all parties , ''","depth":11},{"id":44,"text":"but `` it 's unfortunately not possible in the face of current whistle-blower protection laws . ''","depth":11},{"id":45,"text":"He pointed out","depth":11},{"id":46,"text":"that the U.S. government 's Whistleblower Protection Act does n't cover someone like him , a former government contractor .","depth":11},{"id":47,"text":"`` There are so many holes in the laws ,","depth":12},{"id":48,"text":"the protections","depth":16},{"id":49,"text":"they afford","depth":16},{"id":50,"text":"are so weak ,","depth":15},{"id":51,"text":"and the processes","depth":16},{"id":52,"text":"for reporting","depth":17},{"id":53,"text":"they provide","depth":17},{"id":54,"text":"are so ineffective","depth":15},{"id":55,"text":"that they appear to be intended to discourage reporting of even the clearest wrongdoing , ''","depth":13},{"id":56,"text":"he wrote .","depth":11},{"id":57,"text":"`` ... My case clearly demonstrates the need for comprehensive whistle-blower protection act reform . ''","depth":8},{"id":58,"text":"Snowden offered his remarks from Russia ,","depth":8},{"id":59,"text":"where he 's been since June ,","depth":8},{"id":60,"text":"having been granted a one-year asylum .","depth":7},{"id":61,"text":"Pushkov 's remarks appear to open the door to an extension of that asylum .","depth":6},{"id":62,"text":"The U.S. government has n't stayed silent on his case , either .","depth":5},{"id":63,"text":"On Thursday , around the time","depth":9},{"id":64,"text":"that Snowden was answering questions online ,","depth":9},{"id":65,"text":"Attorney General Eric Holder said","depth":8},{"id":66,"text":"that","depth":8},{"id":67,"text":"`` if Mr. Snowden wanted to come back to the United States","depth":10},{"id":68,"text":"and enter a plea ,","depth":10},{"id":69,"text":"we would engage with his lawyers . ''","depth":9},{"id":70,"text":"The government would take the same tack with anyone","depth":9},{"id":71,"text":"willing to plead guilty ,","depth":9},{"id":72,"text":"Holder said at an event at the University of Virginia 's Miller Center .","depth":8},{"id":73,"text":"But in Snowden 's case , the attorney general insisted ,","depth":8},{"id":74,"text":"`` Clemency is n't something","depth":9},{"id":75,"text":"that we ( are ) willing to consider . ''","depth":9}],"relations":[{"parent":151,"left":0,"right":150,"relation":"organization","nuclearity":"SN"},{"parent":150,"left":79,"right":149,"relation":"organization","nuclearity":"SN"},{"parent":79,"left":77,"right":78,"relation":"context","nuclearity":"NS"},{"parent":77,"left":1,"right":2,"relation":"attribution","nuclearity":"SN"},{"parent":78,"left":3,"right":4,"relation":"adversative","nuclearity":"NN"},{"parent":149,"left":94,"right":148,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":85,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":85,"left":80,"right":84,"relation":"explanation","nuclearity":"NS"},{"parent":80,"left":5,"right":6,"relation":"adversative","nuclearity":"NS"},{"parent":84,"left":7,"right":83,"relation":"attribution","nuclearity":"SN"},{"parent":83,"left":81,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":8,"right":9,"relation":"purpose","nuclearity":"NS"},{"pare