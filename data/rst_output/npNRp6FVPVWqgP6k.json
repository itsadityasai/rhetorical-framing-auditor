"left":41,"right":42,"relation":"elaboration","nuclearity":"NS"},{"parent":257,"left":44,"right":45,"relation":"elaboration","nuclearity":"NS"},{"parent":287,"left":278,"right":286,"relation":"joint","nuclearity":"NN"},{"parent":278,"left":262,"right":277,"relation":"evaluation","nuclearity":"NS"},{"parent":262,"left":46,"right":261,"relation":"adversative","nuclearity":"SN"},{"parent":261,"left":47,"right":260,"relation":"elaboration","nuclearity":"NS"},{"parent":260,"left":48,"right":49,"relation":"purpose","nuclearity":"NS"},{"parent":277,"left":263,"right":276,"relation":"elaboration","nuclearity":"NS"},{"parent":263,"left":50,"right":51,"relation":"attribution","nuclearity":"NS"},{"parent":276,"left":266,"right":275,"relation":"joint","nuclearity":"NN"},{"parent":266,"left":52,"right":265,"relation":"attribution","nuclearity":"SN"},{"parent":265,"left":53,"right":264,"relation":"same-unit","nuclearity":"NN"},{"parent":264,"left":54,"right":55,"relation":"adversative","nuclearity":"NS"},{"parent":275,"left":272,"right":274,"relation":"joint","nuclearity":"NN"},{"parent":272,"left":56,"right":271,"relation":"attribution","nuclearity":"SN"},{"parent":271,"left":57,"right":270,"relation":"same-unit","nuclearity":"NN"},{"parent":270,"left":58,"right":269,"relation":"explanation","nuclearity":"SN"},{"parent":269,"left":59,"right":268,"relation":"attribution","nuclearity":"SN"},{"parent":268,"left":267,"right":62,"relation":"same-unit","nuclearity":"NN"},{"parent":267,"left":60,"right":61,"relation":"elaboration","nuclearity":"NS"},{"parent":274,"left":273,"right":65,"relation":"same-unit","nuclearity":"NN"},{"parent":273,"left":63,"right":64,"relation":"elaboration","nuclearity":"NS"},{"parent":286,"left":283,"right":285,"relation":"joint","nuclearity":"NN"},{"parent":283,"left":66,"right":282,"relation":"explanation","nuclearity":"NS"},{"parent":282,"left":280,"right":281,"relation":"attribution","nuclearity":"SN"},{"parent":280,"left":279,"right":69,"relation":"same-unit","nuclearity":"NN"},{"parent":279,"left":67,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":281,"left":70,"right":71,"relation":"joint","nuclearity":"NN"},{"parent":285,"left":72,"right":284,"relation":"attribution","nuclearity":"SN"},{"parent":284,"left":73,"right":74,"relation":"adversative","nuclearity":"NS"},{"parent":428,"left":302,"right":427,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":297,"right":301,"relation":"adversative","nuclearity":"SN"},{"parent":297,"left":289,"right":296,"relation":"explanation","nuclearity":"NS"},{"parent":289,"left":75,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":296,"left":292,"right":295,"relation":"joint","nuclearity":"NN"},{"parent":292,"left":77,"right":291,"relation":"attribution","nuclearity":"SN"},{"parent":291,"left":290,"right":80,"relation":"same-unit","nuclearity":"NN"},{"parent":290,"left":78,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":293,"right":294,"relation":"same-unit","nuclearity":"NN"},{"parent":293,"left":81,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":83,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":299,"right":300,"relation":"adversative","nuclearity":"SN"},{"parent":299,"left":85,"right":298,"relation":"attribution","nuclearity":"SN"},{"parent":298,"left":86,"right":87,"relation":"attribution","nuclearity":"SN"},{"parent":300,"left":88,"right":89,"relation":"attribution","nuclearity":"SN"},{"parent":427,"left":347,"right":426,"relation":"joint","nuclearity":"NN"},{"parent":347,"left":334,"right":346,"relation":"elaboration","nuclearity":"NS"},{"parent":334,"left":304,"right":333,"relation":"adversative","nuclearity":"SN"},{"parent":304,"left":90,"right":303,"relation":"attribution","nuclearity":"SN"},{"parent":303,"left":91,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":333,"left":93,"right":332,"relation":"elaboration","nuclearity":"NS"},{"