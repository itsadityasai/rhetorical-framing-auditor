{"article_id":"pvyZYTgzVtqmYKKx","edus":[{"id":0,"text":"WASHINGTON , DC -","depth":1},{"id":1,"text":"Obamacare was back in court Tuesday","depth":5},{"id":2,"text":"facing yet another legal challenge .","depth":5},{"id":3,"text":"At issue in the `` Texas vs. United States '' case is whether a lower court judge acted properly","depth":5},{"id":4,"text":"in striking down the Affordable Care Act","depth":7},{"id":5,"text":"( ACA ) ,","depth":7},{"id":6,"text":"declaring the law unconstitutional","depth":7},{"id":7,"text":"after Congress ended the `` individual mandate '' .","depth":7},{"id":8,"text":"The Fifth Circuit Court of Appeals appeared sympathetic Tuesday to Republican efforts","depth":7},{"id":9,"text":"to overturn Obamacare .","depth":7},{"id":10,"text":"They expressed skepticism about Democratic calls","depth":7},{"id":11,"text":"to overturn the lower court ruling .","depth":7},{"id":12,"text":"The judges focused on","depth":6},{"id":13,"text":"whether Obamacare lost its legal justification","depth":7},{"id":14,"text":"after President Trump signed a law in 2017","depth":8},{"id":15,"text":"that eliminated the tax penalty","depth":10},{"id":16,"text":"- known as the `` individual mandate '' -","depth":10},{"id":17,"text":"that had enforced Obamacare 's mandate","depth":10},{"id":18,"text":"that all Americans must buy health insurance .","depth":10},{"id":19,"text":"Whatever the court decides ,","depth":5},{"id":20,"text":"the case could go to the US Supreme Court .","depth":5},{"id":21,"text":"As the appeals court heard arguments on the ACA 's constitutionality ,","depth":5},{"id":22,"text":"Democrats on Capitol Hill held a press conference","depth":9},{"id":23,"text":"warning what could happen","depth":10},{"id":24,"text":"if Obamacare is struck down .","depth":10},{"id":25,"text":"Senate Minority Leader Chuck Schumer","depth":11},{"id":26,"text":"( D-NY )","depth":11},{"id":27,"text":"said ,","depth":10},{"id":28,"text":"`` The stakes ca n't be higher . ''","depth":9},{"id":29,"text":"Democrat lawmakers held up pictures of Americans","depth":10},{"id":30,"text":"positively affected by Obamacare","depth":10},{"id":31,"text":"and said","depth":10},{"id":32,"text":"Republicans would be to blame","depth":11},{"id":33,"text":"if millions of Americans were to lose their health care .","depth":11},{"id":34,"text":"`` If Republicans prevail ,","depth":11},{"id":35,"text":"the protections are obliterated overnight , ''","depth":11},{"id":36,"text":"continued Schumer .","depth":10},{"id":37,"text":"`` They go home","depth":10},{"id":38,"text":"and they say","depth":13},{"id":39,"text":"they want to protect pre-existing conditions ,","depth":13},{"id":40,"text":"and then they act","depth":13},{"id":41,"text":"to take them away...","depth":13},{"id":42,"text":"they say","depth":13},{"id":43,"text":"they want to protect","depth":13},{"id":44,"text":"and then do nothing","depth":13},{"id":45,"text":"to preserve them . ''","depth":13},{"id":46,"text":"But on the Senate floor , Republican Sen. John Cornyn","depth":10},{"id":47,"text":"( R-TX )","depth":10},{"id":48,"text":"argued","depth":9},{"id":49,"text":"that claim is untrue .","depth":8},{"id":50,"text":"`` Blaming Republicans in Congress for a yet-to-be-decided court case does n't make a lot of sense , ''","depth":9},{"id":51,"text":"Cornyn claimed .","depth":9},{"id":52,"text":"`` If there 's one thing","depth":10},{"id":53,"text":"that I think","depth":11},{"id":54,"text":"there is a consensus on in the health care field in Congress","depth":11},{"id":55,"text":"it 's the pre-existing conditions should be covered . ''","depth":9},{"id":56,"text":"Meanwhile , at the Faith and Freedom Coalition 's Road to the Majority conference last week , President Donald Trump teased a forthcoming GOP health care plan .","depth":5},{"id":57,"text":"`` If we win the House back ,","depth":10},{"id":58,"text":"keep the Senate","depth":11},{"id":59,"text":"and keep the presidency ,","depth":11},{"id":60,"text":"we 're going to have a plan","depth":10},{"id":61,"text":"that blows away Obamacare , ''","depth":10},{"id":62,"text":"Trump told the crowd .","depth":8},{"id":63,"text":"`` It 'll be less expensive","depth":8},{"id":64,"text":"and it 'll be far better health insurance","depth":8},{"id":65,"text":"and we 'll be announcing it over the next month or so . ''","depth":6},{"id":66,"text":"Many analysts believe","depth":4},{"id":67,"text":"if the 5th Circuit upholds Obamacare ,","depth":5},{"id":68,"text":"the US Supreme Court wo n't take it up again .","depth":5}],"relations":[{"parent":137,"left":0,"right":136,"relation":"organization","nuclearity":"SN"},{"parent":136,"left":88,"right":135,"relation":"elaboration","nuclearity":"NS"},{"parent":88,"left":75,"right":87,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":70,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":1,"right":2,"relation":"context","nuclearity":"NS"},{"parent":74,"left":3,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":71,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":4,"right":5,"relation":"restatement","nuclearity":"NS"},{"parent":72,"left":6,"right":7,"relation":"context","nuclearity":"NS"},{"parent":87,"left":85,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":85,"left":78,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":76,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":8,"right":9,"relation":"purpose","nuclearity":"NS"},{"parent":77,"left":10,"right":11,"relation":"purpose","nuclearity":"NS"},{"parent":84,"left":12,"right":83,"relation":"attribution","nuclearity":"SN"},{"parent":83,"left":13,"right":82,"relation":"context","nuclearity":"NS"},{"parent":82,"left":14,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":79,"right":80,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":15,