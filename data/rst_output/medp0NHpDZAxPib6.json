{"article_id":"medp0NHpDZAxPib6","edus":[{"id":0,"text":"LISTEN TO ARTICLE 3:10","depth":1},{"id":1,"text":"SHARE THIS ARTICLE","depth":3},{"id":2,"text":"Share Tweet","depth":5},{"id":3,"text":"Post Email","depth":5},{"id":4,"text":"Attorney General William Barr said","depth":8},{"id":5,"text":"Special Counsel Robert Mueller recounted 10 episodes of potential obstruction by President Donald Trump ,","depth":9},{"id":6,"text":"though Barr said","depth":10},{"id":7,"text":"there was evidence","depth":11},{"id":8,"text":"that Trump had \" noncorrupt motives . \"","depth":11},{"id":9,"text":"Barr said","depth":8},{"id":10,"text":"he and his deputy disagreed with some of Mueller ' s theories on obstruction .","depth":8},{"id":11,"text":"`` The president took no action","depth":9},{"id":12,"text":"that in fact deprived the special counsel of the documents and witnesses","depth":10},{"id":13,"text":"necessary to complete the investigation , \"","depth":10},{"id":14,"text":"the attorney general said at a news conference Thursday .","depth":8},{"id":15,"text":"Barr disclosed","depth":11},{"id":16,"text":"that he let the president ' s personal lawyer see the report in advance of its delivery to Congress at 11 a.m. with \" limited redactions. \"","depth":11},{"id":17,"text":"The White House didn ' t request","depth":13},{"id":18,"text":"that additional material be withheld","depth":13},{"id":19,"text":"and there were no redactions","depth":13},{"id":20,"text":"based on executive privilege ,","depth":13},{"id":21,"text":"Barr said .","depth":11},{"id":22,"text":"The attorney general also said","depth":11},{"id":23,"text":"that Russians didn ' t have the \" knowing assistance \" of any Americans in their interference in the 2016 campaign .","depth":11},{"id":24,"text":"\" The Russian operatives","depth":13},{"id":25,"text":"who perpetrated these schemes","depth":13},{"id":26,"text":"did not have the cooperation of President Trump or the Trump campaign","depth":13},{"id":27,"text":"-- or the knowing assistance of any other American for that matter , \"","depth":13},{"id":28,"text":"Barr said .","depth":11},{"id":29,"text":"Barr said","depth":11},{"id":30,"text":"leaders of several congressional committees will be given a version of the report with no redactions","depth":12},{"id":31,"text":"except those","depth":13},{"id":32,"text":"relating to grand jury information .","depth":13},{"id":33,"text":"He also said","depth":11},{"id":34,"text":"he wouldn ' t object to Mueller testifying before Congress ,","depth":12},{"id":35,"text":"as lawmakers have sought .","depth":12},{"id":36,"text":"House Judiciary Chairman Jerrold Nadler sent a letter to Mueller","depth":10},{"id":37,"text":"requesting his testimony \" as soon as possible . \"","depth":10},{"id":38,"text":"Democrats blasted Barr ' s decision","depth":8},{"id":39,"text":"to hold a briefing","depth":9},{"id":40,"text":"before the public could see Mueller ' s findings ,","depth":9},{"id":41,"text":"portraying it as an effort","depth":8},{"id":42,"text":"to spin the findings in Trump ' s favor .","depth":8},{"id":43,"text":"Five House chairmen released a joint statement","depth":8},{"id":44,"text":"calling on Barr to cancel the news conference","depth":9},{"id":45,"text":"and \" let the full report speak for itself . \"","depth":9},{"id":46,"text":"House Speaker Nancy Pelosi and Senate Democratic Leader Chuck Schumer said in a statement","depth":8},{"id":47,"text":"that the only way","depth":10},{"id":48,"text":"to restore public trust after Barr ' s \" regrettably partisan handling \" of the report","depth":10},{"id":49,"text":"was for Mueller to testify .","depth":9},{"id":50,"text":"Mueller Day :","depth":4},{"id":51,"text":"What to Look for","depth":5},{"id":52,"text":"When His Redacted Report Is Out","depth":5},{"id":53,"text":"Barr previously had said","depth":7},{"id":54,"text":"he would withhold material in the report","depth":8},{"id":55,"text":"that touched on classified information , continuing investigations and grand jury proceedings","depth":9},{"id":56,"text":"or that could damage the reputations of people \" peripheral \" to the investigation .","depth":9},{"id":57,"text":"Democrats are demanding the full report","depth":7},{"id":58,"text":"-- and all the evidence behind it .","depth":7},{"id":59,"text":"The House Judiciary Committee voted on April 3 to authorize a subpoena for Barr","depth":7},{"id":60,"text":"to provide that material .","depth":7},{"id":61,"text":"If no accord is reached between the lawmakers and the attorney general ,","depth":7},{"id":62,"text":"a subpoena could result in a legal clash","depth":8},{"id":63,"text":"that could reach the Supreme Court .","depth":8},{"id":64,"text":"In a four-page summary","depth":11},{"id":65,"text":"Barr released last month ,","depth":11},{"id":66,"text":"he said","depth":10},{"id":67,"text":"that Mueller didn ' t establish","depth":10},{"id":68,"text":"that Trump or anyone","depth":13},{"id":69,"text":"associated with his campaign","depth":13},{"id":70,"text":"conspired or coordinated with Russia","depth":12},{"id":71,"text":"\" despite multiple efforts by Russian-affiliated individuals","depth":12},{"id":72,"text":"to assist the Trump campaign . \"","depth":12},{"id":73,"text":"However , Mueller said","depth":10},{"id":74,"text":"his probe didn ' t \" exonerate \" Trump on the question","depth":11},{"id":75,"text":"of whether he obstructed the investigation ,","depth":11},{"id":76,"text":"according to Barr ' s summary .","depth":9},{"id":77,"text":"Rather , Mueller said","depth":8},{"id":78,"text":"he found evidence \" on both sides of the question . \"","depth":8},{"id":79,"text":"Nonetheless , Barr said","depth":7},{"id":80,"text":"that he and Deputy Attorney General Rod Rosenstein ,","depth":10},{"id":81,"text":"who appeared alongside him Thursday ,","depth":10},{"id":82,"text":"reached their own conclusion","depth":9},{"id":83,"text":"that there wasn ' t sufficient evidence","depth":9},{"id":84,"text":"to establish","depth":10},{"id":85,"text":"that Trump committed a crime .","depth":10},{"id":86,"text":"Trump and his allies seized on Barr ' s summary","depth":7},{"id":87,"text":"to declare","depth":8},{"id":88,"text":"that the president was exonerated by Mueller ' s report .","depth":8},{"id":89,"text":"\" The Greatest Political Hoax of all time ! \"","depth":7},{"id":90,"text":"Trump said of the Russia probe in a tweet Thursday morning .","depth":7}],"relations":[{"parent":181,"left":0,"right":180,"relation":"organization","nuclearity":"SN"},{"parent":180,"left":139,"right":179,"relation":"joint","nuclearity":"NN"},{"parent":139,"left":1,"right":138,"relation":"organization","nuclearity":"SN"},{"parent":138,"left":92,"right":137,"relation":"organization","nuclearity":"SN"},{"parent":92,"left":2,"right":3,"relation":"joint","nuclearity":"NN"},{"parent":137,"left":125,"right":136,"relation":"joint","nuclearity":"NN"},{"parent":125,"left":98,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":98,"left":96,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":96,"left":4,"right":95,"relation":"attribution","nuclearity":"SN"},{"parent":95,"left":5,"right":94,"relation":"adversative","nuclearity":"NS"},{"parent":94,"left":6,"right":93,"relation":"attribution","nuclearity":"SN"},{"parent":93,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":97,"left":9,"right":10,"relation":"attribution","nuclearity":"SN"},{"parent":124,"left":101,"right":123,"relation":"joint","nuclearity":"NN"},{"parent":101,"left":100,"right":14,"relation":"attribution","nuclearity":"NS"},{"parent":100,"left":11,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":114,"right":122,"relation":"joint","nuclearity":"NN"},{"parent":114,"left":107,"right":113,"relation":"elaboration","nuclearity":"NS"},{"parent":107,"left":102,"righ