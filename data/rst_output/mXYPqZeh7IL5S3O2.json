{"article_id":"mXYPqZeh7IL5S3O2","edus":[{"id":0,"text":"Joe Biden departs after a campaign stop in Manchester , N.H. , June 5 , 2019 .","depth":3},{"id":1,"text":"( Brian Snyder/Reuters )","depth":3},{"id":2,"text":"In an effort","depth":4},{"id":3,"text":"to woo leftist primary voters ,","depth":4},{"id":4,"text":"the former vice president is showing himself to lack principles","depth":4},{"id":5,"text":"- and further damaging his party ' s 2020 prospects .","depth":4},{"id":6,"text":"Nineteen Democrats","depth":8},{"id":7,"text":"running for president","depth":8},{"id":8,"text":"took the stage in Iowa on Sunday","depth":7},{"id":9,"text":"to woo voters .","depth":6},{"id":10,"text":"It was a circus of left-wingers","depth":7},{"id":11,"text":"going bonkers for things","depth":8},{"id":12,"text":"most Americans don ' t want .","depth":8},{"id":13,"text":"The front-runners back abortion any time before birth ,","depth":7},{"id":14,"text":"abolishing Immigration and Customs Enforcement ,","depth":8},{"id":15,"text":"outlawing gas-burning cars ,","depth":9},{"id":16,"text":"shutting down fossil-fuel industries","depth":11},{"id":17,"text":"that employ millions ,","depth":11},{"id":18,"text":"and redistributing wealth .","depth":10},{"id":19,"text":"These White House contenders are veering far left ,","depth":6},{"id":20,"text":"even though polls show","depth":7},{"id":21,"text":"half their own party ' s voters aren ' t \" liberal . \"","depth":7},{"id":22,"text":"It ' s a worrisome spectacle .","depth":5},{"id":23,"text":"For 150 years , our two-party system has provided political stability","depth":7},{"id":24,"text":"envied by the rest of the world .","depth":7},{"id":25,"text":"Republicans and Democrats put forward broad agendas","depth":9},{"id":26,"text":"to compete for the widest number of voters .","depth":9},{"id":27,"text":"When one party wins ,","depth":9},{"id":28,"text":"the other cedes power","depth":10},{"id":29,"text":"and cooperates in governing .","depth":10},{"id":30,"text":"Not this time .","depth":7},{"id":31,"text":"The Democratic contenders are espousing policies","depth":8},{"id":32,"text":"few Americans support","depth":8},{"id":33,"text":"and giving moderate and conservative members of their own party the cold shoulder .","depth":7},{"id":34,"text":"They ' re also vowing to destroy their Republican opponent , President Donald Trump .","depth":6},{"id":35,"text":"Front-runner Joe Biden wasn ' t in Iowa ,","depth":6},{"id":36,"text":"but his three nearest challengers","depth":11},{"id":37,"text":"- Senator Bernie Sanders","depth":13},{"id":38,"text":"( Vt. ) ,","depth":13},{"id":39,"text":"Senator Elizabeth Warren","depth":14},{"id":40,"text":"( Mass . ) ,","depth":14},{"id":41,"text":"and South Bend , Ind. , mayor Pete Buttigieg -","depth":13},{"id":42,"text":"took aim at Biden ,","depth":10},{"id":43,"text":"warning against picking a moderate .","depth":9},{"id":44,"text":"\" We ' re not going to win","depth":10},{"id":45,"text":"by playing it safe , \"","depth":10},{"id":46,"text":"said Mayor Pete .","depth":9},{"id":47,"text":"Sanders railed against a \" middle-ground strategy \"","depth":8},{"id":48,"text":"that \" changes nothing . \"","depth":8},{"id":49,"text":"So far , Iowans aren ' t convinced .","depth":5},{"id":50,"text":"Polling shows Biden almost ten points ahead of the radicals ,","depth":5},{"id":51,"text":"because he has name recognition","depth":6},{"id":52,"text":"and he ' s electable .","depth":6},{"id":53,"text":"But Biden ' s changing fast .","depth":5},{"id":54,"text":"He ' s dumping long-held positions","depth":7},{"id":55,"text":"and kowtowing to radicals","depth":8},{"id":56,"text":"nipping at his heels .","depth":8},{"id":57,"text":"He ' s already careened left on abortion and climate","depth":7},{"id":58,"text":"and is likely to go for open borders , too .","depth":7},{"id":59,"text":"For decades , Biden opposed taxpayer-funded abortions ,","depth":9},{"id":60,"text":"citing his Catholic faith .","depth":9},{"id":61,"text":"He even authored the 1981 Biden amendment","depth":9},{"id":62,"text":"banning foreign aid from paying for abortion research .","depth":9},{"id":63,"text":"But last week , he flip-flopped ,","depth":8},{"id":64,"text":"announcing","depth":9},{"id":65,"text":"he now supports federal funding .","depth":9},{"id":66,"text":"Does he actually have principles ?","depth":6},{"id":67,"text":"Most Americans ,","depth":8},{"id":68,"text":"including Democrats ,","depth":8},{"id":69,"text":"see abortion as a wrenching , complicated issue .","depth":7},{"id":70,"text":"A recent NPR/Marist poll finds","depth":8},{"id":71,"text":"only 18 percent support third-trimester abortion .","depth":8},{"id":72,"text":"Yet every senator","depth":11},{"id":73,"text":"running for president","depth":11},{"id":74,"text":"voted against a bill","depth":10},{"id":75,"text":"requiring doctors to help infants","depth":10},{"id":76,"text":"who survive a late-term abortion .","depth":10},{"id":77,"text":"Senator Kirsten Gillibrand","depth":12},{"id":78,"text":"( N.Y. )","depth":12},{"id":79,"text":"says","depth":11},{"id":80,"text":"there ' s no room in the party \" for a Democratic candidate","depth":11},{"id":81,"text":"who does not support women ' s full reproductive freedom. \"","depth":11},{"id":82,"text":"That ' s slamming the door on a majority of voters .","depth":9},{"id":83,"text":"On climate , Biden ' s already capitulated to the Green New Dealers .","depth":6},{"id":84,"text":"Last week , he announced his plan","depth":8},{"id":85,"text":"to force the U.S. into zero net carbon emissions by 2050 ,","depth":9},{"id":86,"text":"including regulating gasoline-powered cars out of existence .","depth":9},{"id":87,"text":"This may be popular with coastal elites ,","depth":8},{"id":88,"text":"but say goodbye to heartland voters","depth":9},{"id":89,"text":"working in the auto and fossil-fuel industries .","depth":9},{"id":90,"text":"For years , Biden and mainstream Democrats such as Bill Clinton and Barack Obama called for strong borders .","depth":11},{"id":91,"text":"President Obama was dubbed \" deporter-in-chief. \"","depth":11},{"id":92,"text":"Yet Biden ' s now under assault for his past views .","depth":10},{"id":93,"text":"Expect another flip-flop .","depth":10},{"id":94,"text":"Today , most elected Dems are siding with illegal immigrants instead of with the public .","depth":11},{"id":95,"text":"Last week , the House was asked to pass $ 4.5 billion in border-relief funding","depth":15},{"id":96,"text":"- with the lion ' s share for food , medical care , and schooling for children .","depth":15},{"id":97,"text":"Democrats refused","depth":15},{"id":98,"text":"because a sliver of the funds would pay for border guards and enforcement .","depth":15},{"id":99,"text":"This is proof","depth":14},{"id":100,"text":"that Democrats are for open borders .","depth":14},{"id":101,"text":"Yet polling shows","depth":13},{"id":102,"text":"that 54 percent of Americans want more done","depth":14},{"id":103,"text":"to stop illegal immigration .","depth":14},{"id":104,"text":"Last week , they got it .","depth":9},{"id":105,"text":"Trump , the deal-maker , used tariffs","depth":10},{"id":106,"text":"to coax Mexico into stopping the caravans","depth":11},{"id":107,"text":"long before they would reach the U.S. border .","depth":11},{"id":108,"text":"Trump ' s success left Dems such as Sanders mumbling platitudes","depth":9},{"id":109,"text":"about not going to \" verbal war \" with our allies .","depth":9},{"id":110,"text":"Eleven of the Democratic presidential contenders are also calling for the House to impeach Trump ,","depth":10},{"id":111,"text":"while House speaker Nancy Pelosi says","depth":11},{"id":112,"text":"she wants him in prison .","depth":11},{"id":113,"text":"That ' s banana-republic talk .","depth":9},{"id":114,"text":"Democrats","depth":9},{"id":115,"text":"eyeing the White House","depth":9},{"id":116,"text":"need to get real .","depth":8},{"id":117,"text":"By writing off moderate and conservative members of their own party ,","depth":9},{"id":118,"text":"they ' re boosting Trump ' s chances of reelection .","depth":9},{"id":119,"text":"Then again , Trump ' s reelection may be the gut punch","depth":9},{"id":120,"text":"that brings the Democratic party back to its senses .","depth":9}],"relations":[{"parent":241,"left":126,"right":240,"relation":"explanation","nuclearity":"NS"},{"parent":126,"left":122,"right":125,"relation":"context","nuclearity":"SN"},{"parent":122,"left":0,"right":1,"relation":"attribution","nuclearity":"NS"},{"parent":125,"left":123,"right":124,"relation":"same-unit","nuclearity":"NN"},{"parent":123,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":124,"left":4,"right":5,"relation":"causal","nuclearity":"NS"},{"parent":240,"left":169,"right":239,"relation":"elaboration","nuclearity":"NS"},{"parent":169,"left":142,"right":168,"relation":"elaboration","nuclearity":"NS"},{"parent":142,"left":138,"right":141,"relation":"evaluation","nuclearity":"NS"},{"parent":138,"left":129,"right":137,"relation":"elaboration","nuclearity":"NS"},{"parent":129,"left":128,"right":9,"relation":"purpose","nuclearity":"NS"},{"parent":128,"left":127,"right":8,"relation":"same-unit","nuclearity":"NN"},{"parent":127,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":137,"left":131,"right":136,"relation":"elaboration","nuclearity":"NS"},{"parent":131,"left":10,"right":130,"relation":"elaboration","nuclearity":"NS"},{"parent":130,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":136,"left":13,"right":135,"relation":"joint","nuclearity":"NN"},{"parent":135,"left":14,"right":134,"relation":"joint","nuclearity":"NN"},{"parent":134,"left":15,"right":133,"relation":"joint","nuclearity":"NN"},{"parent":133,"left":132,"right":18,"relation":"joint","nuclearity":"NN"},{"parent":132,"left":16,"right":17,"relation":"elabor