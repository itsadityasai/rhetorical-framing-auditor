learity":"NS"},{"parent":273,"left":125,"right":126,"relation":"attribution","nuclearity":"SN"},{"parent":277,"left":127,"right":276,"relation":"attribution","nuclearity":"SN"},{"parent":276,"left":275,"right":130,"relation":"joint","nuclearity":"NN"},{"parent":275,"left":128,"right":129,"relation":"purpose","nuclearity":"NS"},{"parent":298,"left":292,"right":297,"relation":"joint","nuclearity":"NN"},{"parent":292,"left":291,"right":141,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":284,"right":290,"relation":"explanation","nuclearity":"NS"},{"parent":284,"left":131,"right":283,"relation":"same-unit","nuclearity":"NN"},{"parent":283,"left":132,"right":133,"relation":"context","nuclearity":"SN"},{"parent":290,"left":287,"right":289,"relation":"adversative","nuclearity":"SN"},{"parent":287,"left":285,"right":286,"relation":"elaboration","nuclearity":"NS"},{"parent":285,"left":134,"right":135,"relation":"purpose","nuclearity":"NS"},{"parent":286,"left":136,"right":137,"relation":"attribution","nuclearity":"SN"},{"parent":289,"left":288,"right":140,"relation":"same-unit","nuclearity":"NN"},{"parent":288,"left":138,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":142,"right":296,"relation":"organization","nuclearity":"SN"},{"parent":296,"left":143,"right":295,"relation":"joint","nuclearity":"NN"},{"parent":295,"left":144,"right":294,"relation":"context","nuclearity":"SN"},{"parent":294,"left":293,"right":147,"relation":"same-unit","nuclearity":"NN"},{"parent":293,"left":145,"right":146,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":301,"right":311,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":148,"right":149,"relation":"condition","nuclearity":"NS"},{"parent":311,"left":303,"right":310,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":302,"right":152,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":150,"right":151,"relation":"purpose","nuclearity":"NS"},{"parent":310,"le