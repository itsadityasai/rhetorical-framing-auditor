{"article_id":"L3wlvhpCwFOzOpdB","edus":[{"id":0,"text":"Lawmakers in both parties celebrated reaching a spending deal","depth":5},{"id":1,"text":"that would avoid a government shutdown this week ,","depth":5},{"id":2,"text":"but President Trump took to Twitter on Tuesday morning","depth":5},{"id":3,"text":"to argue","depth":7},{"id":4,"text":"that the country `` needs a good shutdown ''","depth":7},{"id":5,"text":"to fix Senate rules","depth":7},{"id":6,"text":"that require him to negotiate with Democrats .","depth":7},{"id":7,"text":"The deal","depth":8},{"id":8,"text":"struck by Republican and Democratic leaders","depth":8},{"id":9,"text":"to fund the government through Sept. 30","depth":7},{"id":10,"text":"includes some of the increased defense spending","depth":7},{"id":11,"text":"Trump had requested","depth":8},{"id":12,"text":"but not funding for his wall along the Mexican border .","depth":8},{"id":13,"text":"It also continues subsidies for health insurance under Obamacare","depth":7},{"id":14,"text":"and provides emergency funding for Puerto Rico ,","depth":8},{"id":15,"text":"where a budget crisis has threatened Medicaid payments .","depth":8},{"id":16,"text":"Both were big Democratic priorities .","depth":6},{"id":17,"text":"Congress is expected to vote on the deal in the next couple of days ;","depth":5},{"id":18,"text":"the government is currently funded only through Friday under a temporary measure","depth":6},{"id":19,"text":"passed last week .","depth":6},{"id":20,"text":"Trump tweeted Tuesday","depth":6},{"id":21,"text":"that the deal had to be negotiated","depth":6},{"id":22,"text":"because Republicans ca n't push a bill through the Senate","depth":6},{"id":23,"text":"without bipartisan support .","depth":6},{"id":24,"text":"He then suggested changing Senate rules","depth":7},{"id":25,"text":"to scrap the minority party 's ability","depth":8},{"id":26,"text":"to block legislation ,","depth":8},{"id":27,"text":"and said","depth":7},{"id":28,"text":"a government shutdown would help .","depth":7},{"id":29,"text":"Senate Majority Leader Mitch McConnell , R-Ky. , changed the Senate rules this year","depth":7},{"id":30,"text":"to allow Supreme Court Justice Neil Gorsuch to be confirmed","depth":8},{"id":31,"text":"without Democratic support ,","depth":8},{"id":32,"text":"but he said","depth":7},{"id":33,"text":"he would not change the rules for other legislation .","depth":7},{"id":34,"text":"Trump 's budget director","depth":9},{"id":35,"text":"- former congressman Mick Mulvaney -","depth":9},{"id":36,"text":"told reporters Tuesday ,","depth":8},{"id":37,"text":"`` The president ' s tweet was","depth":9},{"id":38,"text":"'we might need a shutdown at some point","depth":10},{"id":39,"text":"to drive home","depth":11},{"id":40,"text":"that Washington needs to be fixed . '","depth":11},{"id":41,"text":"I think","depth":9},{"id":42,"text":"that ' s a defensible position , one","depth":10},{"id":43,"text":"we ' ll deal with in September . ''","depth":10},{"id":44,"text":"But Mulvaney added ,","depth":8},{"id":45,"text":"`` The truth of the matter though is now we ' ve averted a government shutdown in a way","depth":9},{"id":46,"text":"that allows the president to fund his priorities .","depth":9},{"id":47,"text":"That ' s the story now ,","depth":9},{"id":48,"text":"not what might happen in September .","depth":9},{"id":49,"text":"We ' ve got a lot of things to do between now and September . ''","depth":8},{"id":50,"text":"House Appropriations Chairman Rodney Frelinghuysen , R-N.J. , said simply ,","depth":6},{"id":51,"text":"\" I don ' t ever want to see a government shut down . \"","depth":6},{"id":52,"text":"Democrats expressed dismay at the president","depth":5},{"id":53,"text":"appearing to advocate for a government shutdown .","depth":5},{"id":54,"text":"Speaking later in the day at an event","depth":4},{"id":55,"text":"to honor the Air Force Academy football team ,","depth":4},{"id":56,"text":"Trump made no reference to a shutdown","depth":3},{"id":57,"text":"and said","depth":4},{"id":58,"text":"the short-term spending bill is `` a clear win for the American people . ''","depth":4},{"id":59,"text":"He said","depth":4},{"id":60,"text":"it makes a downpayment on building his border wall","depth":6},{"id":61,"text":"and includes a major increase in defense spending .","depth":6},{"id":62,"text":"`` We are at last reversing years of military cuts , ''","depth":6},{"id":63,"text":"he said .","depth":6}],"relations":[{"parent":127,"left":117,"right":126,"relation":"joint","nuclearity":"NN"},{"parent":117,"left":83,"right":116,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":70,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":65,"right":69,"relation":"adversative","nuclearity":"NN"},{"parent":65,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":2,"right":68,"relation":"purpose","nuclearity":"NS"},{"parent":68,"left":66,"right":67,"relation":"purpose","nuclearity":"NS"},{"parent":66,"left":3,"right":4,"relation":"attribution","nuclearity":"SN"},{"parent":67,"left":5,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":79,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":75,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":72,"right":74,"relation":"same-unit","nuclearity":"NN"},{"parent":72,"left":71,"right":9,"relation":"purpose","nuclearity":"NS"},{"parent":71,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":10,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":11,"right":12,"relation":"adversative","nuclearity":"NN"},{"parent":78,"left":77,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":13,"right":76,"relation":"joint","nuclearity":"NN"},{"parent":76,"left":14,"right":15,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":17,"right":80,"rel