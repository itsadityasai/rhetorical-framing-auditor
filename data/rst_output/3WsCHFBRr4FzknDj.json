{"article_id":"3WsCHFBRr4FzknDj","edus":[{"id":0,"text":"Amazon ' s decision","depth":9},{"id":1,"text":"to raise workers ' minimum wage to $ 15 per hour","depth":9},{"id":2,"text":"was welcome news ,","depth":8},{"id":3,"text":"even Sen. Bernie Sanders praised the move .","depth":7},{"id":4,"text":"But for some Amazon employees , the excitement didn ' t last very long","depth":7},{"id":5,"text":"as they learned","depth":8},{"id":6,"text":"that existing financial incentives and bonus programs ,","depth":11},{"id":7,"text":"including stock and monthly bonuses ,","depth":12},{"id":8,"text":"that usually boost paychecks","depth":12},{"id":9,"text":"will be eliminated","depth":10},{"id":10,"text":"starting November 1 .","depth":9},{"id":11,"text":"Several Amazon warehouse workers in the U.S. ,","depth":9},{"id":12,"text":"who spoke to Yahoo Finance on the condition of anonymity","depth":10},{"id":13,"text":"fearing reprisals ,","depth":10},{"id":14,"text":"talked about how the change will negatively affect them .","depth":8},{"id":15,"text":"After the removal of these perks ,","depth":8},{"id":16,"text":"some workers said","depth":9},{"id":17,"text":"they will be making less .","depth":9},{"id":18,"text":"Most of the workers","depth":9},{"id":19,"text":"who voiced concerns","depth":9},{"id":20,"text":"have been working for the company for more than two years ,","depth":9},{"id":21,"text":"and have been earning close to $ 15 an hour before the raise .","depth":9},{"id":22,"text":"While these workers ' hourly rates will rise modestly ,","depth":8},{"id":23,"text":"they said","depth":9},{"id":24,"text":"they could lose thousands of dollars","depth":10},{"id":25,"text":"that they would have collected from the stock and monthly-bonus programs .","depth":10},{"id":26,"text":"Amazon said","depth":6},{"id":27,"text":"those","depth":9},{"id":28,"text":"who are already making $ 15 an hour","depth":9},{"id":29,"text":"will see an increase in pay","depth":8},{"id":30,"text":"but did not specify how much .","depth":7},{"id":31,"text":"An employee","depth":10},{"id":32,"text":"earning $ 15.25 an hour","depth":10},{"id":33,"text":"who has worked for Amazon for more than three years in Arizona","depth":9},{"id":34,"text":"crunched the numbers .","depth":8},{"id":35,"text":"Although he is getting a $ 1 an hour raise ,","depth":9},{"id":36,"text":"which would equate to as much as $ 2,080 in additional pay a year ,","depth":9},{"id":37,"text":"he said","depth":9},{"id":38,"text":"he could have earned a few thousands of dollars more from the incentive programs .","depth":9},{"id":39,"text":"\" Amazon isn ' t giving its employees a raise ,","depth":9},{"id":40,"text":"they ' re taking money from us , \"","depth":9},{"id":41,"text":"he told Yahoo Finance .","depth":8},{"id":42,"text":"\" It only looks good","depth":8},{"id":43,"text":"if folks don ' t know the truth . \"","depth":8},{"id":44,"text":"An Amazon spokesperson said","depth":5},{"id":45,"text":"\" all hourly operations and customer service employees will see an increase in their total compensation","depth":7},{"id":46,"text":"as a result of this announcement .","depth":7},{"id":47,"text":"In addition ,","depth":7},{"id":48,"text":"because it ' s no longer incentive-based ,","depth":8},{"id":49,"text":"the compensation will be more immediate and predictable . \"","depth":8},{"id":50,"text":"Not everyone at Amazon is happy about the wage increase .","depth":6},{"id":51,"text":"( photo credit/Time ) More","depth":6},{"id":52,"text":"In the past , Amazon had used stock options as a major selling point during the recruiting process .","depth":7},{"id":53,"text":"\" One of the ways","depth":13},{"id":54,"text":"we foster ownership among employees","depth":13},{"id":55,"text":"is through Restricted Stock Unit","depth":14},{"id":56,"text":"( RSU )","depth":14},{"id":57,"text":"awards .","depth":13},{"id":58,"text":"RSUs are a key part of our global compensation program ,","depth":12},{"id":59,"text":"which has been carefully designed","depth":13},{"id":60,"text":"to help us attract , motivate and retain employees of the highest caliber , \"","depth":13},{"id":61,"text":"according to an Amazon brochure about the program .","depth":10},{"id":62,"text":"Under RSUs , full-time warehouse workers usually receive two or three shares each year after a two-year vesting period .","depth":10},{"id":63,"text":"Amazon stock","depth":13},{"id":64,"text":"( AMZN )","depth":13},{"id":65,"text":"has been on a bull run","depth":12},{"id":66,"text":"- the share price has more than tripled since 2016","depth":12},{"id":67,"text":"and now is around $ 2,000 .","depth":12},{"id":68,"text":"Amazon said","depth":10},{"id":69,"text":"it ' ll replace RSU with a \" direct stock purchase plan \"","depth":10},{"id":70,"text":"but didn ' t offer any specifics .","depth":9},{"id":71,"text":"Another major perk","depth":11},{"id":72,"text":"that Amazon is phasing out","depth":11},{"id":73,"text":"is employee ' s monthly bonuses ,","depth":11},{"id":74,"text":"called Variable Compensation Pay","depth":12},{"id":75,"text":"( VCP ) .","depth":12},{"id":76,"text":"An employee can earn up to 8 % of their monthly income ,","depth":10},{"id":77,"text":"but it depends on how many hours they work and the facility site ' s production goals .","depth":10},{"id":78,"text":"An average worker usually receives $ 1,800 to $ 3,000 a year through the VCP program ,","depth":9},{"id":79,"text":"according to employees","depth":10},{"id":80,"text":"who talked to Yahoo Finance .","depth":10},{"id":81,"text":"Some said","depth":8},{"id":82,"text":"it ' s especially frustrating to see the program removed now ,","depth":9},{"id":83,"text":"since VCP doubles during peak months in the holiday season .","depth":9},{"id":84,"text":"Amazon warehouse employees go wild","depth":4},{"id":85,"text":"as news breaks of the company ' s new $ 15 minimum wage .","depth":4},{"id":86,"text":"( Screenshot/Youtube )","depth":3},{"id":87,"text":"More","depth":2},{"id":88,"text":"Amazon said","depth":5},{"id":89,"text":"its decision","depth":7},{"id":90,"text":"to eliminate the financial incentive program","depth":7},{"id":91,"text":"was based on employees ' feedback .","depth":6},{"id":92,"text":"\" We ' ve heard from our hourly fulfillment and customer service employees","depth":6},{"id":93,"text":"that they prefer the predictability and immediacy of cash to RSUs , \"","depth":6},{"id":94,"text":"the company wrote in a blog post .","depth":5},{"id":95,"text":"\" The net effect of this change and the new higher cash compensation is significantly more total compensation for employees ,","depth":4},{"id":96,"text":"without any vesting requirements , and with more predictability . \"","depth":4}],"relations":[{"parent":193,"left":183,"right":192,"relation":"elaboration","nuclearity":"NS"},{"parent":183,"left":180,"right":182,"relation":"context","nuclearity":"NS"},{"parent":180,"left":140,"right":179,"relation":"elaboration","nuclearity":"NS"},{"parent":140,"left":122,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":107,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":107,"left":100,"right":106,"relation":"adversative","nuclearity":"SN"},{"parent":100,"left":99,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":98,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":98,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":106,"left":4,"right":105,"relation":"context","nuclearity":"NS"},{"parent":105,"left":5,"right":104,"relation":"attribution","nuclearity":"SN"},{"parent":104,"left":103,"right":10,"relation":"context","nuclearity":"NS"},{"parent":103,"left":102,"right":9,"relation":"same-unit","nuclearity":"NN"},{"parent":102,"left":6,"right":101,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":121,"left":113,"right":120,"relatio