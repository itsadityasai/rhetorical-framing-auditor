ion":"same-unit","nuclearity":"NN"},{"parent":304,"left":138,"right":139,"relation":"condition","nuclearity":"NS"},{"parent":305,"left":140,"right":141,"relation":"attribution","nuclearity":"SN"},{"parent":340,"left":326,"right":339,"relation":"elaboration","nuclearity":"NS"},{"parent":326,"left":315,"right":325,"relation":"organization","nuclearity":"SN"},{"parent":315,"left":144,"right":145,"relation":"context","nuclearity":"SN"},{"parent":325,"left":324,"right":156,"relation":"causal","nuclearity":"SN"},{"parent":324,"left":146,"right":323,"relation":"attribution","nuclearity":"SN"},{"parent":323,"left":147,"right":322,"relation":"purpose","nuclearity":"NS"},{"parent":322,"left":316,"right":321,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":148,"right":149,"relation":"elaboration","nuclearity":"NS"},{"parent":321,"left":319,"right":320,"relation":"elaboration","nuclearity":"NS"},{"parent":319,"left":150,"right":318,"relation":"elaboration","nuclearity":"NS"},{"parent":318,"left":317,"right":153,"relation":"context","nuclearity":"NS"},{"parent":317,"left":151,"right":152,"relation":"elaboration","nuclearity":"NS"},{"parent":320,"left":154,"right":155,"relation":"elaboration","nuclearity":"NS"},{"parent":339,"left":335,"right":338,"relation":"joint","nuclearity":"NN"},{"parent":335,"left":328,"right":334,"relation":"elaboration","nuclearity":"NS"},{"parent":328,"left":327,"right":159,"relation":"context","nuclearity":"NS"},{"parent":327,"left":157,"right":158,"relation":"elaboration","nuclearity":"NS"},{"parent":334,"left":329,"right":333,"relation":"same-unit","nuclearity":"NN"},{"parent":329,"left":160,"right":161,"relation":"elaboration","nuclearity":"NS"},{"parent":333,"left":331,"right":332,"relation":"same-unit","nuclearity":"NN"},{"parent":331,"left":162,"right":330,"relation":"elaboration","nuclearity":"NS"},{"parent":330,"left":163,"right":164,"relation":"elaboration","nuclearity":"NS"},{"parent":332,"left":165,"right":166,"relation":"elaboration","nuclearity":"NS"},{"parent":338,"left":167,"right":337,"relation":"adversative","nuclearity":"SN"},{"parent":337,"left":168,"right":336,"relation":"same-unit","nuclearity":"NN"},{"parent":336,"left":169,"right":170,"relation":"context","nuclearity":"SN"}]}