{"article_id":"BTTIu3245wgaGs0G","edus":[{"id":0,"text":"Cyntoia Brown-Long ,","depth":4},{"id":1,"text":"who was granted clemency earlier this year","depth":5},{"id":2,"text":"after serving 15 years of a life sentence","depth":6},{"id":3,"text":"for killing a man ,","depth":6},{"id":4,"text":"sat down with for a sweeping interview on redemption , finding love in prison and her message to abuse victims .","depth":3},{"id":5,"text":"Brown-Long , now 31 , was released from prison in August","depth":6},{"id":6,"text":"after Tennessee Governor Bill Haslam commuted her sentence","depth":7},{"id":7,"text":"for murdering 43-year-old Johnny Allen ,","depth":9},{"id":8,"text":"who allegedly hired her for sex","depth":10},{"id":9,"text":"when she was 16 .","depth":10},{"id":10,"text":"Her lawyers argued","depth":9},{"id":11,"text":"that she fatally shot Allen in self-defense .","depth":9},{"id":12,"text":"Brown-Long was tried as an adult","depth":6},{"id":13,"text":"and convicted of first-degree murder and aggravated robbery in 2006","depth":7},{"id":14,"text":"without the possibility for parole until 2055 .","depth":7},{"id":15,"text":"In Tennessee , a juvenile","depth":7},{"id":16,"text":"sentenced to life in prison","depth":7},{"id":17,"text":"must spend at least 51 years behind bars","depth":6},{"id":18,"text":"before they are eligible for review","depth":6},{"id":19,"text":"- the highest minimum requirement in the U.S .","depth":6},{"id":20,"text":"Her case received national attention ,","depth":5},{"id":21,"text":"with celebrities like Kim Kardashian West , Rihanna , LeBron James and Snoop Dogg advocating for her freedom .","depth":5},{"id":22,"text":"Lawmakers and criminal justice reform advocates urged Haslem to commute her sentence","depth":5},{"id":23,"text":"alleging years of forced prostitution and abuse .","depth":5},{"id":24,"text":"`` One of my biggest regrets is the way","depth":7},{"id":25,"text":"that I hurt my mother ''","depth":7},{"id":26,"text":"Brown-Long said","depth":9},{"id":27,"text":"she regrets running away from what she has described as a supportive home ,","depth":10},{"id":28,"text":"and has carried the pain","depth":13},{"id":29,"text":"she caused her mother `` for all these years . '' `` One of my biggest regrets is the way","depth":13},{"id":30,"text":"that I hurt my mother , ''","depth":12},{"id":31,"text":"she said .","depth":11},{"id":32,"text":"`` You know","depth":9},{"id":33,"text":"she tried so hard .","depth":10},{"id":34,"text":"She tried everything","depth":11},{"id":35,"text":"that she knew to try . ''","depth":11},{"id":36,"text":"Brown-Long , however , said","depth":9},{"id":37,"text":"there were other factors","depth":10},{"id":38,"text":"that played into her decision-making","depth":11},{"id":39,"text":"when she was young .","depth":11},{"id":40,"text":"`` We have to be more conscious of all of the influences on children , ''","depth":11},{"id":41,"text":"she said .","depth":11},{"id":42,"text":"`` There 's school ,","depth":11},{"id":43,"text":"there 's neighborhood ,","depth":12},{"id":44,"text":"there 's what you 're seeing in the media .","depth":12},{"id":45,"text":"So she tried ,","depth":11},{"id":46,"text":"but it was hard for her to fight the battles","depth":12},{"id":47,"text":"that were going on within me ,","depth":13},{"id":48,"text":"that I had taken on from other places around me . ''","depth":13},{"id":49,"text":"`` When you 're doing time ,","depth":14},{"id":50,"text":"your family is doing time with you .","depth":14},{"id":51,"text":"Your family has to rearrange their lives","depth":14},{"id":52,"text":"because of your absence , ''","depth":14},{"id":53,"text":"she added .","depth":12},{"id":54,"text":"`` They have to be present for you .","depth":12},{"id":55,"text":"You want to shield them from as much","depth":13},{"id":56,"text":"as you can . ''","depth":13},{"id":57,"text":"`` I was in my late twenties","depth":8},{"id":58,"text":"when I actually realized","depth":9},{"id":59,"text":"that I was a trafficking victim ''","depth":9},{"id":60,"text":"Brown-Long said","depth":10},{"id":61,"text":"she was an adult","depth":11},{"id":62,"text":"when she realized","depth":12},{"id":63,"text":"she had fallen victim to a system of abuse .","depth":12},{"id":64,"text":"At the time , she was involved with a Tennessee group","depth":11},{"id":65,"text":"called End Slavery","depth":11},{"id":66,"text":"that works with human trafficking victims .","depth":10},{"id":67,"text":"`` It took many , many years , ''","depth":10},{"id":68,"text":"she said .","depth":10},{"id":69,"text":"`` I was in my late twenties","depth":12},{"id":70,"text":"when I actually realized","depth":13},{"id":71,"text":"that I was a trafficking victim .","depth":13},{"id":72,"text":"For so long ,","depth":13},{"id":73,"text":"you know","depth":14},{"id":74,"text":"I had thought ,","depth":14},{"id":75,"text":"'No , they said","depth":14},{"id":76,"text":"that I was a teenage prostitute .","depth":14},{"id":77,"text":"I knew","depth":14},{"id":78,"text":"what I was doing . ' ''","depth":14},{"id":79,"text":"She said","depth":12},{"id":80,"text":"she dealt with guilt and blame for years .","depth":12},{"id":81,"text":"`` You know ,","depth":14},{"id":82,"text":"of course , I let him manipulate me into doing this , ''","depth":14},{"id":83,"text":"she added .","depth":13},{"id":84,"text":"`` I thought","depth":14},{"id":85,"text":"I was doing something for someone","depth":15},{"id":86,"text":"I figure","depth":16},{"id":87,"text":"was my boyfriend","depth":16},{"id":88,"text":"and that was n't necessarily the truth . ''","depth":13},{"id":89,"text":"Brown-Long recounted","depth":9},{"id":90,"text":"how","depth":11},{"id":91,"text":"once she realized the situation","depth":14},{"id":92,"text":"she had been put in ,","depth":14},{"id":93,"text":"she started searching for answers ,","depth":13},{"id":94,"text":"including `` why I was just so vulnerable . ''","depth":12},{"id":95,"text":"`` You know","depth":13},{"id":96,"text":"there 's a certain element","depth":14},{"id":97,"text":"where you 're just vulnerable","depth":15},{"id":98,"text":"because you 're a child","depth":16},{"id":99,"text":"your mind is just naturally impressionable in that way , ''","depth":16},{"id":100,"text":"she said .","depth":12},{"id":101,"text":"`` But it was like ,","depth":12},{"id":102,"text":"why was it just so easy for this man to come along","depth":13},{"id":103,"text":"and in the space of a few weeks I was doing these things ? ''","depth":13},{"id":104,"text":"She now hopes","depth":9},{"id":105,"text":"other young girls can learn from her story .","depth":9},{"id":106,"text":"`` In some way , everybody is just one bad decision , one mistake , one accident","depth":10},{"id":107,"text":"from being caught up in the justice system , ''","depth":10},{"id":108,"text":"she added .","depth":9},{"id":109,"text":"`` We all should be invested in making sure","depth":9},{"id":110,"text":"that it 's treating people the way","depth":11},{"id":111,"text":"they should be treated ,","depth":11},{"id":112,"text":"the way","depth":11},{"id":113,"text":"that you would want to be treated . ''","depth":11},{"id":114,"text":"After Brown-Long was granted clemency ,","depth":8},{"id":115,"text":"the family of her victim released a statement .","depth":8},{"id":116,"text":"It read , in part :","depth":7},{"id":117,"text":"`` our hearts are broken","depth":7},{"id":118,"text":"because we feel","depth":8},{"id":119,"text":"Johnny never got to defend himself .","depth":9},{"id":120,"text":"We never got to be a voice to him . ''","depth":9},{"id":121,"text":"Brown-Long said","depth":8},{"id":122,"text":"she understands their pain","depth":9},{"id":123,"text":"because `` grief does n't care about what the situation was . ''","depth":9},{"id":124,"text":"`` I completely understand how they feel , ''","depth":9},{"id":125,"text":"Brown-Long said .","depth":9},{"id":126,"text":"`` This was somebody 's son ,","depth":12},{"id":127,"text":"it was someone 's brother .","depth":12},{"id":128,"text":"If you lose someone ,","depth":13},{"id":129,"text":"grief does n't care about what the situation was . '' `` Especially in the justice system , it 's such an adversarial process , ''","depth":13},{"id":130,"text":"she added .","depth":12},{"id":131,"text":"`` Many times , both the defendant and the victim 's voices are left out of it .","depth":10},{"id":132,"text":"So , I think","depth":10},{"id":133,"text":"there are many things","depth":12},{"id":134,"text":"that are left unsaid .","depth":12},{"id":135,"text":"Many things","depth":12},{"id":136,"text":"that people would like to say . ''","depth":12},{"id":137,"text":"Brown-Long said","depth":7},{"id":138,"text":"she would `` absolutely '' be willing to sit down with Allen 's family .","depth":8},{"id":139,"text":"`` If they would ever want to have a conversation","depth":11},{"id":140,"text":"then I 'm open to that , ''","depth":11},{"id":141,"text":"she added .","depth":10},{"id":142,"text":"`` But so far I have n't received any kind of word","depth":10},{"id":143,"text":"that they would be open to that . ''","depth":10},{"id":144,"text":"Although her sentence was commuted ,","depth":6},{"id":145,"text":"Brown-Long remains a convicted murderer .","depth":6},{"id":146,"text":"She said","depth":7},{"id":147,"text":"she does n't believe","depth":8},{"id":148,"text":"the act has come to define her .","depth":8},{"id":149,"text":"`` Yes , I 've made mistakes .","depth":10},{"id":150,"text":"I 've done something","depth":13},{"id":151,"text":"that completely destroyed a family , ''","depth":13},{"id":152,"text":"she said .","depth":12},{"id":153,"text":"`` It damaged multiple people in the process .","depth":11},{"id":154,"text":"We 've all done things","depth":11},{"id":155,"text":"that we can regret .","depth":11},{"id":156,"text":"Obviously some worse than others .","depth":10},{"id":157,"text":"But the point is","depth":9},{"id":158,"text":"there is redemption . ''","depth":9},{"id":159,"text":"Brown-Long said","depth":9},{"id":160,"text":"she saw a change in herself","depth":10},{"id":161,"text":"after spending 15 years behind bars .","depth":10},{"id":162,"text":"She said","depth":10},{"id":163,"text":"she hopes","depth":11},{"id":164,"text":"others can recognize their own power of transformation , too .","depth":11},{"id":165,"text":"`` I do n't think","depth":12},{"id":166,"text":"anybody is beyond repair , ''","depth":12},{"id":167,"text":"she added .","depth":11},{"id":168,"text":"`` I think","depth":11},{"id":169,"text":"that as people we 're so much more complex","depth":12},{"id":170,"text":"than just being limited to our mistakes and the bad decisions","depth":13},{"id":171,"text":"that we make . ''","depth":13},{"id":172,"text":"Brown-Long is married to recording artist J . Long ,","depth":6},{"id":173,"text":"previously known for his work with the R & B group Pretty Ricky .","depth":6},{"id":174,"text":"They tied the knot in August","depth":6},{"id":175,"text":"after she was released .","depth":6},{"id":176,"text":"Brown-Long said","depth":4},{"id":177,"text":"she received letters from all over the world","depth":6},{"id":178,"text":"while she was incarcerated ,","depth":6},{"id":179,"text":"but that Long 's notes stood out .","depth":5},{"id":180,"text":"`` Well aside from the fact that he is very fine , ''","depth":6},{"id":181,"text":"she said with a laugh .","depth":6},{"id":182,"text":"`` [ His letter ] really spoke out to me in a way","depth":6},{"id":183,"text":"that I ca n't describe . ''","depth":6},{"id":184,"text":"She called his letters `` unique ''","depth":6},{"id":185,"text":"and recounted","depth":8},{"id":186,"text":"how she recently found the first one","depth":9},{"id":187,"text":"he sent to her .","depth":9},{"id":188,"text":"The note included # FreeCyntoia2017 on the bottom of the page ,","depth":8},{"id":189,"text":"months before the hashtag became a trend on Twitter .","depth":8},{"id":190,"text":"She said","depth":6},{"id":191,"text":"it 's `` incredible ''","depth":8},{"id":192,"text":"they can now start their life together .","depth":8},{"id":193,"text":"`` I really feel like","depth":9},{"id":194,"text":"I live with my best friend , ''","depth":9},{"id":195,"text":"she added .","depth":8}],"relations":[{"parent":391,"left":219,"right":390,"relation":"elaboration","nuclearity":"NS"},{"parent":219,"left":200,"right":218,"relation":"elaboration","nuclearity":"NS"},{"parent":200,"left":199,"right":4,"relation":"same-unit","nuclearity":"NN"},{"parent":199,"left":0,"right":198,"relation":"elaboration","nuclearity":"NS"},{"parent":198,"left":1,"right":197,"relation":"context","nuclearity":"NS"},{"parent":197,"left":2,"right":3,"relation":"causal","nuclearity":"NS"},{"parent":218,"left":214,"right":217,"relation":"causal","nuclearity":"NS"},{"parent":214,"left":209,"right":213,"relation":"elaboration","nuclearity":"NS"},{"parent":209,"left":206,"right":208,"relation":"context","nuclearity":"NS"},{"parent":206,"left":5,"right":205,"relation":"context","nuclearity":"NS"},{"parent":205,"left":6,"right":204,"relation":"elaboration","nuclearity":"NS"},{"parent":204,"left":202,"right":203,"relation":"elaboration","nuclearity":"NS"},{"parent":202,"left":7,"right":201,"relation":"elaboration","nuclearity":"NS"},{"parent":201,"left":8,"right":9,"relation":"context","nuclearity":"NS"},{"parent":203,"left":10,"right":11,"relation":"attribution","nuclearity":"SN"},{"parent":208,"left":12,"right":207,"relation":"joint","nuclearity":"NN"},{"parent":207,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":213,"left":211,"right":212,"relation":"elaboration","nuclearity":"NS"},{"parent":211,"left":210,"right":17,"relation":"same-unit","nuclearity":"NN"},{"parent":210,"left":15,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":212,"left":18,"right":19,"relation":"e