{"article_id":"ncBE2TS5a1pqGPYf","edus":[{"id":0,"text":"In this April 4 , 2019 , photo","depth":3},{"id":1,"text":"Tara Reade poses for a photo during an interview with The in Nevada City , Calif.","depth":4},{"id":2,"text":"( AP Photo/Donald Thompson )","depth":4},{"id":3,"text":"In this April 4 , 2019 , photo","depth":3},{"id":4,"text":"Tara Reade poses for a photo during an interview with The in Nevada City , Calif.","depth":4},{"id":5,"text":"( AP Photo/Donald Thompson )","depth":4},{"id":6,"text":"WASHINGTON","depth":4},{"id":7,"text":"( AP ) -","depth":4},{"id":8,"text":"Tara Reade , the former Senate staffer","depth":12},{"id":9,"text":"who alleges","depth":13},{"id":10,"text":"Joe Biden sexually assaulted her 27 years ago ,","depth":13},{"id":11,"text":"says","depth":12},{"id":12,"text":"she filed a limited report with a congressional personnel office","depth":13},{"id":13,"text":"that did not explicitly accuse him of sexual assault or harassment .","depth":13},{"id":14,"text":"\" I remember talking","depth":13},{"id":15,"text":"about him wanting me to serve drinks","depth":15},{"id":16,"text":"because he liked my legs","depth":16},{"id":17,"text":"and thought","depth":17},{"id":18,"text":"I was pretty","depth":17},{"id":19,"text":"and it made me uncomfortable , \"","depth":14},{"id":20,"text":"Reade said in an interview Friday with The .","depth":12},{"id":21,"text":"\" I know","depth":12},{"id":22,"text":"that I was too scared","depth":13},{"id":23,"text":"to write about the sexual assault . \"","depth":13},{"id":24,"text":"Reade told the AP twice","depth":12},{"id":25,"text":"that she did not use the phrase \" sexual harassment \"","depth":13},{"id":26,"text":"in filing the complaint ,","depth":13},{"id":27,"text":"but at other points in the interview said","depth":12},{"id":28,"text":"that was the behavior","depth":13},{"id":29,"text":"she believed","depth":14},{"id":30,"text":"she was describing .","depth":14},{"id":31,"text":"She said :","depth":12},{"id":32,"text":"\" I talked about sexual harassment , retaliation .","depth":12},{"id":33,"text":"The main word","depth":14},{"id":34,"text":"I used","depth":14},{"id":35,"text":"- and I know","depth":14},{"id":36,"text":"I didn ' t use sexual harassment -","depth":14},{"id":37,"text":"I used ' uncomfortable. '","depth":13},{"id":38,"text":"And I remember","depth":14},{"id":39,"text":"' retaliation . ' \"","depth":14},{"id":40,"text":"Reade described the report","depth":9},{"id":41,"text":"after the AP discovered additional transcripts and notes from its interviews with Reade last year","depth":10},{"id":42,"text":"in which she says","depth":11},{"id":43,"text":"she \" chickened out \"","depth":12},{"id":44,"text":"after going to the Senate personnel office .","depth":12},{"id":45,"text":"The AP interviewed Reade in 2019","depth":9},{"id":46,"text":"after she accused Biden of uncomfortable and inappropriate touching .","depth":9},{"id":47,"text":"She did not raise allegations of sexual assault against Biden until this year , around the time","depth":9},{"id":48,"text":"he became the presumptive Democratic presidential nominee .","depth":9},{"id":49,"text":"The existence of the Senate report has become a key element of the accusations against Biden ,","depth":10},{"id":50,"text":"which he has flatly denied .","depth":10},{"id":51,"text":"Reade says","depth":13},{"id":52,"text":"she doesn ' t have a copy of the report ,","depth":13},{"id":53,"text":"and Biden said Friday","depth":13},{"id":54,"text":"that he is not aware","depth":14},{"id":55,"text":"that any complaint against him exists .","depth":14},{"id":56,"text":"He asked the Senate and the National Archives to search their records","depth":12},{"id":57,"text":"to try to locate a complaint from Reade .","depth":12},{"id":58,"text":"But Reade is suggesting","depth":11},{"id":59,"text":"that","depth":12},{"id":60,"text":"even if the report surfaces ,","depth":14},{"id":61,"text":"it would not corroborate her assault allegations","depth":14},{"id":62,"text":"because she chose not to detail them at the time .","depth":13},{"id":63,"text":"According to a transcript of her 2019 interview with the AP ,","depth":11},{"id":64,"text":"Reade said :","depth":11},{"id":65,"text":"\" They have this counseling office or something ,","depth":11},{"id":66,"text":"and I think","depth":13},{"id":67,"text":"I walked in there once ,","depth":13},{"id":68,"text":"but then I chickened out. \"","depth":12},{"id":69,"text":"She made a similar statement in a second interview with AP that same day ,","depth":10},{"id":70,"text":"according to written notes from the interview .","depth":10},{"id":71,"text":"On Friday , Reade said","depth":10},{"id":72,"text":"she was referring to having \" chickened out \"","depth":11},{"id":73,"text":"by not filing full harassment or assault allegations against Biden .","depth":11},{"id":74,"text":"In multiple interviews with the AP on Friday , Reade insisted","depth":11},{"id":75,"text":"she filed an \" intake form \" at the Senate personnel office ,","depth":12},{"id":76,"text":"which included her contact information , the office","depth":14},{"id":77,"text":"she worked for","depth":14},{"id":78,"text":"and some broad details of her issues with Biden .","depth":13},{"id":79,"text":"On Saturday , Reade told the AP","depth":12},{"id":80,"text":"there may have been a box","depth":14},{"id":81,"text":"to check on the form","depth":14},{"id":82,"text":"noting a sexual harassment complaint ,","depth":13},{"id":83,"text":"but she couldn ' t remember","depth":13},{"id":84,"text":"and wouldn ' t know for sure","depth":13},{"id":85,"text":"until she saw the form .","depth":12},{"id":86,"text":"Reade also said","depth":9},{"id":87,"text":"she canceled a planned television interview with \" Fox News Sunday \"","depth":10},{"id":88,"text":"because of security concerns .","depth":10},{"id":89,"text":"Reade was one of eight women","depth":9},{"id":90,"text":"who came forward last year with allegations","depth":10},{"id":91,"text":"that Biden made them feel uncomfortable with inappropriate displays of affection .","depth":10},{"id":92,"text":"Biden acknowledged the complaints","depth":9},{"id":93,"text":"and promised to be \" more mindful about respecting personal space in the future . \"","depth":9},{"id":94,"text":"During one of the April 2019 interviews with the AP , she said","depth":9},{"id":95,"text":"Biden rubbed her shoulders and neck","depth":10},{"id":96,"text":"and played with her hair .","depth":10},{"id":97,"text":"She said","depth":10},{"id":98,"text":"she was asked by an aide in Biden ' s Senate office to dress more conservatively","depth":11},{"id":99,"text":"and told \" don ' t be so sexy . \"","depth":11},{"id":100,"text":"She said of Biden :","depth":10},{"id":101,"text":"\" I wasn ' t scared of him ,","depth":11},{"id":102,"text":"that he was going to take me in a room or anything .","depth":12},{"id":103,"text":"It wasn ' t that kind of vibe . \"","depth":12},{"id":104,"text":"The AP reviewed notes of its 2019 interviews with Reade","depth":10},{"id":105,"text":"after she came forward in March with allegations of sexual assault against Biden .","depth":10},{"id":106,"text":"But reporters discovered an additional transcript and notes from those interviews on Friday .","depth":9},{"id":107,"text":"A recording of one of the interviews was deleted","depth":11},{"id":108,"text":"before Reade emerged in 2020 with new allegations against Biden ,","depth":11},{"id":109,"text":"in keeping with the reporter ' s standard practice","depth":11},{"id":110,"text":"for disposing of old interviews .","depth":11},{"id":111,"text":"A portion of that interview was also recorded on video ,","depth":10},{"id":112,"text":"but not the part","depth":11},{"id":113,"text":"in which she spoke of having \" chickened out . \"","depth":11},{"id":114,"text":"The AP declined to publish details of the 2019 interviews at the time","depth":8},{"id":115,"text":"because reporters were unable to corroborate her allegations ,","depth":9},{"id":116,"text":"and aspects of her story contradicted other reporting .","depth":9},{"id":117,"text":"In recent weeks , Reade told the AP and other news organizations","depth":8},{"id":118,"text":"that Biden sexually assaulted her ,","depth":9},{"id":119,"text":"pushing her against a wall in the basement of a Capitol Hill office building in 1993 ,","depth":10},{"id":120,"text":"groping her","depth":11},{"id":121,"text":"and penetrating her with his fingers .","depth":11},{"id":122,"text":"She says","depth":8},{"id":123,"text":"she was fired from Biden ' s office","depth":9},{"id":124,"text":"after filing a complaint with the Senat","depth":11},{"id":125,"text":"","depth":11},{"id":126,"text":"lleging harassment .","depth":10},{"id":127,"text":"he accusation has roiled Biden ' s presidential campaign ,","depth":8},{"id":128,"text":"parking anxiety among Democrats .","depth":9},{"id":129,"text":"epublicans have accused Biden backers of hypocrisy ,","depth":10},{"id":130,"text":"rguing","depth":11},{"id":131,"text":"hat they have been quick to believe women","depth":12},{"id":132,"text":"ho have accused President Donald Trump and other conservatives of assault .","depth":12},{"id":133,"text":"rump has faced multiple accusations of assault and harassment ,","depth":8},{"id":134,"text":"ll of which he denies .","depth":8},{"id":135,"text":"eade says","depth":7},{"id":136,"text":"he was reluctant to share details of the assault during her initial conversations with reporters over a year ago","depth":8},{"id":137,"text":"ecause she was scared of backlash ,","depth":9},{"id":138,"text":"nd was still coming to terms with what happened to her .","depth":9},{"id":139,"text":"wo of Reade ' s associates said publicly this past week","depth":9},{"id":140,"text":"hat Reade had conversations with them","depth":10},{"id":141,"text":"hat they said","depth":11},{"id":142,"text":"orroborated aspects of her allegation .","depth":11},{"id":143,"text":"ne , a former neighbor , said","depth":10},{"id":144,"text":"eade told her about the alleged assault","depth":11},{"id":145,"text":"few years after Reade said","depth":12},{"id":146,"text":"t happened .","depth":12},{"id":147,"text":"he other , a former coworker , said","depth":10},{"id":148,"text":"eade told her","depth":11},{"id":149,"text":"he had been sexually harassed by her boss during her previous job in Washington .","depth":11},{"id":150,"text":"he AP has also spoken to two additional people ,","depth":11},{"id":151,"text":"ho spoke on condition of anonymity","depth":12},{"id":152,"text":"o protect their families ' privacy ,","depth":12},{"id":153,"text":"ho said","depth":11},{"id":154,"text":"eade had told them about aspects of her allegations against Biden years ago .","depth":11},{"id":155,"text":"ne friend ,","depth":13},{"id":156,"text":"ho knew Reade in 1993 ,","depth":13},{"id":157,"text":"aid","depth":12},{"id":158,"text":"eade told them about the alleged assault","depth":12},{"id":159,"text":"hen it happened .","depth":12},{"id":160,"text":"he second friend met Reade more than a decade after the alleged incident","depth":11},{"id":161,"text":"nd confirmed","depth":12},{"id":162,"text":"hat Reade had a conversation with the friend in 2007 or 2008","depth":13},{"id":163,"text":"bout experiencing sexual harassment from Biden","depth":14},{"id":164,"text":"hile working in his Senate office .","depth":14},{"id":165,"text":"DITOR ' S NOTE -","depth":10},{"id":166,"text":"he headline of this story was changed for clarity","depth":11},{"id":167,"text":"nd to incorporate a direct quote from Reade .","depth":11},{"id":168,"text":"he AP also added material to the story ,","depth":11},{"id":169,"text":"hich details the specific words and examples","depth":12},{"id":170,"text":"eade says","depth":13},{"id":171,"text":"he used in a Senate complaint about Joe Biden .","depth":13},{"id":172,"text":"he AP is adding the material","depth":11},{"id":173,"text":"o reflect","depth":12},{"id":174,"text":"hat","depth":14},{"id":175,"text":"hile Reade says","depth":15},{"id":176,"text":"he did not specifically use the words \" sexual harassment \" in the complaint ,","depth":15},{"id":177,"text":"he says","depth":14},{"id":178,"text":"he behavior","depth":16},{"id":179,"text":"he was describing","depth":16},{"id":180,"text":"mounts to sexual harassment .","depth":15},{"id":181,"text":"atch up on the 2020 election campaign with AP experts on our weekly politics podcast , \" Ground Game . \"","depth":2}],"relations":[{"parent":363,"left":187,"right":362,"relation":"context","nuclearity":"SN"},{"parent":187,"left":184,"right":186,"relation":"joint","nuclearity":"NN"},{"parent":184,"left":0,"right":183,"relation":"elaboration","nuclearity":"NS"},{"parent":183,"left":1,"right":2,"relation":"explanation","nuclearity":"NS"},{"parent":186,"left":3,"right":185,"relation":"same-unit","nuclearity":"NN"},{"parent":185,"left":4,"right":5,"relation":"attribution","nuclearity":"NS"},{"parent":362,"left":361,"right":181,"relation":"joint","nuclearity":"NN"},{"parent":361,"left":188,"right":360,"relation":"organization","nuclearity":"SN"},{"parent":188,"left":6,"right":7,"relation":"explanation","nuclearity":"NS"},{"parent":360,"left":296,"right":359,"relation":"elaboration","nuclearity":"NS"},{"parent":296,"left":268,"right":295,"relation":"elaboration","nuclearity":"NS"},{"parent":268,"left":228,"right":267,"relation":"elaboration","nuclearity":"NS"},{"parent":228,"left":224,"right":227,"relation":"context","nuclearity":"NS"},{"parent":224,"left":219,"right":223,"relation":"context","nuclearity":"NS"},{"parent":219,"left":203,"right":218,"relation":"elaboration","nuclearity":"NS"},{"parent":203,"left":193,"right":202,"relation":"elaboration","nuclearity":"NS"},{"parent":193,"left":190,"right":192,"relation":"same-unit","nuclearity":"NN"},{"parent":190,"left":8,"right":189,"relation":"elaboration","nucle