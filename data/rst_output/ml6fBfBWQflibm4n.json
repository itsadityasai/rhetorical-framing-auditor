S"},{"parent":346,"left":341,"right":345,"relation":"elaboration","nuclearity":"NS"},{"parent":341,"left":155,"right":340,"relation":"attribution","nuclearity":"SN"},{"parent":340,"left":337,"right":339,"relation":"same-unit","nuclearity":"NN"},{"parent":337,"left":156,"right":157,"relation":"purpose","nuclearity":"NS"},{"parent":339,"left":338,"right":160,"relation":"same-unit","nuclearity":"NN"},{"parent":338,"left":158,"right":159,"relation":"restatement","nuclearity":"NS"},{"parent":345,"left":344,"right":165,"relation":"causal","nuclearity":"NS"},{"parent":344,"left":343,"right":164,"relation":"purpose","nuclearity":"NS"},{"parent":343,"left":161,"right":342,"relation":"elaboration","nuclearity":"NS"},{"parent":342,"left":162,"right":163,"relation":"purpose","nuclearity":"NS"},{"parent":360,"left":356,"right":359,"relation":"elaboration","nuclearity":"NS"},{"parent":356,"left":354,"right":355,"relation":"purpose","nuclearity":"NS"},{"parent":354,"left":350,"right":353,"relation":"same-unit","nuclearity":"NN"},{"parent":350,"left":167,"right":168,"relation":"purpose","nuclearity":"NS"},{"parent":353,"left":352,"right":172,"relation":"elaboration","nuclearity":"NS"},{"parent":352,"left":351,"right":171,"relation":"same-unit","nuclearity":"NN"},{"parent":351,"left":169,"right":170,"relation":"elaboration","nuclearity":"NS"},{"parent":355,"left":173,"right":174,"relation":"elaboration","nuclearity":"NS"},{"parent":359,"left":175,"right":358,"relation":"purpose","nuclearity":"SN"},{"parent":358,"left":176,"right":357,"relation":"mode","nuclearity":"NS"},{"parent":357,"left":177,"right":178,"relation":"context","nuclearity":"NS"},{"parent":371,"left":367,"right":370,"relation":"explanation","nuclearity":"NS"},{"parent":367,"left":366,"right":181,"relation":"adversative","nuclearity":"SN"},{"parent":366,"left":179,"right":180,"relation":"elaboration","nuclearity":"NS"},{"parent":370,"left":182,"right":369,"relation":"adversative","nuclearity":"NN"},{"parent":369,"left":183,"right":368,"relation":"same-unit","nuclearity":"NN"},{"parent":368,"left":184,"right":185,"relation":"purpose","nuclearity":"NS"}]}