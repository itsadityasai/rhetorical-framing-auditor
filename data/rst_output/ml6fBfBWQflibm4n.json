n":"elaboration","nuclearity":"NS"},{"parent":286,"left":103,"right":285,"relation":"joint","nuclearity":"NN"},{"parent":285,"left":104,"right":105,"relation":"joint","nuclearity":"NN"},{"parent":296,"left":290,"right":295,"relation":"joint","nuclearity":"NN"},{"parent":290,"left":106,"right":289,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":107,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":109,"right":294,"relation":"adversative","nuclearity":"SN"},{"parent":294,"left":292,"right":293,"relation":"same-unit","nuclearity":"NN"},{"parent":292,"left":291,"right":112,"relation":"same-unit","nuclearity":"NN"},{"parent":291,"left":110,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":113,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":299,"right":311,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":115,"right":116,"relation":"mode","nuclearity":"SN"},{"parent":311,"left":117,"right":310,"relation":"explanation","nuclearity":"NS"},{"parent":310,"left":118,"right":309,"relation":"context","nuclearity":"SN"},{"parent":309,"left":302,"right":308,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":301,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":119,"right":300,"relation":"attribution","nuclearity":"SN"},{"parent":300,"left":120,"right":121,"relation":"attribution","nuclearity":"SN"},{"parent":308,"left":123,"right":307,"relation":"attribution","nuclearity":"SN"},{"parent":307,"left":305,"right":306,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":304,"right":127,"relation":"same-unit","nuclearity":"NN"},{"parent":304,"left":124,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":125,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":128,"right":129,"relation":"elaboration","nuclearity":"NS"},{"parent":331,"left":319,"right":330,"relation":"explanation"