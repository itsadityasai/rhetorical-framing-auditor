{"article_id":"6mdieK0bq1mJea4p","edus":[{"id":0,"text":"Some Democratic senators stormed out of the Judiciary Committee Friday morning","depth":4},{"id":1,"text":"after losing their latest bid","depth":6},{"id":2,"text":"to derail Brett Kavanaugh ' s nomination to the Supreme Court ,","depth":6},{"id":3,"text":"protesting what they called a \" ram job \" ahead of a vote later in the day .","depth":5},{"id":4,"text":"Republicans appear to have the votes","depth":6},{"id":5,"text":"to push Judge Kavanaugh through the committee on a party-line vote ,","depth":6},{"id":6,"text":"and they are moving to speed him to the Senate floor ,","depth":5},{"id":7,"text":"saying","depth":5},{"id":8,"text":"Thursday ' s testimony by Christine Blasey Ford","depth":7},{"id":9,"text":"alleging a sexual assault 36 years ago","depth":7},{"id":10,"text":"was compelling , but ultimately unsubstantiated .","depth":6},{"id":11,"text":"Democrats had demanded","depth":6},{"id":12,"text":"that before any committee action senators should hear from a man","depth":7},{"id":13,"text":"Ms. Blasey Ford says","depth":8},{"id":14,"text":"was in the room for the assault .","depth":8},{"id":15,"text":"They tried to force the panel to subpoena that man , Mark Judge .","depth":5},{"id":16,"text":"The committee rejected that on an 11-10 vote ,","depth":6},{"id":17,"text":"then voted to set a time-certain later in the day for a final vote on the nomination .","depth":6},{"id":18,"text":"At that point a number of the more junior Democratic senators conducted a walkout .","depth":5},{"id":19,"text":"Ms. Blasey Ford told the committee a day before","depth":7},{"id":20,"text":"that she remembers Judge Kavanaugh and Mr. Judge pulling her into a room ,","depth":8},{"id":21,"text":"turning up music","depth":9},{"id":22,"text":"and Judge Kavanaugh groping her","depth":10},{"id":23,"text":"and trying to strip off her clothes","depth":11},{"id":24,"text":"as he stifled her cries for help .","depth":11},{"id":25,"text":"Judge Kavanaugh vehemently denied the allegation ,","depth":7},{"id":26,"text":"saying","depth":9},{"id":27,"text":"he doesn ' t question","depth":10},{"id":28,"text":"that Ms. Blasey Ford suffered an assault","depth":10},{"id":29,"text":"but insisting","depth":9},{"id":30,"text":"he had nothing to do with it .","depth":9},{"id":31,"text":"All of those","depth":7},{"id":32,"text":"Ms. Blasey Ford can remember from the party","depth":7},{"id":33,"text":"have denied any memory of an assault , or even of such a party .","depth":6},{"id":34,"text":"Mr. Judge has submitted two declarations ,","depth":7},{"id":35,"text":"including one Thursday after Ms. Blasey Ford ' s testimony ,","depth":7},{"id":36,"text":"elaborating on his denial .","depth":6},{"id":37,"text":"\" I do not recall the events","depth":8},{"id":38,"text":"described by Dr. Ford in her testimony before the U.S. Senate Judiciary Committee today .","depth":8},{"id":39,"text":"I never saw Brett act in the manner","depth":8},{"id":40,"text":"Dr. Ford describes , \"","depth":8},{"id":41,"text":"he said .","depth":6},{"id":42,"text":"As their colleagues debated inside the committee room ,","depth":3},{"id":43,"text":"the Democrats","depth":6},{"id":44,"text":"who walked out","depth":6},{"id":45,"text":"held an impromptu press conference","depth":6},{"id":46,"text":"to complain about the GOP ' s handling of the nomination .","depth":6},{"id":47,"text":"\" It ' s been pushing and pushing and ramming this thing through","depth":6},{"id":48,"text":"because they have the power instead of the integrity","depth":7},{"id":49,"text":"to say","depth":8},{"id":50,"text":"let the American people know what ' s about to happen , \"","depth":8},{"id":51,"text":"said Sen. Kamala Harris , California Democrat .","depth":5},{"id":52,"text":"Ms. Harris ,","depth":6},{"id":53,"text":"thought to be eyeing a 2020 presidential run ,","depth":6},{"id":54,"text":"also quickly began to campaign on her walkout ,","depth":5},{"id":55,"text":"sending out a campaign email","depth":5},{"id":56,"text":"touting her move .","depth":5},{"id":57,"text":"\" Republicans are rushing Judge Kavanaugh ' s confirmation with a sham hearing this morning ,","depth":7},{"id":58,"text":"less than 24 hours after Dr. Ford had the courage","depth":8},{"id":59,"text":"to tell her story in front of the entire country .","depth":8},{"id":60,"text":"This is a disgrace , \"","depth":6},{"id":61,"text":"she wrote .","depth":5},{"id":62,"text":"\" So ,","depth":5},{"id":63,"text":"instead of sitting through this farce ...","depth":6},{"id":64,"text":"I walked out . \"","depth":6}],"relations":[{"parent":129,"left":106,"right":128,"relation":"joint","nuclearity":"NN"},{"parent":106,"left":75,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":68,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":0,"right":67,"relation":"context","nuclearity":"NS"},{"parent":67,"left":66,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":1,"right":2,"relation":"purpose","nuclearity":"NS"},{"parent":74,"left":70,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":69,"right":6,"relation":"joint","nuclearity":"NN"},{"parent":69,"left":4,"right":5,"relation":"purpose","nuclearity":"NS"},{"parent":73,"left":7,"right":72,"relation":"attribution","nuclearity":"SN"},{"parent":72,"left":71,"right":10,"relation":"same-unit","nuclearity":"NN"},{"parent":71,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":105,"left":82,"right":104,"relation":"joint","nuclearity":"NN"},{"parent":82,"left":79,"right":81,"relation":"joint","nuclearity":"NN"},{"parent":79,"left":78,"right":15,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":11,"right":77,"relation":"attribution","nuclearity":"SN"},{"parent":77,"left":12,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":13,"right":14,"relation":"attribution","nuclearity":"SN"},{"p