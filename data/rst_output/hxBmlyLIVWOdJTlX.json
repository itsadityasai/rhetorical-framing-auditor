{"article_id":"hxBmlyLIVWOdJTlX","edus":[{"id":0,"text":"The St. Louis County grand jury","depth":6},{"id":1,"text":"that declined to indict a white police officer in the shooting death of Michael Brown , an unarmed black 18-year-old ,","depth":6},{"id":2,"text":"heard wildly contrasting testimony ,","depth":5},{"id":3,"text":"including witness accounts","depth":6},{"id":4,"text":"that the hulking Brown was charging at Officer Darren Wilson","depth":7},{"id":5,"text":"when he was shot ,","depth":7},{"id":6,"text":"and Wilson 's own claim","depth":6},{"id":7,"text":"that Brown taunted him","depth":8},{"id":8,"text":"as he grabbed for his gun ,","depth":8},{"id":9,"text":"saying ,","depth":8},{"id":10,"text":"`` you are too much of a p -- --","depth":9},{"id":11,"text":"to shoot me . ''","depth":9},{"id":12,"text":"The grand jury decision came late Monday in Missouri","depth":5},{"id":13,"text":"after more than 70 hours of testimony from roughly 60 witnesses ,","depth":6},{"id":14,"text":"spanning 25 days over three months ,","depth":6},{"id":15,"text":"and touched off fresh looting and rioting on the streets of Ferguson and St. Louis .","depth":4},{"id":16,"text":"As the 12 members of the grand jury heard evidence in closed proceedings ,","depth":5},{"id":17,"text":"claims from purported witnesses and civil rights activists told the tale of a youth","depth":6},{"id":18,"text":"gunned down mercilessly","depth":7},{"id":19,"text":"as he held his hands up in surrender .","depth":7},{"id":20,"text":"But the grand jurors ,","depth":7},{"id":21,"text":"including six white men , three white women , two black women and one black man ,","depth":7},{"id":22,"text":"were told a different story .","depth":6},{"id":23,"text":"Brown \" has his arms out with attitude , \"","depth":6},{"id":24,"text":"while \" The cop just stood there , \"","depth":8},{"id":25,"text":"one witness to the shooting","depth":10},{"id":26,"text":"that capped the noon-time confrontation","depth":10},{"id":27,"text":"testified .","depth":9},{"id":28,"text":"\" Dang if that kid didn ' t start running right at the cop like a football player .","depth":8},{"id":29,"text":"Head down . \"","depth":8},{"id":30,"text":"The fatal shots came after a 90-second encounter","depth":7},{"id":31,"text":"that ,","depth":10},{"id":32,"text":"Wilson told the grand jury ,","depth":10},{"id":33,"text":"began","depth":9},{"id":34,"text":"when he saw Brown and a friend , Dorian Johnson , walking in the street on Aug. 9 .","depth":8},{"id":35,"text":"The police officer said","depth":8},{"id":36,"text":"he told them to move to the sidewalk ,","depth":9},{"id":37,"text":"which drew an expletive from Brown .","depth":9},{"id":38,"text":"Wilson noticed","depth":10},{"id":39,"text":"that Brown had a handful of cigars ,","depth":10},{"id":40,"text":"\" and that ' s when it clicked for [ him ] \" that the men were suspects in a theft at a convenience store","depth":10},{"id":41,"text":"reported just minutes earlier .","depth":10},{"id":42,"text":"Wilson , 28 , said","depth":10},{"id":43,"text":"he called for backup","depth":10},{"id":44,"text":"before maneuvering his vehicle in front of Brown and his friend .","depth":9},{"id":45,"text":"Wilson ,","depth":10},{"id":46,"text":"who is much smaller","depth":11},{"id":47,"text":"than the 6-foot , 4-inch , 290-pound Brown was ,","depth":11},{"id":48,"text":"told the panel","depth":9},{"id":49,"text":"of being attacked and in fear for his life","depth":9},{"id":50,"text":"as Brown slammed his squad car door on him","depth":11},{"id":51,"text":"and pummeled him through the window","depth":11},{"id":52,"text":"moments after Wilson confronted him walking in the middle of the street .","depth":10},{"id":53,"text":"Wilson testified","depth":8},{"id":54,"text":"that , \" I felt like a 5-year-old","depth":10},{"id":55,"text":"holding onto Hulk Hogan. \"","depth":10},{"id":56,"text":"The cop added ,","depth":10},{"id":57,"text":"\" Hulk Hogan , that ' s just how big he felt","depth":11},{"id":58,"text":"and how small I felt","depth":12},{"id":59,"text":"just from grasping his arm . \"","depth":12},{"id":60,"text":"\" What do I do not","depth":9},{"id":61,"text":"to get beaten inside my car ? \"","depth":9},{"id":62,"text":"Wilson asked grand jurors .","depth":8},{"id":63,"text":"The officer said","depth":9},{"id":64,"text":"he drew his handgun","depth":11},{"id":65,"text":"and threatened to shoot Brown","depth":12},{"id":66,"text":"if he didn ' t retreat ,","depth":12},{"id":67,"text":"fearing","depth":11},{"id":68,"text":"another punch to the face could \" knock [ him ] out \"","depth":12},{"id":69,"text":"or incapacitate him .","depth":12},{"id":70,"text":"\" He immediately grabs my gun","depth":12},{"id":71,"text":"and says ,","depth":13},{"id":72,"text":"' You are too much of a [ p -- -- ]","depth":14},{"id":73,"text":"to shoot me ' , \"","depth":14},{"id":74,"text":"said Wilson ,","depth":11},{"id":75,"text":"adding","depth":11},{"id":76,"text":"that he thought","depth":13},{"id":77,"text":"he would be shot","depth":13},{"id":78,"text":"when Brown dug the gun into the officer ' s hip .","depth":12},{"id":79,"text":"Wilson said","depth":11},{"id":80,"text":"he managed to pull the trigger","depth":12},{"id":81,"text":"and the gun \" clicked \" twice","depth":14},{"id":82,"text":"without firing","depth":14},{"id":83,"text":"before a shot blasted through the window .","depth":13},{"id":84,"text":"Brown ,","depth":16},{"id":85,"text":"according to Wilson ,","depth":16},{"id":86,"text":"then stepped back","depth":15},{"id":87,"text":"and glared at the officer with the \" most intense , aggressive \" face .","depth":14},{"id":88,"text":"\" The only way","depth":17},{"id":89,"text":"I can describe it ,","depth":17},{"id":90,"text":"it looks like a demon ,","depth":16},{"id":91,"text":"that ' s how angry he looked , \"","depth":15},{"id":92,"text":"Wilson told the grand jury .","depth":14},{"id":93,"text":"\" He comes back toward me again","depth":14},{"id":94,"text":"with his hands up . \"","depth":14},{"id":95,"text":"Wilson shielded his face","depth":15},{"id":96,"text":"and fired again ,","depth":15},{"id":97,"text":"telling the grand jury","depth":16},{"id":98,"text":"he fired two shots in the car","depth":16},{"id":99,"text":"before the unarmed teen fled","depth":16},{"id":100,"text":"and Wilson followed .","depth":16},{"id":101,"text":"When Brown stopped ,","depth":14},{"id":102,"text":"Wilson told him to get on the ground .","depth":14},{"id":103,"text":"Wilson said","depth":14},{"id":104,"text":"he fired a series of shots","depth":15},{"id":105,"text":"when Brown kept approaching him with his right hand under his shirt in the waistband of his pants .","depth":15},{"id":106,"text":"Wilson then fired another round of shots","depth":14},{"id":107,"text":"as Brown approached Wilson","depth":15},{"id":108,"text":"as if he was going to tackle the officer .","depth":15},{"id":109,"text":"\" Just coming straight at me","depth":16},{"id":110,"text":"like he was going to run right through me , \"","depth":16},{"id":111,"text":"Wilson said .","depth":15},{"id":112,"text":"\" And","depth":15},{"id":113,"text":"when he gets about ... 8 to 10 feet away ...","depth":17},{"id":114,"text":"all","depth":18},{"id":115,"text":"I see is his head","depth":18},{"id":116,"text":"and that ' s what I shot . \"","depth":16},{"id":117,"text":"Johnson 's version of events differed in key respects .","depth":6},{"id":118,"text":"He told the grand jury","depth":7},{"id":119,"text":"he expected to be arrested","depth":9},{"id":120,"text":"while they were walking home","depth":9},{"id":121,"text":"after Brown stole cigarillos from a liquor store .","depth":8},{"id":122,"text":"Wilson ,","depth":10},{"id":123,"text":"Johnson said ,","depth":10},{"id":124,"text":"initially drove past the men","depth":9},{"id":125,"text":"after originally telling them to get onto the sidewalk ,","depth":9},{"id":126,"text":"reversing his patrol car","depth":11},{"id":127,"text":"and returning to the pair","depth":11},{"id":128,"text":"after they ignored his demand .","depth":10},{"id":129,"text":"\" After he pulled back ,","depth":10},{"id":130,"text":"there was no more sidewalk talk ,","depth":11},{"id":131,"text":"it was nothing ,","depth":12},{"id":132,"text":"it was just anger , \"","depth":12},{"id":133,"text":"Johnson told the grand jury .","depth":9},{"id":134,"text":"Wilson opened his door suddenly ,","depth":13},{"id":135,"text":"Johnson said ,","depth":13},{"id":136,"text":"striking Brown","depth":13},{"id":137,"text":"before closing the door","depth":14},{"id":138,"text":"and grabbing Brown by the neck .","depth":14},{"id":139,"text":"The two men engaged in a \" tug of war , \"","depth":14},{"id":140,"text":"Johnson said ,","depth":14},{"id":141,"text":"with each holding onto the other ' s shirt and arms .","depth":13},{"id":142,"text":"Johnson said","depth":13},{"id":143,"text":"he heard Wilson say ,","depth":15},{"id":144,"text":"\" I ' ll shoot ! \"","depth":15},{"id":145,"text":"as the men grappled .","depth":14},{"id":146,"text":"Johnson said","depth":12},{"id":147,"text":"he never saw Brown punch Wilson","depth":13},{"id":148,"text":"and didn ' t think","depth":14},{"id":149,"text":"he grabbed the officer ' s gun .","depth":14},{"id":150,"text":"\" At the time I couldn ' t open my mouth , \"","depth":14},{"id":151,"text":"Johnson said .","depth":14},{"id":152,"text":"\" I couldn ' t speak .","depth":14},{"id":153,"text":"I wanted to say","depth":15},{"id":154,"text":"could someone calm down ...","depth":15},{"id":155,"text":"I ' m still standing there ,","depth":15},{"id":156,"text":"more shocked than ever","depth":15},{"id":157,"text":"because I see","depth":15},{"id":158,"text":"it is escalating .","depth":15},{"id":159,"text":"I can see and hear the cuss words ,","depth":14},{"id":160,"text":"I can see the frowns on their faces getting more intense . \"","depth":14},{"id":161,"text":"Johnson said","depth":11},{"id":162,"text":"he and Brown fled","depth":12},{"id":163,"text":"after the initial shots were fired .","depth":12},{"id":164,"text":"Brown stopped","depth":13},{"id":165,"text":"and turned to face the officer , however ,","depth":13},{"id":166,"text":"after Wilson shot again .","depth":12},{"id":167,"text":"\" At that time Big Mike ' s hands was up , but not so much in the air ,","depth":14},{"id":168,"text":"because he had been struck ...","depth":14},{"id":169,"text":"he said ,","depth":16},{"id":170,"text":"' I don ' t have a gun , '","depth":16},{"id":171,"text":"but he ' s still mad ,","depth":16},{"id":172,"text":"he still has his angry face , \"","depth":16},{"id":173,"text":"Johnson said .","depth":14},{"id":174,"text":"\" I don ' t have a gun ...","depth":13},{"id":175,"text":"and","depth":14},{"id":176,"text":"before he can say the second sentence","depth":16},{"id":177,"text":"or before he can even get it out ,","depth":16},{"id":178,"text":"that ' s when the several more shots came . \"","depth":15},{"id":179,"text":"Johnson insisted","depth":8},{"id":180,"text":"Brown did not run at the officer prior to the fatal shots .","depth":8},{"id":181,"text":"\" Some witnesses maintained their original statement","depth":11},{"id":182,"text":"that Mr. Brown had his hands in the air","depth":12},{"id":183,"text":"and was not moving toward the officer","depth":13},{"id":184,"text":"when he was shot , \"","depth":13},{"id":185,"text":"St. Louis County prosecuting attorney Robert McCulloch said .","depth":10},{"id":186,"text":"\" Several witnesses said","depth":10},{"id":187,"text":"Mr. Brown did not raise his hands at all","depth":11},{"id":188,"text":"or that he raised them briefly","depth":12},{"id":189,"text":"and then dropped them","depth":13},{"id":190,"text":"and then turned toward Officer Wilson ,","depth":14},{"id":191,"text":"who then fired several rounds . \"","depth":14},{"id":192,"text":"One witness","depth":13},{"id":193,"text":"whose name was not listed in the grand jury transcripts","depth":13},{"id":194,"text":"testified","depth":12},{"id":195,"text":"he was working in a nearby building","depth":13},{"id":196,"text":"and saw Brown leaning through the police vehicle window","depth":13},{"id":197,"text":"and \" some sort of confrontation \" took place .","depth":12},{"id":198,"text":"A shot rang out ,","depth":13},{"id":199,"text":"he said ,","depth":13},{"id":200,"text":"and Brown fled","depth":13},{"id":201,"text":"as the officer chased him","depth":14},{"id":202,"text":"with his gun drawn .","depth":14},{"id":203,"text":"Brown stopped ,","depth":14},{"id":204,"text":"according to the witness ,","depth":14},{"id":205,"text":"but never raised his hands .","depth":13},{"id":206,"text":"Brown \" ran towards the officer full charge , \"","depth":14},{"id":207,"text":"he said ,","depth":14},{"id":208,"text":"when Wilson fired several shots .","depth":13},{"id":209,"text":"Another witness testified","depth":12},{"id":210,"text":"she and her husband saw the shooting from a nearby apartment complex .","depth":12},{"id":211,"text":"After the first two shots were fired ,","depth":13},{"id":212,"text":"she said","depth":13},{"id":213,"text":"Brown began running from Wilson ' s vehicle","depth":13},{"id":214,"text":"but stopped ,","depth":14},{"id":215,"text":"turned around","depth":15},{"id":216,"text":"and started heading toward Wilson ,","depth":16},{"id":217,"text":"who shot at him .","depth":16},{"id":218,"text":"\" No , he wasn ' t , \"","depth":13},{"id":219,"text":"the witness said","depth":13},{"id":220,"text":"when asked","depth":13},{"id":221,"text":"if it appeared Brown was approaching Wilson in a threatening fashion .","depth":13},{"id":222,"text":"\" I think","depth":13},{"id":223,"text":"he was stunned , honestly . \"","depth":13},{"id":224,"text":"\" He just kept walking toward the officer , \"","depth":14},{"id":225,"text":"she told the grand jury .","depth":14},{"id":226,"text":"\" He didn ' t stop . \"","depth":13},{"id":227,"text":"The Justice Department will continue to investigate the shooting for evidence of a potential civil rights violation ,","depth":3},{"id":228,"text":"although the federal investigators face a higher burden of proof","depth":4},{"id":229,"text":"to establish","depth":5},{"id":230,"text":"whether Wilson willfully deprived Brown of his civil rights .","depth":5},{"id":231,"text":"In recent high-profile shootings , that standard has been tough to satisfy ,","depth":5},{"id":232,"text":"including a case","depth":6},{"id":233,"text":"in which federal prosecutors this year declined to charge officers","depth":7},{"id":234,"text":"who fatally shot an unarmed woman with a baby in her back seat after a car chase from the White House to the U.S. Capitol .","depth":7},{"id":235,"text":"\" For a cop to be indicted","depth":6},{"id":236,"text":"and especially to be convicted later of a crime in these kinds of situations , is very , very unusual , \"","depth":6},{"id":237,"text":"said Chuck Drago , a police practices consultant and former police chief in Oviedo , Fla .","depth":5},{"id":238,"text":"In a 1989 decision , the Supreme Court shaped the national standard","depth":6},{"id":239,"text":"regarding the use of force by officers","depth":7},{"id":240,"text":"when they reasonably fear imminent physical harm .","depth":7},{"id":241,"text":"The use of force must be evaluated through the \" perspective of a reasonable officer on the scene \"","depth":7},{"id":242,"text":"rather than being judged after the fact ,","depth":7},{"id":243,"text":"meaning officers are often given the benefit of the doubt by prosecutors","depth":7},{"id":244,"text":"and grand jurors are reluctant to second-guess their decisions .","depth":7},{"id":245,"text":"Many of the cases","depth":7},{"id":246,"text":"that do not result in charges","depth":7},{"id":247,"text":"involve armed suspects","depth":7},{"id":248,"text":"shot during violent confrontations with police .","depth":7},{"id":249,"text":"But even an officer","depth":9},{"id":250,"text":"who repeatedly shot an unarmed person","depth":10},{"id":251,"text":"- as was the case in Ferguson -","depth":10},{"id":252,"text":"may avoid prosecution","depth":8},{"id":253,"text":"if he or she contends","depth":8},{"id":254,"text":"they felt an imminent risk .","depth":8},{"id":255,"text":"\" A police officer is not like a normal citizen","depth":9},{"id":256,"text":"who discharges their weapon , \"","depth":9},{"id":257,"text":"said Lori Lightfoot , a Chicago attorney","depth":9},{"id":258,"text":"who previously probed police shootings .","depth":9},{"id":259,"text":"\" There is a presumption","depth":8},{"id":260,"text":"that somebody","depth":10},{"id":261,"text":"who is a peace officer ,","depth":11},{"id":262,"text":"and is thereby authorized to use lethal force ,","depth":11},{"id":263,"text":"used it correctly . \"","depth":9}],"relations":[{"parent":527,"left":490,"right":526,"relation":"joint","nuclearity":"NN"},{"parent":490,"left":279,"right":489,"relation":"elaboration","nuclearity":"NS"},{"parent":279,"left":275,"right":278,"relation":"context","nuclearity":"NS"},{"parent":275,"left":266,"right":274,"relation":"elaboration","nuclearity":"NS"},{"parent":266,"left":265,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":265,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":274,"left":268,"right":273,"relation":"same-unit","nuclearity":"NN"},{"parent":268,"left":3,"right":267,"relation":"elaboration","nuclearity":"NS"},{"parent":267,"left":4,"right":5,"relation":"context","nuclearity":"NS"},{"parent":273,"left":6,"right":272,"relation":"elaboration","nuclearity":"NS"},{"parent":272,"left":269,"right":271,"relation":"elaboration","nuclearity":"NS"},{"parent":269,"left":7,"right":8,"relation":"context","nuclearity":"NS"},{"parent":271,"left":9,"right":270,"relation":"attribution","nuclearity":"SN"},{"parent":27