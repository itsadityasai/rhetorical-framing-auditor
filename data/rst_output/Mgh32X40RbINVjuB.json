{"article_id":"Mgh32X40RbINVjuB","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"The woman","depth":11},{"id":2,"text":"who wrote a confidential letter","depth":12},{"id":3,"text":"accusing Supreme Court nominee Brett Kavanaugh of sexually assaulting her","depth":13},{"id":4,"text":"when they were in high school","depth":13},{"id":5,"text":"says","depth":10},{"id":6,"text":"she feared for her life during the attack .","depth":9},{"id":7,"text":"\" I thought","depth":11},{"id":8,"text":"he might inadvertently kill me , \"","depth":11},{"id":9,"text":"Christine Blasey Ford , 51 , a research psychologist in northern California , told The Washington Post in an interview","depth":11},{"id":10,"text":"published Sunday .","depth":11},{"id":11,"text":"\" He was trying to attack me","depth":11},{"id":12,"text":"and remove my clothing , \"","depth":11},{"id":13,"text":"Ford said .","depth":10},{"id":14,"text":"The Post interview marks the first time","depth":9},{"id":15,"text":"that Ford has allowed her name to be disclosed","depth":9},{"id":16,"text":"since her accusations against Kavanaugh became public last week .","depth":8},{"id":17,"text":"Kavanaugh has denied the allegations .","depth":7},{"id":18,"text":"In a statement to NBC News on Sunday , the White House said ,","depth":8},{"id":19,"text":"`` On Friday , Judge Kavanaugh 'categorically and unequivocally ' denied this allegation .","depth":10},{"id":20,"text":"This has not changed .","depth":10},{"id":21,"text":"Judge Kavanaugh and the White House both stand by that statement . ''","depth":9},{"id":22,"text":"The Senate Judiciary Committee is likely to vote on Kavanaugh ' s nomination Thursday .","depth":8},{"id":23,"text":"But","depth":10},{"id":24,"text":"after the Post published Ford 's account Sunday ,","depth":11},{"id":25,"text":"Senate Minority Leader Chuck Schumer , D-N.Y. , called for the vote to be delayed","depth":12},{"id":26,"text":"until , `` at a very minimum , these serious and credible allegations are thoroughly investigated . ''","depth":12},{"id":27,"text":"\" For too long ,","depth":13},{"id":28,"text":"when women have made serious allegations of abuse ,","depth":14},{"id":29,"text":"they have been ignored , \"","depth":14},{"id":30,"text":"Schumer said .","depth":12},{"id":31,"text":"\" That can not happen in this case .","depth":11},{"id":32,"text":"... To railroad a vote now would be an insult to the women of America and the integrity of the Supreme Court . \"","depth":10},{"id":33,"text":"Other Democrats on the Judiciary Committee also called for the vote to be delayed ,","depth":9},{"id":34,"text":"including Sen. Dick Durbin ,","depth":10},{"id":35,"text":"who called on the FBI to `` complete a professional investigation ''","depth":11},{"id":36,"text":"of what he called `` serious and credible allegations . '' `","depth":11},{"id":37,"text":"` We also must respect and listen to Dr. Ford ,","depth":10},{"id":38,"text":"who is now a target of personal attacks","depth":11},{"id":39,"text":"because she had the courage","depth":12},{"id":40,"text":"to come forward , ''","depth":12},{"id":41,"text":"the Illinois Democrat said in a statement .","depth":9},{"id":42,"text":"Republicans , however , showed no signs of budging .","depth":7},{"id":43,"text":"Grassley 's office issued a statement","depth":10},{"id":44,"text":"that called Ford 's account `` uncorroborated allegations ''","depth":10},{"id":45,"text":"and noted","depth":10},{"id":46,"text":"that no such accusations had turned up during the six times","depth":11},{"id":47,"text":"the FBI has looked into Kavanaugh 's background over his decades of public service .","depth":11},{"id":48,"text":"The statement also blasted Democrats ' `` tactics and motives ''","depth":10},{"id":49,"text":"for bringing the allegations to light","depth":10},{"id":50,"text":"just days before the committee is set to vote .","depth":9},{"id":51,"text":"According to the Post ,","depth":5},{"id":52,"text":"Ford is a professor at Palo Alto University","depth":7},{"id":53,"text":"who teaches in a consortium with Stanford University ,","depth":8},{"id":54,"text":"training graduate students in clinical psychology .","depth":8},{"id":55,"text":"Her work has been widely published in academic journals .","depth":6},{"id":56,"text":"More :","depth":6},{"id":57,"text":"Ken Starr says","depth":7},{"id":58,"text":"woman","depth":9},{"id":59,"text":"accusing Kavanaugh of misconduct","depth":9},{"id":60,"text":"' failed ' to come forward for years","depth":8},{"id":61,"text":"More :","depth":6},{"id":62,"text":"Anita Hill weighs in on misconduct allegation against Brett Kavanaugh","depth":6},{"id":63,"text":"Ford said","depth":8},{"id":64,"text":"she decided to come forward and tell her story","depth":9},{"id":65,"text":"after a bare-bones version of the events became public","depth":11},{"id":66,"text":"without her name and consent ,","depth":11},{"id":67,"text":"prompting a denial from Kavanaugh","depth":11},{"id":68,"text":"and throwing his nomination into turmoil .","depth":11},{"id":69,"text":"According to Ford ,","depth":10},{"id":70,"text":"the attack occurred one summer during the early 1980s","depth":11},{"id":71,"text":"when she and Kavanaugh attended a gathering with other teenagers at a house in Montgomery County , Maryland .","depth":11},{"id":72,"text":"Ford contends","depth":12},{"id":73,"text":"that Kavanaugh and a friend ,","depth":14},{"id":74,"text":"both of whom she described as \" stumbling drunk , \"","depth":14},{"id":75,"text":"corralled her into a bedroom .","depth":13},{"id":76,"text":"While his friend watched ,","depth":15},{"id":77,"text":"Ford said ,","depth":15},{"id":78,"text":"Kavanaugh pinned her to a bed on her back","depth":15},{"id":79,"text":"and groped her over her clothes .","depth":15},{"id":80,"text":"Kavanaugh grinded his body against hers","depth":15},{"id":81,"text":"and attempted to pull off her one-piece bathing suit and the clothing","depth":16},{"id":82,"text":"she wore over it ,","depth":16},{"id":83,"text":"she said .","depth":14},{"id":84,"text":"When she tried to scream ,","depth":14},{"id":85,"text":"she said ,","depth":14},{"id":86,"text":"he put his hand over her mouth .","depth":13},{"id":87,"text":"Ford said","depth":12},{"id":88,"text":"she was able to escape","depth":13},{"id":89,"text":"when Kavanaugh ' s friend and classmate at Georgetown Preparatory School , Mark Judge , jumped on top of all of them ,","depth":14},{"id":90,"text":"sending all three tumbling .","depth":14},{"id":91,"text":"She said","depth":12},{"id":92,"text":"she ran from the room ,","depth":13},{"id":93,"text":"briefly locked herself in a bathroom","depth":14},{"id":94,"text":"and then fled from the house .","depth":14},{"id":95,"text":"Ford described the attack in late July in a confidential letter to Sen. Dianne Feinstein of California , the top Democrat on the Senate Judiciary Committee ,","depth":10},{"id":96,"text":"who honored Ford ' s request for confidentiality","depth":11},{"id":97,"text":"but referred the matter to FBI .","depth":11},{"id":98,"text":"The bureau added it to Kavanaugh 's background investigation file","depth":10},{"id":99,"text":"but is not pursuing a criminal investigation .","depth":10},{"id":100,"text":"The Post said","depth":10},{"id":101,"text":"Ford also had contacted the paper through a tip line in early June","depth":11},{"id":102,"text":"when it had become clear that Kavanaugh was on the short list for the Supreme Court nomination .","depth":11},{"id":103,"text":"Ford said","depth":12},{"id":104,"text":"she never told anyone about the attack until 2012 ,","depth":13},{"id":105,"text":"when she was in couple ' s therapy with her husband .","depth":13},{"id":106,"text":"The Post said","depth":14},{"id":107,"text":"portions of the therapist ' s notes were made available to the paper","depth":15},{"id":108,"text":"and that ,","depth":16},{"id":109,"text":"while Kavanaugh wasn ' t mentioned by name ,","depth":18},{"id":110,"text":"the records indicated","depth":18},{"id":111,"text":"that Ford told her therapist","depth":18},{"id":112,"text":"that she had been attacked by students \" from an elitist boys ' school \"","depth":19},{"id":113,"text":"who went on to become \" highly respected and high-ranking members of society in Washington . \"","depth":19},{"id":114,"text":"Notes from an individual therapy session the following year show","depth":14},{"id":115,"text":"Ford described a \" rape attempt \" in her late teens .","depth":14},{"id":116,"text":"Ford ' s husband , Russell Ford , told The Post","depth":13},{"id":117,"text":"that in their 2012 therapy sessions , she recounted the attack","depth":14},{"id":118,"text":"and that she used Kavanaugh ' s last name","depth":15},{"id":119,"text":"and voiced concern","depth":16},{"id":120,"text":"that he might one day be nominated to the Supreme Court .","depth":16},{"id":121,"text":"Ford also took a polygraph test ,","depth":14},{"id":122,"text":"administered by a former FBI agent ,","depth":14},{"id":123,"text":"on the advice of her attorney in early August ,","depth":13},{"id":124,"text":"the paper said .","depth":12},{"id":125,"text":"The test concluded","depth":13},{"id":126,"text":"she was being truthful","depth":13},{"id":127,"text":"when she said","depth":13},{"id":128,"text":"a statement","depth":15},{"id":129,"text":"summarizing her allegations","depth":15},{"id":130,"text":"was accurate .","depth":14},{"id":131,"text":"Ford said","depth":9},{"id":132,"text":"she does not remember some key details of the incident","depth":10},{"id":133,"text":"but believes","depth":12},{"id":134,"text":"it occurred in the summer of 1982 ,","depth":13},{"id":135,"text":"when she was 15 , around the end of her sophomore year at the all-girls Holton-Arms School in Bethesda .","depth":13},{"id":136,"text":"Kavanaugh would have been 17 at the end of his junior year at Georgetown Prep .","depth":11},{"id":137,"text":"The Post said","depth":11},{"id":138,"text":"when it sought comment Sunday ,","depth":11},{"id":139,"text":"the White House forwarded a statement","depth":11},{"id":140,"text":"Kavanaugh issued last week :","depth":11},{"id":141,"text":"\" I categorically and unequivocally deny this allegation .","depth":10},{"id":142,"text":"I did not do this back in high school or at any time . \"","depth":10},{"id":143,"text":"Judge also has denied in newspaper interviews","depth":9},{"id":144,"text":"that the incident occurred .","depth":9},{"id":145,"text":"In addition , Republicans on the Judiciary Committee have released a letter of support from 65 women","depth":8},{"id":146,"text":"who knew the 53-year-old federal appeals court judge during his high school years at Georgetown Prep , an all-boys Jesuit school in Bethesda , Maryland .","depth":8},{"id":147,"text":"`` For the entire time","depth":10},{"id":148,"text":"we have known Brett Kavanaugh ,","depth":10},{"id":149,"text":"he has behaved honorably","depth":10},{"id":150,"text":"and treated women with respect , ''","depth":10},{"id":151,"text":"the letter said .","depth":8},{"id":152,"text":"Feinstein said Sunday","depth":8},{"id":153,"text":"that the FBI should investigate the allegations against Kavanaugh","depth":9},{"id":154,"text":"before the committee moves forward with his nomination .","depth":9},{"id":155,"text":"\" It has always been Mrs. Ford ' s decision","depth":11},{"id":156,"text":"whether to come forward publicly , \"","depth":11},{"id":157,"text":"the senator said .","depth":10},{"id":158,"text":"\" For any woman , sharing an experience","depth":12},{"id":159,"text":"involving sexual assault","depth":12},{"id":160,"text":"- particularly when it involves a politically connected man with influence , authority and power -","depth":11},{"id":161,"text":"is extraordinarily difficult . \"","depth":10},{"id":162,"text":"\" From the outset , \"","depth":12},{"id":163,"text":"Feinstein said ,","depth":12},{"id":164,"text":"\" I have believed","depth":12},{"id":165,"text":"these allegations were extremely serious","depth":13},{"id":166,"text":"and bear heavily on Judge Kavanaugh ' s character .","depth":13},{"id":167,"text":"However ,","depth":11},{"id":168,"text":"as we have seen over the past few days ,","depth":12},{"id":169,"text":"they also come at a price for the victim .","depth":12},{"id":170,"text":"I hope","depth":10},{"id":171,"text":"the attacks and shaming of her will stop","depth":11},{"id":172,"text":"and this will be treated with the seriousness","depth":12},{"id":173,"text":"it deserves . \"","depth":12},{"id":174,"text":"More :","depth":3},{"id":175,"text":"Brett Kavanaugh :","depth":4},{"id":176,"text":"Supreme Court nominee straight out of central casting","depth":4}],"relations":[{"parent":353,"left":0,"right":352,"relation":"organization","nuclearity":"SN"},{"parent":352,"left":349,"right":351,"relation":"context","nuclearity":"NS"},{"parent":349,"left":231,"right":348,"relation":"elaboration","nuclearity":"NS"},{"parent":231,"left":226,"right":230,"relation":"elaboration","nuclearity":"NS"},{"parent":226,"left":197,"right":225,"relation":"elaboration","nuclearity":"NS"},{"parent":197,"left":192,"right":196,"relation":"elaboration","nuclearity":"NS"},{"parent":192,"left":189,"right":191,"relation":"elaboration","nuclearity":"NS"},{"parent":189,"left":182,"right":188,"relation":"elaboration","nuclearity":"NS"},{"parent":182,"left":181,"right":6,"relation":"attribution","nuclearity":"SN"},{"parent":181,"left":180,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":180,"left":1,"right":179,"relation":"elaboration","nuclearity":"NS"},{"parent":179,"left":2,"right":178,"relation":"elaboration","nuclearity":"NS"},{"parent":178,"left":3,"right":4,"relation":"context","nuclearity":"NS"},{"parent":188,"left":185,"right":187,"relation":"elaboration","nuclearity":"NS"},{"parent":185,"left":183,"right":184,"relation":"attribution","nuclearity":"NS"},{"par