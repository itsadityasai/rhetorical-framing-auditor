{"article_id":"b1LXOTNIYlZRbkXv","edus":[{"id":0,"text":"Outgoing Rep. Martha McSally has been appointed","depth":5},{"id":1,"text":"to fill former Sen. John McCain 's seat","depth":5},{"id":2,"text":"just over a month after losing the race for the state 's other Senate seat .","depth":4},{"id":3,"text":"Interested in Republican Party ?","depth":5},{"id":4,"text":"Add Republican Party as an interest","depth":6},{"id":5,"text":"to stay up to date on the latest Republican Party news , video , and analysis from .","depth":6},{"id":6,"text":"Add Interest","depth":4},{"id":7,"text":"Arizona Gov . Doug Ducey announced her appointment Tuesday morning ,","depth":4},{"id":8,"text":"just days after Sen. Jon Kyl confirmed","depth":5},{"id":9,"text":"that he was stepping down from the role .","depth":5},{"id":10,"text":"In the press release","depth":6},{"id":11,"text":"announcing her appointment ,","depth":6},{"id":12,"text":"Ducey said","depth":5},{"id":13,"text":"that McSally `` is uniquely qualified","depth":5},{"id":14,"text":"to step up and fight for Arizona ' s interests in the U.S . Senate . ''","depth":5},{"id":15,"text":"McSally , a two-term congresswoman , gained national attention","depth":5},{"id":16,"text":"when she faced off against Democrat Rep. Kyrsten Sinema this fall","depth":7},{"id":17,"text":"as they both fought to take over the Senate seat","depth":8},{"id":18,"text":"being vacated by Sen. Jeff Flake 's decision","depth":9},{"id":19,"text":"not to run for re-election .","depth":9},{"id":20,"text":"Sinema won the seat in a relatively close race ,","depth":8},{"id":21,"text":"with Sinema winning 50 percent of the vote to McSally 's 47.6 percent .","depth":8},{"id":22,"text":"McSally conceded six days after the election .","depth":7},{"id":23,"text":"That election was already a historic one ,","depth":7},{"id":24,"text":"with Sinema becoming the first female","depth":8},{"id":25,"text":"to represent Arizona in the Senate .","depth":8},{"id":26,"text":"Now , the state will be one of only a few","depth":8},{"id":27,"text":"to be represented by two women .","depth":8},{"id":28,"text":"With McSally 's appointment , she and Sinema will be the only serving bipartisan pair of female senators","depth":9},{"id":29,"text":"representing their state .","depth":9},{"id":30,"text":"The only other instance","depth":10},{"id":31,"text":"of that happening","depth":10},{"id":32,"text":"was in New Hampshire from 2011 to 2017 .","depth":9},{"id":33,"text":"There are several other pairs of female senators","depth":8},{"id":34,"text":"who will be in the Senate come 2019","depth":8},{"id":35,"text":"-- in California , New Hampshire , Minnesota and Nevada --","depth":7},{"id":36,"text":"but the Arizona duo are the only ones of opposite parties .","depth":6},{"id":37,"text":"Six-term Republican Sen. John McCain passed away in late August , just days before the Republican primary in the race for Flake 's seat ,","depth":6},{"id":38,"text":"and he had an outsize impact on the race .","depth":6},{"id":39,"text":"McSally spoke movingly during her primary night victory speech about how he served as a mentor to her ,","depth":7},{"id":40,"text":"both because of their military backgrounds and their love of Arizona .","depth":7},{"id":41,"text":"`` I am forever grateful to have had the chance","depth":8},{"id":42,"text":"to know him","depth":9},{"id":43,"text":"to learn from him","depth":10},{"id":44,"text":"and even to work with him , ''","depth":10},{"id":45,"text":"she said in her Aug. 28 speech .","depth":7},{"id":46,"text":"That said ,","depth":8},{"id":47,"text":"she did not receive an endorsement from the McCain family in the midterm race ,","depth":9},{"id":48,"text":"even though she and Cindy McCain spoke at the same Election Eve event","depth":10},{"id":49,"text":"-- alongside Ducey and Kyl .","depth":10},{"id":50,"text":"In spite of the fact","depth":9},{"id":51,"text":"that McCain held his seat for decades ,","depth":9},{"id":52,"text":"it lies within the power of the governor and not McCain 's family to determine who will fill the spot","depth":9},{"id":53,"text":"until a special election can be held","depth":10},{"id":54,"text":"to formally fill it in 2020 .","depth":10},{"id":55,"text":"At a news conference today , Ducey said","depth":7},{"id":56,"text":"that he was grateful","depth":8},{"id":57,"text":"that McSally and Cindy McCain `` were able to get together","depth":9},{"id":58,"text":"and visit earlier this week","depth":10},{"id":59,"text":"and clear the air . ''","depth":10},{"id":60,"text":"Cindy McCain posted a tweet","depth":8},{"id":61,"text":"supporting the decision","depth":9},{"id":62,"text":"and calling on McSally to remember her husband 's legacy .","depth":9},{"id":63,"text":"`` My husband ' s greatest legacy was placing service to AZ & USA ahead of his own self-interest .","depth":10},{"id":64,"text":"I respect @ dougducey 's decision","depth":12},{"id":65,"text":"to appoint @ RepMcSally","depth":13},{"id":66,"text":"to fill the remainder of his term .","depth":13},{"id":67,"text":"Arizonans will be pulling for her ,","depth":12},{"id":68,"text":"hoping","depth":13},{"id":69,"text":"that she will follow his example of selfless leadership , ''","depth":13},{"id":70,"text":"she wrote on Twitter .","depth":9},{"id":71,"text":"My husband ' s greatest legacy was placing service to AZ & USA ahead of his own self-interest .","depth":9},{"id":72,"text":"I respect @ dougducey 's decision","depth":11},{"id":73,"text":"to appoint @ RepMcSally","depth":12},{"id":74,"text":"to fill the remainder of his term .","depth":12},{"id":75,"text":"Arizonans will be pulling for her ,","depth":11},{"id":76,"text":"hoping","depth":12},{"id":77,"text":"that she will follow his example of selfless leadership","depth":12},{"id":78,"text":"- Cindy McCain","depth":8},{"id":79,"text":"( @ cindymccain )","depth":8},{"id":80,"text":"December 18 , 2018","depth":7},{"id":81,"text":"For her part , McSally said","depth":6},{"id":82,"text":"that she looks forward to working with her recent rival Sinema","depth":8},{"id":83,"text":"-- who she accused of treason during the campaign --","depth":8},{"id":84,"text":"while they both serve as the state 's representatives in the Senate for the next two years .","depth":7},{"id":85,"text":"`` I am humbled and grateful to have this opportunity","depth":8},{"id":86,"text":"to serve","depth":9},{"id":87,"text":"and be a voice for all Arizonans .","depth":9},{"id":88,"text":"I look forward to working with Senator-Elect Kyrsten Sinema","depth":9},{"id":89,"text":"and getting to work from day one , ''","depth":9},{"id":90,"text":"McSally said in Ducey 's news release","depth":9},{"id":91,"text":"announcing her appointment .","depth":9},{"id":92,"text":"She echoed that sentiment at the news conference hours later ,","depth":8},{"id":93,"text":"saying","depth":9},{"id":94,"text":"that she texted Sinema this morning","depth":10},{"id":95,"text":"and she plans to work with her in the Senate `` just like we did in the House . ''","depth":10},{"id":96,"text":"`` There 's a lot of common ground between us","depth":9},{"id":97,"text":"and I 'm ready to hit it running , ''","depth":9},{"id":98,"text":"McSally said .","depth":8},{"id":99,"text":"Ducey noted","depth":6},{"id":100,"text":"that Sinema will be sworn in before McSally ,","depth":7},{"id":101,"text":"making Sinema the senior Senator from Arizona .","depth":7},{"id":102,"text":"He said","depth":6},{"id":103,"text":"that decision was made in an effort","depth":7},{"id":104,"text":"to `` respect the will of the voters . ''","depth":7},{"id":105,"text":"Assuming McSally 's appointment progresses ,","depth":6},{"id":106,"text":"the special election for McCain 's seat will be held in 2020 ,","depth":6},{"id":107,"text":"and then would be up for it 's regularly scheduled re-election in 2022 .","depth":5},{"id":108,"text":"Should McSally continue forward ,","depth":7},{"id":109,"text":"and run for re-election ,","depth":7},{"id":110,"text":"she will have campaigned three times in six years ,","depth":7},{"id":111,"text":"losing once .","depth":7},{"id":112,"text":"And","depth":6},{"id":113,"text":"since McCain won his sixth term in 2016","depth":8},{"id":114,"text":"and Sinema 's seat is up for re-election in 2024 ,","depth":8},{"id":115,"text":"Arizonans will have gone through five Senate elections in a decade .","depth":7}],"relations":[{"parent":231,"left":130,"right":230,"relation":"elaboration","nuclearity":"NS"},{"parent":130,"left":122,"right":129,"relation":"organization","nuclearity":"SN"},{"parent":122,"left":118,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":118,"left":117,"right":2,"relation":"context","nuclearity":"NS"},{"parent":117,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":121,"left":120,"right":6,"relation":"joint","nuclearity":"NN"},{"parent":120,"left":3,"right":119,"relation":"topic","nuclearity":"SN"},{"parent":119,"left":4,"right":5,"relation":"purpose","nuclearity":"NS"},{"parent":129,"left":124,"right":128,"relation":"elaboration","nuclearity":"NS"},{"parent":124,"left":7,"right":123,"relation":"context","nuclearity":"NS"},{"parent":123,"left":8,"right":9,"relation":"attribution","nuclearity":"SN"},{"parent":128,"left":126,"right":127,"relation":"attribution","nuclearity":"SN"},{"parent":126,"left":125,"right":12,"relation":"same-unit","nuclearity":"NN"},{"parent":125,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":127,"left":13,"right":14,"relation":"purpose","nuclearity":"NS"},{"parent":230,"left":195,"right":229,"relation":"joint","nuclearity":"NN"},{"parent":195,"left":151,"right":194,"relation":"elaboration","nuclearity":"NS"},{"parent":151,"left":137,"right":150,"relation":"elaboration","nuclearity":"NS"},{"parent":137,"left":15,"right":136,"relation":"context","nuclearity":"NS"},{"parent":136,"left":133,"right":135,"relation":"elaboration","nuclearity":"NS"},{