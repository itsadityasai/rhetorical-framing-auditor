{"article_id":"rZmff2z3FwDFZLzf","edus":[{"id":0,"text":"Fired FBI Director James B. Comey told agents","depth":4},{"id":1,"text":"he appeared to have lost track of two memos","depth":5},{"id":2,"text":"he kept detailing conversations with President Trump ,","depth":5},{"id":3,"text":"according to new documents","depth":4},{"id":4,"text":"revealed Wednesday by Judicial Watch .","depth":4},{"id":5,"text":"The FBI sent agents to visit Mr. Comey at home in 2017 , after his firing ,","depth":5},{"id":6,"text":"to speak with him about the memos ,","depth":6},{"id":7,"text":"which the former director had leaked","depth":7},{"id":8,"text":"in order to embarrass Mr. Trump .","depth":7},{"id":9,"text":"Agents collected four memos from Mr. Comey","depth":6},{"id":10,"text":"ranging in dates from February to June .","depth":6},{"id":11,"text":"But Mr. Comey told the agents","depth":6},{"id":12,"text":"two memos","depth":8},{"id":13,"text":"he believed","depth":9},{"id":14,"text":"he wrote","depth":9},{"id":15,"text":"\" were missing . \"","depth":7},{"id":16,"text":"Agents recounted :","depth":4},{"id":17,"text":"\" In the first occurrence ,","depth":8},{"id":18,"text":"Comey said","depth":8},{"id":19,"text":"at an unknown date and time , between January 7 , 2017 ,","depth":9},{"id":20,"text":"which Comey believed","depth":10},{"id":21,"text":"was the date of his briefing at Trump Tower , and Trump ' s inauguration on January 20th , 2017 , Comey received a phone call from President Elect Donald J. Trump .","depth":10},{"id":22,"text":"The originating telephone number may have had a New York area code .","depth":8},{"id":23,"text":"Following the telephone conversation ,","depth":7},{"id":24,"text":"Comey drafted and e-mailed a memo to James Rybicki and FBI Deputy Director Andrew McCabe . \"","depth":7},{"id":25,"text":"\" In the second instance , Comey was on his way to a FBI leadership conference in Leesburg , Virginia","depth":9},{"id":26,"text":"( March 9 , 2017 )","depth":9},{"id":27,"text":"when he was diverted to Liberty Crossing","depth":9},{"id":28,"text":"to respond to a request from Trump","depth":10},{"id":29,"text":"to contact him .","depth":10},{"id":30,"text":"Comey contacted Trump from Liberty Crossing on a Top Secret telephone line .","depth":8},{"id":31,"text":"The conversation was \" all business \"","depth":9},{"id":32,"text":"and related to [ redacted ] .","depth":9},{"id":33,"text":"Comey is less sure","depth":8},{"id":34,"text":"he drafted a memo for his conversation","depth":8},{"id":35,"text":"but","depth":8},{"id":36,"text":"if he did ,","depth":9},{"id":37,"text":"he may have sent it on the FBI ' s Top Secret network . \"","depth":9},{"id":38,"text":"The agents ' account was contained in an FBI log","depth":4},{"id":39,"text":"detailing evidence collection .","depth":4},{"id":40,"text":"Judicial Watch obtained the log","depth":4},{"id":41,"text":"after filing a Freedom of Information Act lawsuit","depth":5},{"id":42,"text":"demanding the Justice Department ' s records","depth":6},{"id":43,"text":"pertaining to Mr. Comey ' s memos and his sharing them with the special counsel ' s office .","depth":6},{"id":44,"text":"Special counsel Robert Mueller has said","depth":4},{"id":45,"text":"Mr. Trump ' s behavior","depth":6},{"id":46,"text":"surrounding Mr. Comey ' s firing","depth":6},{"id":47,"text":"raised questions of attempted obstruction of justice .","depth":5},{"id":48,"text":"The memos themselves , though , have also drawn scrutiny , with suggestions","depth":5},{"id":49,"text":"that Mr. Comey acted improperly","depth":6},{"id":50,"text":"and mishandled classified information .","depth":6},{"id":51,"text":"President Tom Fitton said","depth":6},{"id":52,"text":"the newly revealed log entry shows","depth":8},{"id":53,"text":"Mr. Comey never should have had the memos at his home ,","depth":8},{"id":54,"text":"and the FBI itself bungled","depth":8},{"id":55,"text":"by failing to secure the files .","depth":8},{"id":56,"text":"\" Mr . Comey ' s illegal leaking these FBI files as part of his vendetta against President Trump","depth":8},{"id":57,"text":"( directly resulting in the corrupt appointment of Robert Mueller )","depth":8},{"id":58,"text":"ought to be the subject of a criminal investigation , \"","depth":7},{"id":59,"text":"Mr. Fitton said in a statement .","depth":6}],"relations":[{"parent":119,"left":97,"right":118,"relation":"elaboration","nuclearity":"NS"},{"parent":97,"left":64,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":62,"right":63,"relation":"attribution","nuclearity":"NS"},{"parent":62,"left":0,"right":61,"relation":"attribution","nuclearity":"SN"},{"parent":61,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":96,"left":74,"right":95,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":67,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":5,"right":66,"relation":"purpose","nuclearity":"NS"},{"parent":66,"left":6,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":7,"right":8,"relation":"purpose","nuclearity":"NS"},{"parent":73,"left":68,"right":72,"relation":"adversative","nuclearity":"NN"},{"parent":68,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":11,"right":71,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":70,"right":15,"relation":"same-unit","nuclearity":"NN"},{"parent":70,"left":12,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":13,"right":14,"relation":"attribution","nuclearity":"SN"},{"parent":95,"left":16,"right":94,"relation":"attribution","nuclearity":"SN"},{"parent":94,"left":81,"right":93,"relation":"joint","nuclearity":"NN"},{"parent":81,"left":79,"right":80,"relation":"joint","nuclearity":"NN"},{"parent":79,"left":75,"right":78,"relation":"same-unit","nuclearity":"NN"},{"parent":75,