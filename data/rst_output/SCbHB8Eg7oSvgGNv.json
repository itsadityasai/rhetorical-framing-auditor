{"article_id":"SCbHB8Eg7oSvgGNv","edus":[{"id":0,"text":"Story highlights","depth":1},{"id":1,"text":"A conservative group launches a new ad campaign against Obama","depth":3},{"id":2,"text":"President Barack Obama cites continued growth in brief reference to job numbers","depth":6},{"id":3,"text":"`` His policies have not worked , ''","depth":7},{"id":4,"text":"certain GOP nominee Mitt Romney says of Obama","depth":7},{"id":5,"text":"Obama wraps up a two-day bus tour to key battleground states","depth":5},{"id":6,"text":"President Barack Obama downplayed a weak jobs report Friday","depth":9},{"id":7,"text":"as he wrapped up a two-day bus tour to critical states in the November election ,","depth":9},{"id":8,"text":"while Republicans pounced on the news","depth":9},{"id":9,"text":"to declare","depth":10},{"id":10,"text":"the president 's policies have failed .","depth":10},{"id":11,"text":"Stock prices plunged on the report","depth":10},{"id":12,"text":"that the economy created 80,000 jobs in June , well below the number","depth":11},{"id":13,"text":"needed","depth":12},{"id":14,"text":"to bring down the 8.2 % unemployment rate .","depth":12},{"id":15,"text":"At a campaign event in Poland , Ohio , Obama said","depth":11},{"id":16,"text":"the job growth","depth":14},{"id":17,"text":"-- while smaller than needed --","depth":14},{"id":18,"text":"continued a trend","depth":13},{"id":19,"text":"that has added 4.4 million jobs in the past 28 months","depth":13},{"id":20,"text":"following what he called `` the worst economic crisis of our lifetime . ''","depth":13},{"id":21,"text":"Republicans , however , called the weak growth a result of Obama policies","depth":12},{"id":22,"text":"that do n't work .","depth":12},{"id":23,"text":"Certain GOP presidential nominee Mitt Romney called the jobs figures a `` kick in the gut for middle-class families , ''","depth":12},{"id":24,"text":"blaming Obama 's policies for continued high unemployment","depth":13},{"id":25,"text":"and saying","depth":14},{"id":26,"text":"it was `` time for Americans to choose","depth":15},{"id":27,"text":"whether they want more of the same . ''","depth":15},{"id":28,"text":"JUST WATCHED","depth":14},{"id":29,"text":"Romney :","depth":15},{"id":30,"text":"Jobs report a 'kick in the gut '","depth":15},{"id":31,"text":"Replay More Videos ...","depth":13},{"id":32,"text":"MUST WATCH Romney :","depth":13},{"id":33,"text":"Jobs report a 'kick in the gut '","depth":13},{"id":34,"text":"01:30","depth":11},{"id":35,"text":"JUST WATCHED","depth":13},{"id":36,"text":"June jobs report disappoints","depth":13},{"id":37,"text":"Replay More Videos ...","depth":14},{"id":38,"text":"MUST WATCH June jobs report disappoints","depth":14},{"id":39,"text":"01:55","depth":13},{"id":40,"text":"JUST WATCHED Dueling Obama , Romney bus tours","depth":15},{"id":41,"text":"Replay More Videos ...","depth":15},{"id":42,"text":"MUST WATCH Dueling Obama , Romney bus tours","depth":14},{"id":43,"text":"03:07","depth":13},{"id":44,"text":"JUST WATCHED","depth":16},{"id":45,"text":"Landrieu :","depth":17},{"id":46,"text":"President Obama doing good job","depth":17},{"id":47,"text":"Replay More Videos ...","depth":16},{"id":48,"text":"MUST WATCH Landrieu :","depth":17},{"id":49,"text":"President Obama doing good job","depth":17},{"id":50,"text":"00:44","depth":14},{"id":51,"text":"JUST WATCHED","depth":14},{"id":52,"text":"Romney clarifies health care positions","depth":14},{"id":53,"text":"Replay More Videos ...","depth":11},{"id":54,"text":"MUST WATCH","depth":12},{"id":55,"text":"Romney clarifies health care positions","depth":12},{"id":56,"text":"05:49","depth":10},{"id":57,"text":"`` His policies have not worked , ''","depth":8},{"id":58,"text":"Romney said at a brief news conference in New Hampshire ,","depth":9},{"id":59,"text":"where he is vacationing with his family .","depth":9},{"id":60,"text":"Referring to more than three years of unemployment higher than 8 % ,","depth":9},{"id":61,"text":"Romney said","depth":10},{"id":62,"text":"`` the evidence is in , again and again and again ''","depth":10},{"id":63,"text":"and added","depth":9},{"id":64,"text":"that the continuing high unemployment rate `` pretty much defines lack of success . ''","depth":9},{"id":65,"text":"Other Republican leaders echoed Romney 's remarks ,","depth":9},{"id":66,"text":"with House Speaker John Boehner taking a jab at Obama 's comment last month","depth":11},{"id":67,"text":"that","depth":12},{"id":68,"text":"when compared to public sector job creation ,","depth":13},{"id":69,"text":"the private sector was `` doing fine . ''","depth":13},{"id":70,"text":"`` Today 's report shows","depth":12},{"id":71,"text":"the private sector clearly is n't 'doing fine '","depth":13},{"id":72,"text":"and that President Obama 's policies have failed , ''","depth":13},{"id":73,"text":"Boehner , R-Ohio , said in a statement .","depth":11},{"id":74,"text":"Republican National Committee Chairman Reince Priebus ' statement said ,","depth":9},{"id":75,"text":"`` The Obama economy is defined by chronically high unemployment . ''","depth":9},{"id":76,"text":"Also Friday , an independent group","depth":12},{"id":77,"text":"co-founded by conservative operative Karl Rove","depth":12},{"id":78,"text":"said","depth":11},{"id":79,"text":"it was launching a new ad","depth":12},{"id":80,"text":"targeting what","depth":13},{"id":81,"text":"it claimed","depth":14},{"id":82,"text":"were Obama 's excuses for the bad economy .","depth":14},{"id":83,"text":"Crossroads GPS said","depth":12},{"id":84,"text":"the spot was the first wave of a $ 25 million ad buy","depth":13},{"id":85,"text":"starting July 10","depth":14},{"id":86,"text":"and running through early August in Colorado , Florida , Iowa , Michigan , North Carolina , New Hampshire , Nevada , Ohio and Virginia","depth":15},{"id":87,"text":"-- all swing states","depth":16},{"id":88,"text":"that both Democrats and Republicans will heavily contest in the presidential election .","depth":16},{"id":89,"text":"In speeches in Ohio and Pennsylvania","depth":14},{"id":90,"text":"to conclude the bus tour ,","depth":14},{"id":91,"text":"Obama referred to the negative ads by Republicans","depth":13},{"id":92,"text":"and told supporters not to get discouraged .","depth":12},{"id":93,"text":"`` You 'll hear the same thing from them over and over again ,","depth":14},{"id":94,"text":"because they know","depth":15},{"id":95,"text":"that their economic theory is n't going to sell , ''","depth":15},{"id":96,"text":"the president told a Pittsburgh event .","depth":13},{"id":97,"text":"`` So all","depth":16},{"id":98,"text":"they 've got to argue","depth":16},{"id":99,"text":"is the economy 's not moving as fast","depth":16},{"id":100,"text":"as it needs to .","depth":16},{"id":101,"text":"Jobs are n't growing as fast","depth":15},{"id":102,"text":"as they need to .","depth":15},{"id":103,"text":"And it 's all Obama 's fault .","depth":14},{"id":104,"text":"That 's basically their only message . ''","depth":14},{"id":105,"text":"Obama briefly mentioned the new jobs report in Ohio","depth":13},{"id":106,"text":"and did n't refer to it specifically in Pittsburgh .","depth":13},{"id":107,"text":"Instead , his full-fledged campaign speeches emphasized restoring opportunity for the middle class , in contrast to what he characterized as Republican policies","depth":13},{"id":108,"text":"that favor corporations and the wealthy .","depth":13},{"id":109,"text":"In Ohio , Obama joked with the crowd ,","depth":13},{"id":110,"text":"kissed at least one baby","depth":14},{"id":111,"text":"and outlined his vision of middle-class opportunity","depth":14},{"id":112,"text":"while making sure to note his administration 's help","depth":13},{"id":113,"text":"in reviving the U.S. auto industry ,","depth":14},{"id":114,"text":"which is big in the state .","depth":14},{"id":115,"text":"He rebuffed GOP criticism","depth":11},{"id":116,"text":"that his policies are wrong ,","depth":11},{"id":117,"text":"blaming political stalemate in Washington for the failure by Congress","depth":11},{"id":118,"text":"to pass needed job creation measures","depth":13},{"id":119,"text":"he has endorsed ,","depth":13},{"id":120,"text":"such as ending tax breaks for companies","depth":13},{"id":121,"text":"that send jobs overseas .","depth":13},{"id":122,"text":"`` This election is about how we break that stalemate , ''","depth":11},{"id":123,"text":"Obama said .","depth":11},{"id":124,"text":"`` It 's in your power to break the stalemate . ''","depth":10},{"id":125,"text":"House Democratic leader Nancy Pelosi , meanwhile , accused congressional Republicans of obstructing economic progress","depth":10},{"id":126,"text":"by focusing on partisan politics , such as a planned House vote next week","depth":11},{"id":127,"text":"to repeal the health care reform law","depth":12},{"id":128,"text":"in what would be a purely symbolic gesture .","depth":12},{"id":129,"text":"`` It 's time for Republicans to abandon their agenda of obstruction and delay ,","depth":11},{"id":130,"text":"and work with Democrats","depth":12},{"id":131,"text":"to create jobs","depth":13},{"id":132,"text":"and strengthen the middle class , ''","depth":13},{"id":133,"text":"said a statement by Pelosi , D-California .","depth":10},{"id":134,"text":"Republicans accuse Democrats of similar tactics against measures","depth":10},{"id":135,"text":"passed by the GOP-majority House","depth":11},{"id":136,"text":"that have died in the Democratic-controlled Senate .","depth":11},{"id":137,"text":"However , former Republican presidential candidate Jon Huntsman publicly criticized his party Friday for failing to focus `` on a bigger , bolder , more confident future for the United States","depth":11},{"id":138,"text":"-- future","depth":12},{"id":139,"text":"based on problem solving , inclusiveness , and a willingness","depth":13},{"id":140,"text":"to address the trust deficit ,","depth":14},{"id":141,"text":"which is every bit as corrosive as our fiscal and economic deficits . ''","depth":14},{"id":142,"text":"In a statement","depth":12},{"id":143,"text":"announcing","depth":13},{"id":144,"text":"he wo n't attend the GOP convention in August ,","depth":13},{"id":145,"text":"Huntsman called for `` a return to the party","depth":13},{"id":146,"text":"we have been in the past ,","depth":13},{"id":147,"text":"from Lincoln right on through to Reagan ,","depth":13},{"id":148,"text":"that was always willing to put our country before politics . ''","depth":13},{"id":149,"text":"After Obama returns to Washington on Friday afternoon ,","depth":8},{"id":150,"text":"he will sign a giant transportation bill","depth":9},{"id":151,"text":"that includes funding for road and bridge construction and repairs","depth":10},{"id":152,"text":"-- a component of Obama 's jobs plan","depth":12},{"id":153,"text":"that Congress passed last week as part of a package","depth":13},{"id":154,"text":"that included holding down interest rates on federal student loans .","depth":13},{"id":155,"text":"Both components were top priorities for Obama","depth":12},{"id":156,"text":"and passed after lengthy negotiations in Congress","depth":13},{"id":157,"text":"that were delayed by partisan posturing .","depth":13},{"id":158,"text":"All polling so far shows a tight race between Obama and Romney ,","depth":6},{"id":159,"text":"and that voters consider the economy the top issue .","depth":6},{"id":160,"text":"Obama contends","depth":9},{"id":161,"text":"the economy continues to show slow growth","depth":10},{"id":162,"text":"after the deep recession","depth":11},{"id":163,"text":"he inherited ,","depth":11},{"id":164,"text":"while Romney argues","depth":9},{"id":165,"text":"the president 's policies deter job creation .","depth":9},{"id":166,"text":"In his remarks Friday , Romney specified what he called excessive corporate taxes and regulatory burdens as the main culprits .","depth":8},{"id":167,"text":"`` The president 's policies have not got America working again , ''","depth":10},{"id":168,"text":"Romney said .","depth":10},{"id":169,"text":"`` The president 's going to have to stand up","depth":10},{"id":170,"text":"and take responsibility for it . ''","depth":10},{"id":171,"text":"Obama , however , said","depth":8},{"id":172,"text":"the policies","depth":12},{"id":173,"text":"espoused by Romney and Republicans","depth":12},{"id":174,"text":"-- such as cutting taxes","depth":12},{"id":175,"text":"and removing regulations --","depth":12},{"id":176,"text":"failed under the Bush administration","depth":10},{"id":177,"text":"and only would help the rich get richer","depth":10},{"id":178,"text":"while keeping the middle class stagnant or worse .","depth":10},{"id":179,"text":"`` We saw us fighting two wars on a credit card , ''","depth":9},{"id":180,"text":"Obama said of what happened","depth":10},{"id":181,"text":"before he took office .","depth":10},{"id":182,"text":"`` The tax cuts turned a surplus into a deficit","depth":10},{"id":183,"text":"and the lack of regulation resulted in what happened on Wall Street","depth":11},{"id":184,"text":"and we ended up with the biggest crisis","depth":12},{"id":185,"text":"we have ever seen .","depth":12},{"id":186,"text":"It ai n't right .","depth":10},{"id":187,"text":"It is not a smart theory . ''","depth":10},{"id":188,"text":"At the heart of the issue are the differing philosophies of the two parties ,","depth":5},{"id":189,"text":"with Obama and Democrats advocating a combination of strategic spending , increased revenue and entitlement reforms","depth":7},{"id":190,"text":"to reduce budget deficits and the national debt","depth":7},{"id":191,"text":"while Romney and Republicans focus on shrinking government .","depth":6},{"id":192,"text":"Health care reform also has emerged as a major point of contention ,","depth":6},{"id":193,"text":"especially after last week 's Supreme Court ruling","depth":7},{"id":194,"text":"that upheld the signature legislation of Obama 's presidency so far .","depth":7},{"id":195,"text":"The Romney campaign has been dogged by conflicting stances on the issue ,","depth":8},{"id":196,"text":"which is a vulnerability for the former Massachusetts governor","depth":9},{"id":197,"text":"who implemented a similar plan in the state","depth":10},{"id":198,"text":"but now calls for repeal of the federal law","depth":11},{"id":199,"text":"known as Obamacare .","depth":11},{"id":200,"text":"GOP leaders emphasized","depth":9},{"id":201,"text":"that the high court ruling","depth":12},{"id":202,"text":"that the law 's most controversial section","depth":14},{"id":203,"text":"-- the individual mandate","depth":15},{"id":204,"text":"requiring people to have health insurance --","depth":15},{"id":205,"text":"amounted to a kind of tax","depth":13},{"id":206,"text":"was evidence","depth":11},{"id":207,"text":"that Obama deceived the nation in 2009","depth":11},{"id":208,"text":"by denying","depth":12},{"id":209,"text":"it was a tax increase .","depth":12},{"id":210,"text":"However , a top Romney adviser","depth":12},{"id":211,"text":"-- seeking to protect the candidate from Democratic charges","depth":13},{"id":212,"text":"that he implemented a similar tax increase in Massachusetts --","depth":13},{"id":213,"text":"insisted","depth":11},{"id":214,"text":"that the individual mandate was not a tax but a penalty ,","depth":11},{"id":215,"text":"as argued by Obama .","depth":11},{"id":216,"text":"Romney then had to declare publicly","depth":11},{"id":217,"text":"that the Supreme Court ruling means","depth":12},{"id":218,"text":"the mandate is a tax ,","depth":12},{"id":219,"text":"but added more confusion","depth":11},{"id":220,"text":"by making clear","depth":12},{"id":221,"text":"he disagreed with the high court decision .","depth":12},{"id":222,"text":"Obama kept up the pressure on Romney on the issue ,","depth":8},{"id":223,"text":"assailing him in an interview","depth":10},{"id":224,"text":"airing Friday","depth":10},{"id":225,"text":"for reversing his position on the penalty provision .","depth":9},{"id":226,"text":"A short portion of the interview was distributed by Obama 's campaign early Friday .","depth":8},{"id":227,"text":"The remainder of the interview with WLWT-TV in Cincinnati was not immediately available .","depth":8},{"id":228,"text":"Romney `` was one of the biggest promoters of the individual mandate , ''","depth":8},{"id":229,"text":"Obama said in the interview .","depth":8},{"id":230,"text":"`` In Massachusetts , his whole idea was that we should n't have people","depth":8},{"id":231,"text":"who can afford to get health insurance","depth":9},{"id":232,"text":"to not buy it","depth":10},{"id":233,"text":"and then force you or me , or John Q . Public to have to pay for him","depth":11},{"id":234,"text":"when he gets sick . ''","depth":11},{"id":235,"text":"Now ,","depth":10},{"id":236,"text":"Obama said ,","depth":10},{"id":237,"text":"Romney 's reversal from `` penalty '' to `` tax '' raises the question","depth":9},{"id":238,"text":"of `` are you doing that","depth":9},{"id":239,"text":"because of politics ? ''","depth":9},{"id":240,"text":"`` Are you abandoning a principle","depth":10},{"id":241,"text":"that you fought for , for six years","depth":10},{"id":242,"text":"simply because you 're getting pressure for two days from Rush Limbaugh or some critics in Washington ? ''","depth":9},{"id":243,"text":"Obama said .","depth":8},{"id":244,"text":"Romney 's campaign responded","depth":8},{"id":245,"text":"that Obama `` told the American people","depth":10},{"id":246,"text":"that Obamacare was not a new tax ,","depth":10},{"id":247,"text":"then sent his lawyers","depth":11},{"id":248,"text":"to convince the Supreme Court","depth":12},{"id":249,"text":"that it was a new tax ,","depth":12},{"id":250,"text":"and now is insisting","depth":12},{"id":251,"text":"-- again --","depth":12},{"id":252,"text":"that it is not a tax . ''","depth":11},{"id":253,"text":"`` Americans deserve straight answers from their president , ''","depth":8},{"id":254,"text":"a campaign statement said .","depth":8},{"id":255,"text":"When asked about the issue ,","depth":8},{"id":256,"text":"Romney said Friday","depth":9},{"id":257,"text":"that he always maintained","depth":10},{"id":258,"text":"that health care should be managed at the state level , like his program in Massachusetts , rather than at the federal level under Obamacare .","depth":10},{"id":259,"text":"Obama 's solicitor general argued before the Supreme Court in March","depth":10},{"id":260,"text":"that the individual mandate could be viewed as constitutional under Congress ' taxation power .","depth":10},{"id":261,"text":"Donald Verrilli said","depth":11},{"id":262,"text":"the fee would be collected by the Internal Revenue Service on April 15 , the day","depth":12},{"id":263,"text":"Americans pay their federal income taxes .","depth":12},{"id":264,"text":"Asked by Associate Justice Samuel Alito","depth":12},{"id":265,"text":"`` can the mandate be viewed as a tax ? ''","depth":12},{"id":266,"text":"Verrilli responded ,","depth":12},{"id":267,"text":"`` I think","depth":13},{"id":268,"text":"it could . ''","depth":13},{"id":269,"text":"In his speech at the Ohio school , Obama raised the issue again ,","depth":9},{"id":270,"text":"saying to cheers","depth":10},{"id":271,"text":"that including the individual mandate with its penalty provision was the right thing","depth":11},{"id":272,"text":"to do .","depth":11}],"relations":[{"parent":545,"left":0,"right":544,"relation":"organization","nuclearity":"SN"},{"parent":544,"left":429,"right":543,"relation":"joint","nuclearity":"NN"},{"parent":429,"left":1,"right":428,"relation":"organization","nuclearity":"SN"},{"parent":428,"left":276,"right":427,"relation":"context","nuclearity":"SN"},{"parent":276,"left":275,"right":5,"relation":"context","nuclearity":"NS"},{"parent":275,"left":2,"right":274,"relation":"context","nuclearity":"SN"},{"parent":274,"left":3,"right":4,"relation":"attribution","nuclearity":"NS"},{"parent":427,"left":334,"right":426,"relation":"joint","nuclearity":"NN"},{"parent":334,"left":326,"right":333,"relation":"elaboration","nuclearity":"NS"},{"parent":326,"left":280,"right":325,"relation":"elaboration","nuclearity":"NS"},{"parent":280,"left":277,"right":279,"relation":"adversative","nuclearity":"NN"},{"parent":277,"left":6,"right":7,"relation":"context","nuclearity":"NS"},{"parent":279,"left":8,"right":278,"relation":"purpose","nuclearity":"NS"},{"parent":278,"left":9,"right":10,"relation":"attribution","nuclearity":"SN"},{"parent":325,"left":296,"right":324,"relation":"joint","nuclearity":"NN"},{"parent":296,"left":283,"right":295,"relation":"elaboration","nuclearity":"NS"},{"parent":283,"left":11,"right":282,"relation":"elaboration","nuclearity":"NS"},{"parent":282,"left":12,"right":281,"relation":"elaboration","nuclearity":"NS"},{"parent":281,"left":13,"right":14,"relation":"purpose","nuclearity":"NS"},{"parent":295,"left":288,"right":294,"relation":"adversative","nuclearity":"NN"},{"parent":288,"left":15,"right":287,"relation":"attribution","nuclearity":"SN"},{"parent":287,"left":285,"right":286,"relation":"elaboration","nuclearity":"NS"},{"parent":285,"left":284,"right":18,"relation":"same-unit","nuclearity":"NN"},{"parent":284,"left":16,"right":17,"relation":"adversative","nuclearity":"NS"},{"parent":286,"left":19,"right":20,"relation":"context","nuclearity":"NS"},{"parent":294,"left":289,"right":293,"relation":"joint","nuclearity":"NN"},{"parent":289,"left":21,"right":22,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":23,"right":292,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":24,"right":291,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":25,"right":290,"relation":"attribution","nuclearity":"SN"},{"parent":290,"left":26,"right":27,"relation":"elaboration","nuclearity":"NS"},{