{"article_id":"L7w06XLmKJdlXbis","edus":[{"id":0,"text":"Story highlights","depth":1},{"id":1,"text":"President Obama reiterates his call","depth":6},{"id":2,"text":"for the wealthy to pay more taxes","depth":6},{"id":3,"text":"Obama , House Speaker John Boehner have three weeks","depth":7},{"id":4,"text":"to reach a deal","depth":7},{"id":5,"text":"Automatic tax hikes and spending cuts are set to take effect on January 1","depth":6},{"id":6,"text":"The two sides are talking to each other ,","depth":5},{"id":7,"text":"but revealing little","depth":5},{"id":8,"text":"It 's crunch time","depth":8},{"id":9,"text":"for avoiding the fiscal cliff","depth":8},{"id":10,"text":"as President Barack Obama and House Speaker John Boehner and their aides hold private talks on issues","depth":8},{"id":11,"text":"that will impact every American .","depth":8},{"id":12,"text":"Three weeks remain","depth":8},{"id":13,"text":"to cut a deal","depth":8},{"id":14,"text":"before the automatic tax hikes and spending cuts of the fiscal cliff go into effect on January 1 .","depth":7},{"id":15,"text":"Obama and Boehner met face-to-face on Sunday for the first time since November 16 .","depth":8},{"id":16,"text":"It also was their first one-on-one meeting in more than a year ,","depth":9},{"id":17,"text":"when talks broke down on a comprehensive agreement","depth":10},{"id":18,"text":"to reduce the nation 's chronic federal deficits and debt .","depth":10},{"id":19,"text":"In a rare display of bipartisan concurrence , both sides issued identical statements after the meeting","depth":9},{"id":20,"text":"that said","depth":10},{"id":21,"text":"no details would be forthcoming .","depth":10},{"id":22,"text":"Staff on both sides also have been talking ,","depth":9},{"id":23,"text":"but few details were available .","depth":9},{"id":24,"text":"`` I 'm willing to compromise a little bit , ''","depth":8},{"id":25,"text":"Obama said Monday in a campaign-style speech to a Michigan diesel engine plant .","depth":8},{"id":26,"text":"However , he continued to insist on higher tax rates on the wealthiest Americans ,","depth":8},{"id":27,"text":"saying","depth":9},{"id":28,"text":"`` that 's a principle","depth":10},{"id":29,"text":"I 'm not going to compromise on . ''","depth":10},{"id":30,"text":"JUST WATCHED","depth":11},{"id":31,"text":"Visualize the fiscal cliff","depth":13},{"id":32,"text":"Replay More Videos ...","depth":13},{"id":33,"text":"MUST WATCH","depth":12},{"id":34,"text":"Visualize the fiscal cliff","depth":11},{"id":35,"text":"02:10","depth":11},{"id":36,"text":"JUST WATCHED","depth":11},{"id":37,"text":"iReporters sound off on the fiscal cliff","depth":12},{"id":38,"text":"Replay More Videos ...","depth":13},{"id":39,"text":"MUST WATCH","depth":14},{"id":40,"text":"iReporters sound off on the fiscal cliff","depth":15},{"id":41,"text":"06:18","depth":15},{"id":42,"text":"JUST WATCHED","depth":11},{"id":43,"text":"What if we go off the fiscal cliff ?","depth":14},{"id":44,"text":"Replay More Videos ...","depth":14},{"id":45,"text":"MUST WATCH","depth":13},{"id":46,"text":"What if we go off the fiscal cliff ?","depth":13},{"id":47,"text":"01:10","depth":13},{"id":48,"text":"Boehner 's spokesman , meanwhile , said","depth":10},{"id":49,"text":"the latest Republican offer","depth":12},{"id":50,"text":"-- which rejects Obama 's call","depth":13},{"id":51,"text":"for rates to rise on the highest tax brackets --","depth":13},{"id":52,"text":"remained the GOP position .","depth":11},{"id":53,"text":"The outline for a deal has become clear in recent weeks .","depth":12},{"id":54,"text":"Both sides agree","depth":16},{"id":55,"text":"that more revenue from taxes should be part of the equation ,","depth":16},{"id":56,"text":"with Obama seeking $ 1.6 trillion","depth":16},{"id":57,"text":"and Republicans offering $ 800 billion .","depth":16},{"id":58,"text":"However , Boehner 's side wants additional revenue to come from tax reform , such as eliminating some deductions and loopholes ,","depth":15},{"id":59,"text":"while Obama demands the higher tax rates on income over $ 250,000 for families as part of the equation .","depth":15},{"id":60,"text":"Boehner and Republicans also seek savings from entitlement programs such as Social Security , Medicare and Medicaid","depth":15},{"id":61,"text":"totaling another $ 800 billion or so ,","depth":15},{"id":62,"text":"while Obama has proposed $ 400 billion in reduced entitlement costs .","depth":15},{"id":63,"text":"Social Security would not be included .","depth":15},{"id":64,"text":"Another sticky issue","depth":14},{"id":65,"text":"-- whether the need","depth":16},{"id":66,"text":"to raise the federal debt ceiling early next year","depth":16},{"id":67,"text":"should be part of the discussion --","depth":15},{"id":68,"text":"also appears unresolved .","depth":13},{"id":69,"text":"Obama says","depth":14},{"id":70,"text":"absolutely not ,","depth":14},{"id":71,"text":"while Boehner says","depth":14},{"id":72,"text":"that any increase in the federal borrowing limit must be offset by spending cuts .","depth":14},{"id":73,"text":"It remains unclear","depth":13},{"id":74,"text":"if a deal will happen before the end of the year","depth":14},{"id":75,"text":"or if the negotiations will carry over into 2013 ,","depth":15},{"id":76,"text":"after the fiscal cliff takes effect .","depth":15},{"id":77,"text":"While economists warn","depth":14},{"id":78,"text":"that going over the fiscal cliff could lead to recession ,","depth":14},{"id":79,"text":"the administration has signaled","depth":14},{"id":80,"text":"it can delay some of the effects","depth":15},{"id":81,"text":"to allow time","depth":16},{"id":82,"text":"to work out an agreement .","depth":16},{"id":83,"text":"Without action now ,","depth":13},{"id":84,"text":"the nonpartisan Tax Policy Center estimates","depth":14},{"id":85,"text":"that middle-class families would pay about $ 2,000 a year more in taxes .","depth":14},{"id":86,"text":"Even with a deal , revisions in the tax code and other changes would mean everyone pays a bit more","depth":13},{"id":87,"text":"starting next year .","depth":13},{"id":88,"text":"All signs point toward a two-step approach","depth":10},{"id":89,"text":"sought by the newly re-elected Obama .","depth":10},{"id":90,"text":"An initial agreement","depth":11},{"id":91,"text":"reached now","depth":11},{"id":92,"text":"would extend current tax rates for most people","depth":11},{"id":93,"text":"while letting rates return to higher levels of the Clinton era on the two highest income brackets .","depth":11},{"id":94,"text":"JUST WATCHED","depth":12},{"id":95,"text":"Fiscal cliff and cost of doing nothing","depth":12},{"id":96,"text":"Replay More Videos ...","depth":12},{"id":97,"text":"MUST WATCH","depth":13},{"id":98,"text":"Fiscal cliff and cost of doing nothing","depth":13},{"id":99,"text":"07:24","depth":10},{"id":100,"text":"JUST WATCHED","depth":12},{"id":101,"text":"The fiscal cliff and food safety","depth":12},{"id":102,"text":"Replay More Videos ...","depth":12},{"id":103,"text":"MUST WATCH The fiscal cliff and food safety","depth":12},{"id":104,"text":"02:02","depth":11},{"id":105,"text":"JUST WATCHED","depth":13},{"id":106,"text":"Gross :","depth":14},{"id":107,"text":"U.S. needs $ 16T deficit plan","depth":14},{"id":108,"text":"Replay More Videos ...","depth":14},{"id":109,"text":"MUST WATCH Gross :","depth":15},{"id":110,"text":"U.S. needs $ 16T deficit plan","depth":15},{"id":111,"text":"05:29","depth":13},{"id":112,"text":"Republicans oppose any tax rate hike ,","depth":10},{"id":113,"text":"so a possible compromise would increase the income threshold for the higher rates to kick in above the $ 250,000 figure","depth":11},{"id":114,"text":"sought by Obama .","depth":11},{"id":115,"text":"Such an agreement would put off the main worry of the fiscal cliff","depth":10},{"id":116,"text":"-- expiration of Bush-era tax cuts","depth":11},{"id":117,"text":"that would result in higher rates for everyone .","depth":11},{"id":118,"text":"Obama and Democrats say","depth":10},{"id":119,"text":"they would then be ready to negotiate significant savings from entitlement programs ,","depth":10},{"id":120,"text":"while Republicans say","depth":10},{"id":121,"text":"they need to first see commitment on entitlement reforms","depth":11},{"id":122,"text":"before accepting any higher tax rates .","depth":11},{"id":123,"text":"`` The Republican offer","depth":11},{"id":124,"text":"made last week","depth":11},{"id":125,"text":"remains the Republican offer ,","depth":10},{"id":126,"text":"and we continue to wait for the president to identify the spending cuts","depth":10},{"id":127,"text":"he 's willing to make as part of the 'balanced ' approach","depth":11},{"id":128,"text":"he promised the American people , ''","depth":11},{"id":129,"text":"said Boehner spokesman Michael Steel .","depth":8},{"id":130,"text":"Meanwhile , White House spokesman Jay Carney told reporters","depth":8},{"id":131,"text":"that Republicans have failed to fully explain their proposal","depth":9},{"id":132,"text":"to increase revenue by $ 800 billion .","depth":9},{"id":133,"text":"`` The president is the only party","depth":11},{"id":134,"text":"to put forward a plan with specificity on both the spending and revenue side , ''","depth":11},{"id":135,"text":"Carney said ,","depth":10},{"id":136,"text":"describing the Republican plan so far as `` unnamed closures in loopholes and unnamed caps in deductions . ''","depth":9},{"id":137,"text":"To move forward ,","depth":11},{"id":138,"text":"he continued ,","depth":11},{"id":139,"text":"`` Republicans have to recognize","depth":10},{"id":140,"text":"that we can not afford ,","depth":11},{"id":141,"text":"the public does not support ,","depth":11},{"id":142,"text":"and it is economically a bad idea","depth":11},{"id":143,"text":"to extend tax cuts for millionaires and billionaires and those making over $ 250,000 . ''","depth":11},{"id":144,"text":"Some in Congress warn","depth":8},{"id":145,"text":"that the legislative process will need two weeks","depth":10},{"id":146,"text":"to work through potentially complex measures from any proposed deal ,","depth":10},{"id":147,"text":"meaning a de facto deadline of Friday may exist for negotiators .","depth":9},{"id":148,"text":"At the same time , voices from inside and outside the process say","depth":9},{"id":149,"text":"something must happen now .","depth":9},{"id":150,"text":"On Sunday , International Monetary Fund chief Christine Lagarde echoed numerous economic experts","depth":9},{"id":151,"text":"in predicting a sharp drop in confidence and `` zero '' U.S. economic growth","depth":10},{"id":152,"text":"if there 's no agreement .","depth":10},{"id":153,"text":"The tax issue was a main November election campaign topic ,","depth":5},{"id":154,"text":"with Obama saying","depth":7},{"id":155,"text":"the wealthiest Americans must pay more","depth":7},{"id":156,"text":"and Republicans opposing any tax rate increase .","depth":6},{"id":157,"text":"Four polls in the past two weeks ,","depth":7},{"id":158,"text":"including a new one","depth":8},{"id":159,"text":"released Monday ,","depth":8},{"id":160,"text":"show","depth":6},{"id":161,"text":"that more Americans support Obama 's proposal .","depth":5},{"id":162,"text":"The Senate has passed a measure","depth":7},{"id":163,"text":"that holds down tax rates on income below $ 250,000 for families ,","depth":9},{"id":164,"text":"as sought by Obama ,","depth":9},{"id":165,"text":"while letting rates go up to 1990s levels for higher earners .","depth":8},{"id":166,"text":"Obama and Democrats say","depth":7},{"id":167,"text":"House passage of that proposal would clear the way for a broader deal .","depth":7},{"id":168,"text":"However , House Republicans refuse to bring it up for a vote amid cracks in the GOP facade against a rate hike .","depth":7},{"id":169,"text":"Sen. Bob Corker of Tennessee said Sunday","depth":10},{"id":170,"text":"that he would support raising taxes on the top 2 % of income earners ,","depth":10},{"id":171,"text":"arguing","depth":11},{"id":172,"text":"that it will better position Republicans to negotiate for larger spending cuts to Social Security and Medicare","depth":11},{"id":173,"text":"despite opposition from many Democrats .","depth":10},{"id":174,"text":"`` A lot of people are putting forth a theory ,","depth":11},{"id":175,"text":"and I actually think","depth":12},{"id":176,"text":"it has merit ,","depth":12},{"id":177,"text":"where you go ahead and give the president ... the rate increase on the top 2 % ,","depth":11},{"id":178,"text":"and all of a sudden the shift goes back to entitlements , ''","depth":11},{"id":179,"text":"Corker said on `` Fox News Sunday . ''","depth":9},{"id":180,"text":"Fellow Republican Sens . Tom Coburn of Oklahoma and Susan Collins and Olympia Snowe of Maine also have said","depth":7},{"id":181,"text":"they could vote for such a limited tax hike .","depth":7},{"id":182,"text":"On the House side , Rep. Tom Cole of Oklahoma reiterated Sunday","depth":7},{"id":183,"text":"that he could go along with higher rates on the wealthy .","depth":7},{"id":184,"text":"`` You have to do something ,","depth":8},{"id":185,"text":"and doing something requires the cooperation of the Senate ,","depth":10},{"id":186,"text":"which the Democrats run ,","depth":10},{"id":187,"text":"and the signature of the president , ''","depth":9},{"id":188,"text":"he said on CNN 's `` State of the Union . ''","depth":7},{"id":189,"text":"Meanwhile , conservative colleague Rep. Marsha Blackburn of Tennessee refused to budge from GOP orthodoxy against higher tax rates .","depth":6},{"id":190,"text":"Even though Obama won re-election","depth":8},{"id":191,"text":"and Democrats increased their Senate majority","depth":9},{"id":192,"text":"while narrowing the Republican majority in the House ,","depth":9},{"id":193,"text":"she insisted","depth":8},{"id":194,"text":"that the November vote showed","depth":9},{"id":195,"text":"that voters `` clearly said","depth":10},{"id":196,"text":"we do n't want our taxes to go up . ''","depth":10}],"relations":[{"parent":393,"left":0,"right":392,"relation":"organization","nuclearity":"SN"},{"parent":392,"left":348,"right":391,"relation":"joint","nuclearity":"NN"},{"parent":348,"left":203,"right":347,"relation":"context","nuclearity":"SN"},{"parent":203,"left":201,"right":202,"relation":"joint","nuclearity":"NN"},{"parent":201,"left":198,"right":200,"relation":"joint","nuclearity":"NN"},{"parent":198,"left":1,"right":2,"relation":"purpose","nuclearity":"NS"},{"parent":200,"left":199,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":199,"left":3,"right":4,"relation":"purpose","nuclearity":"NS"},{"parent":202,"left":6,"right":7,"relation":"adversative","nuclearity":"NN"},{"parent":347,"left":224,"right":346,"relation":"elaboration","nuclearity":"NS"},{"parent":224,"left":209,"right":223,"relation":"elaboration","nuclearity":"NS"},{"parent":209,"left":206,"right":208,"relation":"elaboration","nuclearity":"NS"},{"parent":206,"left":204,"right":205,"relation":"context","nuclearity":"NS"},{"parent":204,"left":8,"right":9,"relation":"purpose","nuclearity":"NS"},{"parent":205,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":208,"left":207,"right":14,"relation":"context","nuclearity":"NS"},{"parent":207,"left":12,"right":13,"relation":"purpose","nuclearity":"NS"},{"parent":223,"left":217,"right":222,"relation":"elaboration","nuclearity":"NS"},{"parent":217,"left":212,"right":216,"relation":"joint","nuclearity":"NN"},{"parent":212,"left":15,"right":211,"relation":"elaboration","nuclearity":"NS"},{"parent":211,"left":16,"right":210,"relation":"context","nuclearity":"NS"},{"parent":210,"left":17,"right":18,"relation":"elaboration","nuclearity":"NS"},{"parent":216,"left":214,"right":215,"relation":"joint","nuclearity":"NN"},{"parent":214,"left":19,"r