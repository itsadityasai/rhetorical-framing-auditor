{"article_id":"jIiGSjtJL5YRxQfZ","edus":[{"id":0,"text":"Story highlights","depth":2},{"id":1,"text":"Economy shatters expectations ,","depth":3},{"id":2,"text":"pumps out 321,000 jobs in November","depth":3},{"id":3,"text":"Do n't look for President Barack Obama to get much political kudos for America 's humming job creation engine .","depth":4},{"id":4,"text":"The jobless rate is steady at 5.8 percent ,","depth":5},{"id":5,"text":"the stock market 's roaring ,","depth":6},{"id":6,"text":"the housing market is stirring","depth":7},{"id":7,"text":"and the rescued auto industry is motoring .","depth":8},{"id":8,"text":"Gas is down to $ 2.71 a gallon ,","depth":10},{"id":9,"text":"according to an American Automobile Association average ,","depth":10},{"id":10,"text":"leaving a little extra cash for families this Christmas .","depth":9},{"id":11,"text":"New Labor Department figures out Friday show unemployment at a six-year low ,","depth":4},{"id":12,"text":"and the economy shattered expectations","depth":5},{"id":13,"text":"by pumping out more than 320,000 jobs last month in the biggest hiring splurge in three years .","depth":5},{"id":14,"text":"Obama had to suffer through months of grim jobs numbers in his first term ,","depth":5},{"id":15,"text":"but had a spring in his step after Friday 's Labor Department report .","depth":5},{"id":16,"text":"No wonder he turned the White House event","depth":8},{"id":17,"text":"at which he announced his new nominee","depth":9},{"id":18,"text":"to head the Pentagon","depth":9},{"id":19,"text":"into an opportunity","depth":7},{"id":20,"text":"to crow about jobs .","depth":6},{"id":21,"text":"`` So far this year , over the first 11 months of 2014 , our economy has created 2.65 million jobs , ''","depth":8},{"id":22,"text":"he said .","depth":8},{"id":23,"text":"`` That 's more than in any entire year since the 1990s .","depth":8},{"id":24,"text":"Our businesses have now created 10.9 million jobs over the past 57 months in a row .","depth":9},{"id":25,"text":"And that 's the longest streak of private sector job growth on record . ''","depth":9},{"id":26,"text":"Or as Brad Woodhouse , President of progressive group Americans United for Change put it on Twitter :","depth":7},{"id":27,"text":"`` 321K jobs .","depth":9},{"id":28,"text":"50 straight months of job creation .","depth":9},{"id":29,"text":"Thank you @ BarackObama . ''","depth":8},{"id":30,"text":"JUST WATCHED Immigration frustration :","depth":8},{"id":31,"text":"next steps","depth":8},{"id":32,"text":"Replay More Videos ...","depth":8},{"id":33,"text":"MUST WATCH Immigration frustration :","depth":10},{"id":34,"text":"next steps","depth":10},{"id":35,"text":"02:10","depth":9},{"id":36,"text":"JUST WATCHED","depth":10},{"id":37,"text":"Boehner asked to skip Obama SOTU Invite","depth":10},{"id":38,"text":"Replay More Videos ...","depth":9},{"id":39,"text":"MUST WATCH","depth":10},{"id":40,"text":"Boehner asked to skip Obama SOTU Invite","depth":10},{"id":41,"text":"01:30","depth":9},{"id":42,"text":"JUST WATCHED","depth":10},{"id":43,"text":"Obama : Gap between ideals and law","depth":10},{"id":44,"text":"Replay More Videos ...","depth":9},{"id":45,"text":"MUST WATCH Obama :","depth":10},{"id":46,"text":"Gap between ideals and law","depth":10},{"id":47,"text":"01:29","depth":9},{"id":48,"text":"But do n't waste too much time","depth":9},{"id":49,"text":"looking for credit for the President .","depth":9},{"id":50,"text":"He has a political problem ,","depth":10},{"id":51,"text":"however well the economy does .","depth":10},{"id":52,"text":"Most Americans by now have decided","depth":11},{"id":53,"text":"whether they like him or not .","depth":11},{"id":54,"text":"So","depth":11},{"id":55,"text":"even if the economy roars ,","depth":12},{"id":56,"text":"his approval ratings are unlikely to soar .","depth":12},{"id":57,"text":"Despite steering out of the worst slump since the 1930s ,","depth":11},{"id":58,"text":"which was destroying 700,000 jobs a month ,","depth":11},{"id":59,"text":"Obama still gets a thumbs down from Americans on the economy , to the frustration of many inside the West Wing .","depth":10},{"id":60,"text":"His approval numbers are stuck in the mid-to-low 40s","depth":11},{"id":61,"text":"and a CNN/Opinion Research Poll last month found","depth":12},{"id":62,"text":"53 % of Americans disapprove of how he 's handling the economy .","depth":12},{"id":63,"text":"It 's simple .","depth":11},{"id":64,"text":"Many people just do n't feel","depth":12},{"id":65,"text":"their lives are getting better .","depth":12},{"id":66,"text":"Seventy-eight percent of voters in November 's mid-term elections were worried about the direction of the economy in the next year ,","depth":9},{"id":67,"text":"according to exit polls .","depth":9},{"id":68,"text":"`` Has there been more employment since the economic crisis ?","depth":12},{"id":69,"text":"The answer is yes , ''","depth":12},{"id":70,"text":"said Lance Roberts of STA Wealth Management .","depth":11},{"id":71,"text":"`` What we have got to talk about is the quality of the employment . ''","depth":10},{"id":72,"text":"While the economy is pumping out hundreds of thousands of jobs a month ,","depth":12},{"id":73,"text":"it 's barely keeping up with population growth .","depth":12},{"id":74,"text":"Many new jobs are coming in the service sector , in restaurants and bars for instance ,","depth":13},{"id":75,"text":"where work is often part-time , low paid","depth":14},{"id":76,"text":"and lacks benefits","depth":15},{"id":77,"text":"that give people economic security .","depth":15},{"id":78,"text":"Paul Harrington , of the Center for Labor Markets and Policy at Drexel University , said","depth":14},{"id":79,"text":"growth in traditional blue collar jobs","depth":17},{"id":80,"text":"that once anchored the middle class ,","depth":17},{"id":81,"text":"in industries like the building trade ,","depth":16},{"id":82,"text":"is bouncing back too slowly .","depth":15},{"id":83,"text":"`` We would have expected at this stage of the recovery , construction payrolls rebounding a lot better","depth":15},{"id":84,"text":"than they have , ''","depth":15},{"id":85,"text":"said Harrington .","depth":14},{"id":86,"text":"There 's also excess supply in the production sector","depth":11},{"id":87,"text":"which includes food manufacture and work with raw materials like coal and wood .","depth":11},{"id":88,"text":"That goes a long way to explaining why middle class voters in Midwestern , industrial and Southern states lashed out at Democrats in November .","depth":8},{"id":89,"text":"Those voters may also shape the 2016 presidential race","depth":8},{"id":90,"text":"as mid-term exit polls showed","depth":10},{"id":91,"text":"that the economy was easily the most important issue ,","depth":10},{"id":92,"text":"despite a campaign","depth":10},{"id":93,"text":"overtaken by Obamacare , Ebola and ISIS .","depth":10},{"id":94,"text":"Jobs data also shows many Americans still struggling in the shadows .","depth":8},{"id":95,"text":"The Labor Force Participation rate ,","depth":11},{"id":96,"text":"measuring those","depth":12},{"id":97,"text":"who have a job","depth":13},{"id":98,"text":"or are looking for one ,","depth":13},{"id":99,"text":"was stuck near 36-year lows in November .","depth":10},{"id":100,"text":"Hourly wages are stagnant .","depth":11},{"id":101,"text":"`` Middle-class families across the country ,","depth":15},{"id":102,"text":"including my home state of Ohio ,","depth":15},{"id":103,"text":"are struggling to get by on wages","depth":15},{"id":104,"text":"that have n't kept pace with rising costs , ''","depth":15},{"id":105,"text":"said Republican House Speaker John Boehner on Friday ,","depth":13},{"id":106,"text":"blaming Obama for suffocating a quicker recovery","depth":13},{"id":107,"text":"by burdening the economy with `` massive '' regulations and rising health care premiums .","depth":13},{"id":108,"text":"Democrats complain","depth":11},{"id":109,"text":"the GOP has blocked every job creation plan","depth":12},{"id":110,"text":"Obama has offered for years .","depth":12},{"id":111,"text":"Long term trends like the loss of manufacturing jobs overseas and new technology","depth":9},{"id":112,"text":"that wipes out manual jobs","depth":9},{"id":113,"text":"will also shape how people feel about the economy for years to come .","depth":8},{"id":114,"text":"Consumer sentiment ,","depth":8},{"id":115,"text":"as measured by the University of Western Michigan index ,","depth":8},{"id":116,"text":"was at its highest level since the recession in November .","depth":7},{"id":117,"text":"Democratic voters are meanwhile more upbeat on the economy than Republicans ,","depth":8},{"id":118,"text":"according to the Gallup survey .","depth":8},{"id":119,"text":"That suggests","depth":8},{"id":120,"text":"people decide on how the economy is doing","depth":9},{"id":121,"text":"depending on who lives in the White House .","depth":9},{"id":122,"text":"But Obama can console himself with one thought :","depth":7},{"id":123,"text":"history is more likely to look more kindly on his economic recovery than those","depth":8},{"id":124,"text":"who lived through it .","depth":8}],"relations":[{"parent":249,"left":127,"right":248,"relation":"organization","nuclearity":"SN"},{"parent":127,"left":0,"right":126,"relation":"organization","nuclearity":"SN"},{"parent":126,"left":1,"right":2,"relation":"joint","nuclearity":"NN"},{"parent":248,"left":137,"right":247,"relation":"joint","nuclearity":"NN"},{"parent":137,"left":134,"right":136,"relation":"joint","nuclearity":"NN"},{"parent":134,"left":3,"right":133,"relation":"explanation","nuclearity":"NS"},{"parent":133,"left":4,"right":132,"relation":"joint","nuclearity":"NN"},{"parent":132,"left":5,"right":131,"relation":"joint","nuclearity":"NN"},{"parent":131,"left":6,"right":130,"relation":"joint","nuclearity":"NN"},{"parent":130,"left":7,"right":129,"relation":