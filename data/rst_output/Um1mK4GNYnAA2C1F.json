n","nuclearity":"NS"},{"parent":286,"left":71,"right":285,"relation":"elaboration","nuclearity":"NS"},{"parent":285,"left":284,"right":74,"relation":"joint","nuclearity":"NN"},{"parent":284,"left":72,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":76,"right":293,"relation":"attribution","nuclearity":"SN"},{"parent":293,"left":291,"right":292,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":77,"right":290,"relation":"attribution","nuclearity":"SN"},{"parent":290,"left":78,"right":289,"relation":"joint","nuclearity":"NN"},{"parent":289,"left":288,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":288,"left":79,"right":80,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":82,"right":83,"relation":"causal","nuclearity":"NS"},{"parent":300,"left":297,"right":299,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":84,"right":85,"relation":"attribution","nuclearity":"SN"},{"parent":299,"left":86,"right":298,"relation":"context","nuclearity":"SN"},{"parent":298,"left":87,"right":88,"relation":"attribution","nuclearity":"SN"},{"parent":378,"left":323,"right":377,"relation":"joint","nuclearity":"NN"},{"parent":323,"left":309,"right":322,"relation":"joint","nuclearity":"NN"},{"parent":309,"left":307,"right":308,"relation":"elaboration","nuclearity":"NS"},{"parent":307,"left":89,"right":306,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":304,"right":305,"relation":"joint","nuclearity":"NN"},{"parent":304,"left":303,"right":93,"relation":"same-unit","nuclearity":"NN"},{"parent":303,"left":90,"right":302,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":91,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":94,"right":95,"relation":"attribution","nuclearity":"SN"},{"parent":308,"left":96,"right":97,"relation":"attribution","nuclearity":"SN"},{"parent":322,"left":314,"right":321,"relation":"joint","nuclearity":"NN"},{"parent":314,"left":98,"r