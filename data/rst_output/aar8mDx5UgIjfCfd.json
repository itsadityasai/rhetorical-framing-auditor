{"article_id":"aar8mDx5UgIjfCfd","edus":[{"id":0,"text":"President Obama named federal appeals judge Merrick Garland on Wednesday as his pick","depth":6},{"id":1,"text":"to succeed Antonin Scalia on the U.S. Supreme Court","depth":6},{"id":2,"text":"- setting up a showdown with Republicans","depth":6},{"id":3,"text":"who have vowed to block the choice .","depth":6},{"id":4,"text":"Obama ,","depth":7},{"id":5,"text":"who said","depth":8},{"id":6,"text":"he went through a rigorous and comprehensive screening process ,","depth":8},{"id":7,"text":"said","depth":7},{"id":8,"text":"Garland would bring \" integrity , modesty and an even-handedness \" to the Supreme Court .","depth":7},{"id":9,"text":"\" I said","depth":8},{"id":10,"text":"I would take this process seriously ,","depth":8},{"id":11,"text":"and I did , \"","depth":7},{"id":12,"text":"Obama said at the Rose Garden ceremony .","depth":6},{"id":13,"text":"Yet within minutes , Republicans doubled down on their opposition","depth":7},{"id":14,"text":"to confirming any nominee in an election year ,","depth":7},{"id":15,"text":"insisting","depth":7},{"id":16,"text":"that the vacant seat not be filled","depth":8},{"id":17,"text":"until a new president is sworn in .","depth":8},{"id":18,"text":"\" It is a president ' s constitutional right","depth":8},{"id":19,"text":"to nominate a Supreme Court justice","depth":8},{"id":20,"text":"and it is the Senate ' s constitutional right","depth":8},{"id":21,"text":"to act as a check on a president","depth":9},{"id":22,"text":"and withhold its consent , \"","depth":9},{"id":23,"text":"Senate Majority Leader Mitch McConnell said on the Senate floor .","depth":6},{"id":24,"text":"Obama ,","depth":8},{"id":25,"text":"anticipating the swift resistance ,","depth":9},{"id":26,"text":"urged Republicans to reconsider ,","depth":9},{"id":27,"text":"adding","depth":8},{"id":28,"text":"it would be unprecedented for Garland not to at least get a hearing .","depth":8},{"id":29,"text":"\" I hope","depth":8},{"id":30,"text":"they ' re fair .","depth":9},{"id":31,"text":"That ' s all , \"","depth":10},{"id":32,"text":"Obama said .","depth":10},{"id":33,"text":"\" To give him a fair hearing and up or down vote . \"","depth":7},{"id":34,"text":"Obama said earlier Wednesday","depth":7},{"id":35,"text":"that it was both his \" constitutional duty","depth":9},{"id":36,"text":"to nominate a justice","depth":9},{"id":37,"text":"and one of the most important decisions","depth":9},{"id":38,"text":"that I","depth":11},{"id":39,"text":"- or any president -","depth":11},{"id":40,"text":"will make . \"","depth":10},{"id":41,"text":"He added ,","depth":8},{"id":42,"text":"\" I ' m doing my job .","depth":8},{"id":43,"text":"I hope","depth":8},{"id":44,"text":"that our senators will do their jobs ,","depth":9},{"id":45,"text":"and move quickly","depth":10},{"id":46,"text":"to consider my nominee . \"","depth":10},{"id":47,"text":"A Senate confirmation is required","depth":4},{"id":48,"text":"for any nominee to join the bench .","depth":4},{"id":49,"text":"Before the announcement , Sen. Mike Lee , R-Utah , also told Fox News","depth":7},{"id":50,"text":"that neither he nor his GOP colleagues on the Senate Judiciary Committee would back down","depth":8},{"id":51,"text":"and declared once more","depth":9},{"id":52,"text":"he would stop the nomination from going forward .","depth":9},{"id":53,"text":"\" We ' ve been clear , \"","depth":7},{"id":54,"text":"Lee said of his plan","depth":8},{"id":55,"text":"to reject Garland ' s nomination .","depth":8},{"id":56,"text":"Garland has served under both Republicans and Democrats .","depth":9},{"id":57,"text":"He clerked for the court ' s liberal icon , Justice William J. Brennan Jr .","depth":9},{"id":58,"text":"In 1997 , 32 Republicans voted in favor of his nomination ,","depth":9},{"id":59,"text":"including seven","depth":10},{"id":60,"text":"who are still members of the Senate .","depth":10},{"id":61,"text":"Garland was mentioned as a possible nominee","depth":8},{"id":62,"text":"when Justice Paul Stevens retired in 2010 .","depth":8},{"id":63,"text":"Sen. Chuck Schumer of New York , the No . 3 Democratic leader , called Garland 's section , `` a bipartisan choice , ''","depth":8},{"id":64,"text":"adding :","depth":9},{"id":65,"text":"`` If the Republicans ca n't support him ,","depth":10},{"id":66,"text":"who can they support ? ''","depth":10},{"id":67,"text":"Senate Minority Leader Harry Reid ,","depth":11},{"id":68,"text":"who spoke to Obama Wednesday morning ,","depth":11},{"id":69,"text":"said in brief remarks on the Senate floor","depth":10},{"id":70,"text":"that Republicans must act on the president 's choice .","depth":9},{"id":71,"text":"`` He 's doing his job this morning ,","depth":10},{"id":72,"text":"they should do theirs , ''","depth":10},{"id":73,"text":"said the Nevada Democrat .","depth":9},{"id":74,"text":"If confirmed ,","depth":9},{"id":75,"text":"Garland would be expected to align with the more liberal members ,","depth":9},{"id":76,"text":"but he is not viewed as down-the-line liberal .","depth":8},{"id":77,"text":"Particularly on criminal defense and national security cases , he 's earned a reputation as centrist ,","depth":8},{"id":78,"text":"and one of the few Democratic-appointed judges","depth":10},{"id":79,"text":"Republicans might have fast-tracked to confirmation","depth":10},{"id":80,"text":"-- under other circumstances .","depth":9},{"id":81,"text":"But in the current climate , Garland remains a tough sell .","depth":6},{"id":82,"text":"Republicans control the Senate ,","depth":9},{"id":83,"text":"which must confirm any nominee ,","depth":9},{"id":84,"text":"and GOP leaders want to leave the choice to the next president ,","depth":9},{"id":85,"text":"denying Obama a chance","depth":10},{"id":86,"text":"to alter the ideological balance of the court","depth":11},{"id":87,"text":"before he leaves office next January .","depth":11},{"id":88,"text":"Republicans contend","depth":8},{"id":89,"text":"that a confirmation fight in an election year would be too politicized .","depth":8},{"id":90,"text":"Ahead of Obama 's announcement , the Republican Party set up a task force","depth":10},{"id":91,"text":"that will orchestrate attack ads , petitions and media outreach .","depth":10},{"id":92,"text":"The aim is to bolster Senate Republicans ' strategy","depth":10},{"id":93,"text":"of denying consideration of Obama 's nominee .","depth":10},{"id":94,"text":"The party 's chairman , Reince Priebus , described it as the GOP 's most comprehensive judicial response effort ever .","depth":8},{"id":95,"text":"On the other side , Obama allies have been drafted","depth":9},{"id":96,"text":"to run a Democratic effort","depth":10},{"id":97,"text":"that will involve liberal groups","depth":11},{"id":98,"text":"that hope","depth":12},{"id":99,"text":"an Obama nominee could pull the high court 's ideological balance to the left .","depth":12},{"id":100,"text":"The effort would target states","depth":9},{"id":101,"text":"where activists believe","depth":11},{"id":102,"text":"Republicans will feel political heat for opposing hearings","depth":11},{"id":103,"text":"once Obama announced his nominee .","depth":10},{"id":104,"text":"For Obama , Garland represents a significant departure from his past two Supreme Court choices .","depth":4},{"id":105,"text":"In nominating Sonia Sotomayor and Elena Kagan ,","depth":5},{"id":106,"text":"the president eagerly seized the chance","depth":7},{"id":107,"text":"to broaden the court 's diversity","depth":8},{"id":108,"text":"and rebalance the overwhelming male institution .","depth":8},{"id":109,"text":"Sotomayor was the first Hispanic","depth":8},{"id":110,"text":"confirmed to the court ,","depth":8},{"id":111,"text":"Kagan only the fourth woman .","depth":7},{"id":112,"text":"Garland","depth":6},{"id":113,"text":"-- a white , male jurist with an Ivy League pedigree and career","depth":7},{"id":114,"text":"spent largely in the upper echelon of the Washington 's legal elite --","depth":7},{"id":115,"text":"breaks no barriers .","depth":5},{"id":116,"text":"At 63 years old , he would be the oldest Supreme Court nominee since Lewis Powell ,","depth":6},{"id":117,"text":"who was 64","depth":7},{"id":118,"text":"when he was confirmed in late 1971 .","depth":7},{"id":119,"text":"Presidents tend to appoint young judges with the hope","depth":7},{"id":120,"text":"they will shape the court 's direction for as long as possible .","depth":7},{"id":121,"text":"Those factors had , until now , made Garland something of a perpetual bridesmaid , repeatedly on Obama 's Supreme Court lists , but never chosen .","depth":7},{"id":122,"text":"But Garland found his moment at time","depth":9},{"id":123,"text":"when Democrats are seeking to apply maximum pressure on Republicans .","depth":9},{"id":124,"text":"A key part of their strategy is casting Republicans as knee-jerk obstructionists","depth":10},{"id":125,"text":"ready to shoot down a nominee","depth":11},{"id":126,"text":"that many in their own ranks once considered a consensus candidate .","depth":11},{"id":127,"text":"In 2010 , Utah Sen. Orrin Hatch called Garland `` terrific ''","depth":11},{"id":128,"text":"and said","depth":12},{"id":129,"text":"he could be confirmed `` virtually unanimously . ''","depth":12},{"id":130,"text":"The White House planned to highlight Hatch 's past support , as well as other glowing comments about Garland from conservatives .","depth":10},{"id":131,"text":"A native of Chicago and graduate of Harvard College and Harvard Law School , Garland clerked for two appointees of Republican President Dwight D. Eisenhower","depth":5},{"id":132,"text":"-- the liberal U.S. Supreme Court Justice William Brennan Jr. and Judge Henry J . Friendly ,","depth":6},{"id":133,"text":"for whom Chief Justice John Roberts also clerked .","depth":6},{"id":134,"text":"In 1988 , he gave up a plush partner 's office in a powerhouse law firms","depth":7},{"id":135,"text":"to cut his teeth in criminal cases .","depth":7},{"id":136,"text":"As an assistant U.S. attorney , he joined the team","depth":9},{"id":137,"text":"prosecuting a Reagan White House aide","depth":10},{"id":138,"text":"charged with illegal lobbying","depth":10},{"id":139,"text":"and did early work on the drug case against then-D.C. Mayor Marion Barry .","depth":8},{"id":140,"text":"He held a top-ranking post in the Justice Department","depth":9},{"id":141,"text":"when he was dispatched to Oklahoma City the day","depth":11},{"id":142,"text":"after bombing at the federal courthouse","depth":11},{"id":143,"text":"to supervise the investigation .","depth":10},{"id":144,"text":"The case made his career and his reputation .","depth":9},{"id":145,"text":"He oversaw the convictions of Timothy McVeigh and Terry Nichols ,","depth":10},{"id":146,"text":"and went on to supervise the investigation into Unabomber Ted Kaczynski .","depth":10},{"id":147,"text":"President Bill Clinton first nominated him to the D.C . Circuit in 1995 .","depth":6},{"id":148,"text":"His prolonged confirmation process may prove to have prepared him for the one ahead .","depth":6},{"id":149,"text":"Garland waited 2 1/2 years","depth":6},{"id":150,"text":"to win confirmation to the appeals court .","depth":6},{"id":151,"text":"Then , as now , one of the man","depth":9},{"id":152,"text":"blocking path","depth":9},{"id":153,"text":"was Iowa Sen. Charles Grassley ,","depth":8},{"id":154,"text":"argued","depth":8},{"id":155,"text":"he had no quarrel with Garland 's credentials ,","depth":9},{"id":156,"text":"but a beef with the notion","depth":10},{"id":157,"text":"of a Democratic president","depth":11},{"id":158,"text":"trying to fill a court","depth":12},{"id":159,"text":"he argued","depth":13},{"id":160,"text":"had too many seats .","depth":13},{"id":161,"text":"Grassley ultimately relented ,","depth":8},{"id":162,"text":"although he was not one of the 32 Republicans","depth":9},{"id":163,"text":"who voted in favor of Garland 's confirmation .","depth":9},{"id":164,"text":"Nor was Sen. Mitch McConnell , the other major hurdle for Garland now .","depth":7},{"id":165,"text":"The Republicans","depth":6},{"id":166,"text":"who voted in favor of confirmation","depth":6},{"id":167,"text":"are Sen. Dan Coats , Sen. Thad Cochran , Sen. Susan Collins , Sen. Orrin Hatch , Sen. Jim Inhofe , Sen. John McCain , and Sen. Pat Roberts .","depth":5}],"relations":[{"parent":335,"left":271,"right":334,"relation":"elaboration","nuclearity":"NS"},{"parent":271,"left":214,"right":270,"relation":"elaboration","nuclearity":"NS"},{"parent":214,"left":180,"right":213,"relation":"elaboration","nuclearity":"NS"},{"parent":180,"left":171,"right":179,"relation":"elaboration","nuclearity":"NS"},{"parent":171,"left":169,"right":170,"relation":"causal","nuclearity":"NS"},{"parent":169,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":170,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":179,"left":175,"right":178,"relation":"elaboration","nuclearity":"NS"},{"parent":175,"left":173,"right":174,"relation":"same-unit","nuclearity":"NN"},{"parent":173,"left":4,"right":172,"relation":"elaboration","nuclearity":"NS"},{"parent":172,"left":5,"right":6,"relation":"attribution","nuclearity":"SN"},{"parent":174,"left":7,"right":8,"relation":"attribution","nuclearity":"SN"},{"parent":178,"left":177,"right":12,"relation":"attribution","nuclearity":"NS"},{"parent":177,"left":176,"right":11,"relation":"restatement","nuclearity":"NN"},{"parent":176,"left":9,"right":10,"relation":"attribution","nuclearity":"SN"},{"parent":213,"left":190,"right":212,"relation":"elaboration","nuclearity":"NS"},{"parent":190,"left":184,"right":189,"relation":"elaboration","nuclearity":"NS"},{"parent":184,"left":181,"right":183,"relation":"elaboration","nuclearity":"NS"},{"parent":181,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":