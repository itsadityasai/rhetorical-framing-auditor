right":31,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":299,"right":301,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":296,"right":298,"relation":"same-unit","nuclearity":"NN"},{"parent":296,"left":32,"right":33,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":297,"right":36,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":34,"right":35,"relation":"restatement","nuclearity":"NS"},{"parent":301,"left":37,"right":300,"relation":"elaboration","nuclearity":"NS"},{"parent":300,"left":38,"right":39,"relation":"adversative","nuclearity":"NS"},{"parent":319,"left":309,"right":318,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":307,"right":308,"relation":"restatement","nuclearity":"NN"},{"parent":307,"left":40,"right":306,"relation":"attribution","nuclearity":"SN"},{"parent":306,"left":41,"right":42,"relation":"attribution","nuclearity":"SN"},{"parent":308,"left":43,"right":44,"relation":"restatement","nuclearity":"NN"},{"parent":318,"left":311,"right":317,"relation":"elaboration","nuclearity":"NS"},{"parent":311,"left":45,"right":310,"relation":"attribution","nuclearity":"SN"},{"parent":310,"left":46,"right":47,"relation":"joint","nuclearity":"NN"},{"parent":317,"left":316,"right":54,"relation":"attribution","nuclearity":"NS"},{"parent":316,"left":48,"right":315,"relation":"restatement","nuclearity":"NN"},{"parent":315,"left":314,"right":53,"relation":"evaluation","nuclearity":"NS"},{"parent":314,"left":49,"right":313,"relation":"same-unit","nuclearity":"NN"},{"parent":313,"left":50,"right":312,"relation":"context","nuclearity":"SN"},{"parent":312,"left":51,"right":52,"relation":"attribution","nuclearity":"SN"},{"parent":327,"left":325,"right":326,"relation":"elaboration","nuclearity":"NS"},{"parent":325,"left":55,"right":324,"relation":"elaboration","nuclearity":"NS"},{"parent":324,"left":322,"right":323,"relation":"joint","nuclearity":"NN"},{"parent":322,"left":56,"right":57,"relation":"elabor