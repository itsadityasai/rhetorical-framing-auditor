{"article_id":"f1ik2thzWjx94saJ","edus":[{"id":0,"text":"NEW YORK/WASHINGTON","depth":1},{"id":1,"text":"( ) -","depth":3},{"id":2,"text":"Nearly 1 in 4 Americans were under orders","depth":8},{"id":3,"text":"to close up shop","depth":9},{"id":4,"text":"and stay at home on Saturday ,","depth":9},{"id":5,"text":"as lawmakers in Washington neared a deal","depth":8},{"id":6,"text":"that could pump a record $ 1 trillion into the economy","depth":9},{"id":7,"text":"to limit the economic damage from the coronavirus .","depth":9},{"id":8,"text":"New Jersey ' s governor followed four other states","depth":9},{"id":9,"text":"- California , New York , Illinois and Connecticut -","depth":9},{"id":10,"text":"that have imposed unprecedented restrictions","depth":9},{"id":11,"text":"to slow the spread of infections ,","depth":10},{"id":12,"text":"which have risen exponentially .","depth":10},{"id":13,"text":"Governors in other states urged citizens to avoid large gatherings ,","depth":9},{"id":14,"text":"even if restrictions were not in place .","depth":9},{"id":15,"text":"\" It ' s like we are all lost in a movie","depth":10},{"id":16,"text":"that we can ' t relate to in any way , \"","depth":10},{"id":17,"text":"West Virginia Governor Jim Justice said ,","depth":10},{"id":18,"text":"as he urged residents of his state to take the threat more seriously .","depth":10},{"id":19,"text":"At least 23,941 cases of the novel coronavirus have been reported in the United States","depth":7},{"id":20,"text":"and 306 people have died from the COVID-19 disease as of Saturday evening ,","depth":7},{"id":21,"text":"according to a tally of state and local government websites .","depth":6},{"id":22,"text":"In Washington , Republican and Democratic leaders appeared to be nearing a deal","depth":7},{"id":23,"text":"to pump more than $ 1 trillion into the economy ,","depth":8},{"id":24,"text":"adding to the hundreds of billions of dollars in fiscal and monetary stimulus","depth":9},{"id":25,"text":"that has already been deployed","depth":10},{"id":26,"text":"to prop up the world ' s largest economy .","depth":10},{"id":27,"text":"\" I think","depth":9},{"id":28,"text":"we ' re clearly going to get there , \"","depth":9},{"id":29,"text":"said Senate Republican Leader Mitch McConnell ,","depth":9},{"id":30,"text":"who scheduled a vote for Monday .","depth":9},{"id":31,"text":"Hard-hit airlines are pressing for $ 29 billion in cash ,","depth":9},{"id":32,"text":"promising in return not to furlough employees before September .","depth":9},{"id":33,"text":"But lawmakers said","depth":9},{"id":34,"text":"they were inclined to offer loans instead .","depth":9},{"id":35,"text":"Two members of the U.S. House of Representatives have tested positive ,","depth":6},{"id":36,"text":"and U.S. Vice President Mike Pence and his wife tested negative","depth":8},{"id":37,"text":"after an unidentified aide was diagnosed with the virus .","depth":8},{"id":38,"text":"Pence staffers said","depth":8},{"id":39,"text":"the aide had mild symptoms","depth":9},{"id":40,"text":"and had not had close contact with Pence or President Donald Trump .","depth":9},{"id":41,"text":"Related Coverage","depth":3},{"id":42,"text":"Factbox :","depth":6},{"id":43,"text":"Latest on the spread of the coronavirus around the world","depth":6},{"id":44,"text":"Trump tested negative for the virus last week ,","depth":8},{"id":45,"text":"according to his doctor .","depth":8},{"id":46,"text":"Graphic :","depth":9},{"id":47,"text":"Tracking the spread of the global coronavirus","depth":9},{"id":48,"text":"- here","depth":8},{"id":49,"text":"As hospitals braced for an influx of patients ,","depth":7},{"id":50,"text":"Dr. Anthony Fauci , the U.S. government ' s top infectious disease expert , urged Americans to postpone non-essential surgeries","depth":8},{"id":51,"text":"to keep beds available .","depth":8},{"id":52,"text":"The Trump administration has struggled to line up tests","depth":8},{"id":53,"text":"to diagnose the disease ,","depth":8},{"id":54,"text":"masks","depth":9},{"id":55,"text":"to slow its transmission ,","depth":9},{"id":56,"text":"and medical equipment","depth":9},{"id":57,"text":"to treat those","depth":10},{"id":58,"text":"who have contracted it .","depth":10},{"id":59,"text":"The U.S. Food and Drug Administration approved a test","depth":9},{"id":60,"text":"that can deliver a result in 45 minutes , rather than days ,","depth":9},{"id":61,"text":"according to Cepheid , its maker .","depth":8},{"id":62,"text":"At the White House , officials said","depth":9},{"id":63,"text":"they were delivering more tests and equipment","depth":10},{"id":64,"text":"where they were needed ,","depth":10},{"id":65,"text":"but declined to say","depth":9},{"id":66,"text":"whether they had met benchmarks","depth":10},{"id":67,"text":"they had laid out earlier in the week .","depth":10},{"id":68,"text":"Graphic :","depth":9},{"id":69,"text":"The novel coronavirus in the United States - here","depth":9},{"id":70,"text":"State and local officials say","depth":10},{"id":71,"text":"they are scrambling for supplies .","depth":10},{"id":72,"text":"A view of Aegis Living at Marymoor , an assisted living facility","depth":12},{"id":73,"text":"linked to several cases of coronavirus , during the coronavirus disease","depth":14},{"id":74,"text":"( COVID-19 )","depth":14},{"id":75,"text":"outbreak in Redmond , Washington , U.S.","depth":13},{"id":76,"text":"March 21 , 2020 .","depth":11},{"id":77,"text":"/Lindsey Wasson","depth":10},{"id":78,"text":"\" We ' ve gotten no help from the federal government , or limited help , \"","depth":11},{"id":79,"text":"Illinois Governor J.B. Pritzker said at a news briefing .","depth":11},{"id":80,"text":"New York Governor Andrew Cuomo said","depth":13},{"id":81,"text":"the state had identified 6,000 ventilators","depth":15},{"id":82,"text":"to help sick patients keep breathing ,","depth":15},{"id":83,"text":"but needed 30,000 more .","depth":14},{"id":84,"text":"He said","depth":13},{"id":85,"text":"the state is sending 1 million N95 respirator masks to New York City","depth":14},{"id":86,"text":"- short of the 3 million","depth":15},{"id":87,"text":"city officials are seeking .","depth":15},{"id":88,"text":"\" We are literally scouring the globe for medical supplies , \"","depth":12},{"id":89,"text":"Cuomo said .","depth":12},{"id":90,"text":"In New York City ,","depth":12},{"id":91,"text":"where more than 6,000 cases have been diagnosed ,","depth":12},{"id":92,"text":"about a dozen people waited for a test in the parking lot of the Brooklyn Hospital Center .","depth":11},{"id":93,"text":"\" That ' s insane , \"","depth":12},{"id":94,"text":"city council member Mark Levine said in a phone interview .","depth":12},{"id":95,"text":"\" If they ' re well enough","depth":14},{"id":96,"text":"to stand in a line ,","depth":14},{"id":97,"text":"they should be home resting ,","depth":13},{"id":98,"text":"they don ' t need a test ,","depth":13},{"id":99,"text":"and they need to get out of the way . \"","depth":13},{"id":100,"text":"Federal authorities briefly stopped flights","depth":10},{"id":101,"text":"arriving at New York City-area airports","depth":10},{"id":102,"text":"after a trainee at an air traffic control center tested positive .","depth":9},{"id":103,"text":"Neighboring New Jersey became the latest state on Saturday","depth":9},{"id":104,"text":"to adopt a statewide directive","depth":10},{"id":105,"text":"requiring residents to remain indoors except for trips to grocery stores , pharmacies , gas stations and other \" essential businesses . \"","depth":10},{"id":106,"text":"Stay-at-home orders now apply to 84 million people in states","depth":9},{"id":107,"text":"that account for a third of the nation ' s economy .","depth":9},{"id":108,"text":"Other states encouraged residents to reduce activity","depth":11},{"id":109,"text":"but did not put restrictions in place .","depth":11},{"id":110,"text":"Missouri went in a different direction ,","depth":11},{"id":111,"text":"allowing child-care providers to take on more children .","depth":11},{"id":112,"text":"The state directives were for the most part issued","depth":10},{"id":113,"text":"without strict enforcement mechanisms","depth":11},{"id":114,"text":"to back them up .","depth":11},{"id":115,"text":"Cuomo said","depth":10},{"id":116,"text":"New York would fine and close businesses","depth":11},{"id":117,"text":"that defy the order .","depth":11},{"id":118,"text":"Chicago Mayor Lori Lightfoot said","depth":11},{"id":119,"text":"police would \" admonish \" people to go home .","depth":11},{"id":120,"text":"In Ridgefield , Connecticut ,","depth":14},{"id":121,"text":"where six new cases were reported on Saturday ,","depth":14},{"id":122,"text":"town official Rudy Marconi said","depth":13},{"id":123,"text":"he would dispatch the police","depth":13},{"id":124,"text":"to break up a teenagers ' basketball game .","depth":13},{"id":125,"text":"\" We have no other tools in our toolbox .","depth":13},{"id":126,"text":"We have to rely on the social distancing , \"","depth":13},{"id":127,"text":"he said .","depth":12}],"relations":[{"parent":255,"left":0,"right":254,"relation":"organization","nuclearity":"SN"},{"parent":254,"left":167,"right":253,"relation":"elaboration","nuclearity":"NS"},{"parent":167,"left":1,"right":166,"relation":"organization","nuclearity":"SN"},{"parent":166,"left":147,"right":165,"relation":"elaboration","nuclearity":"NS"},{"parent":147,"left":144,"right":146,"relation":"context","nuclearity":"NS"},{"parent":144,"left":133,"right":143,"relation":"elaboration","nuclearity":"NS"},{"parent":133,"left":130,"right":132,"relation":"context","nuclearity":"NS"},{"parent":130,"left":2,"right":129,"relation":"purpose","nuclearity":"NS"},{"parent":129,"left":3,"right":4,"relation":"joint","nuclearity":"NN"},{"parent":132,"left":5,"right":131,"relation":"elaboration","nuclearity":"NS"},{"parent":131,"left":6,"right":7,"