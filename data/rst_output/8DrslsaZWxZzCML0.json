{"article_id":"8DrslsaZWxZzCML0","edus":[{"id":0,"text":"Attorney General Jeff Sessions fired back at President Trump Thursday ,","depth":4},{"id":1,"text":"insisting","depth":5},{"id":2,"text":"he will not let politics dictate Department of Justice investigations .","depth":5},{"id":3,"text":"\" While I am Attorney General ,","depth":6},{"id":4,"text":"the actions of the Department of Justice will not be improperly influenced by political considerations , \"","depth":6},{"id":5,"text":"Mr . Sessions said in a statement .","depth":5},{"id":6,"text":"\" I demand the highest standards ,","depth":6},{"id":7,"text":"and","depth":7},{"id":8,"text":"where they are not met ,","depth":8},{"id":9,"text":"I take action .","depth":8},{"id":10,"text":"However , no nation has a more talented , more dedicated group of law enforcement investigators and prosecutors than the United States . \"","depth":5},{"id":11,"text":"The statement marks one of the few times","depth":4},{"id":12,"text":"Mr . Sessions has acknowledged the president ' s attacks .","depth":4},{"id":13,"text":"Mr . Sessions is a frequent target of derision for Mr. Trump ,","depth":4},{"id":14,"text":"who has savaged his attorney general","depth":5},{"id":15,"text":"for recusing himself from Special Counsel Robert Mueller ' s Russia investigation and failure","depth":6},{"id":16,"text":"to investigate","depth":7},{"id":17,"text":"whether Hillary Clinton got favorable treatment from the Justice Department .","depth":7},{"id":18,"text":"During a Thursday morning interview on \" Fox & Friends , \" Mr. Trump renewed his criticism of Mr . Sessions ,","depth":4},{"id":19,"text":"accusing him of allowing the Justice Department to undermine his administration .","depth":4},{"id":20,"text":"\" I put in an attorney general","depth":8},{"id":21,"text":"that never took control of the Justice Department ,","depth":8},{"id":22,"text":"Jeff Sessions , \"","depth":7},{"id":23,"text":"Mr. Trump said .","depth":6},{"id":24,"text":"\" It ' s sort of an incredible thing . \"","depth":6},{"id":25,"text":"Mr. Trump pointed to the several examples of misapplied justice ,","depth":7},{"id":26,"text":"including the case of Imran Awan , the former IT administrator for Democratic Rep. Debbie Wasserman Schultz of Florida ,","depth":8},{"id":27,"text":"who received no jail time from a judge this week for bank fraud","depth":9},{"id":28,"text":"after federal prosecutors didn ' t pursue more serious charges","depth":10},{"id":29,"text":"of running a spy ring inside Congress","depth":11},{"id":30,"text":"and stealing congressional computer equipment .","depth":11},{"id":31,"text":"\" He had more information on the corruption of the Democrats than anybody , \"","depth":6},{"id":32,"text":"Mr. Trump said .","depth":6},{"id":33,"text":"\" They gave him nothing .","depth":6},{"id":34,"text":"He ' s a Democrat ,","depth":8},{"id":35,"text":"he got nothing .","depth":8},{"id":36,"text":"The reason","depth":9},{"id":37,"text":"he got nothing","depth":9},{"id":38,"text":"is because the ' Dems ' are very strong in the Justice Department . \"","depth":8},{"id":39,"text":"In his statement , Mr . Sessions insisted","depth":5},{"id":40,"text":"he has been in control of the Justice Department .","depth":5},{"id":41,"text":"\" I took control of the Department of Justice the day","depth":7},{"id":42,"text":"I was sworn in ,","depth":7},{"id":43,"text":"which is why we have had unprecedented success","depth":7},{"id":44,"text":"at effectuating the President ' s agenda","depth":8},{"id":45,"text":"one","depth":9},{"id":46,"text":"hat protects the safety and security and rights of the American people ,","depth":10},{"id":47,"text":"educes violent crime ,","depth":11},{"id":48,"text":"nforces our immigration laws ,","depth":12},{"id":49,"text":"romotes economic growth ,","depth":13},{"id":50,"text":"nd advances religious liberty , \"","depth":13},{"id":51,"text":"e said .","depth":5},{"id":52,"text":"he president also raised the issue of fired FBI agent Peter Strzok and his paramour , FBI attorney Lisa Page ,","depth":8},{"id":53,"text":"ho exchanged anti-Trump text messages during the campaign .","depth":8},{"id":54,"text":"r. Strzok went on to work on special counsel Robert Mueller ' s team .","depth":7},{"id":55,"text":"It ' s really subversion , \"","depth":7},{"id":56,"text":"he president said of the pair .","depth":7},{"id":57,"text":"And our Justice Department doesn ' t do anything about it .","depth":6},{"id":58,"text":"eople say","depth":8},{"id":59,"text":"you appointed Jeff Sessions .","depth":8},{"id":60,"text":"said","depth":8},{"id":61,"text":"did . \"","depth":8},{"id":62,"text":"sked if he might fire Mr . Sessions after the midterm elections ,","depth":8},{"id":63,"text":"r. Trump didn ' t answer directly .","depth":8},{"id":64,"text":"There ' s such corruption , \"","depth":10},{"id":65,"text":"e said .","depth":10},{"id":66,"text":"It ' s from before I got here .","depth":9},{"id":67,"text":"t ' s the Obama administration .","depth":9},{"id":68,"text":"hey surveilled my campaign . \"","depth":9},{"id":69,"text":"hen interviewer Ainsley Earhardt noted","depth":9},{"id":70,"text":"hat Deputy Attorney General Rod Rosenstein signed the final request","depth":10},{"id":71,"text":"or a special court","depth":11},{"id":72,"text":"o approve a surveillance warrant ,","depth":11},{"id":73,"text":"r. Trump replied ,","depth":9},{"id":74,"text":"It bothers me ,","depth":10},{"id":75,"text":"t ' s always bothered me . \"","depth":10},{"id":76,"text":"I wanted to stay uninvolved , \"","depth":9},{"id":77,"text":"e said .","depth":9},{"id":78,"text":"But","depth":9},{"id":79,"text":"hen everybody sees what ' s going on in the Justice Department ,","depth":10},{"id":80,"text":"t ' s a very very sad day . \"","depth":10},{"id":81,"text":"eviving his continual complaint","depth":8},{"id":82,"text":"hat Mr . Sessions recused himself from the investigation into possible Russian collusion ,","depth":8},{"id":83,"text":"r. Trump said","depth":8},{"id":84,"text":"he attorney general \" should have told me . \"","depth":8},{"id":85,"text":"He took the job ,","depth":9},{"id":86,"text":"nd then he said","depth":10},{"id":87,"text":"' m going to recuse myself .","depth":10},{"id":88,"text":"said","depth":10},{"id":89,"text":"hat kind of a man is this ? \"","depth":10},{"id":90,"text":"r. Trump said .","depth":9},{"id":91,"text":"He was on the campaign .","depth":8},{"id":92,"text":"he only reason","depth":12},{"id":93,"text":"gave him the job","depth":12},{"id":94,"text":"was ]","depth":11},{"id":95,"text":"ecause I felt loyalty","depth":11},{"id":96,"text":"an original supporter .","depth":11},{"id":97,"text":"e knows","depth":10},{"id":98,"text":"here was no collusion . \"","depth":10}],"relations":[{"parent":197,"left":116,"right":196,"relation":"elaboration","nuclearity":"NS"},{"parent":116,"left":109,"right":115,"relation":"elaboration","nuclearity":"NS"},{"parent":109,"left":101,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":0,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":1,"right":2,"relation":"attribution","nuclearity":"SN"},{"parent":108,"left":103,"right":107,"relation":"joint","nuclearity":"NN"},{"parent":103,"left":102,"right":5,"relation":"attribution","nuclearity":"NS"},{"parent":102,"left":3,"right":4,"relation":"adversative","nuclearity":"SN"},{"parent":107,"left":106,"right":10,"relation":"adversative","nuclearity":"SN"},{"parent":106,"left":6,"right":105,"relation":"joint","nuclearity":"NN"},{"parent":105,"left":7,"right":104,"relation":"same-unit","nuclearity":"NN"},{"parent":104,"left":8,"right":9,"relation":"context","nuclearity":"SN"},{"parent":115,"left":110,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":110,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":114,"left":13,"right":113,"relation":"elaboration","nuclearity":"NS"},{"pare