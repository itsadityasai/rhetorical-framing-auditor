attribution","nuclearity":"SN"},{"parent":300,"left":130,"right":131,"relation":"elaboration","nuclearity":"NS"},{"parent":334,"left":320,"right":333,"relation":"elaboration","nuclearity":"NS"},{"parent":320,"left":313,"right":319,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":306,"right":312,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":135,"right":136,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":137,"right":311,"relation":"attribution","nuclearity":"SN"},{"parent":311,"left":308,"right":310,"relation":"elaboration","nuclearity":"NS"},{"parent":308,"left":138,"right":307,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":139,"right":140,"relation":"attribution","nuclearity":"SN"},{"parent":310,"left":309,"right":143,"relation":"condition","nuclearity":"SN"},{"parent":309,"left":141,"right":142,"relation":"elaboration","nuclearity":"NS"},{"parent":319,"left":318,"right":150,"relation":"adversative","nuclearity":"NN"},{"parent":318,"left":315,"right":317,"relation":"attribution","nuclearity":"SN"},{"parent":315,"left":314,"right":146,"relation":"same-unit","nuclearity":"NN"},{"parent":314,"left":144,"right":145,"relation":"elaboration","nuclearity":"NS"},{"parent":317,"left":147,"right":316,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":148,"right":149,"relation":"elaboration","nuclearity":"NS"},{"parent":333,"left":327,"right":332,"relation":"adversative","nuclearity":"NS"},{"parent":327,"left":322,"right":326,"relation":"attribution","nuclearity":"SN"},{"parent":322,"left":321,"right":153,"relation":"same-unit","nuclearity":"NN"},{"parent":321,"left":151,"right":152,"relation":"elaboration","nuclearity":"NS"},{"parent":326,"left":324,"right":325,"relation":"same-unit","nuclearity":"NN"},{"parent":324,"left":154,"right":323,"relation":"elaboration","nuclearity":"NS"},{"parent":323,"left":155,"right":156,"relation":"purpose","nuclearity":"NS"},{"parent":325,"left":157,"right":158,"relation":"attribution","nuclearity":"SN"},{"parent":332,"left":329,"right":331,"relation":"explanation","nuclearity":"NS"},{"parent":329,"left":328,"right":161,"relation":"adversative","nuclearity":"SN"},{"parent":328,"left":159,"right":160,"relation":"elaboration","nuclearity":"NS"},{"parent":331,"left":162,"right":330,"relation":"attribution","nuclearity":"SN"},{"parent":330,"left":163,"right":164,"relation":"elaboration","nuclearity":"NS"},{"parent":345,"left":336,"right":344,"relation":"adversative","nuclearity":"SN"},{"parent":336,"left":165,"right":166,"relation":"context","nuclearity":"NS"},{"parent":344,"left":338,"right":343,"relation":"elaboration","nuclearity":"NS"},{"parent":338,"left":337,"right":169,"relation":"same-unit","nuclearity":"NN"},{"parent":337,"left":167,"right":168,"relation":"elaboration","nuclearity":"NS"},{"parent":343,"left":341,"right":342,"relation":"elaboration","nuclearity":"NS"},{"parent":341,"left":339,"right":340,"relation":"same-unit","nuclearity":"NN"},{"parent":339,"left":170,"right":171,"relation":"elaboration","nuclearity":"NS"},{"parent":340,"left":172,"right":173,"relation":"elaboration","nuclearity":"NS"},{"parent":342,"left":174,"right":175,"relation":"attribution","nuclearity":"NS"}]}