elaboration","nuclearity":"NS"},{"parent":291,"left":283,"right":290,"relation":"elaboration","nuclearity":"NS"},{"parent":283,"left":282,"right":41,"relation":"same-unit","nuclearity":"NN"},{"parent":282,"left":39,"right":40,"relation":"elaboration","nuclearity":"NS"},{"parent":290,"left":286,"right":289,"relation":"elaboration","nuclearity":"NS"},{"parent":286,"left":42,"right":285,"relation":"attribution","nuclearity":"NS"},{"parent":285,"left":284,"right":45,"relation":"same-unit","nuclearity":"NN"},{"parent":284,"left":43,"right":44,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":287,"right":288,"relation":"same-unit","nuclearity":"NN"},{"parent":287,"left":46,"right":47,"relation":"mode","nuclearity":"NS"},{"parent":288,"left":48,"right":49,"relation":"attribution","nuclearity":"SN"},{"parent":301,"left":298,"right":300,"relation":"adversative","nuclearity":"SN"},{"parent":298,"left":295,"right":297,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":50,"right":294,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":51,"right":293,"relation":"mode","nuclearity":"NS"},{"parent":293,"left":292,"right":54,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":52,"right":53,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":55,"right":296,"relation":"context","nuclearity":"SN"},{"parent":296,"left":56,"right":57,"relation":"attribution","nuclearity":"SN"},{"parent":300,"left":58,"right":299,"relation":"attribution","nuclearity":"SN"},{"parent":299,"left":59,"right":60,"relation":"adversative","nuclearity":"NS"},{"parent":309,"left":305,"right":308,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":304,"right":64,"relation":"adversative","nuclearity":"NN"},{"parent":304,"left":61,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":62,"right":63,"relation":"elaboration","nuclearity":"NS"},{"parent":308,"left":307,"right":68,"relation":"evaluation","nuclearity":"