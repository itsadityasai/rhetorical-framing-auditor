ation":"joint","nuclearity":"NN"},{"parent":226,"left":113,"right":225,"relation":"joint","nuclearity":"NN"},{"parent":225,"left":114,"right":115,"relation":"restatement","nuclearity":"NN"},{"parent":236,"left":232,"right":235,"relation":"elaboration","nuclearity":"NS"},{"parent":232,"left":231,"right":118,"relation":"purpose","nuclearity":"NS"},{"parent":231,"left":116,"right":117,"relation":"joint","nuclearity":"NN"},{"parent":235,"left":234,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":234,"left":233,"right":121,"relation":"attribution","nuclearity":"NS"},{"parent":233,"left":119,"right":120,"relation":"elaboration","nuclearity":"NS"}]}