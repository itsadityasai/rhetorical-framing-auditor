{"article_id":"PoVSfyTJt1wC2GRm","edus":[{"id":0,"text":"Hundreds of the emails from Secretary of State Hillary Clinton","depth":6},{"id":1,"text":"that were turned over to Congress","depth":7},{"id":2,"text":"regarding the Benghazi terrorist attack","depth":7},{"id":3,"text":"indicate","depth":5},{"id":4,"text":"that she and her advisers were closely monitoring the political fallout for the administration.","depth":4},{"id":5,"text":"According to The New York Times ,","depth":6},{"id":6,"text":"sources say","depth":7},{"id":7,"text":"that Clinton 's top aides at times wrote to her about official business from their personal email accounts .","depth":7},{"id":8,"text":"Many of the messages were short or mundane , such as instructions","depth":8},{"id":9,"text":"to print an article","depth":8},{"id":10,"text":"or scheduling and logistics ,","depth":7},{"id":11,"text":"but it 's unclear whether they represent all of the emails on the subject of Benghazi","depth":7},{"id":12,"text":"given that Clinton pre-selected which emails","depth":8},{"id":13,"text":"she turned over to the State Department.","depth":8},{"id":14,"text":"The emails did , however , show","depth":6},{"id":15,"text":"that Clinton and her inner circle reacted","depth":7},{"id":16,"text":"as the administration changed its position on what happened in the Benghazi attack","depth":8},{"id":17,"text":"after then-ambassador to the United Nations Susan Rice appeared on several Sunday news programs instead of Clinton.","depth":8},{"id":18,"text":"Jake Sullivan , a foreign policy adviser , communicated with Clinton","depth":8},{"id":19,"text":"following Rice 's appearances ,","depth":8},{"id":20,"text":"suggesting","depth":8},{"id":21,"text":"he was pleased with the way","depth":9},{"id":22,"text":"they went .","depth":9},{"id":23,"text":"`` She did make clear our view","depth":9},{"id":24,"text":"that this started spontaneously","depth":10},{"id":25,"text":"then evolved , ''","depth":10},{"id":26,"text":"Sullivan wrote to Clinton.","depth":8},{"id":27,"text":"But several weeks later ,","depth":11},{"id":28,"text":"as Rice 's official explanation came under scrutiny ,","depth":11},{"id":29,"text":"Sullivan emailed Clinton","depth":11},{"id":30,"text":"assuring her","depth":12},{"id":31,"text":"that she had avoided the public relations problems","depth":13},{"id":32,"text":"that Rice had found her in ,","depth":13},{"id":33,"text":"the Times reported .","depth":9},{"id":34,"text":"`` You never said 'spontaneous '","depth":10},{"id":35,"text":"or characterized their motivations , ''","depth":10},{"id":36,"text":"Sullivan wrote.","depth":9},{"id":37,"text":"The 300 emails","depth":5},{"id":38,"text":"sent to Congress","depth":5},{"id":39,"text":"represent a small fraction of the emails","depth":5},{"id":40,"text":"Clinton has turned over to the State Department ,","depth":5},{"id":41,"text":"though the department has since requested all of her emails","depth":4},{"id":42,"text":"so as to respond to the committee requests.","depth":4},{"id":43,"text":"Nick Merrill , the spokesman for Clinton , defended the aides ' use of personal email","depth":3},{"id":44,"text":"saying","depth":4},{"id":45,"text":"that it was `` their practice to primarily use their work email","depth":6},{"id":46,"text":"when conducting state business , with only the tiniest fraction of the more than 1 million emails","depth":8},{"id":47,"text":"they sent or received","depth":8},{"id":48,"text":"involving their personal accounts , ''","depth":7},{"id":49,"text":"the Times reported.","depth":5},{"id":50,"text":"But some Republicans are not satisfied with that explanation","depth":4},{"id":51,"text":"and question the records","depth":5},{"id":52,"text":"provided by Clinton.","depth":5},{"id":53,"text":"South Carolina GOP Rep. Trey Gowdy , chairman of the House Select committee on Benghazi , has suggested","depth":5},{"id":54,"text":"he does not believe","depth":7},{"id":55,"text":"Clinton turned over all the Benghazi-related emails","depth":7},{"id":56,"text":"and had called on her to turn over her private email server","depth":7},{"id":57,"text":"so that a neutral party can examine it","depth":8},{"id":58,"text":"to see","depth":9},{"id":59,"text":"if there are other relevant emails","depth":10},{"id":60,"text":"that should be provided to the panel.","depth":10},{"id":61,"text":"The committee is also likely to grill Clinton on why at least four advisers occasionally used personal email accounts","depth":6},{"id":62,"text":"to liaise with her ,","depth":6},{"id":63,"text":"the Times said .","depth":5}],"relations":[{"parent":127,"left":106,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":106,"left":100,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":68,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":67,"right":4,"relation":"attribution","nuclearity":"SN"},{"parent":67,"left":66,"right":3,"relation":"same-unit","nuclearity":"NN"},{"parent":66,"left":0,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":76,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":70,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":5,"right":69,"relation":"attribution","nuclearity":"SN"},{"parent":69,"left":6,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":72,"right":74,"relation":"evaluation","nuclearity":"NS"},{"parent":72,"left":71,"right":10,"relation":"same-unit","nuclearity":"NN"},{"parent":71,"left":8,"right":9,"relation":"purpose","nuclearity":"NS"},{"parent":74,"left":11,"right":73,"relation":"explanation","nuclearity":"NS"},{"parent":73,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":98,"left":79,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":14,"right":78,"relation":"attribution","nuclea