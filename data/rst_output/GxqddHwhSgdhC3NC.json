{"article_id":"GxqddHwhSgdhC3NC","edus":[{"id":0,"text":"Rick Gates , a former top adviser to President Donald Trump 's campaign , appeared in federal court Friday","depth":7},{"id":1,"text":"where he pleaded guilty to conspiracy and lying to the FBI ,","depth":7},{"id":2,"text":"USA Today reported .","depth":6},{"id":3,"text":"Gates , 45 , also promised","depth":6},{"id":4,"text":"he would begin cooperating with prosecutors in special counsel Robert Mueller 's investigation into Russian interference in the 2016 presidential election .","depth":6},{"id":5,"text":"He admitted","depth":7},{"id":6,"text":"he conspired with his former business partner Paul Manafort , 68 ,","depth":9},{"id":7,"text":"who served as Trump 's campaign manager ,","depth":9},{"id":8,"text":"to defraud the U.S.","depth":9},{"id":9,"text":"by hiding money","depth":10},{"id":10,"text":"he earned in Ukraine .","depth":10},{"id":11,"text":"Gates also admitted to lying during a meeting with federal agents three weeks ago about a 2013 discussion","depth":7},{"id":12,"text":"he had with Manafort and an unidentified member of Congress .","depth":7},{"id":13,"text":"His plea came","depth":7},{"id":14,"text":"after prosecutors on Thursday indicted him and Manafort on 32 additional charges .","depth":7},{"id":15,"text":"The former business partners were previously charged with the laundering of millions of dollars overseas , hiding money from the Treasury Department and other crimes .","depth":7},{"id":16,"text":"Both men pleaded not guilty to earlier charges last fall .","depth":7},{"id":17,"text":"Gates faces up from 57 to 71 months in prison ,","depth":5},{"id":18,"text":"U.S. District Judge Amy Jackson said .","depth":5},{"id":19,"text":"He could serve less time","depth":6},{"id":20,"text":"depending on the extent of his cooperation ,","depth":6},{"id":21,"text":"she added .","depth":5},{"id":22,"text":"Gates 's lawyer , Thomas Green , declined to comment ,","depth":4},{"id":23,"text":"saying","depth":6},{"id":24,"text":"he would \" keep our powder dry , \"","depth":6},{"id":25,"text":"USA Today reported .","depth":5},{"id":26,"text":"Manafort said","depth":5},{"id":27,"text":"he has no plans","depth":6},{"id":28,"text":"to change his plea .","depth":6},{"id":29,"text":"`` Notwithstanding that Rick Gates pled today ,","depth":7},{"id":30,"text":"I continue to maintain my innocence , ''","depth":7},{"id":31,"text":"Manafort said in a written statement .","depth":6},{"id":32,"text":"`` I had hoped","depth":9},{"id":33,"text":"and expected","depth":9},{"id":34,"text":"my business colleague would have had the strength","depth":9},{"id":35,"text":"to continue the battle","depth":10},{"id":36,"text":"to prove our innocence .","depth":10},{"id":37,"text":"For reasons","depth":9},{"id":38,"text":"yet to surface","depth":9},{"id":39,"text":"he chose to do otherwise .","depth":8},{"id":40,"text":"This does not alter my commitment","depth":7},{"id":41,"text":"to defend myself against the untrue piled up charges","depth":8},{"id":42,"text":"contained in the indictments against me . ''","depth":8},{"id":43,"text":"White House strategic communications director Mercedes Schlapp told Fox News on Friday ,","depth":3},{"id":44,"text":"USA Today reported ,","depth":3},{"id":45,"text":"that the charges against Manafort and Gates `` have nothing to do with the White House .","depth":3},{"id":46,"text":"They have nothing to do with the president . ''","depth":3}],"relations":[{"parent":93,"left":89,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":68,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":63,"right":67,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":51,"right":62,"relation":"elaboration","nuclearity":"NS"},{"parent":51,"left":49,"right":50,"relation":"elaboration","nuclearity":"NS"},{"parent":49,"left":48,"right":2,"relation":"attribution","nuclearity":"NS"},{"parent":48,"left":0,"right":1,"relation":"conte