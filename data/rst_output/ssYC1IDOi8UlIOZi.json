lation":"organization","nuclearity":"SN"},{"parent":259,"left":50,"right":51,"relation":"attribution","nuclearity":"SN"},{"parent":273,"left":263,"right":272,"relation":"explanation","nuclearity":"NS"},{"parent":263,"left":261,"right":262,"relation":"adversative","nuclearity":"SN"},{"parent":261,"left":260,"right":54,"relation":"same-unit","nuclearity":"NN"},{"parent":260,"left":52,"right":53,"relation":"elaboration","nuclearity":"NS"},{"parent":262,"left":55,"right":56,"relation":"elaboration","nuclearity":"NS"},{"parent":272,"left":264,"right":271,"relation":"context","nuclearity":"NS"},{"parent":264,"left":57,"right":58,"relation":"attribution","nuclearity":"SN"},{"parent":271,"left":265,"right":270,"relation":"context","nuclearity":"SN"},{"parent":265,"left":59,"right":60,"relation":"adversative","nuclearity":"NS"},{"parent":270,"left":61,"right":269,"relation":"elaboration","nuclearity":"NS"},{"parent":269,"left":266,"right":268,"relation":"same-unit","nuclearity":"NN"},{"parent":266,"left":62,"right":63,"relation":"purpose","nuclearity":"NS"},{"parent":268,"left":64,"right":267,"relation":"purpose","nuclearity":"NS"},{"parent":267,"left":65,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":416,"left":318,"right":415,"relation":"joint","nuclearity":"NN"},{"parent":318,"left":67,"right":317,"relation":"organization","nuclearity":"SN"},{"parent":317,"left":299,"right":316,"relation":"joint","nuclearity":"NN"},{"parent":299,"left":277,"right":298,"relation":"joint","nuclearity":"NN"},{"parent":277,"left":68,"right":276,"relation":"adversative","nuclearity":"NN"},{"parent":276,"left":69,"right":275,"relation":"joint","nuclearity":"NN"},{"parent":275,"left":70,"right":71,"relation":"adversative","nuclearity":"NS"},{"parent":298,"left":293,"right":297,"relation":"context","nuclearity":"SN"},{"parent":293,"left":289,"right":292,"relation":"adversative","nuclearity":"NS"},{"parent":289,"left":280,"right":288,"relation":"joint","nuclearity":"NN"},{"parent