{"article_id":"h47pxSkN3XeOVq7J","edus":[{"id":0,"text":"The president and his supporters have long contended","depth":4},{"id":1,"text":"that the Obama administration used the intelligence community","depth":5},{"id":2,"text":"to illegally spy on the Trump campaign in 2016 .","depth":5},{"id":3,"text":"Now , Attorney General William Barr has appointed John Durham , the US attorney in Connecticut ,","depth":5},{"id":4,"text":"to investigate the origins of the Russia investigation","depth":6},{"id":5,"text":"and decide","depth":7},{"id":6,"text":"whether intelligence gathering methods","depth":9},{"id":7,"text":"involving the Trump campaign","depth":9},{"id":8,"text":"were `` lawful and appropriate . ''","depth":8},{"id":9,"text":"As the news broke late Monday","depth":6},{"id":10,"text":"several Republican senators applauded the move .","depth":6},{"id":11,"text":"Sen. Ted Cruz","depth":10},{"id":12,"text":"( R-TX )","depth":10},{"id":13,"text":"told Fox host Sean Hannity","depth":9},{"id":14,"text":"that the investigation will bring accountability to the Justice Department 's 2016 campaign investigation .","depth":8},{"id":15,"text":"`` We need to investigate how politicized it was","depth":8},{"id":16,"text":"and in particular , we need to see what were the roles of the political appointees and who signed off on it , ''","depth":10},{"id":17,"text":"he said .","depth":10},{"id":18,"text":"`` Was it Loretta Lynch ?","depth":10},{"id":19,"text":"Was it John Brennan ?","depth":11},{"id":20,"text":"Was it Joe Biden ?","depth":12},{"id":21,"text":"Was it President Obama himself ? ''","depth":12},{"id":22,"text":"Sen. Tom Cotton","depth":9},{"id":23,"text":"( R-AR )","depth":9},{"id":24,"text":"told News","depth":8},{"id":25,"text":"that Barr `` wants to know","depth":9},{"id":26,"text":"if the spying","depth":11},{"id":27,"text":"that was done on the Trump campaign","depth":11},{"id":28,"text":"had a proper predicate , ''","depth":10},{"id":29,"text":"adding ,","depth":9},{"id":30,"text":"`` I think","depth":10},{"id":31,"text":"a lot of Democrats are very worried about what that probe is going to turn up . ''","depth":10},{"id":32,"text":"President Trump nominated Durham for his current post last year","depth":5},{"id":33,"text":"and the Senate unanimously confirmed him .","depth":5},{"id":34,"text":"The two Democratic senators from Connecticut , Richard Blumenthal , and Chris Murphy , called him a `` fierce , fair prosecutor ''","depth":5},{"id":35,"text":"who knows how to try tough cases .","depth":5},{"id":36,"text":"Ken Starr ,","depth":6},{"id":37,"text":"who served as an independent counsel during the Clinton presidency ,","depth":6},{"id":38,"text":"praised Barr 's choice .","depth":5},{"id":39,"text":"`` He 's totally above politics , ''","depth":7},{"id":40,"text":"said Starr ,","depth":7},{"id":41,"text":"noting","depth":7},{"id":42,"text":"that the Obama administration gave Durham some key assignments ,","depth":8},{"id":43,"text":"including an investigation of CIA detainees .","depth":8},{"id":44,"text":"`` We really have an honest cop on the beat now , ''","depth":6},{"id":45,"text":"said Starr .","depth":6},{"id":46,"text":"Durham 's appointment comes","depth":3},{"id":47,"text":"just weeks after Barr told members of Congress","depth":5},{"id":48,"text":"that he was building a team","depth":6},{"id":49,"text":"to investigate spying against the Trump campaign .","depth":6},{"id":50,"text":"`` I think","depth":7},{"id":51,"text":"spying on a political campaign is a big deal , ''","depth":7},{"id":52,"text":"he said .","depth":6},{"id":53,"text":"`` The generation","depth":9},{"id":54,"text":"I grew up in","depth":9},{"id":55,"text":"which was the Vietnam war ,","depth":8},{"id":56,"text":"people were all concerned about spying on anti-war people by the government","depth":7},{"id":57,"text":"and there were a lot of rules","depth":8},{"id":58,"text":"put in place","depth":8},{"id":59,"text":"to make sure","depth":8},{"id":60,"text":"that there 's an adequate basis","depth":9},{"id":61,"text":"before our law enforcement agencies get involved in political surveillance . ''","depth":9},{"id":62,"text":"The Durham inquiry is separate from an investigation by the Justice Department 's Inspector General .","depth":3},{"id":63,"text":"That is also examining the Russia probe origins","depth":4},{"id":64,"text":"and Barr expects it to be complete this month or next .","depth":4}],"relations":[{"parent":129,"left":110,"right":128,"relation":"elaboration","nuclearity":"NS"},{"parent":110,"left":96,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":96,"left":67,"right":95,"relation":"context","nuclearity":"SN"},{"parent":67,"left":0,"right":66,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":1,"right":2,"relation":"purpose","nuclearity":"NS"},{"parent":95,"left":72,"right":94,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":3,"right":71,"relation":"purpose","nuclearity":"NS"},{"parent":71,"left":4,"right":70,"relation":"joint","nuclearity":"NN"},{"parent":70,"left":5,"right":69,"relation":"attribution","nuclearity":"SN"},{"parent":69,"left":68,"right":8,"relation":"same-unit","nuclearity":"NN"},{"parent":68,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":73,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":9,"right":10,"relation":"context","nuclearity":"SN"},{"parent":93,"left":83,"right":92,"relation":"joint","nuclearity":"NN"},{"parent":83,"left":76,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":75,"right":14,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":74,"right":13,"relation":"same-unit","nuclearity":"NN"},{"parent":74,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":15,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":77,"right":80,"relation":"elaboration","nuclearity":"NS"},{