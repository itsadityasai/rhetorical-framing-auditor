{"article_id":"jwVv7FPYYcRqALXO","edus":[{"id":0,"text":"Lois Lerner ' s lawyer said","depth":3},{"id":1,"text":"she would invoke the Fifth Amendment .","depth":3},{"id":2,"text":"|","depth":3},{"id":3,"text":"John Shinkle/POLITICO","depth":3},{"id":4,"text":"Lois Lerner pleads the Fifth","depth":4},{"id":5,"text":"Lois Lerner , the director of the scandal-plagued IRS division","depth":11},{"id":6,"text":"that oversees nonprofit groups ,","depth":11},{"id":7,"text":"struck a defiant tone in her first public appearance","depth":10},{"id":8,"text":"since the agency acknowledged","depth":10},{"id":9,"text":"that it wrongly targeted conservative groups","depth":11},{"id":10,"text":"applying for a tax exemption .","depth":11},{"id":11,"text":"\" I have not done anything wrong , \"","depth":10},{"id":12,"text":"she told the House Oversight and Government Reform Committee today .","depth":10},{"id":13,"text":"\" I have not broken any laws .","depth":10},{"id":14,"text":"I have not violated any IRS rules or regulations ,","depth":11},{"id":15,"text":"and I have not provided false information to this or any other committee . \"","depth":11},{"id":16,"text":"Lerner refused to answer additional questions from the committee","depth":8},{"id":17,"text":"and invoked her Fifth Amendment right","depth":9},{"id":18,"text":"not to incriminate herself .","depth":9},{"id":19,"text":"She sparked the scandal on May 10","depth":7},{"id":20,"text":"when she told a Washington legal conference","depth":8},{"id":21,"text":"that the IRS inappropriately scrutinized nonprofit groups","depth":9},{"id":22,"text":"if they had ties to organizations like the tea party .","depth":9},{"id":23,"text":"Rep. Trey Gowdy","depth":12},{"id":24,"text":"( R-S.C. )","depth":12},{"id":25,"text":"tried to keep Lerner at the witness table","depth":11},{"id":26,"text":"by arguing","depth":11},{"id":27,"text":"that she waived her Fifth Amendment protection","depth":12},{"id":28,"text":"by giving an opening statement .","depth":12},{"id":29,"text":"Maryland Rep. Elijah Cummings , the top Democrat on the oversight committee , said","depth":10},{"id":30,"text":"she was still allowed to invoke the Fifth Amendment","depth":11},{"id":31,"text":"because she wasn ' t speaking in a courtroom .","depth":11},{"id":32,"text":"Rep. Darrell Issa , the California Republican","depth":12},{"id":33,"text":"who chairs the committee ,","depth":12},{"id":34,"text":"tried to coax Lerner into staying","depth":11},{"id":35,"text":"by offering to narrow the scope of questions .","depth":10},{"id":36,"text":"When she refused ,","depth":10},{"id":37,"text":"Issa told Lerner","depth":11},{"id":38,"text":"she could leave","depth":12},{"id":39,"text":"but is subject to being recalled","depth":13},{"id":40,"text":"as the hearing plays out .","depth":13},{"id":41,"text":"Republicans were skeptical","depth":8},{"id":42,"text":"that Lerner had done nothing wrong .","depth":8},{"id":43,"text":"At a separate House hearing , Treasury Secretary Jack Lew was pressed on whether he agreed with Lerner .","depth":8},{"id":44,"text":"\" I ' m going to wait","depth":10},{"id":45,"text":"until we have all the facts , \"","depth":10},{"id":46,"text":"Lew told the House Financial Services Committee .","depth":9},{"id":47,"text":"Lew told lawmakers","depth":9},{"id":48,"text":"he plans to meet with the new acting IRS Commissioner Daniel Werfel later today .","depth":9},{"id":49,"text":"Werfel is also slated to meet with Senate Finance Committee Chairman Max Baucus on Wednesday .","depth":9},{"id":50,"text":"Issa said","depth":10},{"id":51,"text":"the new IRS chief will appear before his committee soon .","depth":10},{"id":52,"text":"It was a dramatic morning","depth":5},{"id":53,"text":"as lawmakers aggressively probed the biggest public relations debacle","depth":6},{"id":54,"text":"to face the IRS in years .","depth":6},{"id":55,"text":"House Oversight Committee members ramped up pressure on Inspector General J. Russell George","depth":7},{"id":56,"text":"to dig deeper into the IRS mess .","depth":7},{"id":57,"text":"Issa made clear","depth":7},{"id":58,"text":"he won ' t drop the issue anytime soon .","depth":7},{"id":59,"text":"Members have a long list of interviews","depth":6},{"id":60,"text":"scheduled with people involved in the scandal .","depth":6},{"id":61,"text":"The Obama administration used the hearing","depth":4},{"id":62,"text":"to defend itself from charges","depth":5},{"id":63,"text":"that senior staffers were aware","depth":6},{"id":64,"text":"that an inspector general would soon issue a report","depth":7},{"id":65,"text":"finding","depth":8},{"id":66,"text":"that the IRS wrongly targeted conservative groups .","depth":8},{"id":67,"text":"Deputy Treasury Secretary Neal Wolin told the panel","depth":4},{"id":68,"text":"that","depth":5},{"id":69,"text":"although he was aware","depth":7},{"id":70,"text":"the IRS was being investigated ,","depth":7},{"id":71,"text":"he knew nothing about the results of that review","depth":7},{"id":72,"text":"and didn ' t interfere with the probe in any way .","depth":7}],"relations":[{"parent":145,"left":76,"right":144,"relation":"organization","nuclearity":"SN"},{"parent":76,"left":74,"right":75,"relation":"attribution","nuclearity":"NS"},{"parent":74,"left":0,"right":1,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":2,"right":3,"relation":"attribution","nuclearity":"NS"},{"parent":144,"left":132,"right":143,"relation":"elaboration","nuclearity":"NS"},{"parent":132,"left":123,"right":131,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":4,"right":122,"relation":"organization","nuclearity":"SN"},{"parent":122,"left":93,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":93,"left":89,"right":92,"relation":"context","nuclearity":"NS"},{"parent":89,"left":86,"right":88,"relation":"joint","nuclearity":"NN"},{"parent":86,"left":81,"right":85,"relation":"evaluation","nuclearity":"NS"},{"parent":81,"