{"article_id":"haKWQpo59moHtsa1","edus":[{"id":0,"text":"Oct 24","depth":8},{"id":1,"text":"( Reuters ) -","depth":8},{"id":2,"text":"Puerto Rico and Whitefish Energy Holdings on Tuesday defended their $ 300 million contract for the small Montana company","depth":10},{"id":3,"text":"to repair the U.S. territory 's hurricane-ravaged power grid","depth":10},{"id":4,"text":"after the deal was criticized by U.S. lawmakers .","depth":9},{"id":5,"text":"The back-and-forth comes","depth":9},{"id":6,"text":"as Puerto Rico struggles to restore power to more than 80 percent of the island","depth":10},{"id":7,"text":"a month after Hurricane Maria made landfall .","depth":10},{"id":8,"text":"Whitefish last month signed a deal with Puerto Rico 's quasi-public power utility , PREPA ,","depth":9},{"id":9,"text":"to help fix a grid","depth":10},{"id":10,"text":"that was nearly destroyed by Maria , the strongest storm","depth":11},{"id":11,"text":"to hit Puerto Rico in 90 years .","depth":11},{"id":12,"text":"Whitefish was awarded the deal","depth":10},{"id":13,"text":"without a competitive bidding process ,","depth":11},{"id":14,"text":"and despite the facts","depth":12},{"id":15,"text":"that it had just two full-time employees","depth":13},{"id":16,"text":"and was established only two years ago .","depth":13},{"id":17,"text":"That drew criticism from legislators","depth":10},{"id":18,"text":"who suggested","depth":11},{"id":19,"text":"cheaper options might have been available .","depth":11},{"id":20,"text":"In a statement on Tuesday , Governor Ricardo Rossello said","depth":9},{"id":21,"text":"his administration would review PREPA 's contracting practices","depth":10},{"id":22,"text":"and forward findings to the island 's comptroller .","depth":10},{"id":23,"text":"Rossello defended the deal ,","depth":10},{"id":24,"text":"saying","depth":11},{"id":25,"text":"it was necessary","depth":12},{"id":26,"text":"to ensure","depth":13},{"id":27,"text":"Puerto Rico would have workers in place quickly .","depth":13},{"id":28,"text":"`` Of those","depth":12},{"id":29,"text":"( contractors )","depth":12},{"id":30,"text":"who met the requirements and aggressive schedules","depth":12},{"id":31,"text":"to bring brigades ,","depth":12},{"id":32,"text":"one was asking for a substantial amount of money","depth":12},{"id":33,"text":"- which PREPA had no liquidity for -","depth":12},{"id":34,"text":"and another did not require it , ''","depth":12},{"id":35,"text":"Rossello said .","depth":13},{"id":36,"text":"`` That other one is Whitefish . ''","depth":13},{"id":37,"text":"Already in bankruptcy","depth":8},{"id":38,"text":"to shed $ 72 billion of debt ,","depth":8},{"id":39,"text":"Puerto Rico was in financial straits even before the storm .","depth":7},{"id":40,"text":"As the island grapples to get back on its feet ,","depth":7},{"id":41,"text":"power restoration is a key challenge","depth":8},{"id":42,"text":"- and one of keen interest to contractors and lawmakers alike .","depth":8},{"id":43,"text":"Maria cut power to all of Puerto Rico","depth":6},{"id":44,"text":"when it made landfall on Sept. 20 .","depth":6},{"id":45,"text":"As of Monday , only 18 percent had been restored ,","depth":6},{"id":46,"text":"according to U.S. Department of Energy data .","depth":6},{"id":47,"text":"Rossello 's comments followed criticism from lawmakers like Democrat Raul Grijalva , the ranking member of the U.S. House Committee on Natural Resources ,","depth":7},{"id":48,"text":"who said in a statement on Tuesday","depth":8},{"id":49,"text":"that `` Congress needs to understand","depth":9},{"id":50,"text":"why the Whitefish contract was awarded","depth":10},{"id":51,"text":"and whether other , more cost-effective options were available . ''","depth":10},{"id":52,"text":"In a telephone interview Tuesday evening , Whitefish spokesman Ken Luce called the criticism unfounded ,","depth":8},{"id":53,"text":"saying","depth":10},{"id":54,"text":"`` Washington 's got it backwards . '' U.S. lawmakers should be admiring Whitefish","depth":12},{"id":55,"text":"for getting up and running quickly ,","depth":12},{"id":56,"text":"`` while the U.S. government was still assessing what to do , ''","depth":11},{"id":57,"text":"Luce said in a telephone interview .","depth":9},{"id":58,"text":"The firm has been working in Puerto Rico since Oct. 2 ,","depth":8},{"id":59,"text":"Luce added .","depth":8},{"id":60,"text":"Whitefish ,","depth":8},{"id":61,"text":"named for its hometown of Whitefish , Montana ,","depth":8},{"id":62,"text":"has hired dozens of workers , largely through subcontracts ,","depth":7},{"id":63,"text":"as it ramps up operations in Puerto Rico .","depth":6},{"id":64,"text":"Meanwhile , the Department of Defense said on Tuesday","depth":7},{"id":65,"text":"the U.S. Army Corps of Engineers has awarded a similar power grid repair contract to a subsidiary of Fluor Corp .","depth":7},{"id":66,"text":"Greenville , South Carolina-based Fluor Enterprises Inc beat out another undisclosed bidder for a $ 240 million construction contract","depth":8},{"id":67,"text":"set to run through next April ,","depth":8},{"id":68,"text":"the DOD said in a statement .","depth":7},{"id":69,"text":"Others","depth":7},{"id":70,"text":"working on power restoration","depth":7},{"id":71,"text":"include JEA , a Jacksonville , Florida-based utility , and representatives from the New York Power Authority .","depth":6},{"id":72,"text":"Fixing Puerto Rico 's power grid is an enormous task .","depth":4},{"id":73,"text":"Maria would have seriously damaged a healthy grid ,","depth":6},{"id":74,"text":"but Puerto Rico 's was hanging by a thread after years","depth":7},{"id":75,"text":"without maintenance .","depth":7},{"id":76,"text":"PREPA has struggled with heavy management turnover and a $ 9 billion debt load ,","depth":6},{"id":77,"text":"which landed it in bankruptcy in July .","depth":6},{"id":78,"text":"PREPA has set aggressive goals for fixes ,","depth":4},{"id":79,"text":"saying","depth":5},{"id":80,"text":"it wants 95 percent of power back by mid-December , a schedule","depth":6},{"id":81,"text":"viewed as ambitious .","depth":6},{"id":82,"text":"( Reporting by Nick Brown ; additional reporting by David Gaffen )","depth":1}],"relations":[{"parent":165,"left":164,"right":82,"relation":"attribution","nuclearity":"NS"},{"parent":164,"left":154,"right":163,"relation":"elaboration","nuclearity":"NS"},{"parent":154,"left":129,"right":153,"relation":"elaboration","nuclearity":"NS"},{"parent":129,"left":125,"right":128,"relation":"elaboration","nuclearity":"NS"},{"parent":125,"left":119,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":119,"left":90,"right":118,"relation":"elaboration","nuclearity":"NS"},{"parent":90,"left":84,"right":89,"relation":"organization","nuclearity":"SN"},{"parent":84,"left":0,"right":1,"relation":"attribution","nuclearity":"NS"},{"parent":89,"left":86,"right":88,"relation":"context","nuclearity":"NS"},{"parent":86,"left":85,"right":4,"relation":"context","nuclearity":"NS"},{"parent":85,"left":2,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":88,"left":5,"right":87,"relation":"context","nuclearity":"NS"},{"parent":87,"left":6,"right":7,"relation":"context","nuclearity":"NS"},{"parent":118,"left":101,"right":117,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":93,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":93,"left":8,"right":92,"relation":"purpose","nuclearity":"NS"},{"parent":92,"left":9,"right":91,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":97,"right":99,"relation":"causal","nuclearity":"NS"},{"parent":97,"left":12,"right":96,"relation":"mode","nuclearity":"NS"},{"parent":96,"left":13,"right":95,"relation":"joint","nuclearity":"NN"},{"parent":95,"left":14,"right":94,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":15,"right":16,"r