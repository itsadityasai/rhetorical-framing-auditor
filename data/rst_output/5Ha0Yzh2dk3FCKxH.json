parent":299,"left":291,"right":298,"relation":"explanation","nuclearity":"NS"},{"parent":291,"left":78,"right":290,"relation":"explanation","nuclearity":"NS"},{"parent":290,"left":289,"right":82,"relation":"attribution","nuclearity":"NS"},{"parent":289,"left":79,"right":288,"relation":"attribution","nuclearity":"SN"},{"parent":288,"left":80,"right":81,"relation":"purpose","nuclearity":"NS"},{"parent":298,"left":83,"right":297,"relation":"same-unit","nuclearity":"NN"},{"parent":297,"left":295,"right":296,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":294,"right":88,"relation":"condition","nuclearity":"SN"},{"parent":294,"left":84,"right":293,"relation":"same-unit","nuclearity":"NN"},{"parent":293,"left":292,"right":87,"relation":"explanation","nuclearity":"NS"},{"parent":292,"left":85,"right":86,"relation":"explanation","nuclearity":"SN"},{"parent":296,"left":89,"right":90,"relation":"attribution","nuclearity":"SN"},{"parent":323,"left":313,"right":322,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":306,"right":312,"relation":"adversative","nuclearity":"NN"},{"parent":306,"left":91,"right":305,"relation":"mode","nuclearity":"NS"},{"parent":305,"left":92,"right":93,"relation":"attribution","nuclearity":"SN"},{"parent":312,"left":308,"right":311,"relation":"elaboration","nuclearity":"NS"},{"parent":308,"left":307,"right":96,"relation":"purpose","nuclearity":"NS"},{"parent":307,"left":94,"right":95,"relation":"elaboration","nuclearity":"NS"},{"parent":311,"left":309,"right":310,"relation":"same-unit","nuclearity":"NN"},{"parent":309,"left":97,"right":98,"relation":"purpose","nuclearity":"NS"},{"parent":310,"left":99,"right":100,"relation":"mode","nuclearity":"NS"},{"parent":322,"left":317,"right":321,"relation":"joint","nuclearity":"NN"},{"parent":317,"left":101,"right":316,"relation":"joint","nuclearity":"NN"},{"parent":316,"left":314,"right":315,"relation":"attribution","nuclearity":"NS"},{"parent":314,"left":102,"right":103,"relatio