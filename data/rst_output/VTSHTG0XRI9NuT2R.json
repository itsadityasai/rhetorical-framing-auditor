{"article_id":"VTSHTG0XRI9NuT2R","edus":[{"id":0,"text":"House Judiciary Committee Chairman Jerrold Nadler on Sunday said","depth":5},{"id":1,"text":"Attorney General William Barr should release the full report of Special Counsel Robert Mueller without redactions ,","depth":5},{"id":2,"text":"saying","depth":5},{"id":3,"text":"there could be information in the report","depth":6},{"id":4,"text":"that are grounds for impeachment or other actions .","depth":6},{"id":5,"text":"Mr. Nadler , New York Democrat , also said","depth":5},{"id":6,"text":"he didn ' t put much stock in Mr. Barr ' s recent summary of the report ,","depth":6},{"id":7,"text":"calling him a \" biased defender \" of the Trump administration .","depth":6},{"id":8,"text":"\" We are demanding","depth":7},{"id":9,"text":"and we have a right ,","depth":7},{"id":10,"text":"the Congress has a right to the entire report with no redactions whatsoever","depth":7},{"id":11,"text":"so we can see what ' s there , \"","depth":7},{"id":12,"text":"Mr. Nadler said on CBS ' s \" Face the Nation . \"","depth":5},{"id":13,"text":"The Justice Department has indicated","depth":4},{"id":14,"text":"that every page of Mr. Mueller ' s final report on Russian interference in the 2016 election could contain confidential grand jury information ,","depth":4},{"id":15,"text":"and Mr. Nadler acknowledged","depth":5},{"id":16,"text":"lawmakers could have to go to court","depth":6},{"id":17,"text":"to secure those parts .","depth":6},{"id":18,"text":"Mr. Nadler said","depth":6},{"id":19,"text":"it ' s unclear what the rest of the report will turn up .","depth":6},{"id":20,"text":"\" Who knows ?","depth":7},{"id":21,"text":"There could be grounds for impeachment .","depth":9},{"id":22,"text":"There could be grounds for other action , \"","depth":9},{"id":23,"text":"he said .","depth":8},{"id":24,"text":"\" You can commit shameful acts .","depth":7},{"id":25,"text":"You can commit complete betrayals of the public interest","depth":9},{"id":26,"text":"without committing impeachable acts .","depth":9},{"id":27,"text":"And","depth":9},{"id":28,"text":"if you did that ,","depth":10},{"id":29,"text":"the public ought to know that , too . \"","depth":10},{"id":30,"text":"SEE ALSO :","depth":3},{"id":31,"text":"Trump attorney Jay Sekulow not worried","depth":4},{"id":32,"text":"Mueller report could be more damaging than Barr summary","depth":4},{"id":33,"text":"In a four-page summary of the report , Mr. Barr said last month","depth":5},{"id":34,"text":"that it did not establish","depth":6},{"id":35,"text":"that members of the Trump campaign conspired or coordinated with Russia .","depth":6},{"id":36,"text":"The summary also said","depth":5},{"id":37,"text":"the report didn ' t conclude","depth":7},{"id":38,"text":"the president obstructed justice after the fact ,","depth":7},{"id":39,"text":"but that it also didn ' t exonerate him .","depth":6},{"id":40,"text":"Mr. Nadler said","depth":6},{"id":41,"text":"he didn ' t put much stock in Mr. Barr ' s summary .","depth":6},{"id":42,"text":"\" I dismiss what he said","depth":7},{"id":43,"text":"- he ' s a biased defender of the administration , \"","depth":8},{"id":44,"text":"he said .","depth":8},{"id":45,"text":"\" He ' s entitled to be a defender of the administration ,","depth":7},{"id":46,"text":"but he is not entitled to withhold the evidence from Congress . \"","depth":7},{"id":47,"text":"But Rudolph Giuliani ,","depth":9},{"id":48,"text":"who is part of the president ' s legal team ,","depth":9},{"id":49,"text":"said later on the program","depth":8},{"id":50,"text":"that it ' s Mr. Nadler who has pre-judged the case .","depth":7},{"id":51,"text":"\" I didn ' t appreciate his suggestion","depth":9},{"id":52,"text":"the attorney general be biased , \"","depth":9},{"id":53,"text":"Mr. Giuliani said ,","depth":8},{"id":54,"text":"calling Mr. Barr a man of the \" highest integrity . \"","depth":7},{"id":55,"text":"Mr. Giuliani said","depth":7},{"id":56,"text":"he isn ' t concerned","depth":9},{"id":57,"text":"that the full report could be damaging for Mr. Trump ,","depth":9},{"id":58,"text":"despite recent news reports","depth":9},{"id":59,"text":"that indicated","depth":10},{"id":60,"text":"members of Mr. Mueller ' s team have expressed concerns about how Mr. Barr framed the primary conclusions of the report .","depth":10},{"id":61,"text":"\" I guarantee you ,","depth":8},{"id":62,"text":"other than little quibbles , I ' m not worried about the report at all , \"","depth":8},{"id":63,"text":"Mr. Giuliani said .","depth":7}],"relations":[{"parent":127,"left":93,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":93,"left":76,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":68,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":65,"right":67,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":0,"right":1,"relation":"attribution","nuclearity":"SN"},{"parent":67,"left":2,"right":66,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":70,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":5,"right":69,"relation":"attribution","nuclearity":"SN"},{"parent":69,"left":6,"right":7,"relation":"evaluation","nuclearity":"NS"},{"parent":74,"left":73,"right":12,"relation":"attribution","nuclearity":"NS"},{"parent":73,"left":71,"right":72,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":8,"right":9,"relation":"attribution","nuclearity":"SN"},{"parent":72,"left":10,"right":11,"relation":"purpose","nuclearity":"NS"},{"parent":92,"left":77,"right":91,"relation":"joint","nuclearity":"NN"},{"parent":77,"left":13,"right":14,"relation":"attribution","nuclearity":"SN"},{"parent":91,"left":79,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":15,"right":78,"relation":"attribution","nuclearity":"SN"},{"parent":78,"left":1