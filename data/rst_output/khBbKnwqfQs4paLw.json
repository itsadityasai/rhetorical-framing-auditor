arent":240,"left":31,"right":239,"relation":"attribution","nuclearity":"SN"},{"parent":239,"left":32,"right":238,"relation":"joint","nuclearity":"NN"},{"parent":238,"left":33,"right":34,"relation":"context","nuclearity":"NS"},{"parent":242,"left":241,"right":37,"relation":"attribution","nuclearity":"NS"},{"parent":241,"left":35,"right":36,"relation":"context","nuclearity":"NS"},{"parent":260,"left":255,"right":259,"relation":"elaboration","nuclearity":"NS"},{"parent":255,"left":252,"right":254,"relation":"elaboration","nuclearity":"NS"},{"parent":252,"left":245,"right":251,"relation":"elaboration","nuclearity":"NS"},{"parent":245,"left":38,"right":244,"relation":"attribution","nuclearity":"SN"},{"parent":244,"left":39,"right":40,"relation":"elaboration","nuclearity":"NS"},{"parent":251,"left":246,"right":250,"relation":"context","nuclearity":"NS"},{"parent":246,"left":41,"right":42,"relation":"attribution","nuclearity":"NS"},{"parent":250,"left":43,"right":249,"relation":"attribution","nuclearity":"SN"},{"parent":249,"left":248,"right":47,"relation":"same-unit","nuclearity":"NN"},{"parent":248,"left":44,"right":247,"relation":"elaboration","nuclearity":"NS"},{"parent":247,"left":45,"right":46,"relation":"elaboration","nuclearity":"NS"},{"parent":254,"left":253,"right":50,"relation":"attribution","nuclearity":"NS"},{"parent":253,"left":48,"right":49,"relation":"elaboration","nuclearity":"NS"},{"parent":259,"left":51,"right":258,"relation":"adversative","nuclearity":"NN"},{"parent":258,"left":52,"right":257,"relation":"attribution","nuclearity":"SN"},{"parent":257,"left":256,"right":55,"relation":"same-unit","nuclearity":"NN"},{"parent":256,"left":53,"right":54,"relation":"elaboration","nuclearity":"NS"},{"parent":281,"left":265,"right":280,"relation":"elaboration","nuclearity":"NS"},{"parent":265,"left":56,"right":264,"relation":"attribution","nuclearity":"SN"},{"parent":264,"left":57,"right":58,"relation":"elaboration","nuclearity":"NS"},{"parent":280,"left":276,"right":279,"relation":"evaluation","nuclearity":"NS"},{"parent":276,"left":269,"right":275,"relation":"joint","nuclearity":"NN"},{"parent":269,"left":267,"right":268,"relation":"same-unit","nuclearity":"NN"},{"parent":267,"left":59,"right":266,"relation":"elaboration","nuclearity":"NS"},{"parent":266,"left":60,"right":61,"relation":"joint","nuclearity":"NN"},{"parent":268,"left":62,"right":63,"relation":"attribution","nuclearity":"SN"},{"parent":275,"left":272,"right":274,"relation":"elaboration","nuclearity":"NS"},{"parent":272,"left":64,"right":271,"relation":"purpose","nuclearity":"NS"},{"parent":271,"left":65,"right":270,"relation":"elaboration","nuclearity":"NS"},{"parent":270,"left":66,"right":67,"relation":"context","nuclearity":"NS"},{"parent":274,"left":68,"right":273,"relation":"attribution","nuclearity":"SN"},{"parent":273,"left":69,"right":70,"relation":"purpose","nuclearity":"NS"},{"parent":279,"left":71,"right":278,"relation":"attribution","nuclearity":"SN"},{"parent":278,"left":72,"right":277,"relation":"same-unit","nuclearity":"NN"},{"parent":277,"left":73,"right":74,"relation":"condition","nuclearity":"SN"},{"parent":305,"left":295,"right":304,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":289,"right":294,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":286,"right":288,"relation":"elaboration","nuclearity":"NS"},{"parent":286,"left":75,"right":285,"relation":"context","nuclearity":"SN"},{"parent":285,"left":284,"right":79,"relation":"same-unit","nuclearity":"NN"},{"parent":284,"left":76,"right":283,"relation":"same-unit","nuclearity":"NN"},{"parent":283,"left":77,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":288,"left":80,"right":287,"relation":"organization","nuclearity":"SN"},{"parent":287,"left":81,"right":82,"relation":"context","nuclearity":"NS"},{"parent":294,"left":291,"right":293,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":290,"right":85,"relation":"same-unit","nuclearity":"NN"},{"parent":290,"left":83,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":86,"right":292,"relation":"attribution","nuclearity":"SN"},{"parent":292,"left":87,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":299,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":89,"right":298,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":90,"right":297,"relation":"attribution","nuclearity":"SN"},{"parent":297,"left":91,"right":296,"relation":"causal","nuclearity":"NS"},{"parent":296,"left":92,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":94,"right":302,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":301,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":300,"right":97,"relation":"attribution","nuclearity":"NS"},{"parent":300,"left":95,"right":96,"relation":"attribution","nuclearity":"SN"},{"parent":414,"left":344,"right":413,"relation":"elaboration","nuclearity":"NS"},{"parent":344,"left":307,"right":343,"relation":"organization","nuclearity":"SN"},{"parent":307,"left":99,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":343,"left":325,"right":342,"relation":"elaboration","nuclearity":"NS"},{"parent":325,"left":320,"right":324,"relation":"elaboration","nuclearity":"NS"},{"parent":320,"left":314,"right":319,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":309,"right":313,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":308,"right":103,"relation":"same-unit","nuclearity":"NN"},{"parent":308,"left":101,"right":102,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":311,"right":312,"relation":"joint","nuclearity":"NN"},{"parent":311,"left":104,"right":310,"relation":"elaboration","nuclearity":"NS"},{"parent":310,"left":105,"right":106,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":107,"right":108,"relation":"elaboration","nuclearity":"NS"},