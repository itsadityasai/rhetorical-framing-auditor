{"article_id":"FsotkVptDjIgtqVW","edus":[{"id":0,"text":"So the \" Blexit \" push was a bridge too far for Kanye West .","depth":4},{"id":1,"text":"In a series of tweets Tuesday afternoon , the rap star","depth":7},{"id":2,"text":"who proudly wore a MAGA cap","depth":8},{"id":3,"text":"and stole the show from President Trump at the White House","depth":8},{"id":4,"text":"said","depth":6},{"id":5,"text":"he wanted nothing","depth":7},{"id":6,"text":"to do with the campaign","depth":8},{"id":7,"text":"to convince blacks to exit the Democratic Party","depth":8},{"id":8,"text":"and was disassociating himself from politics .","depth":6},{"id":9,"text":"He specifically criticized Candace Owens , the black conservative","depth":6},{"id":10,"text":"pushing the \" Blexit \" campaign","depth":6},{"id":11,"text":"who touted Mr. West ' s involvement","depth":6},{"id":12,"text":"in designing clothing for it at the weekend .","depth":6},{"id":13,"text":"\" I introduced Candace to the person","depth":9},{"id":14,"text":"who made the logo","depth":9},{"id":15,"text":"and they didn ' t want their name on it","depth":9},{"id":16,"text":"so she used mine .","depth":9},{"id":17,"text":"I never wanted any association with Blexit .","depth":9},{"id":18,"text":"I have nothing","depth":10},{"id":19,"text":"to do with it , \"","depth":10},{"id":20,"text":"he said .","depth":8},{"id":21,"text":"I introduced Candace to the person","depth":9},{"id":22,"text":"who made the logo","depth":9},{"id":23,"text":"and they didn ' t want their name on it","depth":9},{"id":24,"text":"so she used mine .","depth":9},{"id":25,"text":"I never wanted any association with Blexit .","depth":8},{"id":26,"text":"I have nothing to do with it .","depth":8},{"id":27,"text":"- ye","depth":7},{"id":28,"text":"( @ kanyewest )","depth":7},{"id":29,"text":"October 30 , 2018","depth":6},{"id":30,"text":"That feeling has apparently soured Mr. West on politics ,","depth":4},{"id":31,"text":"according to the subsequent tweet in his timeline Tuesday .","depth":4},{"id":32,"text":"\" My eyes are now wide open","depth":8},{"id":33,"text":"and now realize","depth":9},{"id":34,"text":"I ' ve been used","depth":10},{"id":35,"text":"to spread messages","depth":11},{"id":36,"text":"I don ' t believe in .","depth":11},{"id":37,"text":"I am distancing myself from politics","depth":8},{"id":38,"text":"and completely focusing on being creative ! ! ! \"","depth":8},{"id":39,"text":"the rap star said .","depth":6},{"id":40,"text":"My eyes are now wide open","depth":8},{"id":41,"text":"and now realize","depth":9},{"id":42,"text":"I ' ve been used","depth":9},{"id":43,"text":"to spread messages","depth":8},{"id":44,"text":"I don ' t believe in .","depth":8},{"id":45,"text":"I am distancing myself from politics","depth":7},{"id":46,"text":"and completely focusing on being creative ! ! !","depth":7},{"id":47,"text":"- ye","depth":6},{"id":48,"text":"( @ kanyewest )","depth":6},{"id":49,"text":"October 30 , 2018","depth":5},{"id":50,"text":"He prepared the way for his distancing himself from Ms. Owens , though ,","depth":4},{"id":51,"text":"by outlining a political platform","depth":5},{"id":52,"text":"and writing","depth":6},{"id":53,"text":"that \" I would like to thank my family , loved ones , and community","depth":7},{"id":54,"text":"for supporting my ACTUAL beliefs and my vision for a better world . \"","depth":7},{"id":55,"text":"That platform didn ' t , on the surface , seem all that MAGA-compliant .","depth":3},{"id":56,"text":"\" I support creating jobs and opportunities for people","depth":5},{"id":57,"text":"who need them the most ,","depth":5},{"id":58,"text":"I support prison reform ,","depth":6},{"id":59,"text":"I support common-sense gun laws","depth":7},{"id":60,"text":"that will make our world safer , \"","depth":7},{"id":61,"text":"he wrote in one tweet .","depth":5},{"id":62,"text":"Mr. West continued :","depth":4},{"id":63,"text":"\" I support those","depth":7},{"id":64,"text":"who risk their lives","depth":8},{"id":65,"text":"to serve and protect us","depth":8},{"id":66,"text":"and I support holding people","depth":7},{"id":67,"text":"who misuse their power accountable .","depth":7},{"id":68,"text":"I believe in love and compassion for people","depth":7},{"id":69,"text":"seeking asylum","depth":7},{"id":70,"text":"and parents","depth":7},{"id":71,"text":"who are fighting","depth":8},{"id":72,"text":"to protect their children from violence and war . \"","depth":8}],"relations":[{"parent":145,"left":122,"right":144,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":102,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":81,"right":101,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":0,"right":80,"relation":"evaluation","nuclearity":"SN"},{"parent":80,"left":76,"right":79,"relation":"attribution","nuclearity":"SN"},{"parent":76,"left":75,"right":4,"relation":"same-unit","nuclearity":"NN"},{"parent":75,"left":1,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":2,"right":3,"relation":"joint","nuclearity":"NN"},{"parent":79,"left":78,"right":8,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":5,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":84,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":82,"right":83,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":97,"right":99,"relation":"attribution","nuclearity":"NS"},{"parent":97,"left":91,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":87,"right":90,"relation":"evaluation","nuclearity":"NS"},{"parent":87,"left":85,"right":86,"relation":"joint","nuclearity":"NN"},{"parent":85,"left":13,"right":14,