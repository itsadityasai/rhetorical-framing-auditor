{"article_id":"oRTWUVnEzKlgBp7c","edus":[{"id":0,"text":"WASHINGTON ( ) -","depth":1},{"id":1,"text":"U.S. senators made a new try","depth":8},{"id":2,"text":"at ending a partial month-long government shutdown through a temporary funding bill","depth":8},{"id":3,"text":"on Thursday ,","depth":7},{"id":4,"text":"but President Donald Trump demanded a \" down payment \" for a border wall","depth":7},{"id":5,"text":"that Democrats reject .","depth":7},{"id":6,"text":"After the Republican-led Senate failed to advance two measures","depth":8},{"id":7,"text":"to reopen shuttered agencies ,","depth":8},{"id":8,"text":"Democratic and Republican lawmakers spoke on the Senate floor","depth":8},{"id":9,"text":"and urged quick passage of a three-week , stopgap funding bill","depth":9},{"id":10,"text":"to create time for talks on border security .","depth":9},{"id":11,"text":"White House spokeswoman Sarah Sanders said","depth":8},{"id":12,"text":"such a measure would only work","depth":9},{"id":13,"text":"\" if there is a large down payment on the wall . \"","depth":9},{"id":14,"text":"But a spokesman for Senate Democratic leader Chuck Schumer said","depth":8},{"id":15,"text":"Senate Democrats had made clear to Republicans","depth":9},{"id":16,"text":"that \" they will not support funding for the wall . \"","depth":9},{"id":17,"text":"Trump ,","depth":8},{"id":18,"text":"who sparked the shutdown , now in its 34th day , with his demand for $ 5.7 billion in funding for the U.S.-Mexico border wall ,","depth":8},{"id":19,"text":"told reporters after the votes in the Senate :","depth":7},{"id":20,"text":"\" We have no choice","depth":8},{"id":21,"text":"but to have a wall or a barrier ,","depth":9},{"id":22,"text":"and","depth":10},{"id":23,"text":"if we don ' t have that ,","depth":11},{"id":24,"text":"it ' s just not going to work , \"","depth":11},{"id":25,"text":"referring to border security .","depth":7},{"id":26,"text":"Trump said","depth":8},{"id":27,"text":"that","depth":9},{"id":28,"text":"if Schumer and Republican Senate Majority Leader Mitch McConnell come to a \" reasonable \" agreement","depth":11},{"id":29,"text":"to end the partial government shutdown ,","depth":11},{"id":30,"text":"\" I would support it , yes . \"","depth":10},{"id":31,"text":"McConnell said late on Thursday","depth":9},{"id":32,"text":"that talks were ongoing .","depth":9},{"id":33,"text":"\" At least we ' re talking .","depth":9},{"id":34,"text":"I think","depth":11},{"id":35,"text":"that ' s better","depth":12},{"id":36,"text":"than it was before , \"","depth":12},{"id":37,"text":"he said .","depth":10},{"id":38,"text":"Democratic House of Representatives Speaker Nancy Pelosi said","depth":7},{"id":39,"text":"Trump ' s demand for a large down payment on a border wall \" is not a reasonable agreement . \"","depth":7},{"id":40,"text":"The shutdown has left 800,000 federal workers without pay and struggling to make ends meet ,","depth":5},{"id":41,"text":"as the effects on government services and the economy reverberate nationwide .","depth":5},{"id":42,"text":"Republican Senator Lindsey Graham said","depth":7},{"id":43,"text":"he had spoken to Trump about a short-term funding bill .","depth":7},{"id":44,"text":"\" All of us believe","depth":9},{"id":45,"text":"if we have three weeks with the government open","depth":10},{"id":46,"text":"that we could find a way forward","depth":11},{"id":47,"text":"to produce a bill","depth":13},{"id":48,"text":"that he would sign ,","depth":13},{"id":49,"text":"that would be good for everybody in the country , \"","depth":12},{"id":50,"text":"Graham said on the Senate floor .","depth":8},{"id":51,"text":"\" To my Democratic friends , money for a barrier is required","depth":8},{"id":52,"text":"to get this deal done . \"","depth":8},{"id":53,"text":"U.S. Senate Majority Leader Mitch McConnell","depth":10},{"id":54,"text":"( R-KY )","depth":10},{"id":55,"text":"leaves the Senate floor","depth":9},{"id":56,"text":"and walks back to his office","depth":8},{"id":57,"text":"after the failure of both competing Republican and Democratic proposals","depth":9},{"id":58,"text":"to end the partial government shutdown","depth":9},{"id":59,"text":"in back to back votes on Capitol Hill in Washington , U.S. , January 24 , 2019 .","depth":8},{"id":60,"text":"/Leah Millis","depth":6},{"id":61,"text":"Earlier , a bill","depth":9},{"id":62,"text":"backed by Trump","depth":9},{"id":63,"text":"to end the shutdown","depth":9},{"id":64,"text":"by funding the wall","depth":9},{"id":65,"text":"and a separate bill","depth":8},{"id":66,"text":"supported by Democrats","depth":9},{"id":67,"text":"to reopen shuttered agencies","depth":10},{"id":68,"text":"without such funding","depth":10},{"id":69,"text":"did not get the votes","depth":7},{"id":70,"text":"required to advance in the 100-member chamber .","depth":7},{"id":71,"text":"Trump has touted Republican unity during the longest shutdown in U.S. history ,","depth":7},{"id":72,"text":"but in a sign of cracks in that resolve , or just a desire for compromise , six Republican senators voted with Democrats on their measure","depth":9},{"id":73,"text":"to reopen government agencies temporarily","depth":10},{"id":74,"text":"without money for a wall .","depth":10},{"id":75,"text":"They included freshman Senator Mitt Romney , the Republican Party ' s 2012 presidential nominee .","depth":8},{"id":76,"text":"\" Democrats have said","depth":9},{"id":77,"text":"they ' re not willing to negotiate","depth":10},{"id":78,"text":"unless the government ' s open .","depth":10},{"id":79,"text":"Well they tried their effort .","depth":11},{"id":80,"text":"I voted for it .","depth":11},{"id":81,"text":"It didn ' t happen .","depth":10},{"id":82,"text":"Now they ' ve got to negotiate , \"","depth":9},{"id":83,"text":"Romney said .","depth":7},{"id":84,"text":"Pelosi told reporters earlier","depth":7},{"id":85,"text":"she was willing to meet with Trump","depth":8},{"id":86,"text":"to discuss the shutdown .","depth":8},{"id":87,"text":"Her comments came","depth":7},{"id":88,"text":"one day after she essentially withdrew an invitation for Trump","depth":9},{"id":89,"text":"to give his State of the Union in the House chamber next Tuesday ,","depth":9},{"id":90,"text":"saying","depth":9},{"id":91,"text":"that would not happen","depth":10},{"id":92,"text":"until the shutdown ended .","depth":10},{"id":93,"text":"Trump ,","depth":8},{"id":94,"text":"who had planned to come","depth":10},{"id":95,"text":"despite the shutdown","depth":10},{"id":96,"text":"and considered giving the speech at another venue ,","depth":9},{"id":97,"text":"conceded late on Wednesday","depth":7},{"id":98,"text":"and said","depth":7},{"id":99,"text":"he would deliver the speech in the House in the \" near future . \"","depth":7},{"id":100,"text":"U.S. Commerce Secretary Wilbur Ross on Thursday urged furloughed federal workers to seek loans","depth":9},{"id":101,"text":"to pay their bills","depth":9},{"id":102,"text":"while adding in a CNBC interview","depth":9},{"id":103,"text":"that he could not understand why they were having trouble getting by .","depth":9},{"id":104,"text":"\" Is this the ' Let them eat cake ' kind of attitude","depth":10},{"id":105,"text":"or ' Call your father for money ? '","depth":11},{"id":106,"text":"or ' This is character building for you ? ' \"","depth":11},{"id":107,"text":"Pelosi asked at a news conference .","depth":9},{"id":108,"text":"She said","depth":9},{"id":109,"text":"she did not understand why Ross would make the comment","depth":10},{"id":110,"text":"\" as hundreds of thousands of men and women are about to miss a second paycheck tomorrow . \"","depth":10},{"id":111,"text":"\" Nancy just said","depth":8},{"id":112,"text":"she ' just doesn ' t understand why ? '","depth":8},{"id":113,"text":"Very simply ,","depth":8},{"id":114,"text":"without a Wall","depth":9},{"id":115,"text":"it all doesn ' t work .","depth":9},{"id":116,"text":"Our Country has a chance","depth":9},{"id":117,"text":"to greatly reduce Crime , Human Trafficking , Gangs and Drugs .","depth":9},{"id":118,"text":"Should have been done for decades .","depth":8},{"id":119,"text":"We will not Cave ! \"","depth":7},{"id":120,"text":"he said in a tweet .","depth":6},{"id":121,"text":"A /Ipsos poll last week found","depth":7},{"id":122,"text":"more than half of Americans blamed Trump for the shutdown","depth":7},{"id":123,"text":"even as he has sought to shift blame to Democrats","depth":6},{"id":124,"text":"after saying last month","depth":6},{"id":125,"text":"he would be \" proud \" to close the government for border security .","depth":6}],"relations":[{"parent":251,"left":0,"right":250,"relation":"organization","nuclearity":"SN"},{"parent":250,"left":185,"right":249,"relation":"elaboration","nuclearity":"NS"},{"parent":185,"left":164,"right":184,"relation":"elaboration","nuclearity":"NS"},{"parent":164,"left":141,"right":163,"relation":"elaboration","nuclearity":"NS"},{"parent":141,"left":130,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":130,"left":128,"right":129,"relation":"adversative","nuclearity":"NN"},{"parent":128,"left":127,"right":3,"relation":"same-unit","nuclearity":"NN"},{"parent":127,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":129,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":140,"left":134,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":134,"left":131,"right":133,"relation":"context","nuclearity":"SN"},{"parent":131,"left":6,"right":7,"relation":"purpose","nuclearity":"NS"},{"parent":133,"left":8,"right":132,"relation":"joint","nuclearity":"NN"},{"parent":132,"left":9,"right":10,"relation":"purpose","nuclearity":"NS"},{"parent":139,"left":136,"right":138,"relation":"adversative","nuclearity":"NN"},{"parent":136,"left":11,"right":135,"relation":"attribution","nuclearity":"SN"},{"parent":135,"left":12,"right":13,"relation":"condition","