rity":"NN"},{"parent":331,"left":158,"right":159,"relation":"elaboration","nuclearity":"NS"},{"parent":341,"left":334,"right":340,"relation":"elaboration","nuclearity":"NS"},{"parent":334,"left":162,"right":163,"relation":"attribution","nuclearity":"SN"},{"parent":340,"left":339,"right":170,"relation":"attribution","nuclearity":"NS"},{"parent":339,"left":337,"right":338,"relation":"elaboration","nuclearity":"NS"},{"parent":337,"left":164,"right":336,"relation":"mode","nuclearity":"SN"},{"parent":336,"left":335,"right":167,"relation":"same-unit","nuclearity":"NN"},{"parent":335,"left":165,"right":166,"relation":"elaboration","nuclearity":"NS"},{"parent":338,"left":168,"right":169,"relation":"purpose","nuclearity":"NS"},{"parent":348,"left":171,"right":347,"relation":"context","nuclearity":"SN"},{"parent":347,"left":172,"right":346,"relation":"causal","nuclearity":"SN"},{"parent":346,"left":173,"right":345,"relation":"same-unit","nuclearity":"NN"},{"parent":345,"left":174,"right":344,"relation":"condition","nuclearity":"SN"},{"parent":344,"left":175,"right":176,"relation":"elaboration","nuclearity":"NS"}]}