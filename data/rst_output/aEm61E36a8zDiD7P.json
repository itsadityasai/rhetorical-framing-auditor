{"article_id":"aEm61E36a8zDiD7P","edus":[{"id":0,"text":"\" I am very proud to announce today","depth":9},{"id":1,"text":"that we have reached a deal","depth":10},{"id":2,"text":"to end the shutdown","depth":11},{"id":3,"text":"and reopen the federal government , \"","depth":11},{"id":4,"text":"Trump said ,","depth":8},{"id":5,"text":"while announcing","depth":9},{"id":6,"text":"that he had agreed to a three-week short-term spending bill","depth":11},{"id":7,"text":"that would reopen the government -","depth":11},{"id":8,"text":"one","depth":11},{"id":9,"text":"that doesn ' t contain wall money .","depth":11},{"id":10,"text":"The legislation would fund the government through February 15 , on the condition","depth":9},{"id":11,"text":"that lawmakers continue negotiations on border security and Trump ' s border wall demands","depth":10},{"id":12,"text":"once the shutdown is over .","depth":10},{"id":13,"text":"This is essentially House Speaker Nancy Pelosi ' s demand , and a very similar bill to the one","depth":7},{"id":14,"text":"that failed in the Senate on Thursday .","depth":7},{"id":15,"text":"Trump couldn ' t help but boost his own position , though .","depth":6},{"id":16,"text":"\" As everyone knows ,","depth":10},{"id":17,"text":"I have a very powerful alternative","depth":10},{"id":18,"text":"but I didn ' t want to use it at this time , \"","depth":9},{"id":19,"text":"he said ,","depth":8},{"id":20,"text":"likely referring to his plan","depth":8},{"id":21,"text":"to declare a national emergency","depth":10},{"id":22,"text":"and pull other funding for his wall ,","depth":10},{"id":23,"text":"something","depth":10},{"id":24,"text":"he did not do","depth":11},{"id":25,"text":"and got a lot of pushback from the right","depth":12},{"id":26,"text":"for considering .","depth":12},{"id":27,"text":"Trump ' s announcement marks a major win for Democrats ,","depth":7},{"id":28,"text":"who ' ve resolutely refused to negotiate on border security","depth":8},{"id":29,"text":"until the government is open again .","depth":8},{"id":30,"text":"While Trump had insisted","depth":8},{"id":31,"text":"he would only agree to a short-term spending bill","depth":9},{"id":32,"text":"if it included a \" down payment \" on the wall ,","depth":9},{"id":33,"text":"Democrats ' refusal","depth":9},{"id":34,"text":"to budge on the matter","depth":9},{"id":35,"text":"appears to have paid off .","depth":8},{"id":36,"text":"The dramatic shift in Trump ' s position comes","depth":7},{"id":37,"text":"as pressure has mounted on the White House","depth":8},{"id":38,"text":"to end the shutdown ,","depth":9},{"id":39,"text":"which has now resulted in two missed pay periods for hundreds of thousands of federal workers , delays to air travel , and stalled services across key agencies .","depth":9},{"id":40,"text":"Numerous polls in recent weeks showed public opinion increasingly souring on the president ,","depth":7},{"id":41,"text":"who ' s been fielding most of the blame about this impasse .","depth":7},{"id":42,"text":"\" The walls","depth":8},{"id":43,"text":"we are building","depth":8},{"id":44,"text":"are not medieval walls .","depth":7},{"id":45,"text":"They are smart walls","depth":7},{"id":46,"text":"designed","depth":9},{"id":47,"text":"to meet the needs of front-line border agents","depth":9},{"id":48,"text":"and are operationally effective , \"","depth":8},{"id":49,"text":"he said ,","depth":6},{"id":50,"text":"describing a proposal","depth":8},{"id":51,"text":"that has essentially been Democrats ' demand","depth":8},{"id":52,"text":"- no concrete wall","depth":8},{"id":53,"text":"but rather a strategic investment in security .","depth":8},{"id":54,"text":"\" We do not need 2,000 miles of concrete wall from sea to shining sea ,","depth":6},{"id":55,"text":"we never did ,","depth":7},{"id":56,"text":"we never proposed that ,","depth":8},{"id":57,"text":"we never wanted that ,","depth":8},{"id":58,"text":"because we have barriers at the border","depth":8},{"id":59,"text":"where our natural structures are as good as anything","depth":9},{"id":60,"text":"we can build , \"","depth":9},{"id":61,"text":"he continued , somewhat mystifyingly - contradicting his own years-long position on the border wall .","depth":7},{"id":62,"text":"\" They ' re already there .","depth":7},{"id":63,"text":"They ' ve been there for millions of years . \"","depth":7},{"id":64,"text":"A pair of failed Senate votes this week were among the developments","depth":5},{"id":65,"text":"that helped move things along :","depth":5},{"id":66,"text":"They indicated","depth":6},{"id":67,"text":"that a proposal","depth":9},{"id":68,"text":"Trump unveiled last weekend ,","depth":9},{"id":69,"text":"which included a $ 5.7 billion demand for a border wall ,","depth":8},{"id":70,"text":"would not be able to make it through Congress ,","depth":7},{"id":71,"text":"and forced the administration to consider possible alternatives .","depth":5},{"id":72,"text":"Democrats have said","depth":5},{"id":73,"text":"they are open to discussions","depth":7},{"id":74,"text":"about increasing border security funding","depth":7},{"id":75,"text":"once the government is open ,","depth":6},{"id":76,"text":"though Pelosi has previously signaled","depth":5},{"id":77,"text":"she ' s not interested in giving Trump any money for a wall","depth":6},{"id":78,"text":"even after the shutdown has ended .","depth":6},{"id":79,"text":"Trump shut down the government in December","depth":3},{"id":80,"text":"because Congress did not approve funds for the border wall , one of his chief campaign promises .","depth":3},{"id":81,"text":"More than a month later , he ' s finally capitulated on a deal","depth":4},{"id":82,"text":"that doesn ' t guarantee wall funding at all ,","depth":4},{"id":83,"text":"a sign of just how little his decision","depth":5},{"id":84,"text":"to shut down the government","depth":5},{"id":85,"text":"ultimately accomplished .","depth":4}],"relations":[{"parent":171,"left":164,"right":170,"relation":"elaboration","nuclearity":"NS"},{"parent":164,"left":149,"right":163,"relation":"elaboration","nuclearity":"NS"},{"parent":149,"left":127,"right":148,"relation":"elaboration","nuclearity":"NS"},{"parent":127,"left":112,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":112,"left":100,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":98,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":98,"left":90,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":90,"left":89,"right":4,"relation":"attribution","nuclearity":"NS"},{"parent":89,"left":0,"right":88,"relation":"attribution","nuclearity":"SN"},{"parent":88,"left":1,"right":87,"relation":"purpose","nuclearity":"NS"},{"parent":87,"left":2,"right":3,"relation":"joint","nuclearity":"NN"},{"parent":97,"left":94,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":5,"right":93,"relation":"attribution","nuclearity":"SN"},{"parent":93,"left":91,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":92,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":96,"left":10,"right":95,"relation":"elaboration","nuclearity":"NS"},{"parent":95,"left":11,"right":12,"relation":"context","nuclearity":"NS"},{"parent":99,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":111,"left":15,"right":110,"relation":"organization","nuclearity":"SN"},{"parent":110,"left":103,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":103,"left":102,"right":19,"relation":"attribution","nuclearity":"NS"},{"parent":102,"left":101,"right":18,"relation":"adversative","nuclearity":"SN"},{"parent":101,"left":16,"right":17,"relation":"explanation","nuclearity":"SN"},{"parent":109,"left":20,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":108,"left":104,"right":107,"relation":"elaboration","n