ation":"elaboration","nuclearity":"NS"},{"parent":279,"left":55,"right":56,"relation":"attribution","nuclearity":"SN"},{"parent":286,"left":284,"right":285,"relation":"joint","nuclearity":"NN"},{"parent":284,"left":282,"right":283,"relation":"elaboration","nuclearity":"NS"},{"parent":282,"left":281,"right":59,"relation":"same-unit","nuclearity":"NN"},{"parent":281,"left":57,"right":58,"relation":"elaboration","nuclearity":"NS"},{"parent":283,"left":60,"right":61,"relation":"attribution","nuclearity":"NS"},{"parent":285,"left":62,"right":63,"relation":"causal","nuclearity":"NS"},{"parent":300,"left":294,"right":299,"relation":"joint","nuclearity":"NN"},{"parent":294,"left":65,"right":293,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":66,"right":292,"relation":"joint","nuclearity":"NN"},{"parent":292,"left":291,"right":69,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":67,"right":68,"relation":"joint","nuclearity":"NN"},{"parent":299,"left":70,"right":298,"relation":"same-unit","nuclearity":"NN"},{"parent":298,"left":295,"right":297,"relation":"context","nuclearity":"SN"},{"parent":295,"left":71,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":296,"right":75,"relation":"same-unit","nuclearity":"NN"},{"parent":296,"left":73,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":302,"right":305,"relation":"organization","nuclearity":"SN"},{"parent":302,"left":76,"right":77,"relation":"organization","nuclearity":"SN"},{"parent":305,"left":304,"right":81,"relation":"explanation","nuclearity":"NS"},{"parent":304,"left":78,"right":303,"relation":"organization","nuclearity":"SN"},{"parent":303,"left":79,"right":80,"relation":"organization","nuclearity":"SN"},{"parent":330,"left":318,"right":329,"relation":"adversative","nuclearity":"NN"},{"parent":318,"left":312,"right":317,"relation":"joint","nuclearity":"NN"},{"parent":312,"left":309,"right":311,"relation":"explanation","nuclearity":"NS"},{"parent