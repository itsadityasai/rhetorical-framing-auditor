n":"elaboration","nuclearity":"NS"},{"parent":320,"left":309,"right":319,"relation":"joint","nuclearity":"NN"},{"parent":309,"left":301,"right":308,"relation":"joint","nuclearity":"NN"},{"parent":301,"left":293,"right":300,"relation":"attribution","nuclearity":"SN"},{"parent":293,"left":292,"right":126,"relation":"same-unit","nuclearity":"NN"},{"parent":292,"left":123,"right":291,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":124,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":300,"left":299,"right":134,"relation":"attribution","nuclearity":"NS"},{"parent":299,"left":127,"right":298,"relation":"joint","nuclearity":"NN"},{"parent":298,"left":294,"right":297,"relation":"explanation","nuclearity":"NS"},{"parent":294,"left":128,"right":129,"relation":"attribution","nuclearity":"SN"},{"parent":297,"left":296,"right":133,"relation":"explanation","nuclearity":"SN"},{"parent":296,"left":130,"right":295,"relation":"attribution","nuclearity":"SN"},{"parent":295,"left":131,"right":132,"relation":"context","nuclearity":"NS"},{"parent":308,"left":303,"right":307,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":135,"right":302,"relation":"attribution","nuclearity":"SN"},{"parent":302,"left":136,"right":137,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":305,"right":306,"relation":"attribution","nuclearity":"NS"},{"parent":305,"left":138,"right":304,"relation":"restatement","nuclearity":"NN"},{"parent":304,"left":139,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":141,"right":142,"relation":"elaboration","nuclearity":"NS"},{"parent":319,"left":311,"right":318,"relation":"elaboration","nuclearity":"NS"},{"parent":311,"left":143,"right":310,"relation":"attribution","nuclearity":"SN"},{"parent":310,"left":144,"right":145,"relation":"joint","nuclearity":"NN"},{"parent":318,"left":314,"right":317,"relation":"adversative","nuclearity":"NN"},{"parent":314,"left":313,"right":149,"relation":"attribution","nuclearity":"NS"},{"parent":313,"left":146,"right":312,"relation":"attribution","nuclearity":"SN"},{"parent":312,"left":147,"right":148,"relation":"purpose","nuclearity":"NS"},{"parent":317,"left":150,"right":316,"relation":"attribution","nuclearity":"NS"},{"parent":316,"left":151,"right":315,"relation":"elaboration","nuclearity":"NS"},{"parent":315,"left":152,"right":153,"relation":"attribution","nuclearity":"SN"},{"parent":334,"left":330,"right":333,"relation":"elaboration","nuclearity":"NS"},{"parent":330,"left":329,"right":164,"relation":"joint","nuclearity":"NN"},{"parent":329,"left":321,"right":328,"relation":"elaboration","nuclearity":"NS"},{"parent":321,"left":154,"right":155,"relation":"mode","nuclearity":"NS"},{"parent":328,"left":325,"right":327,"relation":"elaboration","nuclearity":"NS"},{"parent":325,"left":156,"right":324,"relation":"attribution","nuclearity":"SN"},{"parent":324,"left":323,"right":160,"relation":"explanation","nuclearity":"SN"},{"parent":323,"left":157,"right":322,"relation":"evaluation","nuclearity":"SN"},{"parent":322,"left":158,"right":159,"relation":"adversative","nuclearity":"NN"},{"parent":327,"left":161,"right":326,"relation":"attribution","nuclearity":"SN"},{"parent":326,"left":162,"right":163,"relation":"context","nuclearity":"NS"},{"parent":333,"left":165,"right":332,"relation":"organization","nuclearity":"SN"},{"parent":332,"left":166,"right":331,"relation":"purpose","nuclearity":"NS"},{"parent":331,"left":167,"right":168,"relation":"attribution","nuclearity":"SN"}]}