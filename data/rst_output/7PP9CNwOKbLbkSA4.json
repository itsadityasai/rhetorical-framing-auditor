,"left":76,"right":77,"relation":"joint","nuclearity":"NN"},{"parent":292,"left":291,"right":83,"relation":"attribution","nuclearity":"NS"},{"parent":291,"left":79,"right":290,"relation":"adversative","nuclearity":"NN"},{"parent":290,"left":80,"right":289,"relation":"causal","nuclearity":"NS"},{"parent":289,"left":81,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":298,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":297,"right":88,"relation":"attribution","nuclearity":"SN"},{"parent":297,"left":296,"right":87,"relation":"same-unit","nuclearity":"NN"},{"parent":296,"left":85,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":300,"right":302,"relation":"adversative","nuclearity":"NN"},{"parent":300,"left":299,"right":91,"relation":"attribution","nuclearity":"NS"},{"parent":299,"left":89,"right":90,"relation":"attribution","nuclearity":"SN"},{"parent":302,"left":92,"right":301,"relation":"same-unit","nuclearity":"NN"},{"parent":301,"left":93,"right":94,"relation":"context","nuclearity":"SN"},{"parent":419,"left":309,"right":418,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":95,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":418,"left":318,"right":417,"relation":"joint","nuclearity":"NN"},{"parent":318,"left":317,"right":106,"relation":"context","nuclearity":"NS"},{"parent":317,"left":316,"right":105,"relation":"context","nuclearity":"NS"},{"parent":316,"left":313,"right":315,"relation":"joint","nuclearity":"NN"},{"parent":313,"left":97,"right":312,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":98,"right":311,"relation":"purpose","nuclearity":"NS"},{"parent":311,"left":99,"right":310,"relation":"attribution","nuclearity":"SN"},{"parent":310,"left":100,"right":101,"relation":"elaboration","nuclearity":"NS"},{"parent":315,"left":102,"right":314,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":103,"right":104,"relation":"purp