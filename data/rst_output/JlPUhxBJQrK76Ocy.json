","nuclearity":"SN"},{"parent":255,"left":40,"right":41,"relation":"attribution","nuclearity":"SN"},{"parent":267,"left":262,"right":266,"relation":"joint","nuclearity":"NN"},{"parent":262,"left":259,"right":261,"relation":"elaboration","nuclearity":"NS"},{"parent":259,"left":43,"right":44,"relation":"organization","nuclearity":"SN"},{"parent":261,"left":45,"right":260,"relation":"elaboration","nuclearity":"NS"},{"parent":260,"left":46,"right":47,"relation":"context","nuclearity":"NS"},{"parent":266,"left":263,"right":265,"relation":"organization","nuclearity":"SN"},{"parent":263,"left":48,"right":49,"relation":"organization","nuclearity":"SN"},{"parent":265,"left":50,"right":264,"relation":"elaboration","nuclearity":"NS"},{"parent":264,"left":51,"right":52,"relation":"elaboration","nuclearity":"NS"},{"parent":435,"left":347,"right":434,"relation":"elaboration","nuclearity":"NS"},{"parent":347,"left":305,"right":346,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":290,"right":304,"relation":"joint","nuclearity":"NN"},{"parent":290,"left":276,"right":289,"relation":"elaboration","nuclearity":"NS"},{"parent":276,"left":273,"right":275,"relation":"elaboration","nuclearity":"NS"},{"parent":273,"left":53,"right":272,"relation":"attribution","nuclearity":"SN"},{"parent":272,"left":54,"right":271,"relation":"mode","nuclearity":"NS"},{"parent":271,"left":55,"right":56,"relation":"elaboration","nuclearity":"NS"},{"parent":275,"left":57,"right":274,"relation":"joint","nuclearity":"NN"},{"parent":274,"left":58,"right":59,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":283,"right":288,"relation":"joint","nuclearity":"NN"},{"parent":283,"left":279,"right":282,"relation":"elaboration","nuclearity":"NS"},{"parent":279,"left":278,"right":63,"relation":"attribution","nuclearity":"NS"},{"parent":278,"left":60,"right":277,"relation":"attribution","nuclearity":"SN"},{"parent":277,"left":61,"right":62,"relation":"condition","nuclearity":"NS"},{"parent":2