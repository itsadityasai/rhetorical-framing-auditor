{"article_id":"eMo2WJpIHZPnV4fe","edus":[{"id":0,"text":"President Barack Obama opposes the mandatory quarantine of health workers","depth":7},{"id":1,"text":"returning from treating Ebola patients in Africa","depth":7},{"id":2,"text":"that was announced Friday by Andrew Cuomo and Chris Christie ,","depth":6},{"id":3,"text":"but the governors of New York and New Jersey took matters into their own hands","depth":8},{"id":4,"text":"because the federal government has proved itself incompetent ,","depth":8},{"id":5,"text":"The Wall Street Journal said in an editorial.","depth":7},{"id":6,"text":"Cuomo , the New York governor , has reportedly reversed himself under White House pressure .","depth":6},{"id":7,"text":"Nurse Kaci Hickox remains in New Jersey quarantine","depth":6},{"id":8,"text":"- under protest -","depth":6},{"id":9,"text":"having returned from treating Ebola patients in Sierra Leone.","depth":5},{"id":10,"text":"Illinois has put in place its own 21-day quarantine .","depth":4},{"id":11,"text":"Florida is insisting","depth":6},{"id":12,"text":"returnees from West African countries in Ebola 's path be monitored twice daily.","depth":6},{"id":13,"text":"The 21-day quarantine could well dissuade some medical personnel from volunteering in West Africa","depth":7},{"id":14,"text":"as the administration and the National Institutes of Health 's Anthony Fauci have argued .","depth":7},{"id":15,"text":"Yet the foremost responsibility of elected officials is to their own constituents ,","depth":7},{"id":16,"text":"the Journal writes.","depth":7},{"id":17,"text":"The patchwork of state decisions comes","depth":4},{"id":18,"text":"after physician Craig Spencer tested positive for Ebola","depth":5},{"id":19,"text":"upon returning to New York City","depth":6},{"id":20,"text":"from treating patients in Africa .","depth":6},{"id":21,"text":"The day before he developed a fever ,","depth":6},{"id":22,"text":"though he felt fatigued ,","depth":6},{"id":23,"text":"Spencer traveled on the subway","depth":7},{"id":24,"text":"to go bowling","depth":7},{"id":25,"text":"- notwithstanding the city 's and CDC 's self-quarantine guidelines.","depth":6},{"id":26,"text":"While it 's unlikely Spencer put anyone","depth":9},{"id":27,"text":"he came into contact with","depth":9},{"id":28,"text":"in jeopardy ,","depth":8},{"id":29,"text":"`` you ca n't blame politicians","depth":9},{"id":30,"text":"for wanting to reduce the risks ''","depth":9},{"id":31,"text":"given the panic and economic harm","depth":9},{"id":32,"text":"that could result","depth":10},{"id":33,"text":"were anyone to catch Ebola on the subway ,","depth":10},{"id":34,"text":"according to the Journal . `` The real problem is that the CDC , the World Health Organization , the Health and Human Services Department and the White House have all given ample reason","depth":7},{"id":35,"text":"not to trust their assurances .","depth":7},{"id":36,"text":"They said","depth":8},{"id":37,"text":"the chance of an Ebola case in the U.S. was remote .","depth":8},{"id":38,"text":"They said","depth":9},{"id":39,"text":"airport screeners would catch anyone sick","depth":10},{"id":40,"text":"trying to enter .","depth":10},{"id":41,"text":"They said","depth":10},{"id":42,"text":"U.S. hospitals were prepared for such cases ,","depth":11},{"id":43,"text":"and that doctors and nurses would be protected .","depth":11},{"id":44,"text":"And they said","depth":10},{"id":45,"text":"self-quarantines would prevent new cases , ''","depth":10},{"id":46,"text":"the Journal wrote.","depth":6},{"id":47,"text":"Meanwhile , NBC News reported","depth":2},{"id":48,"text":"that New York City health officials corrected themselves","depth":3},{"id":49,"text":"to say","depth":4},{"id":50,"text":"that Spencer 's temperature","depth":7},{"id":51,"text":"when brought to the hospital","depth":7},{"id":52,"text":"was 100.3 degrees ,","depth":6},{"id":53,"text":"not 103 degree","depth":6},{"id":54,"text":"as first reported .","depth":6}],"relations":[{"parent":109,"left":101,"right":108,"relation":"context","nuclearity":"NS"},{"parent":101,"left":71,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":64,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":61,"right":63,"relation":"elaboration","nuclearity":"NS"},{"parent":61,"left":57,"right":60,"relation":"adversative","nuclearity":"NN"},{"parent":57,"left":56,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":56,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":59,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":59,"left":58,"right":5,"relation":"attribution","nuclearity":"NS"},{"parent":58,"left":3,"right":4,"relation":"causal","nuclearity":"NS"},{"parent":63,"left":62,"right":9,"relation":"context","nuclearity":"NS"},{"parent":62,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":10,"right":69,"relation":"joint","nuclearity":"NN"},{"parent":69,"left":65,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":11,"right":12,"relation":"attribution","nuclearity":"SN"},{"parent":68,"left":66,"right":67,"relation":"adversative","nuclearity":"NN"},{"parent":66,"left":13,"right":14,"relation":"attribution","nuclearity":"NS"},{"parent":67,"left":15,"right":16,"relation":"attribution","nuclearity":"NS"},{"parent":100,"left":74,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":17,"right":73,"relation":"context","nuclearity":"NS"},{"parent":73,"left":18,"right":72,"relation":"context","nuclearity":"NS"},{"parent":72,"left":19,"right":20,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":78,"right":98,"relation":"evaluation","nuclearity":"NS"},{"parent":78,"left":75,"right":77,"relation":"adversative","nuclearity":"SN"},{"parent":75,"left":21,"right":22,"relation":"adversative","nuclearity":"NS"},{"parent":77,"left":76,"right":25,"relation":"adversative","nuc