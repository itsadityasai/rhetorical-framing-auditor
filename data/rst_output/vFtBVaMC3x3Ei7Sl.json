{"article_id":"vFtBVaMC3x3Ei7Sl","edus":[{"id":0,"text":"Republicans have argued","depth":3},{"id":1,"text":"that transferring federal employee health benefit to health care exchanges is a special exemption for Congress .","depth":3},{"id":2,"text":"Government plans to give subsidies for Congress","depth":3},{"id":3,"text":"to buy insurance on exchanges","depth":3},{"id":4,"text":"WAS","depth":2},{"id":5,"text":"INGTON -","depth":3},{"id":6,"text":"en. Ron Johnson , R-Wis. , filed a lawsuit Monday","depth":9},{"id":7,"text":"hallenging the Obama administration 's decision","depth":10},{"id":8,"text":"o provide health insurance subsidies to members of Congress and their staff .","depth":10},{"id":9,"text":"he senator said","depth":9},{"id":10,"text":"e believes","depth":10},{"id":11,"text":"he decision gives lawmakers special","depth":12},{"id":12,"text":"and illegal -","depth":12},{"id":13,"text":"reatment .","depth":11},{"id":14,"text":"nder the Affordable Care Act","depth":11},{"id":15,"text":"widely known as Obamacare -","depth":11},{"id":16,"text":"embers of Congress and their employees were kicked off their federal health plan","depth":11},{"id":17,"text":"nd forced to buy insurance through an exchange .","depth":11},{"id":18,"text":"he federal Office of Personnel Management issued a rule last September","depth":10},{"id":19,"text":"aking clear","depth":11},{"id":20,"text":"hat the federal government would continue to pay the employer contribution for congressional health benefits at the same rate","depth":12},{"id":21,"text":"s if members and their staff were still on the federal employee health plan .","depth":12},{"id":22,"text":"ome lawmakers have argued","depth":11},{"id":23,"text":"hat this amounts to a federal subsidy","depth":12},{"id":24,"text":"o pay for coverage","depth":13},{"id":25,"text":"hat other Americans are not entitled to .","depth":13},{"id":26,"text":"nly Americans","depth":13},{"id":27,"text":"ho make less than about $ 45,000 annually","depth":13},{"id":28,"text":"ualify for federal subsidies .","depth":12},{"id":29,"text":"embers of Congress are paid $ 175,000 per year .","depth":11},{"id":30,"text":"` That 's completely unfair , completely unjust , ''","depth":10},{"id":31,"text":"ohnson said at a press conference at the U.S. Capitol .","depth":10},{"id":32,"text":"is lawyers in the case are Paul Clement , a former solicitor general under George W. Bush , and Rick Esenberg , founder and president of the Wisconsin Institute for Law & Liberty .","depth":6},{"id":33,"text":"he issue may seem petty to some outside the Beltway","depth":10},{"id":34,"text":"liberal critics assailed Johnson","depth":12},{"id":35,"text":"hen he first talked about suing in October ,","depth":12},{"id":36,"text":"aying","depth":12},{"id":37,"text":"e was trying to deprive his own staff members of health insurance benefits .","depth":12},{"id":38,"text":"ut to the senator , the case is about more than the subsidies .","depth":9},{"id":39,"text":"e said","depth":10},{"id":40,"text":"t 's about reining in what he calls presidential overreach .","depth":10},{"id":41,"text":"` This is ,","depth":11},{"id":42,"text":"think ,","depth":12},{"id":43,"text":"very important constitutional question , ''","depth":12},{"id":44,"text":"aid Johnson ,","depth":11},{"id":45,"text":"ho is funding the suit through his campaign committee .","depth":11},{"id":46,"text":"he subsidies for lawmakers and staff were not spelled out in the law itself ,","depth":9},{"id":47,"text":"nd Johnson said","depth":10},{"id":48,"text":"e believes","depth":11},{"id":49,"text":"t violates the law .","depth":11},{"id":50,"text":"` This lawsuit is about enforcing that law , ''","depth":9},{"id":51,"text":"ohnson said .","depth":9},{"id":52,"text":"PM officials said","depth":11},{"id":53,"text":"hen they issued the rule","depth":11},{"id":54,"text":"hat the agency has the authority","depth":12},{"id":55,"text":"o administer employee health benefits","depth":12},{"id":56,"text":"ecause members of Congress and their staff are still federal employees .","depth":11},{"id":57,"text":"` It is within OPM 's interpretive authority . . . to clarify","depth":10},{"id":58,"text":"hat a Government contribution may be provided to ,","depth":11},{"id":59,"text":"nd to establish the means for a Government contribution towards health benefits for , Members of Congress and congressional staff ,","depth":12},{"id":60,"text":"ust as we do for other Federal employees . ''","depth":12},{"id":61,"text":"n order for the case to proceed ,","depth":11},{"id":62,"text":"ohnson will have to prove","depth":12},{"id":63,"text":"e has been harmed by the OPM ruling ,","depth":12},{"id":64,"text":"e said ,","depth":10},{"id":65,"text":"iving him grounds","depth":10},{"id":66,"text":"o sue .","depth":10},{"id":67,"text":"e alleges in the complaint","depth":10},{"id":68,"text":"iled Monday in U.S. District Court in Green Bay , Wis. ,","depth":10},{"id":69,"text":"hat he and other members of Congress are dealing with an undue administrative burden","depth":10},{"id":70,"text":"ecause they must designate which members of their staff are subject to the change .","depth":10},{"id":71,"text":"n addition , the complaint argues","depth":9},{"id":72,"text":"hat the OPM ruling is forcing him to participate in something","depth":10},{"id":73,"text":"hat he believes","depth":11},{"id":74,"text":"s illegal .","depth":11},{"id":75,"text":"ot all of his GOP colleagues are on board with Johnson 's Obamacare suit .","depth":6},{"id":76,"text":"ellow Wisconsin Republican Rep. James Sensenbrenner on Sunday called the lawsuit an `` unfortunate political stunt . '","depth":8},{"id":77,"text":"`` Senator Johnson should spend his time legislating","depth":11},{"id":78,"text":"ather than litigating","depth":11},{"id":79,"text":"s our country is facing big problems","depth":11},{"id":80,"text":"hat must be addressed by Congress","depth":12},{"id":81,"text":"not the courts , ''","depth":12},{"id":82,"text":"ensenbrenner said .","depth":9},{"id":83,"text":"` All Republicans want to repeal Obamacare ,","depth":9},{"id":84,"text":"ut this politically motivated lawsuit only takes public attention away from how bad all of Obamacare really is","depth":10},{"id":85,"text":"nd focuses it on a trivial issue .","depth":10},{"id":86,"text":"ortunately , Senator Johnson 's suit is likely frivolous","depth":9},{"id":87,"text":"nd will not achieve the result","depth":10},{"id":88,"text":"e 's seeking . ''","depth":10},{"id":89,"text":"ohnson on Monday said","depth":6},{"id":90,"text":"e was `` disappointed '' and `` a little confused '' by Sensenbrenner 's reaction ,","depth":7},{"id":91,"text":"ut he said","depth":8},{"id":92,"text":"e 's moving forward regardless .","depth":8}],"relations":[{"parent":185,"left":96,"right":184,"relation":"organization","nuclearity":"SN"},{"parent":96,"left":94,"right":95,"relation":"context","nuclearity":"SN"},{"parent":94,"left":0,"right":1,"relation":"attribution","nuclearity":"SN"},{"parent":95,"left":2,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":184,"left":4,"right":183,"relation":"organization","nuclearity":"SN"},{"parent":183,"left":5,"right":182,"relation":"organization","nuclearity":"SN"},{"parent":182,"left":164,"right":181,"relation":"elaboration","nuclearity":"NS"},{"parent":164,"left":122,"right":163,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":121,"right":32,"relation":"elaboration","nuclearity":"NS"},{"parent":121,"left":103,"right":120,"relation":"elaboration","nuclearity":"NS"},{"parent":103,"left":98,"right":102,"relation":"elaboration","nuclearity":"NS"},{"parent":98,"left":6,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":97,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":9,"right":101,"relation":"attribution","nuclearity":"SN"},{"parent":101,"left":10,"right":100,"relation":"attribution","nuclearity":"SN"},{"parent":1