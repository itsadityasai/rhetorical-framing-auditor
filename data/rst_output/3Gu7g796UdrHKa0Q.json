{"article_id":"3Gu7g796UdrHKa0Q","edus":[{"id":0,"text":"Yesterday , Georgia Governor Brian Kemp issued an Executive Order","depth":8},{"id":1,"text":"striking down mask requirements in at least fifteen local jurisdictions .","depth":8},{"id":2,"text":"While the governor has encouraged Georgians to mask up","depth":9},{"id":3,"text":"to prevent the spread of coronavirus ,","depth":9},{"id":4,"text":"he has called mandates \" a bridge too far. \"","depth":8},{"id":5,"text":"So","depth":8},{"id":6,"text":"despite growing evidence","depth":10},{"id":7,"text":"that masks work ,","depth":10},{"id":8,"text":"and Kemp ' s own exhortation","depth":10},{"id":9,"text":"that people should mask up","depth":11},{"id":10,"text":"if they want to watch college football this fall ,","depth":11},{"id":11,"text":"the newest order explicitly makes them optional .","depth":7},{"id":12,"text":"[ A ] ny state , county , or municipal law , order , ordinance , rule , or regulation","depth":8},{"id":13,"text":"that requires persons to wear face coverings , masks , face shields , or any other Personal Protective Equipment while in places of public accommodation or on public property","depth":8},{"id":14,"text":"are suspended to the extent","depth":8},{"id":15,"text":"that they are more restrictive than this Executive Order .","depth":8},{"id":16,"text":"The ordinance also caps indoor gatherings at fifty persons","depth":8},{"id":17,"text":"and suspends the requirement","depth":9},{"id":18,"text":"that Georgians renew their gun permits during the pandemic .","depth":9},{"id":19,"text":"So","depth":8},{"id":20,"text":"if anyone needs to shoot a virus ,","depth":9},{"id":21,"text":"they ' ll be able to do it .","depth":9},{"id":22,"text":"Phew !","depth":4},{"id":23,"text":"Next door in Alabama , Republican Governor Kay Ivey instituted a mask mandate yesterday .","depth":5},{"id":24,"text":"Mississippi ' s governor Tate Reeves tweeted a long thread on dangers of a herd immunity approach ,","depth":6},{"id":25,"text":"encouraging his constituents to wear masks ,","depth":7},{"id":26,"text":"and allowing municipalities to enact their own mask regulations .","depth":7},{"id":27,"text":"But in Georgia , this abridgment of personal liberty will not stand !","depth":6},{"id":28,"text":"Savannah Mayor Van Johnson ,","depth":8},{"id":29,"text":"who was gearing up to enforce his city ' s mask ordinance with warnings and fines ,","depth":8},{"id":30,"text":"was outraged .","depth":7},{"id":31,"text":"It is officially official .","depth":6},{"id":32,"text":"Governor Kemp does not give a damn about us .","depth":8},{"id":33,"text":"Every man and woman for himself/herself .","depth":9},{"id":34,"text":"Ignore the science","depth":10},{"id":35,"text":"and survive","depth":12},{"id":36,"text":"the best","depth":12},{"id":37,"text":"you can .","depth":11},{"id":38,"text":"In # Savannah , we will continue to keep the faith","depth":10},{"id":39,"text":"and follow the science .","depth":10},{"id":40,"text":"Masks will continue to be available !","depth":9},{"id":41,"text":"- Mayor Van Johnson","depth":10},{"id":42,"text":"( @ MayorJohnsonSAV )","depth":10},{"id":43,"text":"July 16 , 2020","depth":9},{"id":44,"text":"\" We ' ve been clear in previous orders and statements","depth":6},{"id":45,"text":"that local mask mandates are unenforceable , \"","depth":6},{"id":46,"text":"Kemp spokeswoman Candice Broce told the Savannah Morning News yesterday ,","depth":6},{"id":47,"text":"when the state reported 3,871 new COVID infections .","depth":6},{"id":48,"text":"\" The Governor has encouraged Georgians to wear them voluntarily for months now . \"","depth":4},{"id":49,"text":"Because Brian Kemp really wants to protect his constituents ' health","depth":5},{"id":50,"text":"and stop this pandemic in its tracks .","depth":5},{"id":51,"text":"Just not enough","depth":5},{"id":52,"text":"to actually do anything at all about it .","depth":5},{"id":53,"text":"Elizabeth Dye","depth":3},{"id":54,"text":"( @ 5DollarFeminist )","depth":3},{"id":55,"text":"lives in Baltimore","depth":3},{"id":56,"text":"where she writes about law and politics .","depth":3}],"relations":[{"parent":113,"left":109,"right":112,"relation":"context","nuclearity":"NS"},{"parent":109,"left":100,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":79,"right":99,"relation":"joint","nuclearity":"NN"},{"parent":79,"left":78,"right":22,"relation":"evaluation","nuclearity":"NS"},{"parent":78,"left":68,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":61,"right":67,"relation":"elaboration","nuclearity":"NS"},{"parent":61,"left":58,"right":60,"relation":"explanation","nuclearity":"NS"},{"parent":58,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":59,"right":4,"relation":"adversative","nuclearity":"SN"},{"parent":59,"left":2,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":67,"left":66,"right":11,"relation":"same-unit","nuclearity":"NN"},{"parent":66,"left":5,"right":65,"relation":"same-unit","nuclearity":"NN"},{"parent":65,"left":62,"right":64,"relation":"same-unit","nuclearity":"NN"},{"parent":62,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":8,"right":63,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":9,"right":10,"relation":"condition","nuclearity":"NS"},{"parent":77,"left":71,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":69,"right":70,"relation":"same-unit","nuclearity":"NN"},{"parent":69,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":14,"right":15,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":73,"right":75,"relation":"causal","nuclearity":"NS"},{"parent":73,"left":16,"right":72,"relation":"joint","nuclearity":"NN"},{"parent":72,"left":17,"right":18,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":19,"right":74,"relation":"same-unit","nucle