{"article_id":"WiTLbfyrN0QfqfZp","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"Supreme Court nominee Brett Kavanaugh spoke to Fox News in an interview","depth":5},{"id":2,"text":"aired Monday night on `` The Story with Martha MacCallum , ''","depth":5},{"id":3,"text":"following allegations of sexual misconduct by two women .","depth":4},{"id":4,"text":"Sitting next to his wife , Ashley Estes Kavanaugh ,","depth":6},{"id":5,"text":"the nominee flatly refuted the accusations","depth":6},{"id":6,"text":"as he sought to defend himself","depth":5},{"id":7,"text":"days before the Senate Judiciary Committee is scheduled to have another hearing on his confirmation .","depth":4},{"id":8,"text":"President Donald Trump nominated Kavanaugh in July","depth":7},{"id":9,"text":"to succeed Justice Anthony Kennedy on the high court .","depth":7},{"id":10,"text":"That vote on Kavanaugh 's nomination has been pushed back","depth":10},{"id":11,"text":"so he can answer allegations","depth":11},{"id":12,"text":"leveled by one of his accusers :","depth":12},{"id":13,"text":"psychology researcher and Palo Alto University professor Christine Blasey Ford .","depth":12},{"id":14,"text":"She alleges","depth":10},{"id":15,"text":"that ,","depth":12},{"id":16,"text":"while both were in high school ,","depth":12},{"id":17,"text":"Kavanaugh held her down ,","depth":12},{"id":18,"text":"put his hand over her mouth","depth":14},{"id":19,"text":"to silence her ,","depth":14},{"id":20,"text":"and tried to remove her clothes .","depth":13},{"id":21,"text":"A second woman , Deborah Ramirez , a Yale University classmate of Kavanaugh 's , claims","depth":10},{"id":22,"text":"that he exposed himself to her","depth":11},{"id":23,"text":"and shoved his penis in her face at a dorm room party in their freshman year at the Ivy League school .","depth":11},{"id":24,"text":"She said","depth":11},{"id":25,"text":"they were playing a drinking game at the time","depth":11},{"id":26,"text":"and admits","depth":11},{"id":27,"text":"there are gaps in her memory of that night .","depth":11},{"id":28,"text":"The judge said","depth":8},{"id":29,"text":"he never had sexual intercourse `` or anything close to ( it ) ''","depth":9},{"id":30,"text":"until long after he left Georgetown Prep , the elite all-boys Catholic high school","depth":10},{"id":31,"text":"he attended in Rockville , Maryland .","depth":10},{"id":32,"text":"\" So you ' re saying through all these years","depth":10},{"id":33,"text":"that are in question","depth":10},{"id":34,"text":"that you were a virgin ? \"","depth":9},{"id":35,"text":"MacCallum asked Kavanaugh .","depth":8},{"id":36,"text":"She pressed on :","depth":10},{"id":37,"text":"\" And through what years in college ,","depth":11},{"id":38,"text":"since we ' re probing into your personal life here ? \"","depth":11},{"id":39,"text":"\" Many years after , I ' ll leave it at that , ''","depth":11},{"id":40,"text":"he answered .","depth":11},{"id":41,"text":"`` Many years after . ''","depth":10},{"id":42,"text":"\" The truth is I ' ve never sexually assaulted anyone , in high school or otherwise .","depth":9},{"id":43,"text":"I am not questioning","depth":13},{"id":44,"text":"and have not questioned","depth":13},{"id":45,"text":"that perhaps Dr. Ford at some point in her life was sexually assaulted by someone at some place ,","depth":12},{"id":46,"text":"but what I know is I ' ve never sexually assaulted anyone , \"","depth":11},{"id":47,"text":"Kavanaugh said .","depth":10},{"id":48,"text":"He went further","depth":8},{"id":49,"text":"by saying","depth":9},{"id":50,"text":"he was n't even in the same place","depth":11},{"id":51,"text":"where Ford was","depth":11},{"id":52,"text":"when the alleged assault took place .","depth":10},{"id":53,"text":"\" I was never at any such party , ''","depth":9},{"id":54,"text":"he told MacCallum .","depth":9},{"id":55,"text":"`` The other people","depth":12},{"id":56,"text":"who alleged to be present","depth":12},{"id":57,"text":"have said","depth":11},{"id":58,"text":"they do not remember any such party .","depth":10},{"id":59,"text":"A woman","depth":12},{"id":60,"text":"who was present ,","depth":12},{"id":61,"text":"another woman","depth":14},{"id":62,"text":"who was present","depth":14},{"id":63,"text":"who was Dr. Ford ' s lifelong friend","depth":13},{"id":64,"text":"has said","depth":12},{"id":65,"text":"she doesn ' t know me","depth":11},{"id":66,"text":"and never remembers","depth":12},{"id":67,"text":"being at a party with me at any time in her life . \"","depth":12},{"id":68,"text":"Kavanaugh appears resolute about his desire","depth":6},{"id":69,"text":"to be confirmed to the nation 's highest court .","depth":6},{"id":70,"text":"\" I ' m not going to let false accusations drive us out of this process","depth":6},{"id":71,"text":"and we ' re looking for a fair process","depth":8},{"id":72,"text":"where I can be heard","depth":9},{"id":73,"text":"and defend my integrity , my lifelong record , ''","depth":9},{"id":74,"text":"Kavanaugh said .","depth":8},{"id":75,"text":"`` My lifelong record","depth":11},{"id":76,"text":"of promoting dignity and equality for women","depth":11},{"id":77,"text":"starting with the women","depth":12},{"id":78,"text":"who knew me","depth":13},{"id":79,"text":"when I was 14 years old , ''","depth":13},{"id":80,"text":"he continued .","depth":11},{"id":81,"text":"`` I ' m not going anywhere . \"","depth":9},{"id":82,"text":"So far , Trump is standing by his pick .","depth":5},{"id":83,"text":"He told reporters during an appearance at the United Nations General Assembly in New York","depth":6},{"id":84,"text":"that Kavanaugh `` is an absolutely outstanding person .","depth":7},{"id":85,"text":"Hopefully he will be confirmed quickly . ''","depth":7},{"id":86,"text":"Ashley Kavanaugh sat next to her husband","depth":9},{"id":87,"text":"as he forcefully defended himself .","depth":9},{"id":88,"text":"Often nodding in agreement","depth":10},{"id":89,"text":"as the judge spoke ,","depth":10},{"id":90,"text":"Ashley Kavanaugh said","depth":10},{"id":91,"text":"she 's known him for 17 years","depth":11},{"id":92,"text":"and described him as `` decent ... kind ... and good ''","depth":12},{"id":93,"text":"as she defended him .","depth":12},{"id":94,"text":"`` It 's been very difficult to have these conversations with your children , ''","depth":10},{"id":95,"text":"she told MacCallum .","depth":10},{"id":96,"text":"`` But they know Brett","depth":10},{"id":97,"text":"and they know the truth .","depth":10},{"id":98,"text":"And we told them from the very beginning of this process","depth":11},{"id":99,"text":"this will be not fun sometimes .","depth":11},{"id":100,"text":"You 're going to hear things .","depth":11},{"id":101,"text":"People feel strongly","depth":12},{"id":102,"text":"and you need to know that .","depth":12},{"id":103,"text":"Just remember","depth":10},{"id":104,"text":"you know your dad . ''","depth":10},{"id":105,"text":"Ashley Kavanaugh was the personal secretary to President George W. Bush","depth":8},{"id":106,"text":"when Brett Kavanaugh worked in the White House .","depth":8},{"id":107,"text":"His first date with his future bride was Sept. 10 , 2001 .","depth":8},{"id":108,"text":"The next morning , they were among those","depth":9},{"id":109,"text":"whisked out of the White House during the 9/11 attacks .","depth":9},{"id":110,"text":"Kavanaugh chose Fox News for his only interview","depth":10},{"id":111,"text":"- so far -","depth":10},{"id":112,"text":"to refute the allegations .","depth":9},{"id":113,"text":"MacCallum ,","depth":10},{"id":114,"text":"who joined Fox News Channel in 2004 ,","depth":10},{"id":115,"text":"is one of the more prominent personalities on a network","depth":10},{"id":116,"text":"that features Sean Hannity , Geraldo Rivera and Brit Hume .","depth":10},{"id":117,"text":"MacCallum pointedly asked Kavanaugh to address :","depth":8},{"id":118,"text":"the specific allegations","depth":10},{"id":119,"text":"( he repeatedly refuted them ) ;","depth":10},{"id":120,"text":"whether he had ever blacked out","depth":12},{"id":121,"text":"from drinking too much in high school","depth":12},{"id":122,"text":"( he said","depth":12},{"id":123,"text":"that never happened ) ;","depth":12},{"id":124,"text":"and whether similar allegations by someone in high school should count against them later in life","depth":11},{"id":125,"text":"( `` I think","depth":13},{"id":126,"text":"everyone 's judged on their whole life , ''","depth":13},{"id":127,"text":"he responded . )","depth":12},{"id":128,"text":"Shaunna Thomas , executive director of UltraViolet Action , a progressive groups","depth":11},{"id":129,"text":"that opposes Kavanaugh 's confirmation ,","depth":11},{"id":130,"text":"criticized the judge","depth":10},{"id":131,"text":"for choosing the `` comfort of a partisan network ''","depth":10},{"id":132,"text":"to air his denials .","depth":10},{"id":133,"text":"\" If Kavanaugh really wanted to get to the truth ,","depth":10},{"id":134,"text":"he ' d go to the FBI , not Fox News , ''","depth":10},{"id":135,"text":"she said .","depth":9},{"id":136,"text":"`` This was the move of a political hack , not a nominee to the Supreme Court . ''","depth":7}],"relations":[{"parent":273,"left":0,"right":272,"relation":"organization","nuclearity":"SN"},{"parent":272,"left":143,"right":271,"relation":"elaboration","nuclearity":"NS"},{"parent":143,"left":139,"right":142,"relation":"context","nuclearity":"NS"},{"parent":139,"left":138,"right":3,"relation":"context","nuclearity":"NS"},{"parent":138,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":142,"left":141,"right":7,"relation":"context","nuclearity":"NS"},{"parent":141,"left":140,"right":6,"relation":"context","nuclearity":"NS"},{"parent":140,"left":4,"right":5,"relation":"context","nuclearity":"SN"},{"parent":271,"left":216,"right":270,"relation":"elaboration","nuclearit