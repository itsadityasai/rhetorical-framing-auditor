arent":338,"left":333,"right":337,"relation":"purpose","nuclearity":"NS"},{"parent":333,"left":167,"right":168,"relation":"mode","nuclearity":"NS"},{"parent":337,"left":334,"right":336,"relation":"condition","nuclearity":"NS"},{"parent":334,"left":169,"right":170,"relation":"purpose","nuclearity":"NS"},{"parent":336,"left":171,"right":335,"relation":"elaboration","nuclearity":"NS"},{"parent":335,"left":172,"right":173,"relation":"elaboration","nuclearity":"NS"}]}