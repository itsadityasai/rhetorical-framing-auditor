{"article_id":"CkFCXPkdcMCIRKk4","edus":[{"id":0,"text":"FERGUSON , Mo . -","depth":1},{"id":1,"text":"While this St. Louis suburb holds its breath","depth":6},{"id":2,"text":"waiting to learn","depth":7},{"id":3,"text":"whether a grand jury will indict officer Darren Wilson , 28 , in the shooting death of Michael Brown , 18 ,","depth":7},{"id":4,"text":"people are talking .","depth":5},{"id":5,"text":"At restaurants , coffee shops and dinner tables and on social media , everyone is buzzing about the case and what may have happened during the fatal Aug. 9 shooting .","depth":4},{"id":6,"text":"looks at some myths and facts behind the shooting .","depth":3},{"id":7,"text":"MYTH :","depth":5},{"id":8,"text":"We do n't have any idea","depth":6},{"id":9,"text":"when the grand jury decision might happen .","depth":6},{"id":10,"text":"FACT :","depth":5},{"id":11,"text":"It will come on or after Saturday","depth":8},{"id":12,"text":"( Nov. 15 ) ,","depth":8},{"id":13,"text":"according to St. Louis County Prosecuting Attorney Robert McCulloch .","depth":7},{"id":14,"text":"The grand jury is still hearing evidence","depth":7},{"id":15,"text":"and will make a decision","depth":8},{"id":16,"text":"once it is completed .","depth":8},{"id":17,"text":"MYTH :","depth":7},{"id":18,"text":"Wilson stopped Brown","depth":8},{"id":19,"text":"because he was a suspect in a robbery .","depth":8},{"id":20,"text":"FACT :","depth":8},{"id":21,"text":"Wilson did not know","depth":10},{"id":22,"text":"Brown was a suspect in a strong-arm robbery","depth":11},{"id":23,"text":"that happened moments before the shooting ,","depth":11},{"id":24,"text":"according to Ferguson Police Chief Tom Jackson .","depth":9},{"id":25,"text":"Wilson stopped Brown and his friend","depth":9},{"id":26,"text":"for walking in the middle of the street ,","depth":9},{"id":27,"text":"Jackson said .","depth":8},{"id":28,"text":"MYTH :","depth":9},{"id":29,"text":"Autopsies tell us EXACTLY what happened","depth":10},{"id":30,"text":"when Brown was shot .","depth":10},{"id":31,"text":"FACT :","depth":9},{"id":32,"text":"Police say","depth":11},{"id":33,"text":"Brown struggled with Wilson inside his police car ,","depth":12},{"id":34,"text":"then reached for Wilson 's weapon .","depth":12},{"id":35,"text":"Brown 's family and some witnesses say","depth":11},{"id":36,"text":"Wilson killed Brown","depth":12},{"id":37,"text":"as he raised his hands in surrender .","depth":12},{"id":38,"text":"Multiple pathologists say","depth":8},{"id":39,"text":"the autopsy","depth":11},{"id":40,"text":"performed by the St. Louis County medical examiner","depth":11},{"id":41,"text":"and the pathologist","depth":11},{"id":42,"text":"hired by Brown 's family","depth":11},{"id":43,"text":"could support either version .","depth":9},{"id":44,"text":"Pathologists say","depth":8},{"id":45,"text":"forensic science alone ca n't determine","depth":9},{"id":46,"text":"whether Wilson justifiably shot the teen .","depth":9},{"id":47,"text":"Judy Melinek , a forensic pathologist","depth":11},{"id":48,"text":"based in California ,","depth":11},{"id":49,"text":"says","depth":10},{"id":50,"text":"she was quoted out of context in a St. Louis Post-Dispatch story","depth":10},{"id":51,"text":"that said","depth":11},{"id":52,"text":"she thought","depth":12},{"id":53,"text":"the St. Louis County medical examiner 's autopsy of Brown supported Wilson 's claim","depth":13},{"id":54,"text":"that Brown was reaching for his gun .","depth":13},{"id":55,"text":"Melinek and others say","depth":9},{"id":56,"text":"crucial missing information","depth":12},{"id":57,"text":"including blood-spatter evidence , the number and location of bullet casings , the height of the officer 's weapon and other ballistic information","depth":12},{"id":58,"text":"must be factored in","depth":11},{"id":59,"text":"to determine what happened .","depth":10},{"id":60,"text":"FACT :","depth":6},{"id":61,"text":"The city is mainly calm","depth":8},{"id":62,"text":"as residents wait for the grand jury decision .","depth":8},{"id":63,"text":"Protesters are not in the streets every night .","depth":8},{"id":64,"text":"Missouri Gov . Jay Nixon said","depth":9},{"id":65,"text":"he would call in the National Guard","depth":10},{"id":66,"text":"only if unrest makes it necessary .","depth":10},{"id":67,"text":"MYTH :","depth":8},{"id":68,"text":"The grand jury is deciding","depth":9},{"id":69,"text":"whether or not Wilson was justified in the fatal shooting .","depth":9},{"id":70,"text":"FACT :","depth":8},{"id":71,"text":"Legal experts stress","depth":10},{"id":72,"text":"the grand jury is not weighing","depth":11},{"id":73,"text":"whether Wilson was justified in shooting Brown .","depth":11},{"id":74,"text":"`` They are not making a decision on officer Wilson 's guilt , ''","depth":11},{"id":75,"text":"said Peter Joy , a criminal defense attorney and law professor at Washington University-St. Louis .","depth":11},{"id":76,"text":"The jury is simply weighing","depth":11},{"id":77,"text":"if there is probable cause","depth":12},{"id":78,"text":"that a crime was committed .","depth":12},{"id":79,"text":"FACT :","depth":8},{"id":80,"text":"Wilson has been on paid administrative leave since the shooting .","depth":10},{"id":81,"text":"Ferguson Police Chief Tom Jackson told KSDK","depth":11},{"id":82,"text":"that","depth":12},{"id":83,"text":"if the grand jury does not indict Wilson ,","depth":13},{"id":84,"text":"he will immediately return to active duty .","depth":13},{"id":85,"text":"Wilson 's assignment has yet to be determined .","depth":12},{"id":86,"text":"However , Jackson said","depth":13},{"id":87,"text":"if the grand jury does return an indictment ,","depth":14},{"id":88,"text":"officer Wilson will most likely be fired .","depth":14},{"id":89,"text":"Jackson says","depth":12},{"id":90,"text":"he has not had any contact with Wilson ,","depth":13},{"id":91,"text":"and it is unclear whether he would want to return to the police force .","depth":13},{"id":92,"text":"Later , Jackson clarified his statements to MSNBC ,","depth":12},{"id":93,"text":"saying","depth":13},{"id":94,"text":"he was speaking in legal terms .","depth":13},{"id":95,"text":"He said","depth":13},{"id":96,"text":"Missouri law would allow Wilson to return to the force","depth":14},{"id":97,"text":"if he is cleared of any charges .","depth":14},{"id":98,"text":"The police department would also conduct an internal review of the Michael Brown shooting ,","depth":13},{"id":99,"text":"to see","depth":14},{"id":100,"text":"if Wilson violated any Ferguson police department policies .","depth":14},{"id":101,"text":"FACT :","depth":8},{"id":102,"text":"The 18-year-old was unarmed ,","depth":9},{"id":103,"text":"St. Louis County Police Chief Joe Belmar said in a news conference .","depth":9}],"relations":[{"parent":207,"left":0,"right":206,"relation":"organization","nuclearity":"SN"},{"parent":206,"left":109,"right":205,"relation":"organization","nuclearity":"SN"},{"parent":109,"left":108,"right":6,"relation":"context","nuclearity":"SN"},{"parent":108,"left":107,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":107,"left":106,"right":4,"relation":"context","nuclearity":"SN"},{"parent":106,"left":1,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":105,"left":2,"right":3,"relation":"attribution","nuclearity":"SN"},{"parent":205,"left":118,"right":204,"relation":"joint","nuclearity":"NN"},{"parent":118,"left":111,"right":117,"relation":"organization","nuclearity":"SN"},{"parent":111,"left":7,"right":110,"relation":"organization","nuclearity":"SN"},{"parent":110,"left":8,"right":9,"relation":"attribution","nuclearity":"SN"},{"parent":117,"left":10,"right":116,"relation":"organization","nuclearity":"SN"},{"parent":116,"left":113,"right":115,"relation":"elaboration","nuclearity":"NS"},{"parent":113,"left":112,"right":13,"relation":"attribution","nuclearity":"NS"},{"parent":112,"left":11,"right":12,"relatio