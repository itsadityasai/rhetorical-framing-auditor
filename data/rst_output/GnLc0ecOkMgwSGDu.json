{"article_id":"GnLc0ecOkMgwSGDu","edus":[{"id":0,"text":"LISTEN TO ARTICLE 3:00","depth":1},{"id":1,"text":"SHARE THIS ARTICLE","depth":5},{"id":2,"text":"Share Tweet","depth":6},{"id":3,"text":"Post Email","depth":6},{"id":4,"text":"President Donald Trump said","depth":8},{"id":5,"text":"he may soon meet with China ' s Xi Jinping","depth":9},{"id":6,"text":"to finalize details of a possible trade deal","depth":9},{"id":7,"text":"as he declared","depth":8},{"id":8,"text":"negotiations in Washington were making progress .","depth":8},{"id":9,"text":"\" Meetings are going well with good intent and spirit on both sides , \"","depth":8},{"id":10,"text":"Trump said in a tweet Thursday .","depth":8},{"id":11,"text":"\" No final deal will be made","depth":9},{"id":12,"text":"until my friend President Xi , and I , meet in the near future","depth":10},{"id":13,"text":"to discuss","depth":11},{"id":14,"text":"and agree on some of the long standing and more difficult points , \"","depth":11},{"id":15,"text":"Trump said in another posting .","depth":8},{"id":16,"text":"U.S. Trade Representative Robert Lighthizer was leading a second day of negotiations Thursday with Chinese Vice Premier Liu He , the highest-level talks","depth":7},{"id":17,"text":"since Trump met Xi on Dec. 1","depth":8},{"id":18,"text":"and declared a 90-day truce .","depth":8},{"id":19,"text":"Trump is scheduled to meet with Liu later in the day .","depth":6},{"id":20,"text":"Speaking at the White House ,","depth":7},{"id":21,"text":"Trump said","depth":7},{"id":22,"text":"he thinks","depth":8},{"id":23,"text":"a deal with China can be reached by March 1 ,","depth":8},{"id":24,"text":"and","depth":8},{"id":25,"text":"if not","depth":9},{"id":26,"text":"he ' ll go ahead with plans","depth":10},{"id":27,"text":"to more than double tariffs on $ 200 billion in Chinese imports .","depth":10},{"id":28,"text":"Donald Trump and Liu He during a meeting on trade talks in Washington , D.C. , on Jan. 31 .","depth":6},{"id":29,"text":"Photographer :","depth":7},{"id":30,"text":"Al Drago/","depth":7},{"id":31,"text":"Chinese officials did not bring any major new proposals to the table for this week ' s talks","depth":8},{"id":32,"text":"other than an invitation","depth":9},{"id":33,"text":"for Trump","depth":10},{"id":34,"text":"to meet with Xi in February after the U.S. president ' s meeting with North Korean leader Kim Jong Un ,","depth":10},{"id":35,"text":"according to one person familiar with the state of negotiations .","depth":7},{"id":36,"text":"China ' s top trade negotiators are in the U.S.","depth":9},{"id":37,"text":"meeting with our representatives .","depth":9},{"id":38,"text":"Meetings are going well with good intent and spirit on both sides .","depth":9},{"id":39,"text":"China does not want an increase in Tariffs","depth":11},{"id":40,"text":"and feels","depth":12},{"id":41,"text":"they will do much better","depth":13},{"id":42,"text":"if they make a deal .","depth":13},{"id":43,"text":"They are correct .","depth":10},{"id":44,"text":"I will be ......","depth":7},{"id":45,"text":"- Donald J. Trump","depth":7},{"id":46,"text":"( @ realDonaldTrump )","depth":7},{"id":47,"text":"January 31 , 2019","depth":6},{"id":48,"text":"A breakthrough deal is seen as unlikely from this round of negotiations ,","depth":5},{"id":49,"text":"and the White House has said","depth":6},{"id":50,"text":"a concluding statement will be released","depth":7},{"id":51,"text":"outlining progress","depth":8},{"id":52,"text":"made on core issues such as Chinese technology transfers and intellectual property practices , market access , and Beijing ' s pledge","depth":9},{"id":53,"text":"to buy more American goods .","depth":9},{"id":54,"text":"Myron Brilliant , executive vice president and head of international affairs at the U.S. Chamber of Commerce , said","depth":6},{"id":55,"text":"officials have told him","depth":7},{"id":56,"text":"that progress is being made on some issues but not on concerns about forced-technology transfers and other industrial policies .","depth":7},{"id":57,"text":"\" We ' re at halftime of the Super Bowl of trade relations , \"","depth":7},{"id":58,"text":"Brilliant said on a conference call Thursday with reporters .","depth":7},{"id":59,"text":"\" There ' s still work to be done ,","depth":9},{"id":60,"text":"there are still gaps in some of the important issues ,","depth":9},{"id":61,"text":"and we ' re hopeful","depth":9},{"id":62,"text":"that the two sides will work through this in a continuing , constructive and positive manner . ' '","depth":9},{"id":63,"text":"Brilliant said","depth":8},{"id":64,"text":"it will be positive","depth":11},{"id":65,"text":"if the March 1 deadline is delayed","depth":11},{"id":66,"text":"but significant progress is made .","depth":10},{"id":67,"text":"But","depth":10},{"id":68,"text":"if there ' s little movement during the next 30 days ,","depth":11},{"id":69,"text":"\" the markets will react poorly","depth":12},{"id":70,"text":"because it will be a signal","depth":13},{"id":71,"text":"that the two sides have not found common ground on some of these sticky issues . ' '","depth":13},{"id":72,"text":"Trump ' s comments Thursday","depth":6},{"id":73,"text":"-- including that an agreement has a \" very good chance","depth":7},{"id":74,"text":"of happening \" --","depth":7},{"id":75,"text":"were the clearest articulation","depth":7},{"id":76,"text":"he has given so far","depth":7},{"id":77,"text":"of his desire","depth":7},{"id":78,"text":"to resolve his trade war with China .","depth":7},{"id":79,"text":"That bold declaration is at odds with the consensus view of analysts and many in the business community","depth":6},{"id":80,"text":"who argue","depth":7},{"id":81,"text":"that extracting meaningful concessions from China will take time","depth":8},{"id":82,"text":"and could potentially require years","depth":9},{"id":83,"text":"to verify .","depth":9},{"id":84,"text":"It also conflicts with what China hawks in Trump ' s own administration have been saying all along .","depth":7},{"id":85,"text":"Their view has been that extracting real reforms from China","depth":10},{"id":86,"text":"that fundamentally alter its economic model","depth":10},{"id":87,"text":"-- and making sure","depth":10},{"id":88,"text":"they stick --","depth":10},{"id":89,"text":"would entail a long grind .","depth":8},{"id":90,"text":"They also have mocked previous administrations","depth":7},{"id":91,"text":"for claiming victory in discussions with China","depth":8},{"id":92,"text":"only to see Beijing later flout agreements .","depth":8}],"relations":[{"parent":185,"left":0,"right":184,"relation":"organization","nuclearity":"SN"},{"parent":184,"left":139,"right":183,"relation":"elaboration","nuclearity":"NS"},{"parent":139,"left":111,"right":138,"relation":"elaboration","nuclearity":"NS"},{"parent":111,"left":95,"right":110,"relation":"organization","nuclearity":"SN"},{"parent":95,"left":1,"right":94,"relation":"restatement","nuclearity":"NN"},{"parent":94,"left":2,"right":3,"relation":"joint","nuclearity":"NN"},{"parent":110,"left":106,"right":109,"relation":"context","nuclearity":"NS"},{"parent":106,"left":99,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":97,"right":98,"relation":"context","nuclearity":"NS"},{"parent":97,"left":4,"right":96,"relation":"attribution","nuclearity":"SN"},{"parent":96,"left":5,"right":6,"relation":"purpose","nuclearity":"NS"},{"parent":98,"left":7,"right":8,"relation":"attribution","nuclearity":"SN"},{"parent":105,"left":100,"right":104,"relation":"joint","nuclearity":"NN"},{"parent":100,"left":9,"right":10,"relation":"attribution","nuclearity":"NS"},{"parent":104,"left":103,"right":15,"relation":"attribution","nuclearity":"NS"},{"parent":103,"left":11,"right":102,"relation":"condition","nuclearity":"NS"},{"parent":102,"left":12,"right":101,"relation":"purpose","nuclearity":"NS"},{"parent":101,"left":13,"right":14,"relation":"joint