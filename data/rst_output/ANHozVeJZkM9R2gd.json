{"article_id":"ANHozVeJZkM9R2gd","edus":[{"id":0,"text":"Economists :","depth":2},{"id":1,"text":"Romney 's 12 Million Jobs Target Realistic ,","depth":3},{"id":2,"text":"Even If He Loses","depth":3},{"id":3,"text":"As the election draws closer ,","depth":4},{"id":4,"text":"the economy and jobs remain top issues in the presidential race .","depth":4},{"id":5,"text":"President Obama points to the improvement in the labor market","depth":4},{"id":6,"text":"since he took office in the midst of a downward spiral .","depth":4},{"id":7,"text":"Both he and Republican presidential nominee Mitt Romney have five-point plans","depth":6},{"id":8,"text":"for improving the economy ,","depth":6},{"id":9,"text":"although their strategies differ .","depth":5},{"id":10,"text":"Romney claims","depth":9},{"id":11,"text":"his leadership would greatly improve the nation 's economy :","depth":9},{"id":12,"text":"`` If we do those five things ,","depth":11},{"id":13,"text":"our economy will come roaring back , ''","depth":11},{"id":14,"text":"Romney pledged at a rally in Iowa on Friday .","depth":10},{"id":15,"text":"`` We will create 12 million new jobs in just four years . ''","depth":9},{"id":16,"text":"It sounds like a very big number","depth":9},{"id":17,"text":"- 12 million jobs -","depth":9},{"id":18,"text":"especially coming out of a deep recession","depth":9},{"id":19,"text":"followed by three years of what many have described as lackluster job growth .","depth":9},{"id":20,"text":"`` The 12 million jobs has been my forecast for quite some time , ''","depth":8},{"id":21,"text":"says Mark Zandi , chief economist at Moody 's Analytics .","depth":8},{"id":22,"text":"Zandi is in the economic forecasting business ,","depth":8},{"id":23,"text":"and he expects the economy to add an average of 3 million jobs a year over the next four years ,","depth":9},{"id":24,"text":"which would total 12 million jobs .","depth":9},{"id":25,"text":"Zandi adds","depth":9},{"id":26,"text":"that he does n't know","depth":11},{"id":27,"text":"who will win the presidency .","depth":11},{"id":28,"text":"And for the purposes of this projection , it does n't much matter .","depth":10},{"id":29,"text":"`` Cold hard facts .","depth":11},{"id":30,"text":"Politics completely aside .","depth":12},{"id":31,"text":"I 'm just doing the numbers , ''","depth":12},{"id":32,"text":"says Zandi .","depth":10},{"id":33,"text":"`` I feel confident","depth":10},{"id":34,"text":"that we 're going to create 12 million jobs over the next four years","depth":12},{"id":35,"text":"and we 're going to feel a lot better about this economy ,","depth":12},{"id":36,"text":"regardless of who is president . ''","depth":11},{"id":37,"text":"What makes him so confident ?","depth":8},{"id":38,"text":"A lot of modeling and a deep dive into industry-level economic data .","depth":8},{"id":39,"text":"In particular , he expects the housing market to finally break out of the deep freeze","depth":8},{"id":40,"text":"it 's been in","depth":9},{"id":41,"text":"since the financial crisis hit .","depth":9},{"id":42,"text":"`` The housing cycle 's going to kick into gear .","depth":8},{"id":43,"text":"A lot more homes are going to be built , office buildings , retail space .","depth":11},{"id":44,"text":"House prices are going to rise , ''","depth":11},{"id":45,"text":"says Zandi .","depth":10},{"id":46,"text":"`` That 's going to lift consumer spending and retailing and leisure and hospitality ,","depth":10},{"id":47,"text":"and this is going to create a lot of jobs . ''","depth":10},{"id":48,"text":"Zandi is n't the only one","depth":6},{"id":49,"text":"predicting robust job growth .","depth":6},{"id":50,"text":"Joel Prakken , senior managing director of Macroeconomic Advisers , forecasts 11 million jobs added over the next president 's term .","depth":6},{"id":51,"text":"`` That is not based on anyone 's particular set of economic policies , ''","depth":8},{"id":52,"text":"Prakken adds .","depth":8},{"id":53,"text":"When he first heard Romney 's 12 million jobs claim ,","depth":11},{"id":54,"text":"Prakken says","depth":11},{"id":55,"text":"he scurried to his calculator .","depth":10},{"id":56,"text":"And what he found was Romney 's campaign promise fit well with broad economic trends .","depth":9},{"id":57,"text":"`` It 's not a projection","depth":11},{"id":58,"text":"that 's incredible .","depth":11},{"id":59,"text":"It 's just that it might happen anyway , ''","depth":10},{"id":60,"text":"Prakken says .","depth":9},{"id":61,"text":"Romney economic adviser John Taylor takes this and other similar forecasts as validation","depth":8},{"id":62,"text":"that the candidate has set a realistic goal .","depth":8},{"id":63,"text":"`` It 's a solid estimate .","depth":10},{"id":64,"text":"It 's a robust estimate .","depth":10},{"id":65,"text":"It 's something","depth":10},{"id":66,"text":"that can be done with the right policies , ''","depth":10},{"id":67,"text":"Taylor says .","depth":8},{"id":68,"text":"Taylor , a professor at Stanford , and three other prominent conservative economists wrote a white paper","depth":7},{"id":69,"text":"making the case for Romney 's economic plan .","depth":7},{"id":70,"text":"The argument in short -","depth":8},{"id":71,"text":"this economic recovery has been weaker than those in the past","depth":9},{"id":72,"text":"because of Obama 's policies .","depth":9},{"id":73,"text":"For his part , Obama is n't setting many specific economic goals for his second term ,","depth":8},{"id":74,"text":"though he has said","depth":9},{"id":75,"text":"he 'd create a million manufacturing jobs .","depth":9},{"id":76,"text":"Taylor says","depth":9},{"id":77,"text":"a Romney presidency","depth":11},{"id":78,"text":"- with his plan for economic growth -","depth":11},{"id":79,"text":"would lead to a more typical recovery .","depth":10},{"id":80,"text":"`` If we have that kind of recovery again ,","depth":10},{"id":81,"text":"the prediction is you 'd get about 12 million jobs .","depth":10},{"id":82,"text":"So that 's one way","depth":11},{"id":83,"text":"to think about this , ''","depth":11},{"id":84,"text":"Taylor says .","depth":10},{"id":85,"text":"Of course ,","depth":9},{"id":86,"text":"if the economic forecasters are right ,","depth":10},{"id":87,"text":"we 're poised for that more typical recovery over the next four years .","depth":10},{"id":88,"text":"No matter whose five-point plan is in place .","depth":8}],"relations":[{"parent":177,"left":91,"right":176,"relation":"organization","nuclearity":"SN"},{"parent":91,"left":0,"right":90,"relation":"attribution","nuclearity":"SN"},{"parent":90,"left":1,"right":2,"relation":"adversative","nuclearity":"NS"},{"parent":176,"left":94,"right":175,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":92,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":92,"left":3,"right":4,"relation":"context","nuclearity":"SN"},{"parent":93,"left":5,"right":6,"relation":"context","nuclearity":"NS"},{"parent":175,"left":134,"right":174,"relation":"elaboration","nuclearity":"NS"},{"parent":134,"left":96,"right":133,"relation":"elaboration","nuclearity":"NS"},{"parent":96,"left":95,"right":9,"relation":"adversative","nuclearity":"NS"},{"parent":95,"left":7,"right":8,"relation":"purpose","nuclearity":"NS"},{"parent":133,"left":110,"right":132,"relation":"elaboration","nuclearity":"NS"},{"parent":110,"left":105,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":105,"left":101,"right":104,"relation":"evaluation","nuclearity":"NS"},{"parent":101,"left":97,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":97,"left":10,"right":11,"relation":"attribution","nuclearity":"SN"},{"parent":100,"left":99,"right":15,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":98,"right":14,"relation":"attribution","nuclearity":"NS"},{"parent":98,"left":12,"right":13,"relation":"condition","nuclearity":"SN"},{"parent":104,"left":102,"right":103,"relatio