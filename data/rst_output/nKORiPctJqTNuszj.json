{"article_id":"nKORiPctJqTNuszj","edus":[{"id":0,"text":"Fighting back tears ,","depth":5},{"id":1,"text":"British Prime Minister Theresa May said on Friday","depth":5},{"id":2,"text":"she would quit ,","depth":5},{"id":3,"text":"triggering a contest","depth":6},{"id":4,"text":"that will bring a new leader to power","depth":7},{"id":5,"text":"who is likely to push for a more decisive Brexit divorce deal .","depth":7},{"id":6,"text":"May 's departure will deepen the Brexit crisis","depth":4},{"id":7,"text":"as a new leader is likely to want a more decisive split ,","depth":5},{"id":8,"text":"raising the chances of a confrontation with the European Union and a potentially unpredictable snap parliamentary election .","depth":5},{"id":9,"text":"May set out a timetable for her departure","depth":3},{"id":10,"text":"- she will resign as Conservative Party leader on June 7","depth":4},{"id":11,"text":"with a leadership contest","depth":5},{"id":12,"text":"beginning the following week .","depth":5},{"id":13,"text":"Her voice cracking with emotion ,","depth":6},{"id":14,"text":"May ,","depth":8},{"id":15,"text":"who endured crises and humiliation in her failed effort","depth":9},{"id":16,"text":"to find a compromise Brexit deal","depth":10},{"id":17,"text":"that parliament could ratify ,","depth":10},{"id":18,"text":"said","depth":7},{"id":19,"text":"she bore no ill will .","depth":5},{"id":20,"text":"`` I will shortly leave the job","depth":8},{"id":21,"text":"that has been the honor of my life","depth":9},{"id":22,"text":"to hold , ''","depth":9},{"id":23,"text":"May said .","depth":7},{"id":24,"text":"`` The second female prime minister , but certainly not the last . ''","depth":6},{"id":25,"text":"`` I do so with no ill will but with enormous and enduring gratitude","depth":7},{"id":26,"text":"to have had the opportunity","depth":8},{"id":27,"text":"to serve the country","depth":9},{"id":28,"text":"I love , ''","depth":9},{"id":29,"text":"May said ,","depth":7},{"id":30,"text":"with her husband , Philip , looking on .","depth":7},{"id":31,"text":"May , once a reluctant supporter of EU membership ,","depth":6},{"id":32,"text":"who won the top job in the turmoil","depth":7},{"id":33,"text":"that followed the 2016 Brexit vote ,","depth":7},{"id":34,"text":"steps down with her central pledges","depth":7},{"id":35,"text":"- to lead the United Kingdom out of the bloc and heal its divisions -","depth":7},{"id":36,"text":"unfulfilled .","depth":6},{"id":37,"text":"`` It is , and will always remain ,","depth":7},{"id":38,"text":"a matter of deep regret to me that I have not been able to deliver Brexit , ''","depth":7},{"id":39,"text":"May said ,","depth":6},{"id":40,"text":"adding","depth":6},{"id":41,"text":"that her successor would have to find a consensus","depth":7},{"id":42,"text":"to honor the 2016 referendum result .","depth":7},{"id":43,"text":"May bequeaths a deeply divided country and a political elite","depth":5},{"id":44,"text":"that is deadlocked over how , when or whether to leave the EU .","depth":5},{"id":45,"text":"The leading contenders","depth":7},{"id":46,"text":"to succeed May","depth":7},{"id":47,"text":"all want a tougher divorce deal ,","depth":6},{"id":48,"text":"although the EU has said","depth":6},{"id":49,"text":"it will not renegotiate the Withdrawal Treaty","depth":7},{"id":50,"text":"it sealed in November .","depth":7},{"id":51,"text":"Boris Johnson , the face of the official Brexit campaign in 2016 , is the favorite","depth":6},{"id":52,"text":"to succeed May .","depth":6},{"id":53,"text":"Betting markets put a 40 % implied probability on Johnson winning the top job .","depth":5},{"id":54,"text":"Others","depth":7},{"id":55,"text":"tipped by betting markets","depth":7},{"id":56,"text":"are Dominic Raab , a Brexit supporter and former Brexit secretary , with a 14 % implied probability on his chances .","depth":6},{"id":57,"text":"Environment Secretary Michael Gove , former House of Commons leader Andrea Leadsom and Foreign Secretary Jeremy Hunt each have a 7 % probability ,","depth":7},{"id":58,"text":"according to betting markets .","depth":7},{"id":59,"text":"Defense Secretary Penny Mordaunt and International Development Secretary Rory Stewart each have a 4 % chance of the top job","depth":7},{"id":60,"text":"while Home Secretary","depth":9},{"id":61,"text":"( interior minister )","depth":9},{"id":62,"text":"Sajid Javid has a 3 % chance .","depth":8}],"relations":[{"parent":125,"left":75,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":71,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":68,"right":70,"relation":"causal","nuclearity":"NS"},{"parent":68,"left":64,"right":67,"relation":"attribution","nuclearity":"SN"},{"parent":64,"left":0,"right":1,"relation":"context","nuclearity":"SN"},{"parent":67,"left":2,"right":66,"relation":"causal","nuclearity":"NS"},{"parent":66,"left":3,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":6,"right":69,"relation":"causal","nuclearity":"NS"},{"parent":69,"left":7,"right":8,"relation":"causal","nuclearity":"NS"},{"parent":74,"left":9,"right":73,"relation":"organization","nuclearity":"SN"},{"parent":73,"left":10,"right":72,"relation":"context","nuclearity":"NS"},{"parent":72,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":124,"left":104,"right":123,"relation":"elaboration","nuclearity":"NS"},{"parent":104,"left":92,"right":103,"relation":"elaboration","nuclearity":"NS"},{"parent":92,"left":81,"right":91,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":80,"right":19,"relation":"attribution","nuclearity":"SN"},{"parent":80,"left":13,"right":79,"relation":"context","nuclearity":"SN"},{"parent":79,"left":78,"right":18,"relation":"same-unit","nuclearity":"NN"},{"parent":78,"left":14,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":