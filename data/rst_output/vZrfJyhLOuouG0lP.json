{"article_id":"vZrfJyhLOuouG0lP","edus":[{"id":0,"text":"FERGUSON , Mo . -","depth":1},{"id":1,"text":"Five protesters were arrested","depth":8},{"id":2,"text":"and some businesses were damaged Tuesday night","depth":8},{"id":3,"text":"after a memorial to Michael Brown was destroyed in a fire .","depth":7},{"id":4,"text":"The confrontation reignited tensions in the St. Louis suburb","depth":7},{"id":5,"text":"that was rocked by violence this summer","depth":8},{"id":6,"text":"after Brown , an unarmed teenager , was shot by a Ferguson police officer .","depth":8},{"id":7,"text":"During a news conference Wednesday , Capt . Ron Johnson with the Missouri State Highway Patrol said","depth":6},{"id":8,"text":"two St. Louis County police officers were injured during the unrest .","depth":7},{"id":9,"text":"Johnson said","depth":9},{"id":10,"text":"one of the officers was hit just underneath his eye with a rock .","depth":9},{"id":11,"text":"He is expected to recover .","depth":8},{"id":12,"text":"The unrest started Tuesday","depth":7},{"id":13,"text":"when a beauty supply store was looted and vandalized by several people","depth":8},{"id":14,"text":"attempting to haul out a cash register .","depth":8},{"id":15,"text":"Johnson said","depth":7},{"id":16,"text":"the manager said","depth":8},{"id":17,"text":"this was the third time","depth":9},{"id":18,"text":"the store had been broken into in the last six weeks .","depth":9},{"id":19,"text":"Police responded to the break-in","depth":7},{"id":20,"text":"and then several gunshots were heard","depth":8},{"id":21,"text":"and approximately 200 people gathered at the site","depth":9},{"id":22,"text":"where demonstrations were held after the Aug. 9 shooting of Brown , 18 , by Ferguson police officer Darren Wilson .","depth":9},{"id":23,"text":"After the break-in , a fire was reported at a restaurant on Carson Road .","depth":10},{"id":24,"text":"Johnson said","depth":11},{"id":25,"text":"the investigation shows","depth":12},{"id":26,"text":"gasoline appears to have been poured around the restaurant .","depth":12},{"id":27,"text":"He said","depth":10},{"id":28,"text":"the fire was put out by Ferguson firefighters .","depth":10},{"id":29,"text":"Some protesters said","depth":10},{"id":30,"text":"they were in the streets","depth":11},{"id":31,"text":"because the makeshift memorial to Brown burned earlier in the day .","depth":11},{"id":32,"text":"Protesters said","depth":10},{"id":33,"text":"they believed","depth":11},{"id":34,"text":"it was set intentionally .","depth":11},{"id":35,"text":"The fire started around 6:45 a.m. CT Tuesday on Canfield Drive , the street","depth":11},{"id":36,"text":"where Wilson killed Brown ,","depth":11},{"id":37,"text":"said Capt . Jeremy Corcoran with the Ferguson police .","depth":10},{"id":38,"text":"Johnson said","depth":10},{"id":39,"text":"the fire started small enough","depth":12},{"id":40,"text":"to have been put out with a cup of water ,","depth":12},{"id":41,"text":"but","depth":12},{"id":42,"text":"instead of acting ,","depth":13},{"id":43,"text":"some people stood","depth":15},{"id":44,"text":"watching the fire for 11 minutes","depth":15},{"id":45,"text":"until police and firefighters arrived .","depth":14},{"id":46,"text":"He said","depth":10},{"id":47,"text":"the cause of the fire has not yet been determined ,","depth":11},{"id":48,"text":"but he does n't believe","depth":12},{"id":49,"text":"that a police officer started it .","depth":12},{"id":50,"text":"He says","depth":10},{"id":51,"text":"a full investigation is underway","depth":11},{"id":52,"text":"to determine the cause .","depth":11},{"id":53,"text":"Later Tuesday , residents later rebuilt the memorial .","depth":5},{"id":54,"text":"The blaze angered many people","depth":7},{"id":55,"text":"who live near the scene .","depth":7},{"id":56,"text":"One man said","depth":7},{"id":57,"text":"it was like a grave being desecrated .","depth":7},{"id":58,"text":"Around 12:15 a.m. , unpeaceful people started to flash lights into the eyes of police ,","depth":8},{"id":59,"text":"shouting about shooting officers","depth":9},{"id":60,"text":"and burning down the town ,","depth":9},{"id":61,"text":"Johnson said Wednesday .","depth":7},{"id":62,"text":"He said","depth":9},{"id":63,"text":"the protesters were positioning themselves close to officers ,","depth":10},{"id":64,"text":"so the decision was made","depth":11},{"id":65,"text":"to disperse the crowd .","depth":11},{"id":66,"text":"Johnson said","depth":9},{"id":67,"text":"when they attempted to break up the group ,","depth":10},{"id":68,"text":"some started throwing bottles , rocks and other items at police ,","depth":11},{"id":69,"text":"injuring two officers .","depth":11},{"id":70,"text":"The unrest continued ,","depth":10},{"id":71,"text":"Johnson said ,","depth":10},{"id":72,"text":"when someone near Canfield fired shots at the officers .","depth":10},{"id":73,"text":"He said","depth":11},{"id":74,"text":"he saw the muzzle flash from the gun","depth":12},{"id":75,"text":"and sought shelter .","depth":12},{"id":76,"text":"Officers were wearing bulletproof vests ,","depth":11},{"id":77,"text":"but Johnson said","depth":12},{"id":78,"text":"a lot of the heavy equipment","depth":14},{"id":79,"text":"used during the unrest in August","depth":14},{"id":80,"text":"was not used Tuesday ,","depth":13},{"id":81,"text":"but they will start to respond to the area in riot gear","depth":11},{"id":82,"text":"if it becomes necessary .","depth":11},{"id":83,"text":"Johnson also said","depth":10},{"id":84,"text":"a Molotov cocktail was thrown at a parking facility .","depth":10},{"id":85,"text":"Of the five people","depth":8},{"id":86,"text":"arrested","depth":9},{"id":87,"text":"for failing to disperse ,","depth":9},{"id":88,"text":"Johnson believed","depth":7},{"id":89,"text":"one person also is facing assault and inciting a riot charges .","depth":6},{"id":90,"text":"Brown 's death led to weeks of protest and unrest in the St. Louis suburb .","depth":5},{"id":91,"text":"After a month without an arrest ,","depth":6},{"id":92,"text":"Brown 's parents and activists questioned","depth":7},{"id":93,"text":"why Wilson had not been indicted in the killing .","depth":7},{"id":94,"text":"At the time of the shooting , witnesses in the area said","depth":5},{"id":95,"text":"Brown had raised his hands","depth":7},{"id":96,"text":"to surrender","depth":7},{"id":97,"text":"as he was shot .","depth":6},{"id":98,"text":"A state grand jury and the U.S. Department of Justice are continuing to investigate .","depth":3}],"relations":[{"parent":197,"left":0,"right":196,"relation":"organization","nuclearity":"SN"},{"parent":196,"left":187,"right":195,"relation":"context","nuclearity":"NS"},{"parent":187,"left":150,"right":186,"relation":"joint","nuclearity":"NN"},{"parent":150,"left":109,"right":149,"relation":"elaboration","nuclearity":"NS"},{"parent":109,"left":104,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":104,"left":101,"right":103,"relation":"causal","nuclearity":"NS"},{"parent":101,"left":100,"right":3,"relation":"context","nuclearity":"NS"},{"parent":100,"left":1,"right":2,"relation":"joint","nuclearity":"NN"},{"parent":103,"left":4,"right":102,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":5,"right":6,"relation":"context","nuclearity":"NS"},{"parent":108,"left":7,"right":107,"relation":"attribution","nuclearity":"SN"},{"parent":107,"left":8,"right":106,"relation":"elaboration","nuclearity":"NS"},{"parent":106,"left":105,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":105,"left":9,"right":10,"relation":"attribution","nuclearity":"SN"},{"parent":149,"left":115,"right":148,"relation":"joint","nuclearity":"NN"},{"parent":115,"left":111,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":111,"left":12,"right":110,"relation":"context","nuclearity":"NS"},{"parent":110,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{