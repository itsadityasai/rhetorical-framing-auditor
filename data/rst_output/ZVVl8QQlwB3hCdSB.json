{"article_id":"ZVVl8QQlwB3hCdSB","edus":[{"id":0,"text":"President Trump issued a memorandum on Friday","depth":4},{"id":1,"text":"banning most transgender troops from military service .","depth":4},{"id":2,"text":"\" Among other things , the policies","depth":7},{"id":3,"text":"set forth by the Secretary of Defense","depth":7},{"id":4,"text":"state that transgender persons with a history or diagnosis of gender dysphoria","depth":7},{"id":5,"text":"- individuals","depth":8},{"id":6,"text":"who","depth":10},{"id":7,"text":"the policies state","depth":10},{"id":8,"text":"may require substantial medical treatment ,","depth":10},{"id":9,"text":"including medications and surgery -","depth":10},{"id":10,"text":"are disqualified from military service except under certain limited circumstances , \"","depth":5},{"id":11,"text":"said the memo ,","depth":6},{"id":12,"text":"which was filed in U.S. District Court in Seattle on Friday ,","depth":6},{"id":13,"text":"according to Politico .","depth":5},{"id":14,"text":"The policy was based on the results of a promised study within the Departments of Defense and Homeland Security .","depth":4},{"id":15,"text":"The study was established by Secretary of Defense James Mattis last August","depth":5},{"id":16,"text":"\" to provide advice and recommendations on the implementation of the president ' s direction . \"","depth":5},{"id":17,"text":"The study ' s results ,","depth":7},{"id":18,"text":"published on February 22 ,","depth":7},{"id":19,"text":"sharply countered the Obama administration ' s policy","depth":8},{"id":20,"text":"to allow transgender service ,","depth":8},{"id":21,"text":"which was based \" on a study","depth":8},{"id":22,"text":"prepared by the RAND National Defense Research Institute. \"","depth":8},{"id":23,"text":"That study ,","depth":7},{"id":24,"text":"according to the Defense Department memorandum ,","depth":7},{"id":25,"text":"\" contained significant shortcomings . \"","depth":6},{"id":26,"text":"\" Based on the work of the Panel and the Department ' s best military judgment , \"","depth":7},{"id":27,"text":"stated the Defense Department memorandum ,","depth":7},{"id":28,"text":"\" the Department of Defense concludes","depth":7},{"id":29,"text":"that there are substantial risks","depth":8},{"id":30,"text":"associated with allowing the accession and retention of individuals with a history or diagnosis of gender dysphoria","depth":9},{"id":31,"text":"and require ,","depth":11},{"id":32,"text":"or have already undertaken , a course of treatment","depth":11},{"id":33,"text":"to change their gender .","depth":10},{"id":34,"text":"Furthermore , the Department also finds","depth":6},{"id":35,"text":"that exempting such persons from well-established mental health , physical health , and sex-standards ,","depth":9},{"id":36,"text":"which apply to all Service members ,","depth":10},{"id":37,"text":"including transgender Service members","depth":11},{"id":38,"text":"without gender dysphoria ,","depth":11},{"id":39,"text":"could undermine readiness ,","depth":8},{"id":40,"text":"disrupt unit cohesion ,","depth":8},{"id":41,"text":"and impose an unreasonable burden on the military","depth":9},{"id":42,"text":"that is not conducive to military effectiveness and lethality . \"","depth":9},{"id":43,"text":"The memo allows the Secretary of Defense and the Homeland Security Secretary leeway","depth":3},{"id":44,"text":"as to how the policy is implemented .","depth":3},{"id":45,"text":"Both \" may exercise their authority","depth":3},{"id":46,"text":"to implement any appropriate policies","depth":4},{"id":47,"text":"concerning military service by transgender individuals . \"","depth":4}],"relations":[{"parent":95,"left":90,"right":94,"relation":"elaboration","nuclearity":"NS"},{"parent":90,"left":61,"right":89,"relation":"elaboration","nuclearity":"NS"},{"parent":61,"left":49,"right":60,"relation":"elaboration","nuclearity":"NS"},{"parent":49,"left":0,"right":1,"relation":"elaboration","n