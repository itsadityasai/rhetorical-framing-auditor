rent":314,"left":304,"right":313,"relation":"joint","nuclearity":"NN"},{"parent":304,"left":295,"right":303,"relation":"joint","nuclearity":"NN"},{"parent":295,"left":292,"right":294,"relation":"organization","nuclearity":"SN"},{"parent":292,"left":291,"right":38,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":35,"right":290,"relation":"organization","nuclearity":"SN"},{"parent":290,"left":36,"right":37,"relation":"organization","nuclearity":"SN"},{"parent":294,"left":293,"right":41,"relation":"context","nuclearity":"NS"},{"parent":293,"left":39,"right":40,"relation":"organization","nuclearity":"SN"},{"parent":303,"left":300,"right":302,"relation":"joint","nuclearity":"NN"},{"parent":300,"left":297,"right":299,"relation":"joint","nuclearity":"NN"},{"parent":297,"left":296,"right":44,"relation":"context","nuclearity":"SN"},{"parent":296,"left":42,"right":43,"relation":"organization","nuclearity":"SN"},{"parent":299,"left":298,"right":47,"relation":"context","nuclearity":"NS"},{"parent":298,"left":45,"right":46,"relation":"organization","nuclearity":"SN"},{"parent":302,"left":48,"right":301,"relation":"same-unit","nuclearity":"NN"},{"parent":301,"left":49,"right":50,"relation":"attribution","nuclearity":"SN"},{"parent":313,"left":308,"right":312,"relation":"joint","nuclearity":"NN"},{"parent":308,"left":51,"right":307,"relation":"organization","nuclearity":"SN"},{"parent":307,"left":306,"right":55,"relation":"context","nuclearity":"NS"},{"parent":306,"left":52,"right":305,"relation":"organization","nuclearity":"SN"},{"parent":305,"left":53,"right":54,"relation":"attribution","nuclearity":"SN"},{"parent":312,"left":56,"right":311,"relation":"organization","nuclearity":"SN"},{"parent":311,"left":57,"right":310,"relation":"context","nuclearity":"SN"},{"parent":310,"left":58,"right":309,"relation":"organization","nuclearity":"SN"},{"parent":309,"left":59,"right":60,"relation":"organization","nuclearity":"SN"},{"parent":370,"left":335,"right":369,"relation":"ela