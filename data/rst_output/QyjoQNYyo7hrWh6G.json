ty":"NS"},{"parent":335,"left":158,"right":159,"relation":"elaboration","nuclearity":"NS"},{"parent":347,"left":341,"right":346,"relation":"elaboration","nuclearity":"NS"},{"parent":341,"left":160,"right":340,"relation":"attribution","nuclearity":"SN"},{"parent":340,"left":339,"right":165,"relation":"same-unit","nuclearity":"NN"},{"parent":339,"left":161,"right":338,"relation":"elaboration","nuclearity":"NS"},{"parent":338,"left":162,"right":337,"relation":"joint","nuclearity":"NN"},{"parent":337,"left":163,"right":164,"relation":"elaboration","nuclearity":"NS"},{"parent":346,"left":343,"right":345,"relation":"elaboration","nuclearity":"NS"},{"parent":343,"left":342,"right":168,"relation":"attribution","nuclearity":"NS"},{"parent":342,"left":166,"right":167,"relation":"elaboration","nuclearity":"NS"},{"parent":345,"left":344,"right":171,"relation":"elaboration","nuclearity":"NS"},{"parent":344,"left":169,"right":170,"relation":"elaboration","nuclearity":"NS"},{"parent":355,"left":352,"right":354,"relation":"elaboration","nuclearity":"NS"},{"parent":352,"left":350,"right":351,"relation":"elaboration","nuclearity":"NS"},{"parent":350,"left":349,"right":174,"relation":"same-unit","nuclearity":"NN"},{"parent":349,"left":172,"right":173,"relation":"elaboration","nuclearity":"NS"},{"parent":351,"left":175,"right":176,"relation":"attribution","nuclearity":"SN"},{"parent":354,"left":177,"right":353,"relation":"purpose","nuclearity":"NS"},{"parent":353,"left":178,"right":179,"relation":"elaboration","nuclearity":"NS"}]}