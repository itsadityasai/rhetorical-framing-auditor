{"article_id":"5mZ0IylsL3VzKzob","edus":[{"id":0,"text":"President Trump has selected former pharmaceutical executive Alex Azar as his newest pick","depth":5},{"id":1,"text":"to lead the department of Health and Human Services .","depth":5},{"id":2,"text":"Mr. Trump tweeted","depth":9},{"id":3,"text":"while overseas","depth":9},{"id":4,"text":"of his intentions","depth":9},{"id":5,"text":"to tap Azar ,","depth":9},{"id":6,"text":"writing","depth":8},{"id":7,"text":"that Azar `` will be a star for better healthcare and lower drug prices ! ''","depth":8},{"id":8,"text":"Happy to announce ,","depth":7},{"id":9,"text":"I am nominating Alex Azar","depth":9},{"id":10,"text":"to be the next HHS Secretary .","depth":9},{"id":11,"text":"He will be a star for better healthcare and lower drug prices !","depth":8},{"id":12,"text":"- Donald J. Trump","depth":7},{"id":13,"text":"( @ realDonaldTrump )","depth":7},{"id":14,"text":"November 13 , 2017","depth":6},{"id":15,"text":"Vice President Mike Pence applauded the move by Trump ,","depth":6},{"id":16,"text":"saying","depth":7},{"id":17,"text":"the president `` continues to recruit smart and capable leaders","depth":8},{"id":18,"text":"focused on Making America Great Again . ''","depth":8},{"id":19,"text":"He added","depth":6},{"id":20,"text":"that Azar would bring `` decades of health care experience '' to his HHS post .","depth":6},{"id":21,"text":"Congratulations to Alex Azar","depth":8},{"id":22,"text":"for being @ POTUS ' choice","depth":9},{"id":23,"text":"to lead @ HHSGov .","depth":9},{"id":24,"text":"Alex brings decades of health care experience .","depth":7},{"id":25,"text":"@ POTUS continues to recruit smart & capable leaders","depth":7},{"id":26,"text":"focused on Making America Great Again !","depth":7},{"id":27,"text":"https : //t.co/2ZxGbIMp0n","depth":6},{"id":28,"text":"- Vice President Mike Pence","depth":8},{"id":29,"text":"( @ VP )","depth":8},{"id":30,"text":"November 13 , 2017","depth":7},{"id":31,"text":"This would n't be Azar 's first stint with the Department ,","depth":5},{"id":32,"text":"previously serving as general counsel and later as deputy secretary of HHS under President George W. Bush 's administration .","depth":5},{"id":33,"text":"Following his time at HHS ,","depth":5},{"id":34,"text":"he rose to role of President of Eli Lilly USA , a global pharmaceutical company .","depth":5},{"id":35,"text":"He comes on board","depth":7},{"id":36,"text":"after Mr. Trump selected Eric Hargan","depth":9},{"id":37,"text":"to serve as acting HHS secretary last month ,","depth":9},{"id":38,"text":"filling the vacant spot","depth":10},{"id":39,"text":"left by former secretary Tom Price","depth":10},{"id":40,"text":"who resigned amid of flurry of probes into his government travel .","depth":9},{"id":41,"text":"In a statement from White House press secretary Sarah Huckabee Sanders ,","depth":8},{"id":42,"text":"Price `` offered his resignation ''","depth":10},{"id":43,"text":"and `` the president accepted ''","depth":10},{"id":44,"text":"late September .","depth":9},{"id":45,"text":"Mr. Trump had indicated","depth":10},{"id":46,"text":"he might fire Price ,","depth":10},{"id":47,"text":"and said","depth":10},{"id":48,"text":"he was `` not happy '' with the `` optics '' of the situation .","depth":10},{"id":49,"text":"Mr. Trump at the time called Price a `` very fine person . ''","depth":8},{"id":50,"text":"Politico first reported","depth":7},{"id":51,"text":"that Price had billed the government for at least $ 400,000 in private charter planes .","depth":7},{"id":52,"text":"A second report found","depth":7},{"id":53,"text":"that Price also used at least $ 500,000 worth of military jet travel abroad for him and his wife , Betty .","depth":7},{"id":54,"text":"In his letter to the president , Price cited the recent controversies","depth":6},{"id":55,"text":"surrounding his expensive travel ,","depth":6},{"id":56,"text":"saying","depth":6},{"id":57,"text":"`` I have spent forty years both as a doctor and public servant","depth":8},{"id":58,"text":"putting people first .","depth":8},{"id":59,"text":"I regret","depth":8},{"id":60,"text":"that the recent events have created a distraction from these important objectives . ''","depth":8},{"id":61,"text":"Price 's tenure in the Trump administration lasted less than eight months .","depth":1}],"relations":[{"parent":123,"left":122,"right":61,"relation":"context","nuclearity":"NS"},{"parent":122,"left":92,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":92,"left":76,"right":91,"relation":"joint","nuclearity":"NN"},{"parent":76,"left":63,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":75,"left":72,"right":74,"relation":"attribution","nuclearity":"NS"},{"parent":72,"left":68,"right":71,"relation":"attribution","nuclearity":"SN"},{"parent":68,"left":66,"right":67,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":64,"right":65,"relation":"attribution","nuclearity":"SN"},{"parent":64,"left":2,"right":3,"relation":"context","nuclearity":"NS"},{"parent":65,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":6,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":8,"right":70,"relation":"attribution","nuclearity":"SN"},{"parent":70,"left":69,"right":11,"relation":"evaluation","nuclearity":"NS"},{"parent":69,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":73,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":81,"right":90,"relation":"joint","nuclearity":"NN"},{"parent":81,"left":79,"right":80,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":15,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":16,"right":77,"relation":"attribution","nuclearity":"SN"},{"parent":77,"le