{"article_id":"DdwQcXArODteqm7S","edus":[{"id":0,"text":"Tennessee Gov . Bill Haslam granted clemency Monday to Cyntoia Brown , an alleged sex traffic victim","depth":5},{"id":1,"text":"who was sentenced to life in prison","depth":8},{"id":2,"text":"when she was 16","depth":8},{"id":3,"text":"after killing a man","depth":7},{"id":4,"text":"and whose case was championed by celebrities such as Kim Kardashian West , Rihanna and LeBron James .","depth":6},{"id":5,"text":"Haslam commuted her life sentence","depth":6},{"id":6,"text":"and Brown will be released to parole supervision on Aug. 7 ,","depth":6},{"id":7,"text":"he said in a statement .","depth":5},{"id":8,"text":"Brown had served 15 years in prison before the governor ' s decision .","depth":3},{"id":9,"text":"\" Cyntoia Brown committed , by her own admission , a horrific crime at the age of 16 , \"","depth":4},{"id":10,"text":"Haslam said .","depth":4},{"id":11,"text":"\" Yet , imposing a life sentence on a juvenile","depth":5},{"id":12,"text":"that would require her to serve at least 51 years","depth":7},{"id":13,"text":"before even being eligible for parole consideration","depth":7},{"id":14,"text":"is too harsh ,","depth":6},{"id":15,"text":"especially in light of the extraordinary steps","depth":6},{"id":16,"text":"Ms. Brown has taken","depth":6},{"id":17,"text":"to rebuild her life . \"","depth":5},{"id":18,"text":"CYNTOIA BROWN ,","depth":7},{"id":19,"text":"SERVING LIFE FOR MURDER ,","depth":7},{"id":20,"text":"ASKS TENNESSEE PAROLE BOARD FOR CLEMENCY :","depth":6},{"id":21,"text":"A LOOK AT HER CASE","depth":5},{"id":22,"text":"Brown will be subjected to certain restrictions upon her release ,","depth":7},{"id":23,"text":"according to The Tennessean .","depth":7},{"id":24,"text":"Brown must report to counseling sessions","depth":8},{"id":25,"text":"and will need to complete 50 hours of community service .","depth":8},{"id":26,"text":"Brown will also be required to work with at-risk youth","depth":8},{"id":27,"text":"and be required to get a job .","depth":8},{"id":28,"text":"Brown thanked Haslam in a statement through her lawyers for his \" act of mercy","depth":7},{"id":29,"text":"in giving me a second chance . \"","depth":7},{"id":30,"text":"\" With God 's help , I am committed to live the rest of my life","depth":9},{"id":31,"text":"helping others , especially young people .","depth":9},{"id":32,"text":"My hope is to help other young girls avoid ending up","depth":9},{"id":33,"text":"where I have been , \"","depth":9},{"id":34,"text":"Brown ' s statement read .","depth":7},{"id":35,"text":"Brown ' s case resurfaced late last year","depth":5},{"id":36,"text":"after several celebrities called on authorities","depth":6},{"id":37,"text":"to release her from prison .","depth":6},{"id":38,"text":"Rihanna , Kardashian West and James were among Brown ' s supporters .","depth":5},{"id":39,"text":"\" The system has failed .","depth":7},{"id":40,"text":"It ' s heartbreaking to see a young girl sex trafficked","depth":9},{"id":41,"text":"then","depth":10},{"id":42,"text":"when she has the courage","depth":12},{"id":43,"text":"to fight back","depth":12},{"id":44,"text":"is jailed for life ! \"","depth":11},{"id":45,"text":"Kardashian said in a November 2017 tweet .","depth":8},{"id":46,"text":"\" We have to do better","depth":8},{"id":47,"text":"& do what ' s right .","depth":8},{"id":48,"text":"I ' ve called my attorneys yesterday","depth":8},{"id":49,"text":"to see what can be done","depth":9},{"id":50,"text":"to fix this . \"","depth":9},{"id":51,"text":"Brown , now 30 , was convicted of first-degree murder in 2006 ,","depth":7},{"id":52,"text":"for killing 43-year-old Johnny Allen .","depth":7},{"id":53,"text":"Brown said at the time","depth":8},{"id":54,"text":"she was forced into prostitution","depth":9},{"id":55,"text":"and was scared for her life","depth":10},{"id":56,"text":"before she shot and killed Allen .","depth":10},{"id":57,"text":"At the time , prosecutors said","depth":8},{"id":58,"text":"Brown killed Allen","depth":9},{"id":59,"text":"to rob him .","depth":9},{"id":60,"text":"She was tried as an adult in 2006","depth":6},{"id":61,"text":"and convicted of first-degree murder .","depth":6},{"id":62,"text":"Since she ' s been in prison ,","depth":6},{"id":63,"text":"Brown has earned her associates degree from Lipscomb University ,","depth":7},{"id":64,"text":"WZTV-TV reported .","depth":7},{"id":65,"text":"She is also working on a bachelor 's degree ,","depth":6},{"id":66,"text":"according to the news station .","depth":6},{"id":67,"text":"Brown wouldn ' t have been paroled","depth":5},{"id":68,"text":"until she was 69","depth":5},{"id":69,"text":"if not for Haslam ' s clemency .","depth":5},{"id":70,"text":"It was the Republican governor ' s first clemency grant of his tenure .","depth":5}],"relations":[{"parent":141,"left":88,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":88,"left":79,"right":87,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":78,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":75,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":0,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":73,"right":4,"relation":"joint","nuclearity":"NN"},{"parent":73,"left":72,"right":3,"relation":"context","nuclearity":"NS"},{"parent":72,"left":1,"right":2,"relation":"context","nuclearity":"NS"},{"parent":77,"left":76,"right":7,"relation":"attribution","nuclearity":"NS"},{"parent":76,"left":5,"right":6,"relation":"joint","nuclearity":"NN"},{"parent":87,"left":80,"right":86,"relation":"adversative","nuclearity":"SN"},{"parent":80,"left":9,"right":10,"relation":"attribution","nuclearity":"NS"},{"parent":86,"left":83,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":11,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":81,"right":14,"relation":"same-unit","nuclearity":"N