rent":345,"left":162,"right":344,"relation":"attribution","nuclearity":"SN"},{"parent":344,"left":163,"right":343,"relation":"joint","nuclearity":"NN"},{"parent":343,"left":164,"right":342,"relation":"joint","nuclearity":"NN"},{"parent":342,"left":165,"right":166,"relation":"context","nuclearity":"NS"},{"parent":354,"left":350,"right":353,"relation":"adversative","nuclearity":"NN"},{"parent":350,"left":349,"right":170,"relation":"attribution","nuclearity":"NS"},{"parent":349,"left":348,"right":169,"relation":"same-unit","nuclearity":"NN"},{"parent":348,"left":167,"right":168,"relation":"context","nuclearity":"NS"},{"parent":353,"left":351,"right":352,"relation":"joint","nuclearity":"NN"},{"parent":351,"left":171,"right":172,"relation":"attribution","nuclearity":"SN"},{"parent":352,"left":173,"right":174,"relation":"attribution","nuclearity":"SN"},{"parent":364,"left":175,"right":363,"relation":"joint","nuclearity":"NN"},{"parent":363,"left":359,"right":362,"relation":"joint","nuclearity":"NN"},{"parent":359,"left":358,"right":179,"relation":"elaboration","nuclearity":"NS"},{"parent":358,"left":357,"right":178,"relation":"same-unit","nuclearity":"NN"},{"parent":357,"left":176,"right":177,"relation":"elaboration","nuclearity":"NS"},{"parent":362,"left":360,"right":361,"relation":"same-unit","nuclearity":"NN"},{"parent":360,"left":180,"right":181,"relation":"elaboration","nuclearity":"NS"},{"parent":361,"left":182,"right":183,"relation":"elaboration","nuclearity":"NS"},{"parent":370,"left":184,"right":185,"relation":"organization","nuclearity":"SN"}]}