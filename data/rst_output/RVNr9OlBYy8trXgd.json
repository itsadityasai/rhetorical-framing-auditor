{"article_id":"RVNr9OlBYy8trXgd","edus":[{"id":0,"text":"Joe Biden Calls For Trump Impeachment","depth":2},{"id":1,"text":"'To Preserve Our Constitution '","depth":2},{"id":2,"text":"Former Vice President Joe Biden called for President Trump 's impeachment and removal from office , on Wednesday .","depth":3},{"id":3,"text":"Up until now , Biden had reserved judgment ,","depth":5},{"id":4,"text":"saying","depth":6},{"id":5,"text":"he supported the House 's impeachment inquiry","depth":7},{"id":6,"text":"and wanted to see what the facts showed .","depth":7},{"id":7,"text":"But in a campaign speech in Rochester , N.H. , Biden was unequivocal ,","depth":6},{"id":8,"text":"saying","depth":7},{"id":9,"text":"that","depth":8},{"id":10,"text":"`` to preserve our Constitution , our democracy , our basic integrity ,","depth":9},{"id":11,"text":"[ Trump ] should be impeached . ''","depth":9},{"id":12,"text":"Biden said","depth":8},{"id":13,"text":"the case was already clear before the public .","depth":8},{"id":14,"text":"`` With his words and his actions , President Trump has indicted himself .","depth":11},{"id":15,"text":"By obstructing justice ,","depth":13},{"id":16,"text":"refusing to comply with the congressional inquiry ,","depth":13},{"id":17,"text":"he 's already convicted himself , ''","depth":12},{"id":18,"text":"Biden said .","depth":10},{"id":19,"text":"`` In full view of the world and the American people , Donald Trump has violated his oath of office ,","depth":10},{"id":20,"text":"betrayed this nation","depth":11},{"id":21,"text":"and committed impeachable acts . ''","depth":11},{"id":22,"text":"Biden later argued","depth":9},{"id":23,"text":"that `` impeachment is n't only about what the president has done","depth":10},{"id":24,"text":"- it 's about the threat","depth":12},{"id":25,"text":"the president poses to the nation","depth":12},{"id":26,"text":"if allowed to remain in office . ''","depth":11},{"id":27,"text":"Accordingly ,","depth":9},{"id":28,"text":"Biden said ,","depth":9},{"id":29,"text":"Congress should remove him","depth":8},{"id":30,"text":"before voters go to polls","depth":8},{"id":31,"text":"to choose the president on Election Day next year .","depth":8},{"id":32,"text":"Biden and his family were the subject of an effort by Trump","depth":8},{"id":33,"text":"to request political assistance from the government of Ukraine","depth":8},{"id":34,"text":"that was connected to U.S. military assistance and offers of engagement with Trump himself .","depth":7},{"id":35,"text":"Trump , his aides and some State Department diplomats were involved with an effort","depth":8},{"id":36,"text":"to get Ukrainian President Volodymyr Zelenskiy to launch investigations into Biden 's family and into a conspiracy theory","depth":9},{"id":37,"text":"believed by Trump","depth":10},{"id":38,"text":"about the political interference in the 2016 presidential race .","depth":10},{"id":39,"text":"Trump has defended the propriety of those actions","depth":8},{"id":40,"text":"and also called for the government of China to investigate the Biden family , too .","depth":8},{"id":41,"text":"Trump and his supporters have sought to call attention to what they call the questionable business dealings of Biden 's son Hunter .","depth":6},{"id":42,"text":"The president mocked the Bidens on Wednesday on Twitter in a response to the campaign speech .","depth":6},{"id":43,"text":"The back and forth between Trump and Biden followed the White House 's declaration on Tuesday","depth":6},{"id":44,"text":"that it would not accommodate Congress with documents or witnesses in the impeachment inquiry .","depth":6},{"id":45,"text":"Without a vote","depth":9},{"id":46,"text":"to initiate an inquiry by the full House ,","depth":9},{"id":47,"text":"argued White House counsel Pat Cipollone ,","depth":8},{"id":48,"text":"there is no impeachment inquiry","depth":8},{"id":49,"text":"the administration is bound to respect .","depth":8},{"id":50,"text":"But White House officials also wo n't commit to cooperating with Congress","depth":7},{"id":51,"text":"if the House were to convene a vote","depth":8},{"id":52,"text":"on launching an impeachment inquiry .","depth":8},{"id":53,"text":"Biden used his speech in New Hampshire","depth":6},{"id":54,"text":"to fault what he called that rejection laws and democratic norms ,","depth":6},{"id":55,"text":"saying of the president","depth":6},{"id":56,"text":"that `` he is seeing no limits to his power","depth":9},{"id":57,"text":"regardless of what the Constitution says ''","depth":9},{"id":58,"text":"and that `` he believes","depth":9},{"id":59,"text":"if he does something ,","depth":11},{"id":60,"text":"it 's legal - period . '' Trump `` believes","depth":11},{"id":61,"text":"he can and will get away with anything","depth":11},{"id":62,"text":"he does .","depth":11},{"id":63,"text":"We all laughed","depth":11},{"id":64,"text":"when he said","depth":12},{"id":65,"text":"he could stand in the middle of Fifth Avenue","depth":13},{"id":66,"text":"and shoot someone","depth":14},{"id":67,"text":"and get away with it , ''","depth":14},{"id":68,"text":"said Biden ,","depth":10},{"id":69,"text":"alluding a statement","depth":10},{"id":70,"text":"Trump made during the 2016 campaign .","depth":10},{"id":71,"text":"`` It 's no joke , ''","depth":10},{"id":72,"text":"Biden insisted .","depth":10},{"id":73,"text":"`` He 's shooting holes in the Constitution ,","depth":10},{"id":74,"text":"and we can not let him get away with it . ''","depth":10},{"id":75,"text":"Biden has led the crowded Democratic primary field","depth":7},{"id":76,"text":"since he entered the race","depth":7},{"id":77,"text":"but has since been caught in polling by Massachusetts Sen. Elizabeth Warren","depth":7},{"id":78,"text":"-who earlier called for Trump 's impeachment .","depth":7},{"id":79,"text":"A Biden aide says","depth":7},{"id":80,"text":"that the former vice president has seen the past two weeks as `` a remarkable period in American history ''","depth":8},{"id":81,"text":"that made clear what he believes","depth":9},{"id":82,"text":"are Trump 's obstruction and wrongdoing .","depth":9},{"id":83,"text":"That gave Biden no choice","depth":8},{"id":84,"text":"but to make his stance on impeachment clear ,","depth":8},{"id":85,"text":"the aide says .","depth":7}],"relations":[{"parent":171,"left":87,"right":170,"relation":"organization","nuclearity":"SN"},{"parent":87,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":170,"left":116,"right":169,"relation":"elaboration","nuclearity":"NS"},{"parent":116,"left":2,"right":115,"relation":"elaboration","nuclearity":"NS"},{"parent":115,"left":90,"right":114,"relation":"adversative","nuclearity":"SN"},{"parent":90,"left":3,"right":89,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":4,"right":88,"relation":"attribution","nuclearity":"SN"},{"parent":88,"left":5,"right":6,"relation":"joint","nuclearity":"NN"},{"parent":114,"left":94,"right":113,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":7,"right":93,"relation":"evaluation","nuclearity":"SN"},{"parent":93,"left":8,"right":92,"relation":"attribution","nuclearity":"SN"},{"parent":92,"left":9,"right":91,"relation":"same-unit","nuclearity":"NN"},{"parent":91,"left":10,"right":11,"relation":"purpose","nuclearity":"SN"},{"parent":113,"left":108,"right":112,"relation":"explanation","nuclearity":"SN"},{"parent":108,"left":95,"right":107,"relation":"elaboration","nuclearity":"NS"},{"parent":95,"left":12,"right":13,"relation":"attribution","nuclearity":"SN"},{"parent":107,"left":102,"right":106,"relation":"joint","nuclearity":"NN"},{"parent":102,"left":99,"right":101,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":98,"right":18,"relation":"attribution","nuclearity":"NS"},{"parent":98,"left":14,"right":97,"relation":"explanation","nuclearity":"NS"},{"parent":97,"left":96,"right":17,"relation":"mode","nuclearity":"SN"},{"parent":96,"left":1