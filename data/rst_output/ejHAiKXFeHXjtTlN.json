{"article_id":"ejHAiKXFeHXjtTlN","edus":[{"id":0,"text":"The number of Americans","depth":6},{"id":1,"text":"filing initial applications for unemployment benefits","depth":6},{"id":2,"text":"fell to a 42-year low last week in the latest sign","depth":6},{"id":3,"text":"the labor market is poised for further gains .","depth":6},{"id":4,"text":"First-time claims for the week","depth":10},{"id":5,"text":"ending July 18","depth":10},{"id":6,"text":"dropped by 26,000 to 255,000 , the lowest level since 1973 ,","depth":9},{"id":7,"text":"the Labor Department said Thursday .","depth":8},{"id":8,"text":"Economists","depth":9},{"id":9,"text":"surveyed by Bloomberg","depth":9},{"id":10,"text":"expected a dip of just 3,000 .","depth":8},{"id":11,"text":"The four-week average ,","depth":8},{"id":12,"text":"which smooths out volatility ,","depth":8},{"id":13,"text":"declined by 4,000 to 282,500 .","depth":7},{"id":14,"text":"Last week ' s decline was likely accentuated by two big summer auto plant shutdowns .","depth":6},{"id":15,"text":"Yet the total was a record low","depth":7},{"id":16,"text":"after adjusting for population gains since 1973 .","depth":7},{"id":17,"text":"Initial jobless claims are a reliable gauge of layoffs .","depth":4},{"id":18,"text":"And with the unemployment rate at a seven-year low of 5.3 % and a growing number of workers","depth":6},{"id":19,"text":"feeling confident enough","depth":7},{"id":20,"text":"to switch jobs ,","depth":7},{"id":21,"text":"many employers are holding on to staffers .","depth":5},{"id":22,"text":"\" There is certainly no sign","depth":4},{"id":23,"text":"of the labor market losing momentum , \"","depth":4},{"id":24,"text":"says Jim O ' Sullivan , chief U.S. economist for High Frequency Economics .","depth":3},{"id":25,"text":"The economy has gained nearly 3 million jobs in the past year .","depth":3},{"id":26,"text":"With that many more people","depth":5},{"id":27,"text":"earning paychecks ,","depth":5},{"id":28,"text":"economists forecast","depth":5},{"id":29,"text":"that spending should pick up","depth":6},{"id":30,"text":"and help fuel growth for the rest of this year .","depth":6},{"id":31,"text":"Even so , there are some signs of ongoing weakness in the job market .","depth":3},{"id":32,"text":"The unemployment rate fell in June","depth":5},{"id":33,"text":"mostly because many of the unemployed stopped looking for work ,","depth":6},{"id":34,"text":"rather than found jobs .","depth":6},{"id":35,"text":"The proportion of Americans","depth":7},{"id":36,"text":"working or looking for work","depth":7},{"id":37,"text":"fell to a 38-year low .","depth":6},{"id":38,"text":"And average hourly pay was unchanged last month from May .","depth":8},{"id":39,"text":"Pay has risen at roughly a 2 percent annual pace","depth":10},{"id":40,"text":"since the recession ended in 2009 ,","depth":10},{"id":41,"text":"below the 3.5 percent typical in a healthy economy .","depth":9},{"id":42,"text":"That sluggish wage growth is likely keeping spending from increasing as much","depth":8},{"id":43,"text":"as the healthy job growth would suggest .","depth":8},{"id":44,"text":"Analysts expect","depth":7},{"id":45,"text":"the economy will expand at about a 2.5 percent annual rate in the second quarter ,","depth":8},{"id":46,"text":"after contracting 0.2 percent in the first three months of the year .","depth":8}],"relations":[{"parent":93,"left":71,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":68,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":63,"right":67,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":50,"right":62,"relation":"elaboration","nuclearity":"NS"},{"parent":50,"left":48,"right":49,"relation":"same-unit","nuclearity":"NN"},{"parent":48,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":49,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":62,"left":59,"right":61,"relation":"elaboration",