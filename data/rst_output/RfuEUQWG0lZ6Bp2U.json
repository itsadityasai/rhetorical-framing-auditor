{"article_id":"RfuEUQWG0lZ6Bp2U","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"Republican Sen. Jeff Flake says","depth":5},{"id":2,"text":"he will block all of President Trump ' s judicial nominees","depth":6},{"id":3,"text":"until his bill","depth":8},{"id":4,"text":"to protect special counsel Robert Mueller","depth":8},{"id":5,"text":"goes to a vote .","depth":7},{"id":6,"text":"Flake ' s move comes","depth":5},{"id":7,"text":"after Trump forced Attorney General Jeff Sessions to resign","depth":8},{"id":8,"text":"and appointed Matt Whitaker , a Trump loyalist","depth":9},{"id":9,"text":"who has repeatedly criticized Mueller ' s investigation ,","depth":9},{"id":10,"text":"as acting attorney general .","depth":7},{"id":11,"text":"Trump had repeatedly railed against Sessions","depth":7},{"id":12,"text":"for recusing himself from overseeing the investigation of Russian interference in the 2016 election .","depth":7},{"id":13,"text":"Flake has long been a critic of Trump","depth":6},{"id":14,"text":"but has mostly declined to use his leverage in the razor-thin Senate","depth":7},{"id":15,"text":"to hold up Republican judges .","depth":7},{"id":16,"text":"That changed Wednesday","depth":7},{"id":17,"text":"when Flake sought unanimous consent","depth":9},{"id":18,"text":"to bring his bill","depth":11},{"id":19,"text":"to protect Mueller","depth":11},{"id":20,"text":"forward for debate .","depth":10},{"id":21,"text":"Majority Leader Mitch McConnell refused ,","depth":9},{"id":22,"text":"blocking the bill .","depth":9},{"id":23,"text":"Flake then declared","depth":8},{"id":24,"text":"he will vote to reject all judicial nominees .","depth":8},{"id":25,"text":"\" This is not a moment","depth":9},{"id":26,"text":"for our national leadership to be weak or irresolute , \"","depth":9},{"id":27,"text":"he said on the Senate floor .","depth":8},{"id":28,"text":"Flake is the swing vote in the Senate Judiciary Committee","depth":6},{"id":29,"text":"and , with Democrats , can vote down judicial nominations .","depth":6},{"id":30,"text":"McConnell could still bring these nominations forward to the Senate floor against the will of the committee ,","depth":7},{"id":31,"text":"but Flake said","depth":8},{"id":32,"text":"he doubts this would happen","depth":9},{"id":33,"text":"because it would alienate GOP senators .","depth":9},{"id":34,"text":"\" I ' d be surprised ,","depth":8},{"id":35,"text":"because there ' s such a slim margin on the floor .","depth":8},{"id":36,"text":"Some members are sticklers for precedent","depth":9},{"id":37,"text":"and you don ' t want to get in the habit","depth":10},{"id":38,"text":"of basically nullifying a committee ' s actions , \"","depth":10},{"id":39,"text":"said Flake .","depth":8},{"id":40,"text":"McConnell has made confirming conservative judges to lifetime appointments one of his top priorities under the Trump administration .","depth":5},{"id":41,"text":"Dozens of nominations hang in the balance .","depth":5},{"id":42,"text":"If he were to bypass the Judicial Committee ,","depth":6},{"id":43,"text":"Flake would need the help of just one more Republican senator","depth":7},{"id":44,"text":"to kill nominations .","depth":7},{"id":45,"text":"Flake said","depth":6},{"id":46,"text":"he is in talks with other Republicans","depth":8},{"id":47,"text":"to team up with him ,","depth":8},{"id":48,"text":"but did not identify who .","depth":7},{"id":49,"text":"The Senate Judiciary Committee passed the Mueller protection bill months ago ,","depth":6},{"id":50,"text":"but Mitch McConnell repeatedly refused to bring it forward for a vote .","depth":7},{"id":51,"text":"He argued","depth":8},{"id":52,"text":"the bill is unnecessary","depth":9},{"id":53,"text":"because there is no sign","depth":10},{"id":54,"text":"that Trump will fire Mueller .","depth":10},{"id":55,"text":"Flake argues","depth":7},{"id":56,"text":"that is no longer true .","depth":7},{"id":57,"text":"\" The justification","depth":11},{"id":58,"text":"given in April","depth":11},{"id":59,"text":"for not bringing it to the floor for a vote","depth":10},{"id":60,"text":"was that nobody was being fired ,","depth":10},{"id":61,"text":"nothing to see here ,","depth":11},{"id":62,"text":"special counsel Mueller was not in any danger .","depth":11},{"id":63,"text":"That clearly is not the case now , \"","depth":8},{"id":64,"text":"said Flake Wednesday .","depth":7},{"id":65,"text":"The Special Counsel Independence and Integrity Act ,","depth":7},{"id":66,"text":"cosponsored by Democratic Sen. Chris Coons ,","depth":7},{"id":67,"text":"would require","depth":8},{"id":68,"text":"that the special counsel could only be fired for good cause ,","depth":8},{"id":69,"text":"and would allow for the courts to overturn the firing","depth":8},{"id":70,"text":"if good cause could not be proved .","depth":8},{"id":71,"text":"Coons said","depth":8},{"id":72,"text":"he is certain","depth":9},{"id":73,"text":"the bill has the needed support of 60 senators","depth":10},{"id":74,"text":"to pass the Senate .","depth":10},{"id":75,"text":"But it has always faced very long odds","depth":9},{"id":76,"text":"of becoming law ,","depth":9},{"id":77,"text":"given that it would require Trump signing on to a measure","depth":9},{"id":78,"text":"that limits his own powers .","depth":9},{"id":79,"text":"Technically Trump can not fire Mueller on his own .","depth":7},{"id":80,"text":"Under current Justice Department regulations , only the attorney general can fire Mueller .","depth":8},{"id":81,"text":"Deputy Attorney General Rod Rosenstein , the department ' s number two official , had overseen the Mueller investigation","depth":10},{"id":82,"text":"since Sessions recused himself last year .","depth":10},{"id":83,"text":"Whitaker ' s appointment as acting attorney general puts him in charge of the probe ,","depth":10},{"id":84,"text":"but Democrats have called on him to recuse himself as well .","depth":10}],"relations":[{"parent":169