{"article_id":"6cW7YODGLTwTA65w","edus":[{"id":0,"text":"Lerner retired from the agency effective Monday .","depth":2},{"id":1,"text":"Lerner still Hill 's favorite piñata","depth":2},{"id":2,"text":"Lois Lerner is the political piñata","depth":8},{"id":3,"text":"that Congress still loves to whack","depth":8},{"id":4,"text":"months after she awkwardly acknowledged","depth":8},{"id":5,"text":"that the IRS wrongly scrutinized conservative groups for years .","depth":8},{"id":6,"text":"Her sudden retirement on Monday after 12 years at the agency won ' t change that .","depth":6},{"id":7,"text":"She ' s still a central figure in three congressional investigations into the political targeting scandal","depth":8},{"id":8,"text":"that embroiled the IRS","depth":10},{"id":9,"text":"- and the Obama administration -","depth":10},{"id":10,"text":"in May .","depth":9},{"id":11,"text":"House Oversight and Government Reform Committee Chairman Darrell Issa","depth":10},{"id":12,"text":"( R-Calif. )","depth":10},{"id":13,"text":"has an outstanding subpoena","depth":10},{"id":14,"text":"to compel her testimony before his panel .","depth":10},{"id":15,"text":"And as a 30-year veteran of the civil service , Lerner is still eligible for a pension","depth":9},{"id":16,"text":"- something","depth":10},{"id":17,"text":"that is sure to further anger critics in Congress .","depth":10},{"id":18,"text":"\" Her departure does not answer these questions","depth":8},{"id":19,"text":"or diminish the committee ' s interest","depth":9},{"id":20,"text":"in hearing her testimony , \"","depth":9},{"id":21,"text":"Issa said in a statement .","depth":7},{"id":22,"text":"Utah Sen. Orrin Hatch , the top Republican on the Finance Committee , said","depth":6},{"id":23,"text":"Lerner ' s retirement \" does not mean the investigation is over . \"","depth":8},{"id":24,"text":"\" Far from it , \"","depth":9},{"id":25,"text":"he said .","depth":9},{"id":26,"text":"\" In fact , there are many serious unanswered questions","depth":9},{"id":27,"text":"that must be addressed","depth":9},{"id":28,"text":"so we can get to the truth . \"","depth":8},{"id":29,"text":"Even Democrats","depth":9},{"id":30,"text":"who have slammed the GOP","depth":10},{"id":31,"text":"for politicizing congressional probes into the IRS","depth":10},{"id":32,"text":"didn ' t pull their punches .","depth":8},{"id":33,"text":"\" Lois Lerner is being held responsible for her gross mismanagement of the IRS tax-exempt division ,","depth":9},{"id":34,"text":"which led to improper handling of applications for tax-exempt status ,","depth":10},{"id":35,"text":"whether conservative [ or ] progressive , \"","depth":10},{"id":36,"text":"said Michigan Rep. Sander Levin , the top Democrat on the House Ways and Means Committee .","depth":8},{"id":37,"text":"A Democratic congressional aide said","depth":9},{"id":38,"text":"the IRS was moving toward terminating Lerner","depth":10},{"id":39,"text":"after completing an investigation into her role in the targeting controversy .","depth":10},{"id":40,"text":"The IRS found","depth":11},{"id":41,"text":"that Lerner ,","depth":14},{"id":42,"text":"who led the agency ' s unit","depth":15},{"id":43,"text":"that reviewed requests for tax exemptions ,","depth":15},{"id":44,"text":"mismanaged her department","depth":13},{"id":45,"text":"and was \" neglectful of duty \"","depth":12},{"id":46,"text":"but found no evidence of political bias ,","depth":10},{"id":47,"text":"the aide said .","depth":9},{"id":48,"text":"William Taylor , Lerner ' s attorney , did not immediately return a request for comment .","depth":7},{"id":49,"text":"Lerner sparked the IRS scandal in May","depth":6},{"id":50,"text":"when she told an American Bar Association conference","depth":7},{"id":51,"text":"that the agency wrongly targeted tea party groups","depth":8},{"id":52,"text":"applying for a tax exemption .","depth":8},{"id":53,"text":"The admission threw the White House into crisis mode ,","depth":6},{"id":54,"text":"forcing Treasury Secretary Jack Lew to ask then-IRS chief Steven Miller to step down .","depth":7},{"id":55,"text":"President Barack Obama later replaced Miller with Daniel Werfel , a former Office of Management and Budget official .","depth":7},{"id":56,"text":"Lerner was placed on administrative leave later in May after an explosive appearance before the House Oversight Committee","depth":9},{"id":57,"text":"in which she boldly declared her innocence","depth":10},{"id":58,"text":"before invoking her Fifth Amendment right","depth":12},{"id":59,"text":"to avoid self-incrimination","depth":12},{"id":60,"text":"and refused to answer questions from lawmakers .","depth":11},{"id":61,"text":"\" I have not done anything wrong , \"","depth":10},{"id":62,"text":"she said at the May 22 hearing .","depth":10},{"id":63,"text":"\" I have not broken any laws .","depth":10},{"id":64,"text":"I have not violated any IRS rules or regulations ,","depth":11},{"id":65,"text":"and I have not provided false information to this or any other committee . \"","depth":11},{"id":66,"text":"Issa and committee Republicans disagreed .","depth":9},{"id":67,"text":"They later voted to recall Lerner","depth":10},{"id":68,"text":"and said","depth":11},{"id":69,"text":"she waived her Fifth Amendment rights","depth":12},{"id":70,"text":"by declaring her innocence","depth":13},{"id":71,"text":"without allowing lawmakers to question her .","depth":13},{"id":72,"text":"Issa hasn ' t indicated","depth":9},{"id":73,"text":"when he plans to call Lerner back to Capitol Hill .","depth":9},{"id":74,"text":"Taylor , Lerner ' s attorney , has told","depth":7},{"id":75,"text":"that his client is interested in immunity in exchange","depth":8},{"id":76,"text":"for testifying before Issa ' s panel again .","depth":8},{"id":77,"text":"Lerner quickly became the public face of the IRS scandal .","depth":6},{"id":78,"text":"She initially blamed mid-level IRS employees in Cincinnati for the targeting","depth":9},{"id":79,"text":"but congressional investigators have rejected that explanation .","depth":9},{"id":80,"text":"Emails and documents","depth":11},{"id":81,"text":"released by the House Oversight Committee","depth":11},{"id":82,"text":"show","depth":10},{"id":83,"text":"that Lerner and other senior IRS leaders in Washington knew of the targeting early on .","depth":9},{"id":84,"text":"Democrats and Republicans joined together","depth":10},{"id":85,"text":"to call for Lerner ' s ouster in the early days of May ,","depth":10},{"id":86,"text":"saying","depth":10},{"id":87,"text":"she misled them about the scope of the targeting and the extent","depth":11},{"id":88,"text":"to which IRS ' s top brass knew the details .","depth":11},{"id":89,"text":"More recently , congressional Republicans have labored to keep public pressure on the agency","depth":10},{"id":90,"text":"by releasing emails and documents from Lerner and other key IRS officials .","depth":10},{"id":91,"text":"Lerner ' s private and public emails","depth":12},{"id":92,"text":"discussing the IRS from her tenure","depth":12},{"id":93,"text":"are still fair game for congressional investigators","depth":11},{"id":94,"text":"and she can still be asked to testify before interested committees .","depth":10},{"id":95,"text":"The IRS said in a statement on Monday","depth":4},{"id":96,"text":"that it has taken \" decisive actions","depth":5},{"id":97,"text":"to correct failures in exempt organizations management . \"","depth":5},{"id":98,"text":"\" As Werfel has made clear ,","depth":6},{"id":99,"text":"the behavior","depth":8},{"id":100,"text":"cited in the May","depth":9},{"id":101,"text":"[ inspector general ' s ] report","depth":9},{"id":102,"text":"was the result of mismanagement and poor judgment , \"","depth":7},{"id":103,"text":"the statement said .","depth":5},{"id":104,"text":"\" The IRS is making important progress","depth":6},{"id":105,"text":"on fixing the underlying management and organizational deficiencies in the","depth":8},{"id":106,"text":"[ exempt organizations ] area","depth":8},{"id":107,"text":"identified by [ the inspector general ] .","depth":7},{"id":108,"text":"Our goal is to restore the public ' s faith and trust in the tax system . \"","depth":5}],"relations":[{"parent":217,"left":110,"right":216,"relation":"organization","nuclearity":"SN"},{"parent":110,"left":0,"right":1,"relation":"adversative","nuclearity":"NS"},{"parent":216,"left":202,"right":215,"relation":"elaboration","nuclearity":"NS"},{"parent":202,"left":156,"right":201,"relation":"elaboration","nuclearity":"NS"},{"parent":156,"left":129,"right":155,"relation":"joint","nuclearity":"NN"},{"parent":129,"left":114,"right":128,"relation":"elaboration","nuclearity":"NS"},{"parent":114,"left":113,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":113,"left":111,"right":112,"relation":"context","nuclearity":"NS"},{"parent":111,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":112,"left":4,"right":5,"relation":"attribution","nuclearity":"SN"},{"parent":128,"left":124,"right":127,"relation":"elaboration","nuclearity":"NS"},{"parent":124,"left":117,"right":123,"relation":"elaboration","nuclearity":"NS"},{"parent":117,"left":7,"right":116,"relation":"elaboration","nuclearity":"NS"},{"parent":116,"left":115,"right":10,"relation":"same-unit","nuclearity":"NN"},{"parent":115,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":120,"right":122,"relation":"joint","nuclearity":"NN"},{"parent":120,"left":118,"right":119,"relation":"same-unit","nuclearity":"NN"},{"parent":118,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":119,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":15,"right":121,"relation":"evaluation","nuclearity":"NS"},{"parent":121,"left":16,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":127,"left":126,"right":21,"relation":"attribution","nucle