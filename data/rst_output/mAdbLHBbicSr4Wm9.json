{"article_id":"mAdbLHBbicSr4Wm9","edus":[{"id":0,"text":"ALBANY , N.Y.","depth":1},{"id":1,"text":"( AP ) -","depth":2},{"id":2,"text":"New York state enacted one of the nation ' s strongest protections for abortion rights Tuesday , a move","depth":6},{"id":3,"text":"that","depth":8},{"id":4,"text":"state leaders say","depth":8},{"id":5,"text":"was needed","depth":8},{"id":6,"text":"to safeguard those rights","depth":9},{"id":7,"text":"should the U.S. Supreme Court overturn Roe v. Wade .","depth":9},{"id":8,"text":"The Democrat-led Senate and Assembly passed the bill Tuesday , the 46th anniversary of the Roe decision .","depth":6},{"id":9,"text":"Democratic Gov . Andrew Cuomo immediately signed it into law .","depth":7},{"id":10,"text":"At his side at a hastily arranged signing ceremony was Sarah Weddington , the Texas attorney","depth":9},{"id":11,"text":"who successfully argued Roe before the nation ' s highest court .","depth":9},{"id":12,"text":"\" Thank you for what you ' ve done for women , \"","depth":9},{"id":13,"text":"she told Cuomo and the assembled lawmakers and advocates","depth":10},{"id":14,"text":"who worked for years","depth":11},{"id":15,"text":"to pass the bill .","depth":11},{"id":16,"text":"Known as the Reproductive Health Act ,","depth":8},{"id":17,"text":"the measure replaces a 1970 state abortion law","depth":9},{"id":18,"text":"that was passed","depth":10},{"id":19,"text":"three years before Roe legalized abortion nationwide .","depth":10},{"id":20,"text":"It codifies many abortion rights","depth":9},{"id":21,"text":"laid out in Roe and other court rulings ,","depth":9},{"id":22,"text":"including a provision","depth":9},{"id":23,"text":"permitting late-term abortions","depth":10},{"id":24,"text":"when a woman ' s health is endangered .","depth":10},{"id":25,"text":"The previous law ,","depth":9},{"id":26,"text":"which was in conflict with Roe and other subsequent abortion rulings ,","depth":9},{"id":27,"text":"only permitted abortions after 24 weeks of pregnancy","depth":9},{"id":28,"text":"if a woman ' s life was at risk .","depth":9},{"id":29,"text":"The new law also authorizes physician assistants to perform some abortions","depth":8},{"id":30,"text":"and moves the section of state law","depth":11},{"id":31,"text":"dealing with abortion","depth":11},{"id":32,"text":"from the penal code","depth":10},{"id":33,"text":"to health statutes .","depth":9},{"id":34,"text":"Nine other states","depth":8},{"id":35,"text":"including California , Washington and Oregon","depth":8},{"id":36,"text":"have already put protections for abortion rights in their state statute ,","depth":7},{"id":37,"text":"giving them a legal backstop","depth":7},{"id":38,"text":"should Roe be overturned .","depth":7},{"id":39,"text":"Abortion rights supporters had pushed for years to update the law","depth":8},{"id":40,"text":"to reflect those rulings","depth":8},{"id":41,"text":"only to be blocked in the state Senate ,","depth":8},{"id":42,"text":"long controlled by Republicans .","depth":8},{"id":43,"text":"But big election gains put Democrats in charge of the Senate this year ,","depth":7},{"id":44,"text":"and the act easily cleared both chambers .","depth":7},{"id":45,"text":"Supporters said","depth":7},{"id":46,"text":"the election of Republican President Donald Trump","depth":9},{"id":47,"text":"- and his nomination of conservative justices -","depth":9},{"id":48,"text":"helped galvanize the effort .","depth":8},{"id":49,"text":"\" We have a president","depth":9},{"id":50,"text":"who has made it very , very clear","depth":10},{"id":51,"text":"that he wants to overturn Roe v. Wade , \"","depth":10},{"id":52,"text":"said the Senate ' s new leader , Democrat Andrea Stewart-Cousins of Yonkers ,","depth":9},{"id":53,"text":"who vowed to make the bill an early priority in 2019 .","depth":9},{"id":54,"text":"\" Today in New York we are saying","depth":8},{"id":55,"text":"' No .","depth":9},{"id":56,"text":"Not here in New York . ' \"","depth":9},{"id":57,"text":"Opponents lamented the enactment of the act ,","depth":8},{"id":58,"text":"which","depth":10},{"id":59,"text":"some predicted","depth":10},{"id":60,"text":"would lead to an increase in late-term abortion .","depth":9},{"id":61,"text":"Others argued","depth":8},{"id":62,"text":"that the new law could make it harder for prosecutors to bring charges","depth":9},{"id":63,"text":"when a woman is assaulted","depth":10},{"id":64,"text":"and loses her pregnancy .","depth":10},{"id":65,"text":"\" Today , New York state has added a sad chapter to this already solemn date of January 22 , the anniversary of Roe v. Wade , \"","depth":7},{"id":66,"text":"the state ' s Catholic bishops said in a statement .","depth":7},{"id":67,"text":"Republicans in the Senate tried to derail the bill","depth":8},{"id":68,"text":"and offered up proposals","depth":9},{"id":69,"text":"to create new legal penalties","depth":10},{"id":70,"text":"for harming a pregnant woman .","depth":10},{"id":71,"text":"They were joined at a press conference Tuesday morning by Livia Abreu , an Army veteran and Bronx resident","depth":10},{"id":72,"text":"whose ex-boyfriend stabbed her last year ,","depth":11},{"id":73,"text":"ending her 26-week pregnancy .","depth":11},{"id":74,"text":"The man faces multiple charges ,","depth":10},{"id":75,"text":"including violations of the state ' s 1970 law .","depth":10},{"id":76,"text":"Abreu said","depth":10},{"id":77,"text":"repealing the law would tie the hands of prosecutors in similar future cases .","depth":10},{"id":78,"text":"\" The loss of my daughter will be a non-factor , \"","depth":10},{"id":79,"text":"she said .","depth":10},{"id":80,"text":"Supporters of the bill rejected those concerns ,","depth":7},{"id":81,"text":"noting","depth":8},{"id":82,"text":"that the 1973 abortion law is rarely used in domestic violence cases","depth":9},{"id":83,"text":"and that charges","depth":11},{"id":84,"text":"including assault , aggravated assault and attempted murder","depth":11},{"id":85,"text":"could still be sought .","depth":10}],"relations":[{"parent":171,"left":0,"right":170,"relation":"organization","nuclearity":"SN"},{"parent":170,"left":1,"right":169,"relation":"organization","nuclearity":"SN"},{"parent":169,"left":122,"right":168,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":99,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":91,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":2,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":90,"left":87,"right":89,"relation":"same-unit","nuclearity":"NN"},{"parent":87,"left":3,"right":4,"relation":"attribution","nuclearity":"NS"},{"parent":89,"left":5,"right":88,"relation":"purpose","nuclearity":"NS"},{"parent":88,"left":6,"right":7,"relation":"condition","nuclearity":"NS"},{"parent":98,"left":8,"right":97,"relation":"joint","nuclearity":"NN"},{"parent":97,"left":9,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":96,"left":92,"right":95,"relation":"elaboration","nuclearity":"NS"},{"parent":92,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":95,"left":12,"right":94,"relation":"attribution","nuclearity":"NS"},{"parent":94,"left":13,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":93,"left":14,"right":15,"relation":"purpose","nuclearity":"NS"},{"parent":121,"left":116,"right":120,"relation":"joint","nuclearity":"NN"},{"parent":116,"left":107,"right":115,"relation":"elaboration","nuclearity":"NS"},{"parent":107,"left":102,"right":106,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":16,"right":101,"relation":"context","nuclearity":"SN"},{"parent":101,"left":17,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":18,"right":19,"relation":"context","nuclearity":"NS"},{"parent":106,"left":103,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":103,"left":20,"right":21,"relation