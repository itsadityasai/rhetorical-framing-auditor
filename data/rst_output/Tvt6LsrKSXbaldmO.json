ight":89,"relation":"evaluation","nuclearity":"NS"},{"parent":280,"left":85,"right":279,"relation":"elaboration","nuclearity":"NS"},{"parent":279,"left":86,"right":278,"relation":"same-unit","nuclearity":"NN"},{"parent":278,"left":87,"right":88,"relation":"causal","nuclearity":"SN"},{"parent":296,"left":91,"right":295,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":288,"right":294,"relation":"elaboration","nuclearity":"NS"},{"parent":288,"left":287,"right":96,"relation":"adversative","nuclearity":"NN"},{"parent":287,"left":92,"right":286,"relation":"attribution","nuclearity":"SN"},{"parent":286,"left":93,"right":285,"relation":"elaboration","nuclearity":"NS"},{"parent":285,"left":94,"right":95,"relation":"context","nuclearity":"SN"},{"parent":294,"left":292,"right":293,"relation":"evaluation","nuclearity":"NS"},{"parent":292,"left":289,"right":291,"relation":"causal","nuclearity":"NS"},{"parent":289,"left":97,"right":98,"relation":"condition","nuclearity":"SN"},{"parent":291,"left":290,"right":101,"relation":"same-unit","nuclearity":"NN"},{"parent":290,"left":99,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":102,"right":103,"relation":"elaboration","nuclearity":"NS"},{"parent":319,"left":304,"right":318,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":300,"right":303,"relation":"attribution","nuclearity":"NS"},{"parent":300,"left":298,"right":299,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":104,"right":105,"relation":"attribution","nuclearity":"NS"},{"parent":299,"left":106,"right":107,"relation":"adversative","nuclearity":"SN"},{"parent":303,"left":108,"right":302,"relation":"attribution","nuclearity":"NS"},{"parent":302,"left":301,"right":111,"relation":"context","nuclearity":"NS"},{"parent":301,"left":109,"right":110,"relation":"elaboration","nuclearity":"NS"},{"parent":318,"left":307,"right":317,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":306,"right":115,"relation":