e","nuclearity":"NS"},{"parent":311,"left":137,"right":310,"relation":"attribution","nuclearity":"SN"},{"parent":310,"left":138,"right":309,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":139,"right":308,"relation":"elaboration","nuclearity":"NS"},{"parent":308,"left":140,"right":141,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":142,"right":312,"relation":"attribution","nuclearity":"SN"},{"parent":312,"left":143,"right":144,"relation":"elaboration","nuclearity":"NS"},{"parent":345,"left":336,"right":344,"relation":"joint","nuclearity":"NN"},{"parent":336,"left":320,"right":335,"relation":"elaboration","nuclearity":"NS"},{"parent":320,"left":318,"right":319,"relation":"attribution","nuclearity":"SN"},{"parent":318,"left":317,"right":147,"relation":"same-unit","nuclearity":"NN"},{"parent":317,"left":145,"right":146,"relation":"adversative","nuclearity":"NS"},{"parent":319,"left":148,"right":149,"relation":"attribution","nuclearity":"SN"},{"parent":335,"left":325,"right":334,"relation":"elaboration","nuclearity":"NS"},{"parent":325,"left":324,"right":155,"relation":"attribution","nuclearity":"NS"},{"parent":324,"left":150,"right":323,"relation":"attribution","nuclearity":"SN"},{"parent":323,"left":151,"right":322,"relation":"same-unit","nuclearity":"NN"},{"parent":322,"left":152,"right":321,"relation":"condition","nuclearity":"SN"},{"parent":321,"left":153,"right":154,"relation":"mode","nuclearity":"NS"},{"parent":334,"left":333,"right":165,"relation":"attribution","nuclearity":"NS"},{"parent":333,"left":328,"right":332,"relation":"explanation","nuclearity":"NS"},{"parent":328,"left":156,"right":327,"relation":"explanation","nuclearity":"SN"},{"parent":327,"left":157,"right":326,"relation":"elaboration","nuclearity":"NS"},{"parent":326,"left":158,"right":159,"relation":"attribution","nuclearity":"SN"},{"parent":332,"left":329,"right":331,"relation":"explanation","nuclearity":"NS"},{"parent":329,"left":160,"right":161,"relation":"elaboration","nuclearity":"NS"},{"parent":331,"left":330,"right":164,"relation":"same-unit","nuclearity":"NN"},{"parent":330,"left":162,"right":163,"relation":"elaboration","nuclearity":"NS"},{"parent":344,"left":338,"right":343,"relation":"adversative","nuclearity":"NN"},{"parent":338,"left":166,"right":337,"relation":"attribution","nuclearity":"SN"},{"parent":337,"left":167,"right":168,"relation":"elaboration","nuclearity":"NS"},{"parent":343,"left":342,"right":174,"relation":"attribution","nuclearity":"NS"},{"parent":342,"left":341,"right":173,"relation":"same-unit","nuclearity":"NN"},{"parent":341,"left":169,"right":340,"relation":"elaboration","nuclearity":"NS"},{"parent":340,"left":170,"right":339,"relation":"attribution","nuclearity":"SN"},{"parent":339,"left":171,"right":172,"relation":"elaboration","nuclearity":"NS"}]}