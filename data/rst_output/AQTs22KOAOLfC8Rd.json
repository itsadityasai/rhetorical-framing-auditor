{"article_id":"AQTs22KOAOLfC8Rd","edus":[{"id":0,"text":"It 's difficult to keep your distance in a grocery store or pharmacy ,","depth":5},{"id":1,"text":"so now the CDC says","depth":6},{"id":2,"text":"we should wear a homemade mask in public","depth":7},{"id":3,"text":"to slow the spread of the coronavirus - particularly in areas with high community transmission .","depth":7},{"id":4,"text":"Officials do n't want healthy people using medical masks","depth":6},{"id":5,"text":"because of fears","depth":7},{"id":6,"text":"they would buy them all","depth":9},{"id":7,"text":"( kind of like toilet paper )","depth":9},{"id":8,"text":"and not leave them for health care workers .","depth":8},{"id":9,"text":"The masks do n't need to be professional-grade","depth":7},{"id":10,"text":"to help fight against COVID-19 .","depth":7},{"id":11,"text":"According to recent studies ,","depth":7},{"id":12,"text":"the virus can spread between people in proximity","depth":8},{"id":13,"text":"by coughing , sneezing or even speaking .","depth":8},{"id":14,"text":"It is important to note that covering your face with a piece of cloth wo n't protect you .","depth":4},{"id":15,"text":"But , it could help you from spreading the virus","depth":5},{"id":16,"text":"if you 're like some people","depth":6},{"id":17,"text":"who lack symptoms","depth":7},{"id":18,"text":"and do n't know","depth":8},{"id":19,"text":"they have it .","depth":8},{"id":20,"text":"Sewing your own mask is easy ,","depth":4},{"id":21,"text":"says Jeannette Childers ,","depth":5},{"id":22,"text":"who ' s 77","depth":6},{"id":23,"text":"and lives in Mesa , Arizona .","depth":6},{"id":24,"text":"She ' s among scores of volunteers across the country","depth":5},{"id":25,"text":"sewing masks .","depth":5},{"id":26,"text":"So far , she ' s made 65 .","depth":4},{"id":27,"text":"1 . Cut material and interfacing to 12 x 9 inches","depth":3},{"id":28,"text":"2 . Iron interfacing to material","depth":5},{"id":29,"text":"( adhesive side to back of material )","depth":5},{"id":30,"text":"3 .","depth":6},{"id":31,"text":"Once ironed ,","depth":7},{"id":32,"text":"fold fabric in half","depth":8},{"id":33,"text":"with interfacing on the outside","depth":8},{"id":34,"text":"4 . Cut two pieces of elastic","depth":7},{"id":35,"text":"- each 7-inches long","depth":7},{"id":36,"text":"5 . Pin","depth":8},{"id":37,"text":"and sew 1/4-inch from edge","depth":9},{"id":38,"text":"leaving a 2-inch gap in the center","depth":9},{"id":39,"text":"6 . Put elastic band on each corner , inside the material","depth":10},{"id":40,"text":"and pin","depth":12},{"id":41,"text":"to keep in place ,","depth":12},{"id":42,"text":"making sure","depth":12},{"id":43,"text":"the elastic is not twisted .","depth":12},{"id":44,"text":"Pinning in center as well","depth":9},{"id":45,"text":"7 .","depth":11},{"id":46,"text":"Using the pattern ,","depth":12},{"id":47,"text":"mark locations of pleat lines","depth":12},{"id":48,"text":"and add pins on both sides","depth":10},{"id":49,"text":"8 . Fold 3 pleats .","depth":10},{"id":50,"text":"Sew around the entire perimeter of the mask ,","depth":11},{"id":51,"text":"this holds the pleats in place ,","depth":12},{"id":52,"text":"and closes the 2-inch gap","depth":12},{"id":53,"text":"All","depth":6},{"id":54,"text":"you have to do","depth":6},{"id":55,"text":"is remove the pins ,","depth":5},{"id":56,"text":"test out your new mask","depth":5},{"id":57,"text":"and head out","depth":6},{"id":58,"text":"to do your grocery shopping or wherever might make social distancing difficult .","depth":6},{"id":59,"text":"While you ' re at it ,","depth":6},{"id":60,"text":"make extra","depth":7},{"id":61,"text":"to donate .","depth":7},{"id":62,"text":"The cloth face coverings","depth":7},{"id":63,"text":"recommended","depth":7},{"id":64,"text":"are not surgical masks or N-95 respirators ,","depth":7},{"id":65,"text":"which are critical supplies","depth":8},{"id":66,"text":"that must continue to be reserved for health care workers .","depth":8},{"id":67,"text":"Angelica Jaramillo Harding , a nurse in Mesa , Arizona , picks up donated masks from a Joann fabric and Craft store every Friday","depth":7},{"id":68,"text":"to distribute at hospitals , medical centers and clinics .","depth":7},{"id":69,"text":"Last week , she gave away 350 of them .","depth":6},{"id":70,"text":"Since March 23 , Joann stores nationwide have been providing supplies","depth":8},{"id":71,"text":"to make masks for free","depth":9},{"id":72,"text":"if you donate the finished products .","depth":9},{"id":73,"text":"Since then , they ' ve donated more than 16 million .","depth":7},{"id":74,"text":"\" We ' re definitely touched by the community , \"","depth":8},{"id":75,"text":"Harding said .","depth":8},{"id":76,"text":"\" It helps us not to feel alone in this . \"","depth":7}],"relations":[{"parent":153,"left":103,"right":152,"relation":"joint","nuclearity":"NN"},{"parent":103,"left":96,"right":102,"relation":"elaboration","nuclearity":"NS"},{"parent":96,"left":90,"right":95,"relation":"evaluation","nuclearity":"NS"},{"parent":90,"left":80,"right":89,"relation":"explanation","nuclearity":"NS"},{"parent":80,"left":0,"right":79,"relation":"causal","nuclearity":"SN"},{"parent":79,"left":1,"right":78,"relation":"attribution","nuclearity":"SN"},{"parent":78,"left":2,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":89,"left":84,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":4,"right":83,"relation":"causal","nuclearity":"NS"},{"parent":83,"left":5,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":81,"right":8,"relation":"joint","nuclearity":"NN"},{"parent":81,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":88,"left":85,"right":87,"relation":"explanation","nuclearity":"NS"},{"parent":85,"left":9,"right":10,"relation":"purpose","nuclearity":"NS"},{"parent":87,"left":11,"right":86,"relation":"attribution","nuclearity