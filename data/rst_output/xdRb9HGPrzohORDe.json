{"article_id":"xdRb9HGPrzohORDe","edus":[{"id":0,"text":"President Obama repeated this line or a variation of it many times during the campaign","depth":6},{"id":1,"text":"to pass his landmark health care bill :","depth":6},{"id":2,"text":"`` If you like your health care plan ,","depth":6},{"id":3,"text":"you 'll be able to keep your health care plan , period . ''","depth":6},{"id":4,"text":"But","depth":6},{"id":5,"text":"while that might be true for people","depth":8},{"id":6,"text":"who get health insurance through their employer ,","depth":8},{"id":7,"text":"it 's not true for many people","depth":8},{"id":8,"text":"who buy their policies in the individual market","depth":9},{"id":9,"text":"- about 5 percent of the nation 's policyholders .","depth":9},{"id":10,"text":"At a congressional hearing on Capitol Hill Wednesday , Health and Human Services Secretary Kathleen Sebelius said","depth":7},{"id":11,"text":"the president had not broken his promise .","depth":7},{"id":12,"text":"But that claim has been called into question by the hundreds of thousands of cancellation notices","depth":7},{"id":13,"text":"sent to policyholders across the country .","depth":7},{"id":14,"text":"Blue Shield of California recently sent out those notices to more than half of its individual customers ,","depth":5},{"id":15,"text":"telling them","depth":6},{"id":16,"text":"they need to buy more comprehensive policies","depth":7},{"id":17,"text":"because of the Affordable Care Act .","depth":7},{"id":18,"text":"`` As a result of introducing those new health plans ,","depth":7},{"id":19,"text":"we could no longer offer the plan","depth":8},{"id":20,"text":"that they were currently in , ''","depth":8},{"id":21,"text":"says Steve Shivinsky , a Blue Shield California spokesman .","depth":6},{"id":22,"text":"He says","depth":6},{"id":23,"text":"those plans will end Dec. 31 .","depth":6},{"id":24,"text":"Jamie Walters ,","depth":7},{"id":25,"text":"who grows corn on 3,000 acres west of Chicago ,","depth":7},{"id":26,"text":"got a similar letter from his insurer , Blue Cross Blue Shield of Illinois .","depth":6},{"id":27,"text":"His old policy ,","depth":8},{"id":28,"text":"Walters says ,","depth":8},{"id":29,"text":"covered him and his wife and three young children for $ 585 a month with a $ 5,200 family deductible .","depth":7},{"id":30,"text":"He says","depth":8},{"id":31,"text":"he got a rude surprise","depth":10},{"id":32,"text":"when he went shopping for a new plan on HealthCare.gov :","depth":10},{"id":33,"text":"The cheapest plan will cost him $ 902 a month .","depth":9},{"id":34,"text":"`` That plan ,","depth":10},{"id":35,"text":"that costs us over 50 percent more a month ,","depth":10},{"id":36,"text":"changes our deductible from $ 5,200 to $ 12,700 , ''","depth":9},{"id":37,"text":"Walters says .","depth":8},{"id":38,"text":"Part of the reason","depth":8},{"id":39,"text":"it 's so expensive","depth":8},{"id":40,"text":"is that Walters makes too much money","depth":8},{"id":41,"text":"to qualify for any government subsidies .","depth":8},{"id":42,"text":"For a family of four , the subsidies cut off at $ 96,000 per year in modified adjusted gross income .","depth":6},{"id":43,"text":"`` I think","depth":8},{"id":44,"text":"you 'll find","depth":8},{"id":45,"text":"that many small business owners , young professional families , families with dual incomes , etc. , will not qualify for subsidies ,","depth":8},{"id":46,"text":"because the income limits really are very much smack in the middle of the middle class , ''","depth":8},{"id":47,"text":"Walters says .","depth":6},{"id":48,"text":"As for his thoughts on Obama 's claim","depth":6},{"id":49,"text":"that those","depth":8},{"id":50,"text":"who liked their plan","depth":8},{"id":51,"text":"could keep it ,","depth":7},{"id":52,"text":"Walter says ,","depth":6},{"id":53,"text":"`` I do n't know","depth":7},{"id":54,"text":"how you can call it anything but untruthful . ''","depth":7},{"id":55,"text":"Sebelius defended the president at Wednesday 's hearing .","depth":6},{"id":56,"text":"Most consumers in the individual market ,","depth":9},{"id":57,"text":"she said ,","depth":9},{"id":58,"text":"will end up better off .","depth":8},{"id":59,"text":"`` A lot of people will have a much better plan at a similar or lower cost , ''","depth":8},{"id":60,"text":"Sebelius said .","depth":8},{"id":61,"text":"`` Fifty percent of these 11 to 12 million people qualify for a subsidy ,","depth":7},{"id":62,"text":"qualify for financial help","depth":8},{"id":63,"text":"purchasing insurance , for the first time ever . ''","depth":8},{"id":64,"text":"Johanna Humbert of Galien , Mich. , is one of those people .","depth":7},{"id":65,"text":"She recently got a letter from her insurance carrier , Aetna ,","depth":11},{"id":66,"text":"saying","depth":12},{"id":67,"text":"her coverage was being cancelled .","depth":12},{"id":68,"text":"So she went shopping on HealthCare.gov .","depth":10},{"id":69,"text":"`` And","depth":11},{"id":70,"text":"once I got through the few glitches","depth":14},{"id":71,"text":"that everyone is experiencing ,","depth":14},{"id":72,"text":"I was pleased to see","depth":13},{"id":73,"text":"that I could get a subsidy","depth":13},{"id":74,"text":"to help pay for my insurance , ''","depth":13},{"id":75,"text":"Humbert says .","depth":10},{"id":76,"text":"Humbert ,","depth":12},{"id":77,"text":"who makes between $ 30,000 and $ 40,000 a year as a freelance fundraiser for non-profits ,","depth":12},{"id":78,"text":"found a policy similar to her old one .","depth":11},{"id":79,"text":"The deductible is about the same ,","depth":11},{"id":80,"text":"but the monthly premium of approximately $ 275 a month is about half what she paid before .","depth":11},{"id":81,"text":"And ,","depth":10},{"id":82,"text":"she says ,","depth":11},{"id":83,"text":"`` I am very pleased with it . ''","depth":11},{"id":84,"text":"As for that claim","depth":4},{"id":85,"text":"- that nobody with insurance would have to give it up -","depth":4},{"id":86,"text":"Humbert says","depth":3},{"id":87,"text":"she thinks","depth":3},{"id":88,"text":"the president was not fully informed .","depth":3}],"relations":[{"parent":177,"left":172,"right":176,"relation":"elaboration","nuclearity":"NS"},{"parent":172,"left":112,"right":171,"relation":"elaboration","nuclearity":"NS"},{"parent":112,"left":102,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":92,"right":101,"relation":"adversative","nuclearity":"SN"},{"parent":92,"left":90,"right":91,"relation":"attribution","nuclearity":"SN"},{"parent":90,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":91,"left":2,"right":3,"relation":"condition","nuclearity":"SN"},{"parent":101,"left":97,"right":100,"relation":"adversative","nuclearity":"SN"},{"parent":97,"left":4,"right":96,"relation":"same-unit","nuclearity":"NN"},{"parent":96,"left":93,"right":95,"relation":"adversative","nuclearity":"NN"},{"parent":93,"left":5,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":95,"left":7,"right":94,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":8,"right":9,"relation":"restatement","nuclearity":"NN"},{"parent":100,"left":98,"right":99,"relation":"adversative","nuclearity":"NN"},{"parent":98,"left":10,"right":11,"relation":"attribution","nuclearity":"SN"},{"parent":99,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":111,"left":105,"right":110,"relation":"elaboration","nuclearity":"NS"},{"parent":105,"left":14,"right":104,"relation":"elaboration","nuclearity":"NS"},{"parent":104,"left":15,"right":103,"relation":"attribution","nuclearity":"SN"},{"parent":103,"left":16,"right":17,"relation":"explanation","nuclearity":"NS"},{"parent":110,"left":108,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":108,"left":107,"right":21,"relation":"attribution","nuclearity":"NS"},{"parent":107,"left":18,"right":106,"relation":"cau