{"article_id":"gS1EeNx9dWzsFSP1","edus":[{"id":0,"text":"UPDATE II :","depth":6},{"id":1,"text":"Booker 's entire charade has been exposed .","depth":6},{"id":2,"text":"The documents were cleared for publication at 4 a.m. this morning .","depth":6},{"id":3,"text":"Update here .","depth":6},{"id":4,"text":"Now , Grassley 's office has formally released the committee confidential emails","depth":7},{"id":5,"text":"that Booker published earlier ,","depth":7},{"id":6,"text":"along with other Kavanaugh docs","depth":7},{"id":7,"text":"Dems had asked","depth":8},{"id":8,"text":"to be made public .","depth":8},{"id":9,"text":"It was n't immediately clear if this would affect Booker 's possible liability","depth":5},{"id":10,"text":"https : //t.co/21tnqdbK9f","depth":4},{"id":11,"text":"- Zoe Tillman","depth":6},{"id":12,"text":"( @ ZoeTillman )","depth":6},{"id":13,"text":"September 6 , 2018","depth":5},{"id":14,"text":"The third day of Judge Brett Kavanaugh 's hearing","depth":6},{"id":15,"text":"to become the next Supreme Court Justice","depth":6},{"id":16,"text":"got off to a wild start Thursday morning .","depth":5},{"id":17,"text":"Democrat Cory Booker vowed to break Senate rules","depth":7},{"id":18,"text":"by releasing confidential Committee documents","depth":7},{"id":19,"text":"and dared the Senate to expel him","depth":7},{"id":20,"text":"for knowingly doing so .","depth":7},{"id":21,"text":"Any Senator , officer , or employee of the Senate","depth":8},{"id":22,"text":"who shall disclose the secret or confidential business or proceedings of the Senate ,","depth":9},{"id":23,"text":"including the business and proceedings of the committees , subcommittees , and offices of the Senate ,","depth":9},{"id":24,"text":"shall be liable ,","depth":8},{"id":25,"text":"if a Senator ,","depth":10},{"id":26,"text":"to suffer expulsion from the body ;","depth":10},{"id":27,"text":"and","depth":10},{"id":28,"text":"if an officer or employee ,","depth":11},{"id":29,"text":"to dismissal from the service of the Senate , and to punishment for contempt . .","depth":11},{"id":30,"text":"@ CoryBooker :","depth":10},{"id":31,"text":"\" I am going to release the email about racial profiling","depth":11},{"id":32,"text":"and I understand","depth":12},{"id":33,"text":"that the penalty comes with potential ousting from the Senate. \"","depth":12},{"id":34,"text":"pic.twitter.com/BzFtmNNkUA","depth":9},{"id":35,"text":"- Fox News","depth":10},{"id":36,"text":"( @ FoxNews )","depth":10},{"id":37,"text":"September 6 , 2018 .","depth":9},{"id":38,"text":"@ CoryBooker :","depth":9},{"id":39,"text":"\" I sincerely believe","depth":10},{"id":40,"text":"that the public deserves to know this nominee ' s record. \"","depth":10},{"id":41,"text":"https : //t.co/akz4tCODv8","depth":10},{"id":42,"text":"pic.twitter.com/c11xp199N0","depth":10},{"id":43,"text":"- Fox News","depth":11},{"id":44,"text":"( @ FoxNews )","depth":11},{"id":45,"text":"September 6 , 2018","depth":10},{"id":46,"text":"The emails","depth":6},{"id":47,"text":"Booker is referring to","depth":6},{"id":48,"text":"are from Kavanaugh 's time at the White House after 9/11","depth":6},{"id":49,"text":"when he discussed the use of racial profiling in the age of terrorism .","depth":6},{"id":50,"text":"Other Democrat Senators joined Booker","depth":8},{"id":51,"text":"and encouraged their Republican colleagues to also expel them from the body","depth":9},{"id":52,"text":"for knowingly breaking Senate rules .","depth":9},{"id":53,"text":"In addition , they argued","depth":8},{"id":54,"text":"that","depth":9},{"id":55,"text":"because they do n't believe","depth":11},{"id":56,"text":"the Kavanaugh nomination is legitimate ,","depth":11},{"id":57,"text":"they do n't have to follow the rules .","depth":10},{"id":58,"text":"Whitehouse :","depth":8},{"id":59,"text":"' I do not recognize the legitimacy of this hearing","depth":9},{"id":60,"text":"so I do n't have to follow the rules . '","depth":9},{"id":61,"text":"- Chad Felix Greene","depth":9},{"id":62,"text":"( @ chadfelixg )","depth":9},{"id":63,"text":"September 6 , 2018","depth":8},{"id":64,"text":"Eventually through proper Committee processes , the email in question was allowed to be released .","depth":8},{"id":65,"text":"I 've said it before","depth":10},{"id":66,"text":"and I 'll say it again :","depth":10},{"id":67,"text":"I will happily work with any of my colleagues from across the aisle","depth":10},{"id":68,"text":"to go through the necessary steps and processes","depth":11},{"id":69,"text":"to try and get specific classified documents released to the public .","depth":11},{"id":70,"text":"# Kavanaugh # SCOTUS","depth":8},{"id":71,"text":"- Mike Lee","depth":10},{"id":72,"text":"( @ SenMikeLee )","depth":10},{"id":73,"text":"September 6 , 2018","depth":9},{"id":74,"text":"Mike Lee :","depth":8},{"id":75,"text":"I sometimes hate our rules and laws , too .","depth":9},{"id":76,"text":"But","depth":10},{"id":77,"text":"if we don ' t like them ,","depth":11},{"id":78,"text":"we need to respect the process","depth":12},{"id":79,"text":"and change the rules and laws","depth":13},{"id":80,"text":"( not break them ) .","depth":13},{"id":81,"text":"- Guy Benson","depth":9},{"id":82,"text":"( @ guypbenson )","depth":9},{"id":83,"text":"September 6 , 2018","depth":8},{"id":84,"text":"Booker Confidential - Kavanaugh Hearing by Senator Cory Booker on Scribd","depth":1}],"relations":[{"parent":169,"left":168,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":168,"left":98,"right":167,"relation":"elaboration","nuclearity":"NS"},{"parent":98,"left":94,"right":97,"relation":"attribution","nuclearity":"NS"},{"parent":94,"left":88,"right":93,"relation":"context","nuclearity":"SN"},{"parent":88,"left":86,"right":87,"relation":"organization","nuclearity":"SN"},{"parent":86,"left":0,"right":1,"relation":"organization","nuclearity":"SN"},{"parent":87,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"