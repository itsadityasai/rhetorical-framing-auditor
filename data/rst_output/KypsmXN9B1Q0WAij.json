{"article_id":"KypsmXN9B1Q0WAij","edus":[{"id":0,"text":"The platform briefly blocked some of Warren ' s ads","depth":6},{"id":1,"text":"attacking it .","depth":6},{"id":2,"text":"Her response :","depth":6},{"id":3,"text":"' Curious why I think","depth":7},{"id":4,"text":"FB has too much power ? '","depth":7},{"id":5,"text":"Elizabeth Warren could not have asked for a better illustration for her point .","depth":4},{"id":6,"text":"The US senator and Democratic candidate for president took aim at Facebook on Monday evening","depth":5},{"id":7,"text":"after the social network briefly blocked her campaign from running advertisements","depth":6},{"id":8,"text":"that just happened to call for breaking up Facebook .","depth":6},{"id":9,"text":"\" Curious why I think","depth":7},{"id":10,"text":"FB has too much power ? \" ,","depth":7},{"id":11,"text":"Warren said on Twitter .","depth":6},{"id":12,"text":"\" Let ' s start with their ability","depth":8},{"id":13,"text":"to shut down a debate","depth":9},{"id":14,"text":"over whether FB has too much power .","depth":9},{"id":15,"text":"Thanks for restoring my posts .","depth":7},{"id":16,"text":"But I want a social media marketplace","depth":8},{"id":17,"text":"that isn ' t dominated by a single censor .","depth":8},{"id":18,"text":"# BreakUpBigTech . \"","depth":7},{"id":19,"text":"The dustup began","depth":4},{"id":20,"text":"when Politico reported","depth":5},{"id":21,"text":"that Facebook had blocked a number of Facebook ads","depth":6},{"id":22,"text":"that promoted Warren ' s newly announced plan","depth":7},{"id":23,"text":"to break up major tech companies ,","depth":8},{"id":24,"text":"which","depth":10},{"id":25,"text":"she argues","depth":10},{"id":26,"text":"have become too powerful .","depth":9},{"id":27,"text":"Elizabeth Warren is right","depth":7},{"id":28,"text":"-","depth":7},{"id":29,"text":"we must break up Facebook , Google and Amazon |","depth":6},{"id":30,"text":"Robert Reich","depth":5},{"id":31,"text":"Read more","depth":6},{"id":32,"text":"\" Three companies have vast power over our economy and our democracy , \"","depth":10},{"id":33,"text":"the ads read ,","depth":10},{"id":34,"text":"according to Politico .","depth":9},{"id":35,"text":"\" Facebook , Amazon , and Google .","depth":10},{"id":36,"text":"We all use them .","depth":10},{"id":37,"text":"But in their rise to power , they ' ve bulldozed competition ,","depth":10},{"id":38,"text":"used our private information for profit ,","depth":11},{"id":39,"text":"and tilted the playing field in their favor . \"","depth":11},{"id":40,"text":"The idea","depth":10},{"id":41,"text":"that Facebook might be censoring political speech contrary to its interests","depth":10},{"id":42,"text":"proved irresistible to many Facebook critics ,","depth":9},{"id":43,"text":"but the company said","depth":11},{"id":44,"text":"there was a much more mundane explanation .","depth":11},{"id":45,"text":"\" We removed the ads","depth":13},{"id":46,"text":"because they violated our policies against use of our corporate logo , \"","depth":13},{"id":47,"text":"a spokesperson told Politico .","depth":12},{"id":48,"text":"\" In the interest","depth":13},{"id":49,"text":"of allowing robust debate ,","depth":13},{"id":50,"text":"we are restoring the ads . \"","depth":12},{"id":51,"text":"Facebook ' s policies limit the extent","depth":10},{"id":52,"text":"to which advertisers can reference Facebook or Instagram in the text or imagery .","depth":10},{"id":53,"text":"Whether Facebook ' s brief censorship \" shut down a debate \"","depth":6},{"id":54,"text":"is questionable :","depth":7},{"id":55,"text":"numerous other Warren advertisements with a similar anti-tech message remained active during the brief block .","depth":7},{"id":56,"text":"Warren has staked out an aggressive stance","depth":3},{"id":57,"text":"on regulating major tech companies .","depth":3},{"id":58,"text":"After unveiling her plan for anti-trust action on Friday ,","depth":4},{"id":59,"text":"she appeared at the South by Southwest","depth":7},{"id":60,"text":"( SXSW )","depth":7},{"id":61,"text":"festival in Austin , Texas , over the weekend ,","depth":6},{"id":62,"text":"where she voiced her anti-monopolist message before a generally tech-heavy crowd .","depth":5},{"id":63,"text":"\" This only affects tech monopolists , \"","depth":6},{"id":64,"text":"she said of her plan ,","depth":6},{"id":65,"text":"according to Variety .","depth":5},{"id":66,"text":"\" Less monopoly profits ?","depth":5},{"id":67,"text":"Boo hoo . \"","depth":5}],"relations":[{"parent":135,"left":123,"right":134,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":86,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":86,"left":73,"right":85,"relation":"evaluation","nuclearity":"NS"},{"parent":73,"left":72,"right":5,"relation":"evaluation","nuclearity":"NS"},{"parent":72,"left":69,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":2,"right":70,"relation":"attribution","nuclearity":"SN"},{"parent":70,"left":3,"right":4,"relation":"attribution","nuclearity":"SN"},{"parent":85,"left":75,"right":84,"relation":"evaluation","nuclearity":"NS"},{"parent":75,"left":6,"right":74,"relation":"context","nuclearity":"NS"},{"parent":74,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":77,"right":83,"relation":"adversative","nuclearity":"SN"},{"parent":77,"left":76,"right":11,"relation":"attribution","nuclearity":"NS"},{"parent":76,"left":9,"right":10,"relation":"attribution","nuclearity":"SN"},{"parent":83,"left":80,"right":82,"relation":"organization","nuclearity":"SN"},{"parent":80,"left":79,"right":15,"relation":"organization","nuclearity":"NS"},{"parent":79,"left":12,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":81,