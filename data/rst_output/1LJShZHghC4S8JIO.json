{"article_id":"1LJShZHghC4S8JIO","edus":[{"id":0,"text":"The US is to send an additional 2,000 troops to its border with Mexico ,","depth":7},{"id":1,"text":"the Pentagon has announced .","depth":7},{"id":2,"text":"It will bring the total number of troops","depth":8},{"id":3,"text":"stationed on the southern border","depth":8},{"id":4,"text":"to about 4,300 .","depth":7},{"id":5,"text":"The Pentagon said","depth":6},{"id":6,"text":"the soldiers would help border-patrol agents ,","depth":7},{"id":7,"text":"carry out surveillance work","depth":8},{"id":8,"text":"and install miles of razor wire .","depth":8},{"id":9,"text":"It comes","depth":6},{"id":10,"text":"as President Donald Trump battles Congress for funds","depth":8},{"id":11,"text":"to build a wall along the border .","depth":8},{"id":12,"text":"He says","depth":8},{"id":13,"text":"such a measure is needed","depth":9},{"id":14,"text":"to stop illegal immigration .","depth":9},{"id":15,"text":"Mr Trump 's insistence","depth":7},{"id":16,"text":"that the lower house of Congress ,","depth":9},{"id":17,"text":"now controlled by his Democratic opponents ,","depth":9},{"id":18,"text":"include funds for the wall in the US budget recently led to the longest government shutdown in US history .","depth":8},{"id":19,"text":"He struck a temporary deal last month","depth":9},{"id":20,"text":"to reopen government departments","depth":9},{"id":21,"text":"but has threatened to trigger another shutdown","depth":10},{"id":22,"text":"or declare a national emergency","depth":10},{"id":23,"text":"if his demands are not met .","depth":9},{"id":24,"text":"The current agreement expires on 15 February .","depth":7},{"id":25,"text":"Mr Trump is expected to again highlight the issue in his annual State of the Union speech on Tuesday .","depth":3},{"id":26,"text":"The US defence department said","depth":6},{"id":27,"text":"3,750 extra soldiers would be sent to the border ,","depth":7},{"id":28,"text":"although many will replace troops already there .","depth":7},{"id":29,"text":"The first deployments took place in November .","depth":5},{"id":30,"text":"`` Additional units are being deployed for 90 days ,","depth":7},{"id":31,"text":"and we will continue to evaluate the force composition","depth":8},{"id":32,"text":"required to meet the mission","depth":9},{"id":33,"text":"to protect and secure the southern border , ''","depth":9},{"id":34,"text":"a Pentagon statement said .","depth":6},{"id":35,"text":"Their tasks will include `` a mobile surveillance capability through the end of September 2019 , as well as the emplacement of approximately 150 miles of concertina wire between ports of entry '' .","depth":5},{"id":36,"text":"Last Thursday , President Trump tweeted","depth":7},{"id":37,"text":"that extra forces were being sent to the border","depth":8},{"id":38,"text":"to stop migrants","depth":9},{"id":39,"text":"who","depth":11},{"id":40,"text":"he said","depth":11},{"id":41,"text":"were travelling in `` caravans ''","depth":11},{"id":42,"text":"and threatening an `` invasion '' .","depth":11},{"id":43,"text":"He reiterated his claims on Sunday","depth":7},{"id":44,"text":"tweeting :","depth":8},{"id":45,"text":"`` If there is no wall","depth":9},{"id":46,"text":"there is no security . ''","depth":9},{"id":47,"text":"Mr Trump has repeatedly described the situation on the Mexican border as a `` crisis '' ,","depth":6},{"id":48,"text":"although his critics have dismissed the use of troops as a political stunt .","depth":6},{"id":49,"text":"Mr Trump is , however , not the first US president","depth":6},{"id":50,"text":"to send troops to the border with Mexico .","depth":6},{"id":51,"text":"President Barack Obama sent some 1,200 National Guard soldiers","depth":7},{"id":52,"text":"to guard the boundary","depth":7},{"id":53,"text":"while President George W Bush deployed about 6,000 troops","depth":7},{"id":54,"text":"to help Border Patrol agents","depth":8},{"id":55,"text":"in what was called Operation Jump Start .","depth":8},{"id":56,"text":"Officials in Texas recently revealed","depth":5},{"id":57,"text":"that nine migrants on hunger strike at an immigration detention centre were being force-fed .","depth":5},{"id":58,"text":"Immigration officials are using plastic nasal tubes","depth":6},{"id":59,"text":"to feed some of the men ,","depth":6},{"id":60,"text":"but relatives say","depth":6},{"id":61,"text":"it is causing severe nosebleeds and vomiting .","depth":6},{"id":62,"text":"The detainees have refused food in protest against conditions at the El Paso Processing Center .","depth":3},{"id":63,"text":"Immigration and Customs Enforcement","depth":5},{"id":64,"text":"( ICE )","depth":5},{"id":65,"text":"says","depth":4},{"id":66,"text":"a federal judge authorised the force-feeding last month .","depth":3}],"relations":[{"parent":133,"left":122,"right":132,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":92,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":92,"left":91,"right":25,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":75,"right":90,"relation":"context","nuclearity":"NS"},{"parent":75,"left":71,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":68,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":0,"right":1,"relation":"attribution","nuclearity":"NS"},{"parent":70,"left":69,"right":4,"relation":"same-unit","nuclearity":"NN"},{"parent":69,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":5,"right":73,"relation":"attribution","nuclearity":"SN"},{"parent":73,"left":6,"right":72,"relation":"joint","nuclearity":"NN"},{"parent":72,"left":7,"right":8,"relation":"joint","nuclearity":"NN"},{"parent":90,"left":80,"right":89,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":9,"right":79,"relation":"context","nuclearity":"NS"},{"parent":79,"left":76,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left"