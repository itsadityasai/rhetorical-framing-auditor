{"article_id":"37QwWJczeisVJ7Oj","edus":[{"id":0,"text":"George Papadopoulos , the former Trump campaign adviser","depth":6},{"id":1,"text":"recently sentenced to two weeks in jail","depth":7},{"id":2,"text":"for lying to investigators ,","depth":7},{"id":3,"text":"says","depth":5},{"id":4,"text":"Attorney General Jeff Sessions was \" quite enthusiastic \" during the 2016 campaign about the prospect of a summit between President Trump and Russian President Vladimir Putin .","depth":4},{"id":5,"text":"Mr. Papadopoulos said","depth":5},{"id":6,"text":"that at a roundtable of campaign officials in 2016 , he told the table","depth":6},{"id":7,"text":"he had a connection","depth":7},{"id":8,"text":"who could establish a summit between Mr. Trump and Mr. Putin .","depth":7},{"id":9,"text":"President Trump , then a candidate , nodded at him","depth":8},{"id":10,"text":"and didn ' t seem committed ,","depth":8},{"id":11,"text":"but Mr . Sessions seemed \" quite enthusiastic \" about the prospect of a Trump-Putin summit ,","depth":7},{"id":12,"text":"Mr. Papadopoulos said Sunday on ABC ' s \" This Week . \"","depth":6},{"id":13,"text":"Mr . Sessions has testified","depth":6},{"id":14,"text":"that he pushed back on the idea .","depth":6},{"id":15,"text":"\" All","depth":5},{"id":16,"text":"I can say","depth":5},{"id":17,"text":"is this was a meeting from about two years ago","depth":5},{"id":18,"text":"- my recollection differs from Jeff Sessions ' , \"","depth":5},{"id":19,"text":"Mr. Papadopoulos said .","depth":3},{"id":20,"text":"On Friday , Mr. Papadopoulos was sentenced to two weeks in prison","depth":4},{"id":21,"text":"for lying to investigators","depth":5},{"id":22,"text":"probing Russian interference in the 2016 election .","depth":5},{"id":23,"text":"He pleaded guilty in October 2017 to lying to federal investigators about his contacts with Joseph Mifsud , a London-based professor","depth":4},{"id":24,"text":"who supposedly told him in 2016","depth":5},{"id":25,"text":"that Russia had damaging information on Hillary Clinton , Mr. Trump ' s Democratic opponent .","depth":5},{"id":26,"text":"Mr. Papadopoulos said Sunday","depth":5},{"id":27,"text":"he had no recollection","depth":6},{"id":28,"text":"of sending an email about the possible dirt to John Mashburn , a Trump campaign and White House official","depth":8},{"id":29,"text":"who has reportedly testified to congressional investigators","depth":8},{"id":30,"text":"he thought","depth":8},{"id":31,"text":"he got such an alert about possible Clinton dirt from Mr. Papadopoulos .","depth":8},{"id":32,"text":"\" If I did send an email ,","depth":8},{"id":33,"text":"and especially if others were copied on it ,","depth":8},{"id":34,"text":"I ' m sure","depth":8},{"id":35,"text":"that evidence would have [ been ] introduced by now , \"","depth":8},{"id":36,"text":"Mr. Papadopoulos said .","depth":6},{"id":37,"text":"\" If that email was sent ,","depth":6},{"id":38,"text":"even if I deleted it ,","depth":7},{"id":39,"text":"if that ' s what people believe","depth":9},{"id":40,"text":"I did ,","depth":9},{"id":41,"text":"there would be a copy somewhere else . \"","depth":8},{"id":42,"text":"He said","depth":6},{"id":43,"text":"he has no idea","depth":7},{"id":44,"text":"if special counsel Robert Mueller ' s investigation will reveal","depth":8},{"id":45,"text":"that there was actual collusion between Russian officials and the Trump campaign .","depth":8},{"id":46,"text":"\" All","depth":9},{"id":47,"text":"I can say","depth":9},{"id":48,"text":"is that my testimony might have helped move something towards that ,","depth":8},{"id":49,"text":"but I have no idea , \"","depth":7},{"id":50,"text":"he said .","depth":6},{"id":51,"text":"Mr. Trump himself has repeatedly said","depth":5},{"id":52,"text":"there was \" no collusion . \"","depth":5}],"relations":[{"parent":105,"left":72,"right":104,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":67,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":57,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":57,"left":56,"right":4,"relation":"attribution","nuclearity":"SN"},{"parent":56,"left":55,"right":3,"relation":"same-unit","nuclearity":"NN"},{"parent":55,"left":0,"right":54,"relation":"elaboration","nuclearity":"NS"},{"parent":54,"left":1,"right":2,"relation":"causal","nuclearity":"NS"},{"parent":66,"left":60,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":5,"right":59,"relation":"attribution","nuclearity":"SN"},{"parent":59,"left":6,"right":58,"relation":"attribution","nuclearity":"SN"},{"parent":58,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":63,"right":64,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":62,"right":12,"relation":"attribution","nuclearity":"NS"},{"parent":62,"left":61,"right":11,"relation":"adversative","nuclearity":"NN"},{"parent":61,"left":9,"right":10,"relation":"joint","nuclearity":"NN"},{"parent":64,"left":13,"right":14,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":70,"right":19,"relation":"attribution","nuclearity":"NS"},{"parent":70,"left":68,"right":69,"relation":"same-unit","nuclearity":"NN"},{"parent":68,"left":15,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":17,"right":18,"relation":"elaboration","nuclearity":"NS"},{"parent":104,"left":77,"right":103,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":74,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":20,"right":73,"relation":"causal","nuclearity":"NS"},{"parent":73,"left":21,"right":22,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":23,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":24,"right":25,"relation":"attribution","nuclearity":"SN"},{"parent":103,"left":92,"right":102,"relation":"joint","nuclearity":"NN"},{"parent":92,"left":82,"right":91,"relation":"elaboration",