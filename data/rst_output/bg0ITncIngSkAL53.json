n","nuclearity":"NS"},{"parent":285,"left":80,"right":284,"relation":"attribution","nuclearity":"SN"},{"parent":284,"left":81,"right":82,"relation":"attribution","nuclearity":"SN"},{"parent":292,"left":288,"right":291,"relation":"joint","nuclearity":"NN"},{"parent":288,"left":287,"right":86,"relation":"attribution","nuclearity":"NS"},{"parent":287,"left":83,"right":286,"relation":"attribution","nuclearity":"SN"},{"parent":286,"left":84,"right":85,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":87,"right":290,"relation":"attribution","nuclearity":"SN"},{"parent":290,"left":88,"right":289,"relation":"attribution","nuclearity":"SN"},{"parent":289,"left":89,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":319,"left":91,"right":318,"relation":"adversative","nuclearity":"NN"},{"parent":318,"left":298,"right":317,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":92,"right":297,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":93,"right":296,"relation":"attribution","nuclearity":"SN"},{"parent":296,"left":94,"right":95,"relation":"elaboration","nuclearity":"NS"},{"parent":317,"left":307,"right":316,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":302,"right":306,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":301,"right":100,"relation":"attribution","nuclearity":"NS"},{"parent":301,"left":96,"right":300,"relation":"joint","nuclearity":"NN"},{"parent":300,"left":299,"right":99,"relation":"purpose","nuclearity":"NS"},{"parent":299,"left":97,"right":98,"relation":"joint","nuclearity":"NN"},{"parent":306,"left":304,"right":305,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":101,"right":303,"relation":"attribution","nuclearity":"SN"},{"parent":303,"left":102,"right":103,"relation":"purpose","nuclearity":"NS"},{"parent":305,"left":104,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":314,"right":315,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"le