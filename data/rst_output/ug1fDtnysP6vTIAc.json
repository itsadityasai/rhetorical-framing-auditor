{"article_id":"ug1fDtnysP6vTIAc","edus":[{"id":0,"text":"Coronavirus cases hit a new record for a single day Thursday :","depth":4},{"id":1,"text":"nearly forty-thousand .","depth":4},{"id":2,"text":"With states like Texas and Florida posting record numbers of new cases of coronavirus this week","depth":5},{"id":3,"text":"health officials warn Americans to continue taking precautions .","depth":5},{"id":4,"text":"Unlike the early months of the pandemic , the majority of new cases are in younger people under the age of 45 .","depth":8},{"id":5,"text":"Most people","depth":10},{"id":6,"text":"who die from the virus","depth":10},{"id":7,"text":"are over age 80 ,","depth":9},{"id":8,"text":"but the fear is still that asymptomatic young people will pass it to older Americans .","depth":7},{"id":9,"text":"`` Usually when we see a spike in positive cases","depth":9},{"id":10,"text":"two weeks later","depth":10},{"id":11,"text":"we often see an increase in hospitalizations ,","depth":10},{"id":12,"text":"four weeks later is when we see a jump in deaths , ''","depth":8},{"id":13,"text":"News Medical Reporter Lorie Johnson told Faith Nation Thursday .","depth":7},{"id":14,"text":"And the CDC estimates","depth":6},{"id":15,"text":"that 20 million Americans have been infected","depth":7},{"id":16,"text":"- roughly 10 times as many","depth":8},{"id":17,"text":"as have been confirmed .","depth":8},{"id":18,"text":"Texas reported more than 17,000 new cases in the last three days and a record of nearly 5,000 hospitalizations .","depth":5},{"id":19,"text":"Gov . Greg Abbott is now pausing the Lone Star State 's re-opening","depth":6},{"id":20,"text":"and halting elective surgeries in the state 's biggest counties .","depth":6},{"id":21,"text":"Florida is in a similar situation ,","depth":6},{"id":22,"text":"reporting more than 114,000 cases total .","depth":6},{"id":23,"text":"Gov . Ron DeSantis says","depth":7},{"id":24,"text":"part of the uptick is due to increased testing .","depth":7},{"id":25,"text":"`` This is mass testing","depth":8},{"id":26,"text":"regardless of symptoms , ''","depth":8},{"id":27,"text":"he explained .","depth":7},{"id":28,"text":"Wearing masks inside businesses is only mandatory in a handful of states ,","depth":6},{"id":29,"text":"but health experts say","depth":7},{"id":30,"text":"they 're a necessary tool","depth":8},{"id":31,"text":"for containing the spread of COVID .","depth":8},{"id":32,"text":"A new model from the University of Washington suggests","depth":6},{"id":33,"text":"wearing masks could save as many as 33,000 lives between now and October .","depth":6},{"id":34,"text":"However , in new hot spots like Arizona , Texas , and Florida resistance to masks is heating up .","depth":5},{"id":35,"text":"`` Are you gon na let the government tell you","depth":9},{"id":36,"text":"you have to wear a mask ?","depth":9},{"id":37,"text":"No ! ''","depth":8},{"id":38,"text":"chanted protesters in Arizona .","depth":7},{"id":39,"text":"`` It 's our bodies ,","depth":9},{"id":40,"text":"it 's our choice","depth":10},{"id":41,"text":"whether we 're gon na wear them , or not wear them .","depth":10},{"id":42,"text":"You guys are overstepping your boundaries 100 percent , ''","depth":8},{"id":43,"text":"said one woman","depth":8},{"id":44,"text":"speaking at a public hearing in Florida .","depth":8},{"id":45,"text":"While masks may be inconvenient ,","depth":4},{"id":46,"text":"Johnson says","depth":5},{"id":47,"text":"there 's research","depth":6},{"id":48,"text":"to suggest","depth":7},{"id":49,"text":"they work .","depth":7},{"id":50,"text":"`` For some reason masks have become political ,","depth":6},{"id":51,"text":"but the research is clear and overwhelming .","depth":6},{"id":52,"text":"Masks prevent transmission by 50 percent ,","depth":6},{"id":53,"text":"so the overwhelming message is","depth":7},{"id":54,"text":"if you go out","depth":9},{"id":55,"text":"and you ca n't social distance","depth":9},{"id":56,"text":"wear a mask , ''","depth":8},{"id":57,"text":"she said .","depth":4},{"id":58,"text":"Teams from the CDC are deploying to hard hit areas","depth":4},{"id":59,"text":"to trace new outbreaks","depth":5},{"id":60,"text":"and reinforce protective measures .","depth":5},{"id":61,"text":"It 's a strategy","depth":5},{"id":62,"text":"officials say","depth":5},{"id":63,"text":"helped slow new infections in North Carolina and Alabama .","depth":4}],"relations":[{"parent":127,"left":108,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":108,"left":81,"right":107,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":65,"right":80,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":0,"right":1,"relation":"organization","nuclearity":"SN"},{"parent":80,"left":66,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":2,"right":3,"relation":"context","nuclearity":"SN"},{"parent":79,"left":75,"right":78,"relation":"joint","nuclearity":"NN"},{"parent":75,"left":70,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":69,"right":8,"relation":"adversative","nuclearity":"SN"},{"parent":69,"left":4,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":67,"right":7,"relation":"same-unit","nuclearity":"NN"},{"parent":67,"left":5,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":73,"right":13,"relation":"attribution","nuclearity":"NS"},{"parent":73,"left":72,"right":12,"relation":"joint","nuclearity":"NN"},{"parent":72,"left":9,"right":71,"relation":"context","nuclearity":"SN"},{"parent":71,"left":10,"right":11,"relation":"context","nuclearity":"SN"},{"parent":78,"left":14,"right":77,"relation":"attribution","nuclearity":"SN"},{"parent":77,"left":15,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":16,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":107,"left":90,"right":106,"relation":"elaboration","nuclearity":"NS"},{"parent"