{"article_id":"NoBgjEJnzPPdZEbh","edus":[{"id":0,"text":"A record high number of voters now oppose the 2010 Affordable Care Act","depth":6},{"id":1,"text":"and a record low number supports it ,","depth":6},{"id":2,"text":"according to the latest poll .","depth":5},{"id":3,"text":"In addition , a majority thinks","depth":6},{"id":4,"text":"the new law will increase their health care costs ,","depth":6},{"id":5,"text":"while few think","depth":6},{"id":6,"text":"it will improve their quality of care .","depth":6},{"id":7,"text":"The new poll finds","depth":8},{"id":8,"text":"59 percent of voters oppose the health care law , up from 55 percent","depth":9},{"id":9,"text":"who opposed it six months ago","depth":10},{"id":10,"text":"( June 2013 ) .","depth":10},{"id":11,"text":"The increase in opposition comes from both independents and Democrats .","depth":7},{"id":12,"text":"Nearly a third of Democrats","depth":9},{"id":13,"text":"-- 30 percent --","depth":9},{"id":14,"text":"oppose the law , up from 22 percent in June .","depth":8},{"id":15,"text":"Opposition among independents went from 53 percent to 64 percent today .","depth":7},{"id":16,"text":"Overall , 36 percent of voters favor the new health care law .","depth":7},{"id":17,"text":"That ' s down from 40 percent in June","depth":8},{"id":18,"text":"and marks a new low .","depth":8},{"id":19,"text":"Sixty-four percent of Democrats , 29 percent of independents and 11 percent of Republicans like the law .","depth":6},{"id":20,"text":"Enrollment in the Obama health care exchanges began October 1","depth":5},{"id":21,"text":"and the requirement","depth":7},{"id":22,"text":"to have qualifying coverage","depth":7},{"id":23,"text":"started January 1 .","depth":6},{"id":24,"text":"Some apparent reasons for opposition to the law include the fact","depth":5},{"id":25,"text":"that majorities think","depth":6},{"id":26,"text":"the new law will increase their taxes","depth":8},{"id":27,"text":"( 63 percent ) ,","depth":8},{"id":28,"text":"increase their insurance costs","depth":9},{"id":29,"text":"( 62 percent )","depth":9},{"id":30,"text":"and increase the federal deficit","depth":9},{"id":31,"text":"( 56 percent ) .","depth":9},{"id":32,"text":"Meanwhile , just one voter in five thinks","depth":7},{"id":33,"text":"Obamacare will increase the quality of their health care","depth":8},{"id":34,"text":"( 19 percent ) .","depth":8},{"id":35,"text":"More than twice as many expect the quality of their care to get worse","depth":8},{"id":36,"text":"( 39 percent )","depth":8},{"id":37,"text":"and another 37percent think","depth":8},{"id":38,"text":"it will stay the same .","depth":8},{"id":39,"text":"By a 44-36 percent margin , voters think","depth":6},{"id":40,"text":"the quality of health care for all Americans will decrease","depth":8},{"id":41,"text":"rather than increase","depth":8},{"id":42,"text":"as a result of the new law .","depth":7},{"id":43,"text":"Voters disapprove of the job","depth":7},{"id":44,"text":"President Obama is doing on health care","depth":7},{"id":45,"text":"by a 59-38 percent margin .","depth":6},{"id":46,"text":"His highest rating on health care was 48 percent approval in September 2012 ,","depth":6},{"id":47,"text":"while his lowest was 36 percent in November 2013 .","depth":6},{"id":48,"text":"Some lawmakers are questioning the security of the health care exchanges","depth":5},{"id":49,"text":"and raise the possibility of identity theft for participants .","depth":5},{"id":50,"text":"The new poll finds","depth":3},{"id":51,"text":"60 percent of voters lack confidence in the website ' s ability","depth":5},{"id":52,"text":"to keep their information private .","depth":5},{"id":53,"text":"Thirty-seven percent are at least somewhat confident ,","depth":5},{"id":54,"text":"including nine percent","depth":6},{"id":55,"text":"who are \" very \" confident .","depth":6},{"id":56,"text":"The poll is based on landline and cell phone interviews with 1,010 randomly chosen registered voters nationwide","depth":4},{"id":57,"text":"and was conducted under the joint direction of Anderson Robbins Research","depth":7},{"id":58,"text":"( D )","depth":7},{"id":59,"text":"and Shaw & Company Research","depth":7},{"id":60,"text":"( R )","depth":7},{"id":61,"text":"from January 19-21 , 2014 .","depth":5},{"id":62,"text":"The full poll has a margin of sampling error of plus or minus three percentage points .","depth":3}],"relations":[{"parent":125,"left":112,"right":124,"relation":"joint","nuclearity":"NN"},{"parent":112,"left":86,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":86,"left":69,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":65,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":64,"right":2,"relation":"attribution","nuclearity":"NS"},{"parent":64,"left":0,"right":1,"relation":"joint","nuclearity":"NN"},{"parent":68,"left":66,"right":67,"relation":"adversative","nuclearity":"NN"},{"parent":66,"left":3,"right":4,"relation":"attribution","nuclearity":"SN"},{"parent":67,"left":5,"right":6,"relation":"attribution","nuclearity":"SN"},{"parent":85,"left":81,"right":84,"relation":"context","nuclearity":"NS"},{"parent":81,"left":77,"right":80,"relation":"context","nuclearity":"NS"},{"parent":77,"left":73,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":72,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":7,"right":71,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":8,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":9,"right":10,"relation":"context","nuclearity":"NS"},{"parent":76,"left":75,"right":15,"relation":"joint","nuclearity":"NN"},{"parent":75,"left":74,"right":14,"relation":"same-unit","nuclearity":"NN"},{"parent":74,"left":12,"right":13,"relation":"restatement","nuclearity":"NS"},{"parent":80,"left":79,"right":19,"relation":"joint","nuclearity":"NN"},{"parent":79,"left":16,"righ