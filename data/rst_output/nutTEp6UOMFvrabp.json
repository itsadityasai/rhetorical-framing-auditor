{"article_id":"nutTEp6UOMFvrabp","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"Sen. Susan Collins","depth":8},{"id":2,"text":"( R-ME ) ,","depth":8},{"id":3,"text":"a moderate","depth":8},{"id":4,"text":"who 's been known to part ways with her party on key hot-button issues ,","depth":8},{"id":5,"text":"threw her support behind embattled Supreme Court nominee Brett Kavanaugh Friday afternoon ,","depth":6},{"id":6,"text":"paving way for his confirmation .","depth":5},{"id":7,"text":"Collins said","depth":7},{"id":8,"text":"the current confirmation process has reached a new low ,","depth":7},{"id":9,"text":"comparing it to a `` gutter-level political campaign . ''","depth":6},{"id":10,"text":"She then went on to shoot down every argument against Kavanaugh ' s judicial style and beliefs ,","depth":6},{"id":11,"text":"explaining why she ' s voting for him","depth":7},{"id":12,"text":"despite the accusations","depth":8},{"id":13,"text":"he has faced .","depth":8},{"id":14,"text":"URGENT :","depth":5},{"id":15,"text":"Susan Collins is a YES","depth":6},{"id":16,"text":"and that means","depth":7},{"id":17,"text":"that Brett Kavanaugh IS going to be the next U.S. Supreme Court Justice","depth":8},{"id":18,"text":"UNLESS Jeff Flake has another weak moment in an elevator before the final vote Saturday at 5pm .","depth":8},{"id":19,"text":"@ SenatorCollins","depth":6},{"id":20,"text":"# SusanCollins","depth":7},{"id":21,"text":"@ JeffFlake","depth":8},{"id":22,"text":"@ CBNNews","depth":8},{"id":23,"text":"- David Brody","depth":7},{"id":24,"text":"( @ TheBrodyFile )","depth":7},{"id":25,"text":"October 5 , 2018","depth":6},{"id":26,"text":"Collins ' announcement comes","depth":6},{"id":27,"text":"after the Senate voted 51-49 Friday morning","depth":8},{"id":28,"text":"to end debate on Kavanaugh 's nomination","depth":8},{"id":29,"text":"following the latest FBI background investigation into the judge 's behavior as a teenager .","depth":7},{"id":30,"text":"That sets up a final vote for Saturday ,","depth":6},{"id":31,"text":"and several key swing votes are now revealing","depth":7},{"id":32,"text":"how they plan to vote .","depth":7},{"id":33,"text":"Meanwhile , Sen. Jeff Flake","depth":8},{"id":34,"text":"( R-AZ )","depth":8},{"id":35,"text":"says","depth":7},{"id":36,"text":"he too will be voting in favor of Kavanaugh ,","depth":7},{"id":37,"text":"barring any unforeseen developments .","depth":7},{"id":38,"text":"Sen. Lisa Murkowski","depth":9},{"id":39,"text":"( R-AK )","depth":9},{"id":40,"text":"says","depth":8},{"id":41,"text":"she may not vote for Kavanaugh","depth":8},{"id":42,"text":"but that she has n't made up her mind .","depth":8},{"id":43,"text":"Sen. Joe Manchin","depth":12},{"id":44,"text":"( D-WV ) ,","depth":12},{"id":45,"text":"who earlier crossed the aisle","depth":13},{"id":46,"text":"to vote in favor","depth":13},{"id":47,"text":"of ending the debate about Kavanaugh ,","depth":12},{"id":48,"text":"confirmed Friday","depth":10},{"id":49,"text":"that he will support Kavanaugh in the final Senate vote ,","depth":10},{"id":50,"text":"calling him a `` qualified jurist . ''","depth":10},{"id":51,"text":"However , Sen. Heidi Heitkamp","depth":11},{"id":52,"text":"( D-ND )","depth":11},{"id":53,"text":"has said","depth":10},{"id":54,"text":"she 'll vote no .","depth":9},{"id":55,"text":"They 're both facing tough reelection battles in states","depth":8},{"id":56,"text":"that voted for Trump .","depth":8},{"id":57,"text":"Tensions have been running high on Capitol Hill .","depth":6},{"id":58,"text":"Police arrested more than 300 people Thursday","depth":8},{"id":59,"text":"for `` unlawfully demonstrating ''","depth":8},{"id":60,"text":"as senators were taking turns","depth":8},{"id":61,"text":"looking at the FBI report inside a secure room .","depth":8},{"id":62,"text":"Although the report is n't expected to be made public ,","depth":7},{"id":63,"text":"Senate Majority Leader Mitch McConnell took to the Senate floor","depth":9},{"id":64,"text":"to announce","depth":10},{"id":65,"text":"what he had hoped for all along .","depth":10},{"id":66,"text":"`` None of these allegations have been corroborated by the 7th and latest FBI investigation , ''","depth":9},{"id":67,"text":"he said .","depth":9},{"id":68,"text":"However , critics ,","depth":10},{"id":69,"text":"including former Supreme Court Justice John Paul Stevens ,","depth":10},{"id":70,"text":"are now saying","depth":9},{"id":71,"text":"Kavanaugh 's passionate defense before the Senate shows","depth":9},{"id":72,"text":"he does n't have the right temperament","depth":10},{"id":73,"text":"to sit on the court .","depth":10},{"id":74,"text":"In what amounts to a closing argument , Judge Kavanaugh penned an op-ed in the Wall Street Journal","depth":9},{"id":75,"text":"addressing those concerns .","depth":9},{"id":76,"text":"`` I might have been too emotional at times , ''","depth":10},{"id":77,"text":"he wrote .","depth":10},{"id":78,"text":"`` I know","depth":11},{"id":79,"text":"that my tone was sharp ,","depth":12},{"id":80,"text":"and I said a few things","depth":13},{"id":81,"text":"I should not have said .","depth":13},{"id":82,"text":"I hope","depth":11},{"id":83,"text":"everyone can understand","depth":12},{"id":84,"text":"that I was there as a son , husband , and dad . ''","depth":12},{"id":85,"text":"Meanwhile , Democrats are lashing out at the White House ,","depth":8},{"id":86,"text":"accusing the president of ordering an investigation","depth":9},{"id":87,"text":"that was too narrow and void of witnesses","depth":10},{"id":88,"text":"who wanted to talk .","depth":10},{"id":89,"text":"`` Democrats agreed","depth":10},{"id":90,"text":"that the investigation 's scope should be limited .","depth":10},{"id":91,"text":"We did not agree","depth":10},{"id":92,"text":"that the White House should tie the FBI 's hands , ''","depth":10},{"id":93,"text":"said Sen. Dianne Feinstein","depth":10},{"id":94,"text":"( D-CA )","depth":10},{"id":95,"text":"after the report was released .","depth":9},{"id":96,"text":"Speaking to reporters outside the White House ,","depth":8},{"id":97,"text":"Press Secretary Sarah Sanders pushed back .","depth":8},{"id":98,"text":"`` Anybody","depth":10},{"id":99,"text":"who pushes back on the fact","depth":11},{"id":100,"text":"that Doctor Ford was n't given ample opportunity","depth":12},{"id":101,"text":"to make her case","depth":13},{"id":102,"text":"and state her case","depth":13},{"id":103,"text":"has been living in a cave , ''","depth":9},{"id":104,"text":"she said .","depth":8},{"id":105,"text":"Meanwhile , at a campaign rally in Minnesota Thursday night , President Donald Trump pointed to new numbers","depth":8},{"id":106,"text":"that suggest","depth":9},{"id":107,"text":"the Democrats ' rage against Kavanaugh is a political misfire .","depth":9},{"id":108,"text":"`` Their rage-fueled resistance is starting to backfire at a level","depth":9},{"id":109,"text":"that nobody has ever seen before , ''","depth":9},{"id":110,"text":"Trump told the fired-up crowd .","depth":8},{"id":111,"text":"Just weeks before the midterms , a new NPR/PBS/Marist Poll shows enthusiasm among Democrats and Republicans in a statistical tie .","depth":7},{"id":112,"text":"That 's a huge boost for Republican voters","depth":8},{"id":113,"text":"who lagged 10 points behind Democrats before Kavanaugh 's confirmation hearings .","depth":8}],"relations":[{"parent":227,"left":0,"right":226,"relation":"organization","nuclearity":"SN"},{"parent":226,"left":138,"right":225,"relation":"elaboration","nuclearity":"NS"},{"parent":138,"left":126,"right":137,"relation":"elaboration","nuclearity":"NS"},{"parent":126,"left":119,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":119,"left":118,"right":6,"relation":"purpose","nuclearity":"NS"},{"parent":118,"left":117,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":117,"left":115,"right":116,"relation":"same-un