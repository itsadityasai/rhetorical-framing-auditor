{"article_id":"gc2saL7GfFicFyZB","edus":[{"id":0,"text":"WASHINGTON ( ) -","depth":1},{"id":1,"text":"U.S. Republicans on Tuesday fell short yet again in their seven-year drive","depth":8},{"id":2,"text":"to repeal Obamacare ,","depth":8},{"id":3,"text":"in a bitter defeat","depth":8},{"id":4,"text":"that raises more questions about their ability","depth":9},{"id":5,"text":"to enact President Donald Trump ' s agenda .","depth":9},{"id":6,"text":"The party was unable to win enough support from its own senators for a bill","depth":9},{"id":7,"text":"to repeal the 2010 Affordable Care Act","depth":9},{"id":8,"text":"and decided not to put it to a vote ,","depth":8},{"id":9,"text":"several Republicans said .","depth":7},{"id":10,"text":"The bill ' s sponsors vowed to try again ,","depth":7},{"id":11,"text":"but face steeper odds after Sunday ,","depth":8},{"id":12,"text":"when special rules expire","depth":9},{"id":13,"text":"that allow them to pass healthcare legislation","depth":10},{"id":14,"text":"without Democratic support .","depth":10},{"id":15,"text":"\" We basically ran out of time , \"","depth":7},{"id":16,"text":"said Senator Ron Johnson , a co-sponsor of the measure with Senators Bill Cassidy , Lindsey Graham and Dean Heller .","depth":7},{"id":17,"text":"Republicans have now repeatedly failed to deliver on their longtime promise","depth":8},{"id":18,"text":"to roll back former Democratic President Barack Obama ' s signature domestic accomplishment .","depth":8},{"id":19,"text":"They have yet to achieve any major domestic policy successes in Congress this year ,","depth":8},{"id":20,"text":"which could hurt their efforts","depth":9},{"id":21,"text":"to retain control of the Senate and House of Representatives in the November 2018 congressional elections .","depth":9},{"id":22,"text":"Republicans widely view Obamacare ,","depth":9},{"id":23,"text":"which provides coverage to 20 million Americans ,","depth":9},{"id":24,"text":"as a costly government overreach .","depth":8},{"id":25,"text":"Trump vowed frequently during the 2016 election campaign to scrap it .","depth":8},{"id":26,"text":"Democrats have fiercely defended it ,","depth":9},{"id":27,"text":"saying","depth":10},{"id":28,"text":"it has extended health insurance to millions .","depth":10},{"id":29,"text":"After falling short in July ,","depth":9},{"id":30,"text":"Senate Republicans tried again this month with a bill","depth":10},{"id":31,"text":"that would have given states greater control over the hundreds of billions of dollars","depth":11},{"id":32,"text":"that the federal government spends annually on health care .","depth":11},{"id":33,"text":"As before , they ran into objections from members on the right and the center","depth":11},{"id":34,"text":"who opposed repeal for essentially opposite reasons .","depth":11},{"id":35,"text":"Senator Susan Collins , a moderate , complained","depth":12},{"id":36,"text":"it undermined the Medicaid program for the poor","depth":13},{"id":37,"text":"and weakened consumer protections .","depth":13},{"id":38,"text":"Senator Rand Paul , a conservative , said","depth":12},{"id":39,"text":"it left too many of Obamacare ' s regulations and spending programs in place .","depth":12},{"id":40,"text":"Democrats said","depth":11},{"id":41,"text":"it was time","depth":12},{"id":42,"text":"for Republicans to work with them","depth":13},{"id":43,"text":"to fix Obamacare ' s shortcomings ,","depth":13},{"id":44,"text":"and Republican Senator Lamar Alexander said","depth":11},{"id":45,"text":"he would resume talks with Democratic Senator Patty Murray","depth":12},{"id":46,"text":"to shore up the law ' s insurance subsidies .","depth":12},{"id":47,"text":"Shares of healthcare providers ended broadly higher .","depth":8},{"id":48,"text":"Hospital company HCA Healthcare Inc rose 1.8 percent ,","depth":9},{"id":49,"text":"while insurer Centene Corp ,","depth":11},{"id":50,"text":"which focuses on Medicaid ,","depth":11},{"id":51,"text":"rose 2.2 percent .","depth":10},{"id":52,"text":"The insurance industry , hospitals , medical advocacy groups such as the American Medical Association , American Heart Association and American Cancer Society , the AARP advocacy group for the elderly and consumer activists opposed the latest bill .","depth":7},{"id":53,"text":"Senate Majority Leader Mitch McConnell ,","depth":11},{"id":54,"text":"accompanied by","depth":14},{"id":55,"text":"( L-R )","depth":14},{"id":56,"text":"Sen. Lindsey Graham","depth":14},{"id":57,"text":"( R-SC ) ,","depth":14},{"id":58,"text":"Sen. John Barrasso","depth":14},{"id":59,"text":"( R-WY ) ,","depth":14},{"id":60,"text":"Sen. John Thune","depth":15},{"id":61,"text":"( R-SD ) ,","depth":15},{"id":62,"text":"Sen. Bill Cassidy","depth":16},{"id":63,"text":"( R-LA )","depth":16},{"id":64,"text":"and Sen. John Cornyn","depth":16},{"id":65,"text":"( R-TX ) ,","depth":16},{"id":66,"text":"speaks with reporters","depth":10},{"id":67,"text":"following the party luncheons on Capitol Hill in Washington , U.S. , September 26 , 2017 .","depth":9},{"id":68,"text":"/Aaron P. Bernstein","depth":8},{"id":69,"text":"Trump said on Tuesday","depth":5},{"id":70,"text":"his administration was disappointed in \" certain so-called Republicans \"","depth":6},{"id":71,"text":"who did not support the bill .","depth":6},{"id":72,"text":"The Republican president said later","depth":5},{"id":73,"text":"he still had not given up hope","depth":7},{"id":74,"text":"that the law would eventually be repealed .","depth":7},{"id":75,"text":"\" It ' ll happen , \"","depth":7},{"id":76,"text":"he told reporters","depth":8},{"id":77,"text":"while traveling to New York for a fundraiser .","depth":8},{"id":78,"text":"Republicans hold a slim 52-48 majority in the Senate","depth":6},{"id":79,"text":"and at least three senators","depth":8},{"id":80,"text":"- Collins , Paul and John McCain of Arizona -","depth":8},{"id":81,"text":"had publicly rejected the bill .","depth":7},{"id":82,"text":"Republicans crafted special rules earlier this year","depth":7},{"id":83,"text":"that allowed them to pass a bill with a simple majority in the 100-seat chamber .","depth":7},{"id":84,"text":"After those rules expire at the start of the new fiscal year on Sunday ,","depth":7},{"id":85,"text":"they will need at least 60 votes","depth":8},{"id":86,"text":"to advance most legislation .","depth":8},{"id":87,"text":"John Thune , a member of the Republican leadership in the Senate , said","depth":6},{"id":88,"text":"the party would likely not try to undo Obamacare again","depth":7},{"id":89,"text":"until it was clear there were enough votes for it .","depth":7},{"id":90,"text":"He said","depth":6},{"id":91,"text":"the party would now focus on overhauling the U.S. tax code","depth":7},{"id":92,"text":"- another complex undertaking","depth":8},{"id":93,"text":"that could meet with stiff resistance from a wide range of interest groups .","depth":8},{"id":94,"text":"A CBS poll on Monday showed","depth":7},{"id":95,"text":"52 percent of Americans disapproved of the Graham-Cassidy healthcare bill ,","depth":8},{"id":96,"text":"while 20 percent approved .","depth":8},{"id":97,"text":"\" I will readily admit","depth":8},{"id":98,"text":"that the Republican Party has done a bad job","depth":9},{"id":99,"text":"of explaining what we ' re for in terms of replace on Obamacare , \"","depth":9},{"id":100,"text":"Republican Senator Ben Sasse said on the Senate floor .","depth":7},{"id":101,"text":"Six protesters staged a \" die-in \" on the floor of a Senate office building ,","depth":7},{"id":102,"text":"lying on the ground","depth":8},{"id":103,"text":"and covering their heads and bodies with a white shroud","depth":8},{"id":104,"text":"to represent what they said","depth":7},{"id":105,"text":"would be lives lost","depth":8},{"id":106,"text":"if the bill passed .","depth":8},{"id":107,"text":"The non-partisan Congressional Budget Office said","depth":6},{"id":108,"text":"the number of people with health insurance","depth":9},{"id":109,"text":"covering high-cost medical events","depth":9},{"id":110,"text":"would be slashed by millions","depth":8},{"id":111,"text":"if the latest Republican bill had it become law .","depth":7},{"id":112,"text":"The CBO also found","depth":6},{"id":113,"text":"that federal spending on Medicaid would be cut by about $ 1 trillion from 2017 to 2026","depth":7},{"id":114,"text":"and that millions of people would lose their coverage in the program , mainly from a repeal of federal funding for Obamacare ' s Medicaid expansion .","depth":7}],"relations":[{"parent":229,"left":0,"right":228,"relation":"organization","nuclearity":"SN"},{"parent":228,"left":191,"right":227,"relation":"elaboration","nuclearity":"NS"},{"parent":191,"left":182,"right":190,"relation":"elaboration","nuclearity":"NS"},{"parent":182,"left":130,"right":181,"relation":"elaboration","nuclearity":"NS"},{"parent":130,"left":123,"right":129,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":119,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":119,"left":116,"right":118,"relation":"same-unit","nuclearity":"NN"},{"parent":116,"left":1,"right":2,"relation":"purpose","nuclearity":"NS"},{"parent":118,"left":3,"right":117,"relation":"elaboration","nuclearity":"NS"},{"parent":117,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":121,"right":9,"relation":"attribution","nuclearity":"NS"},{"parent":121,"left":120,"right":8,"relation":"causal","nuclearity":"SN"},{"parent":120,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":129,"left":127,"right":128,"relation":"evaluation","nuclearity":"NS"},{"parent":127,"left":10,"right":126,"relation":"adversative","nuclearity":"NN"},{"parent":126,"left":11,"right":125,"relation":"context","nuclearity":"NS"},{"parent":125,"left":12,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":124,"left":13,"right":14,"relation"