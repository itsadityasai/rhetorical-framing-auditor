ight":346,"relation":"joint","nuclearity":"NN"},{"parent":315,"left":140,"right":314,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":141,"right":313,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":142,"right":143,"relation":"joint","nuclearity":"NN"},{"parent":346,"left":339,"right":345,"relation":"elaboration","nuclearity":"NS"},{"parent":339,"left":318,"right":338,"relation":"elaboration","nuclearity":"NS"},{"parent":318,"left":316,"right":317,"relation":"attribution","nuclearity":"NS"},{"parent":316,"left":144,"right":145,"relation":"joint","nuclearity":"NN"},{"parent":317,"left":146,"right":147,"relation":"elaboration","nuclearity":"NS"},{"parent":338,"left":319,"right":337,"relation":"elaboration","nuclearity":"NS"},{"parent":319,"left":148,"right":149,"relation":"adversative","nuclearity":"SN"},{"parent":337,"left":334,"right":336,"relation":"elaboration","nuclearity":"NS"},{"parent":334,"left":322,"right":333,"relation":"elaboration","nuclearity":"NS"},{"parent":322,"left":321,"right":153,"relation":"attribution","nuclearity":"NS"},{"parent":321,"left":150,"right":320,"relation":"attribution","nuclearity":"SN"},{"parent":320,"left":151,"right":152,"relation":"elaboration","nuclearity":"NS"},{"parent":333,"left":327,"right":332,"relation":"elaboration","nuclearity":"NS"},{"parent":327,"left":324,"right":326,"relation":"elaboration","nuclearity":"NS"},{"parent":324,"left":154,"right":323,"relation":"elaboration","nuclearity":"NS"},{"parent":323,"left":155,"right":156,"relation":"elaboration","nuclearity":"NS"},{"parent":326,"left":325,"right":159,"relation":"joint","nuclearity":"NN"},{"parent":325,"left":157,"right":158,"relation":"elaboration","nuclearity":"NS"},{"parent":332,"left":331,"right":165,"relation":"attribution","nuclearity":"NS"},{"parent":331,"left":160,"right":330,"relation":"attribution","nuclearity":"SN"},{"parent":330,"left":329,"right":164,"relation":"same-unit","nuclearity":"NN"},{"parent":329,"left":161,"ri