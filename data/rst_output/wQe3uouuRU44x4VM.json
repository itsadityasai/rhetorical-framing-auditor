{"article_id":"wQe3uouuRU44x4VM","edus":[{"id":0,"text":"President Trump said Friday","depth":4},{"id":1,"text":"that he signed a $ 1.3 trillion omnibus spending bill","depth":5},{"id":2,"text":"because it was vital to rebuilding the military ,","depth":5},{"id":3,"text":"but he trashed Democrats","depth":5},{"id":4,"text":"for tacking on extra spending","depth":5},{"id":5,"text":"and vowed to never again sign another budget-busting measure .","depth":4},{"id":6,"text":"\" I ' ve said to Congress ,","depth":5},{"id":7,"text":"I will never sign a bill like this again , \"","depth":5},{"id":8,"text":"Mr. Trump said ,","depth":4},{"id":9,"text":"calling the legislative process","depth":5},{"id":10,"text":"that produced it","depth":5},{"id":11,"text":"\" ridiculous . \"","depth":4},{"id":12,"text":"Hours earlier , the president had threatened to veto the bill and all but guarantee a government shutdown","depth":5},{"id":13,"text":"when funding would have expired at midnight Friday .","depth":5},{"id":14,"text":"The veto threat startled Washington ,","depth":6},{"id":15,"text":"as it followed repeated assurances from White House officials ,","depth":8},{"id":16,"text":"including Vice President Mike Pence and budget chief Mick Mulvaney ,","depth":8},{"id":17,"text":"that the president wold sign the massive spending package .","depth":7},{"id":18,"text":"He ultimately decided to sign the bill","depth":7},{"id":19,"text":"\" because of the gains","depth":8},{"id":20,"text":"we made for our military , \"","depth":8},{"id":21,"text":"said the president .","depth":6},{"id":22,"text":"Blasting the bill","depth":8},{"id":23,"text":"he was about to sign","depth":8},{"id":24,"text":"for unnecessary spending ,","depth":7},{"id":25,"text":"not fixing DACA","depth":7},{"id":26,"text":"and not fully funding a border wall ,","depth":7},{"id":27,"text":"Mr. Trump demanded changes to Congress ' rules","depth":6},{"id":28,"text":"in order to make progress on vital issues .","depth":6},{"id":29,"text":"He called for Congress to approve a line-item veto for the president and for the Senate","depth":7},{"id":30,"text":"to eliminate the filibuster rule","depth":8},{"id":31,"text":"that requires 60 votes","depth":9},{"id":32,"text":"to advance most legislation .","depth":9},{"id":33,"text":"\" We ' ve got to get a lot of great legislation approved","depth":8},{"id":34,"text":"and without the filibuster rule","depth":9},{"id":35,"text":"it will happen just like magic , \"","depth":9},{"id":36,"text":"said Mr. Trump .","depth":7},{"id":37,"text":"Allowing a line-item veto would require a constitutional amendment","depth":6},{"id":38,"text":"as the Supreme Court ruled","depth":7},{"id":39,"text":"the procedure is unconstitutional in the 1998 decision Clinton v. City of New York .","depth":7},{"id":40,"text":"Mr. Trump boasted","depth":5},{"id":41,"text":"that the bill provide a historic boost to military spending ,","depth":6},{"id":42,"text":"including the largest pay increase for troops in a decade .","depth":6},{"id":43,"text":"The investments ,","depth":6},{"id":44,"text":"he said ,","depth":6},{"id":45,"text":"made good on his pledge","depth":6},{"id":46,"text":"to rebuild the U.S. military into the most formidable fighting force in the world .","depth":6},{"id":47,"text":"\" They hollowed our readiness as a military unit","depth":7},{"id":48,"text":"and put America at really grave risk , \"","depth":7},{"id":49,"text":"he said of years of defense cuts .","depth":6},{"id":50,"text":"\" The omnibus bill reverses this . \"","depth":5},{"id":51,"text":"He blamed the omnibus ' huge price tag on Democrats","depth":6},{"id":52,"text":"who","depth":8},{"id":53,"text":"he said","depth":8},{"id":54,"text":"demanded extra spending in exchange","depth":8},{"id":55,"text":"for funding the military .","depth":8},{"id":56,"text":"He said","depth":7},{"id":57,"text":"the Democrats oppose military spending .","depth":7},{"id":58,"text":"\" If we take something for the military ,","depth":9},{"id":59,"text":"they want something","depth":10},{"id":60,"text":"that in many cases are a wasted sum of money , \"","depth":10},{"id":61,"text":"he said .","depth":8},{"id":62,"text":"\" It ' s not right","depth":8},{"id":63,"text":"and it ' s very bad for our country . \"","depth":8}],"relations":[{"parent":127,"left":75,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":69,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":66,"right":68,"relation":"adversative","nuclearity":"NN"},{"parent":66,"left":0,"right":65,"relation":"attribution","nuclearity":"SN"},{"parent":65,"left":1,"right":2,"relation":"explanation","nuclearity":"NS"},{"parent":68,"left":67,"right":5,"relation":"joint","nuclearity":"NN"},{"parent":67,"left":3,"right":4,"relation":"explanation","nuclearity":"NS"},{"parent":74,"left":71,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":70,"right":8,"relation":"attribution","nuclearity":"NS"},{"parent":70,"left":6,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":73,"left":72,"right":11,"relation":"same-unit","nuclearity":"NN"},{"parent":72,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":126,"left":102,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":84,"right":101,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":76,"right":83,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":12,"right":13,"relation":"context","nuclearity":"NS"},{"parent":83,"left":79,"right":82,"relation":"adversative","nuclearity":"NN"},{"parent":79,"left":14,"right":78,"relation":"context","nuclearity":"NS"},{"parent":78,"left":77,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":15,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":81,"right":21,"relation":"attribution","nuclearity":"NS"},{"parent":81,"left":18,"right":80,"relation":"explanati