on":"elaboration","nuclearity":"NS"},{"parent":231,"left":109,"right":230,"relation":"attribution","nuclearity":"SN"},{"parent":230,"left":110,"right":111,"relation":"joint","nuclearity":"NN"},{"parent":244,"left":235,"right":243,"relation":"context","nuclearity":"SN"},{"parent":235,"left":112,"right":234,"relation":"elaboration","nuclearity":"NS"},{"parent":234,"left":113,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":243,"left":238,"right":242,"relation":"elaboration","nuclearity":"NS"},{"parent":238,"left":115,"right":237,"relation":"attribution","nuclearity":"SN"},{"parent":237,"left":116,"right":236,"relation":"attribution","nuclearity":"SN"},{"parent":236,"left":117,"right":118,"relation":"elaboration","nuclearity":"NS"},{"parent":242,"left":119,"right":241,"relation":"attribution","nuclearity":"SN"},{"parent":241,"left":120,"right":240,"relation":"elaboration","nuclearity":"NS"},{"parent":240,"left":121,"right":239,"relation":"elaboration","nuclearity":"NS"},{"parent":239,"left":122,"right":123,"relation":"elaboration","nuclearity":"NS"}]}