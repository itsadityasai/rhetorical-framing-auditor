{"article_id":"xMmlCZUI4axEGf6I","edus":[{"id":0,"text":"PALM BEACH , Fla.","depth":1},{"id":1,"text":"( AP ) -","depth":2},{"id":2,"text":"President Donald Trump said Sunday","depth":7},{"id":3,"text":"that a program","depth":9},{"id":4,"text":"that protects immigrants","depth":10},{"id":5,"text":"who were brought to the U.S. illegally as children","depth":10},{"id":6,"text":"is \" probably dead , \"","depth":8},{"id":7,"text":"casting a cloud over already tenuous negotiations just days before a deadline on a government funding deal","depth":7},{"id":8,"text":"that Democrats have tied to immigration .","depth":7},{"id":9,"text":"At issue is the Deferred Action for Childhood Arrivals program","depth":7},{"id":10,"text":"created by President Barack Obama","depth":8},{"id":11,"text":"to shield hundreds of thousands of these individuals ,","depth":10},{"id":12,"text":"known as \" Dreamers , \"","depth":10},{"id":13,"text":"from deportation .","depth":9},{"id":14,"text":"Trump ,","depth":9},{"id":15,"text":"who has taken a hard stance against illegal immigration ,","depth":9},{"id":16,"text":"announced last year","depth":8},{"id":17,"text":"that he will end the program","depth":8},{"id":18,"text":"unless Congress comes up with a solution by March .","depth":8},{"id":19,"text":"\" DACA is probably dead","depth":7},{"id":20,"text":"because the Democrats don ' t really want it ,","depth":8},{"id":21,"text":"they just want to talk","depth":9},{"id":22,"text":"and take desperately needed money away from our Military , \"","depth":9},{"id":23,"text":"the Republican president tweeted .","depth":6},{"id":24,"text":"\" I , as President , want people","depth":8},{"id":25,"text":"coming into our Country","depth":9},{"id":26,"text":"who are going to help us become strong and great again ,","depth":9},{"id":27,"text":"people","depth":9},{"id":28,"text":"coming in through a system","depth":10},{"id":29,"text":"based on MERIT .","depth":10},{"id":30,"text":"No more Lotteries !","depth":8},{"id":31,"text":"# AMERICA FIRST . \"","depth":6},{"id":32,"text":"Republicans and Democrats were already at odds over funding the government ,","depth":6},{"id":33,"text":"and the negotiations became more complicated","depth":7},{"id":34,"text":"after Democrats","depth":10},{"id":35,"text":"- whose votes are needed","depth":11},{"id":36,"text":"to pass a government funding bill -","depth":11},{"id":37,"text":"insisted","depth":9},{"id":38,"text":"immigration be included .","depth":8},{"id":39,"text":"Government funding expires midnight Friday","depth":7},{"id":40,"text":"without a deal in place ,","depth":7},{"id":41,"text":"and some government functions will begin to go dark .","depth":6},{"id":42,"text":"Further roiling the talks are comments by Trump during an Oval Office meeting","depth":10},{"id":43,"text":"in which he questioned the need","depth":11},{"id":44,"text":"to admit more Haitians to the U.S. , along with Africans from `` s -- -- hole '' countries ,","depth":11},{"id":45,"text":"according to people","depth":10},{"id":46,"text":"briefed on the conversation","depth":11},{"id":47,"text":"but not authorized to describe it publicly .","depth":11},{"id":48,"text":"He also said in the Thursday meeting","depth":9},{"id":49,"text":"he would prefer immigrants from countries like Norway instead .","depth":9},{"id":50,"text":"The White House has not denied","depth":10},{"id":51,"text":"that Trump said the word \" shithole , \"","depth":10},{"id":52,"text":"though Trump did push back on some depictions of the meeting .","depth":9},{"id":53,"text":"A confidant of Trump ' s told The Associated Press","depth":10},{"id":54,"text":"that the president spent Thursday evening calling friends and outside advisers","depth":11},{"id":55,"text":"to judge their reaction on his inflammatory remarks .","depth":11},{"id":56,"text":"Trump wasn ' t apologetic","depth":12},{"id":57,"text":"and denied","depth":13},{"id":58,"text":"he was racist ,","depth":13},{"id":59,"text":"instead blaming the media","depth":12},{"id":60,"text":"for distorting his meaning ,","depth":12},{"id":61,"text":"said the confidant ,","depth":11},{"id":62,"text":"who wasn ' t authorized to disclose a private conversation","depth":12},{"id":63,"text":"and spoke on condition of anonymity .","depth":12},{"id":64,"text":"The president also rejected as insufficient an immigration deal","depth":8},{"id":65,"text":"drafted by the bipartisan group of lawmakers","depth":9},{"id":66,"text":"who attended that meeting .","depth":9},{"id":67,"text":"The deal had included a pathway to citizenship for the \" Dreamers \"","depth":11},{"id":68,"text":"that would take up to 12 years ,","depth":11},{"id":69,"text":"as well as $ 1.6 billion for border security ,","depth":11},{"id":70,"text":"including Trump ' s promised wall along the U.S.-Mexico border .","depth":11},{"id":71,"text":"Trump ' s staunchest supporters consider any route to citizenship for the \" Dreamers \" amnesty for lawbreakers .","depth":9},{"id":72,"text":"The president has said","depth":9},{"id":73,"text":"any deal must include funding for the wall as well as changes","depth":10},{"id":74,"text":"to make the immigration system a more merit-based structure .","depth":10},{"id":75,"text":"The debate over DACA ' s fate came","depth":7},{"id":76,"text":"as lawmakers faced questioning","depth":8},{"id":77,"text":"about whether Trump is racist .","depth":8},{"id":78,"text":"Rep. Mia Love , R-Utah , the first black female Republican in Congress and the daughter of Haitian immigrants , denounced Trump ' s comments as racist","depth":10},{"id":79,"text":"and called on him to apologize .","depth":10},{"id":80,"text":"\" I think","depth":11},{"id":81,"text":"that would show real leadership , \"","depth":11},{"id":82,"text":"she said on CNN ' s \" State of the Union \" on Sunday .","depth":10},{"id":83,"text":"Sen. David Perdue , R-Ga. ,","depth":14},{"id":84,"text":"who was at Thursday ' s Oval Office meeting ,","depth":14},{"id":85,"text":"insisted Sunday","depth":13},{"id":86,"text":"that Trump did not say \" shithole \"","depth":13},{"id":87,"text":"in referring to African countries .","depth":13},{"id":88,"text":"\" I am telling you","depth":14},{"id":89,"text":"that he did not use that word .","depth":14},{"id":90,"text":"And I ' m telling you","depth":14},{"id":91,"text":"it ' s a gross misrepresentation , \"","depth":14},{"id":92,"text":"Perdue said on ABC ' s \" This Week. \"","depth":12},{"id":93,"text":"He said","depth":11},{"id":94,"text":"Sen. Dick Durbin , D-Ill. , and Sen. Lindsey Graham , R-S.C. , were mistaken","depth":12},{"id":95,"text":"in indicating earlier","depth":13},{"id":96,"text":"that that was the case .","depth":13},{"id":97,"text":"Perdue and Sen. Tom Cotton , R-Ark. , had issued a joint statement Friday","depth":12},{"id":98,"text":"saying","depth":13},{"id":99,"text":"they \" do not recall the President saying those comments specifically. \"","depth":13},{"id":100,"text":"Cotton said Sunday on CBS ' \" Face the Nation \"","depth":12},{"id":101,"text":"that he \" didn ' t hear \" the vulgar word","depth":13},{"id":102,"text":"used .","depth":13},{"id":103,"text":"Homeland Security Secretary Kirstjen Nielsen ,","depth":15},{"id":104,"text":"who also attended Thursday ' s meeting at the Oval Office ,","depth":15},{"id":105,"text":"said ,","depth":14},{"id":106,"text":"\" I don ' t recall that specific phrase being used . \"","depth":13},{"id":107,"text":"Nielsen did dispute , however , Trump ' s assertion","depth":14},{"id":108,"text":"that DACA was \" probably dead . \"","depth":14},{"id":109,"text":"\" I do not believe","depth":15},{"id":110,"text":"DACA is dead , \"","depth":15},{"id":111,"text":"Nielsen said on \" Fox News Sunday. \"","depth":14},{"id":112,"text":"She said","depth":12},{"id":113,"text":"that the bipartisan proposal","depth":15},{"id":114,"text":"rejected by Trump","depth":15},{"id":115,"text":"did not address core security issues","depth":15},{"id":116,"text":"facing her department","depth":15},{"id":117,"text":"and that Trump ' s administration was not interested in \" half measures . \"","depth":13},{"id":118,"text":"Perdue said","depth":9},{"id":119,"text":"that \" the potential is there \" for a deal","depth":11},{"id":120,"text":"to protect the \" Dreamers \"","depth":11},{"id":121,"text":"but that Democrats needed to get serious .","depth":10},{"id":122,"text":"Sen. Michael Bennet , D-Colo. , defended the agreement as a \" principled compromise \" on NBC ' s \" Meet the Press \"","depth":9},{"id":123,"text":"and said ,","depth":10},{"id":124,"text":"\" I hope","depth":11},{"id":125,"text":"people will explore it . \"","depth":11}],"relations":[{"parent":251,"left":0,"right":250,"relation":"organization","nuclearity":"SN"},{"parent":250,"left":1,"right":249,"relation":"organization","nuclearity":"SN"},{"parent":249,"left":155,"right":248,"relation":"elaboration","nuclearity":"NS"},{"parent":155,"left":142,"right":154,"relation":"elaboration","nuclearity":"NS"},{"parent":142,"left":132,"right":141,"relation":"elaboration","nuclearity":"NS"},{"parent":132,"left":130,"right":131,"relation":"causal","nuclearity":"NS"},{"parent":130,"left":2,"right":129,"relation":"attribution","nuclearity":"SN"},{"parent":129,"left":128,"right":6,"relation":"same-unit","nuclearity":"NN"},{"parent":128,"left":3,"right":127,"relation":"elaboration","nuclearity":"NS"},{"parent":127,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":131,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":141,"left":136,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":136,"left":9,"right":135,"relation":"elaboration","nuclearity":"NS"},{"parent":135,"left":10,"right":134,"relation":"purpose","nuclearity":"NS"},{"parent":134,"left":133,"right":13,"relation":"same-unit","nuclearity":"NN"},{"parent":133,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":