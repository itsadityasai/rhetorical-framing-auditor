ent":290,"left":289,"right":73,"relation":"attribution","nuclearity":"NS"},{"parent":289,"left":70,"right":288,"relation":"adversative","nuclearity":"SN"},{"parent":288,"left":71,"right":72,"relation":"purpose","nuclearity":"NS"},{"parent":314,"left":302,"right":313,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":296,"right":301,"relation":"elaboration","nuclearity":"NS"},{"parent":296,"left":74,"right":295,"relation":"attribution","nuclearity":"SN"},{"parent":295,"left":75,"right":294,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":76,"right":293,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":77,"right":78,"relation":"adversative","nuclearity":"NS"},{"parent":301,"left":298,"right":300,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":297,"right":81,"relation":"attribution","nuclearity":"NS"},{"parent":297,"left":79,"right":80,"relation":"elaboration","nuclearity":"NS"},{"parent":300,"left":82,"right":299,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":83,"right":84,"relation":"joint","nuclearity":"NN"},{"parent":313,"left":306,"right":312,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":85,"right":305,"relation":"attribution","nuclearity":"SN"},{"parent":305,"left":304,"right":89,"relation":"adversative","nuclearity":"NS"},{"parent":304,"left":86,"right":303,"relation":"purpose","nuclearity":"NS"},{"parent":303,"left":87,"right":88,"relation":"joint","nuclearity":"NN"},{"parent":312,"left":308,"right":311,"relation":"adversative","nuclearity":"SN"},{"parent":308,"left":307,"right":92,"relation":"attribution","nuclearity":"NS"},{"parent":307,"left":90,"right":91,"relation":"attribution","nuclearity":"SN"},{"parent":311,"left":93,"right":310,"relation":"attribution","nuclearity":"SN"},{"parent":310,"left":94,"right":309,"relation":"purpose","nuclearity":"NS"},{"parent":309,"left":95,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":438,"left":393,"right