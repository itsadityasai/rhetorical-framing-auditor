n":"attribution","nuclearity":"NS"},{"parent":279,"left":278,"right":94,"relation":"same-unit","nuclearity":"NN"},{"parent":278,"left":92,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":282,"left":96,"right":281,"relation":"elaboration","nuclearity":"NS"},{"parent":281,"left":97,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":375,"left":315,"right":374,"relation":"elaboration","nuclearity":"NS"},{"parent":315,"left":299,"right":314,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":293,"right":298,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":285,"right":292,"relation":"elaboration","nuclearity":"NS"},{"parent":285,"left":99,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":288,"right":291,"relation":"joint","nuclearity":"NN"},{"parent":288,"left":287,"right":104,"relation":"joint","nuclearity":"NN"},{"parent":287,"left":286,"right":103,"relation":"same-unit","nuclearity":"NN"},{"parent":286,"left":101,"right":102,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":289,"right":290,"relation":"joint","nuclearity":"NN"},{"parent":289,"left":105,"right":106,"relation":"purpose","nuclearity":"NS"},{"parent":290,"left":107,"right":108,"relation":"purpose","nuclearity":"NS"},{"parent":298,"left":295,"right":297,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":294,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":109,"right":110,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":296,"right":114,"relation":"attribution","nuclearity":"NS"},{"parent":296,"left":112,"right":113,"relation":"explanation","nuclearity":"NS"},{"parent":314,"left":307,"right":313,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":302,"right":306,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":115,"right":301,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":116,"right":300,"relation":"attribution","