{"article_id":"iB7ef8FwmNaa0Oye","edus":[{"id":0,"text":"The man","depth":11},{"id":1,"text":"serving a life prison term","depth":12},{"id":2,"text":"for kidnapping three women","depth":13},{"id":3,"text":"and repeatedly raping them in his home for nearly a decade","depth":13},{"id":4,"text":"has been found dead","depth":10},{"id":5,"text":"and is believed to have committed suicide ,","depth":9},{"id":6,"text":"a prison official said .","depth":8},{"id":7,"text":"Ariel Castro , 53 , was found hanging in his cell around 9:20 p.m. Tuesday at the Correctional Reception Center in Orient ,","depth":9},{"id":8,"text":"located south of Columbus in central Ohio ,","depth":9},{"id":9,"text":"JoEllen Smith , Department of Rehabilitation and Correction spokeswoman , said early Wednesday .","depth":8},{"id":10,"text":"Prison medical staff performed CPR","depth":7},{"id":11,"text":"before Castro was transported to a hospital ,","depth":8},{"id":12,"text":"where he was pronounced dead around 10:50 p.m .","depth":8},{"id":13,"text":"Castro was in protective custody","depth":7},{"id":14,"text":"because of the notoriety of his case ,","depth":7},{"id":15,"text":"meaning he was checked every 30 minutes ,","depth":7},{"id":16,"text":"but was not on suicide watch ,","depth":8},{"id":17,"text":"Smith said .","depth":9},{"id":18,"text":"She said","depth":10},{"id":19,"text":"suicide watch entails constant observation .","depth":10},{"id":20,"text":"The three women disappeared separately between 2002 and 2004 ,","depth":6},{"id":21,"text":"when they were 14 , 16 and 20 years old .","depth":6},{"id":22,"text":"They escaped from Castro 's Cleveland home May 6 ,","depth":8},{"id":23,"text":"when Amanda Berry , one of the women , broke part of a door","depth":10},{"id":24,"text":"and yelled to neighbors for help .","depth":10},{"id":25,"text":"`` Help me , ''","depth":11},{"id":26,"text":"she said in a 911 call .","depth":11},{"id":27,"text":"`` I 've been kidnapped ,","depth":12},{"id":28,"text":"and I 've been missing for 10 years","depth":12},{"id":29,"text":"and I 'm ,","depth":13},{"id":30,"text":"I 'm here ,","depth":13},{"id":31,"text":"I 'm free now . ''","depth":12},{"id":32,"text":"The two other women were so scared of Castro","depth":10},{"id":33,"text":"that they held back initially","depth":11},{"id":34,"text":"even as police officers began to swarm the house .","depth":11},{"id":35,"text":"But quickly they realized","depth":10},{"id":36,"text":"they were free .","depth":10},{"id":37,"text":"`` You saved us !","depth":11},{"id":38,"text":"You saved us ! ''","depth":11},{"id":39,"text":"another of the captives , Michelle Knight , told an officer","depth":10},{"id":40,"text":"as she leaped into his arms .","depth":9},{"id":41,"text":"Castro was arrested that evening .","depth":7},{"id":42,"text":"He had also fathered a child with Berry","depth":11},{"id":43,"text":"while she was in captivity ;","depth":11},{"id":44,"text":"that girl was 6 years old","depth":11},{"id":45,"text":"when freed .","depth":11},{"id":46,"text":"A judge rejected Castro 's request","depth":10},{"id":47,"text":"to have visiting rights with his daughter .","depth":10},{"id":48,"text":"Elation over the women 's rescue soon turned to shock","depth":11},{"id":49,"text":"as details emerged about conditions of their captivity .","depth":11},{"id":50,"text":"Investigators say","depth":12},{"id":51,"text":"they were bound with chains ,","depth":13},{"id":52,"text":"repeatedly raped","depth":14},{"id":53,"text":"and deprived of food and bathroom facilities .","depth":14},{"id":54,"text":"Knight told investigators","depth":12},{"id":55,"text":"she was beaten and starved several times","depth":13},{"id":56,"text":"to force her to miscarry .","depth":13},{"id":57,"text":"Messages","depth":11},{"id":58,"text":"left for the women 's lawyers","depth":11},{"id":59,"text":"were not immediately returned early Wednesday .","depth":10},{"id":60,"text":"Castro was sentenced Aug. 1 to life in prison plus 1,000 years on his guilty plea to 937 counts","depth":5},{"id":61,"text":"including kidnapping and rape .","depth":5},{"id":62,"text":"In a rambling statement , he told the judge","depth":8},{"id":63,"text":"he was not a monster but a man","depth":9},{"id":64,"text":"suffering from a pornography addiction .","depth":9},{"id":65,"text":"`` I 'm not a monster .","depth":9},{"id":66,"text":"I 'm sick , ''","depth":9},{"id":67,"text":"Castro said at his sentencing .","depth":8},{"id":68,"text":"Knight was the only one of the three","depth":8},{"id":69,"text":"who appeared in court at his sentencing .","depth":8},{"id":70,"text":"`` You took 11 years of my life away ,","depth":10},{"id":71,"text":"and I have got it back , ''","depth":10},{"id":72,"text":"she said in the hushed courtroom .","depth":9},{"id":73,"text":"`` I spent 11 years in hell .","depth":9},{"id":74,"text":"Now your hell is just beginning . ''","depth":9},{"id":75,"text":"Castro was watched closely in the Cuyahoga County Jail in the several weeks after his arrest and before his guilty plea ,","depth":8},{"id":76,"text":"with logs","depth":9},{"id":77,"text":"noting his activity every 10 minutes .","depth":9},{"id":78,"text":"He was taken off county jail suicide watch in early June","depth":8},{"id":79,"text":"after authorities determined","depth":9},{"id":80,"text":"he was not a suicide risk .","depth":9},{"id":81,"text":"Castro 's attorneys tried unsuccessfully to have a psychological examination of Castro done at the Cuyahoga County Jail ,","depth":12},{"id":82,"text":"where Castro was housed","depth":12},{"id":83,"text":"before he was turned over to state authorities","depth":11},{"id":84,"text":"following his guilty plea and conviction ,","depth":10},{"id":85,"text":"his attorney , Jaye Schlachet , told The Associated Press early Wednesday .","depth":9},{"id":86,"text":"Schlachet said","depth":9},{"id":87,"text":"he could not immediately comment further .","depth":9},{"id":88,"text":"In an interview last month after Castro 's conviction , Schlachet and attorney Craig Weintraub said","depth":8},{"id":89,"text":"their client clearly fit the profile of sociopathic disorder","depth":9},{"id":90,"text":"and that they hoped","depth":10},{"id":91,"text":"researchers would study him for clues","depth":11},{"id":92,"text":"that could be used","depth":12},{"id":93,"text":"to stop other predators .","depth":12},{"id":94,"text":"This is the second high-profile suicide in an Ohio prison in a month .","depth":3},{"id":95,"text":"On Aug. 4 , death row inmate Billy Slagle was found hanged in his cell just days before his scheduled execution .","depth":4},{"id":96,"text":"He was condemned to death","depth":5},{"id":97,"text":"for fatally stabbing a neighbor .","depth":5},{"id":98,"text":"Get the Monitor Stories","depth":4},{"id":99,"text":"you care about","depth":4},{"id":100,"text":"delivered to your inbox .","depth":3},{"id":101,"text":"By signing up ,","depth":3},{"id":102,"text":"you agree to our Privacy Policy","depth":3}],"relations":[{"parent":205,"left":200,"right":204,"relation":"elaboration","nuclearity":"NS"},{"parent":200,"left":196,"right":199,"relation":"context","nuclearity":"NS"},{"parent":196,"left":162,"right":195,"relation":"elaboration","nuclearity":"NS"},{"parent":162,"left":122,"right":161,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":115,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":115,"left":112,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":112,"left":109,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":109,"left":108,"right":6,"relation":"attribution","nuclearity":"NS"},{"parent":108,"left":107,"right":5,"relation":"joint","nuclearity":"NN"},{"parent":107,"left":106,"right":4,"relation":"same-unit","nuclearity":"NN"},{"parent":106,"left":0,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":105,"left":1,"right":104,"relation":"explanation","nucleari