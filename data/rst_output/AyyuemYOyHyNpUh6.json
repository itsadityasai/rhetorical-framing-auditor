{"article_id":"AyyuemYOyHyNpUh6","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"President Donald Trump 's attorney general nominee , William Barr , is assuring Republican senators","depth":4},{"id":2,"text":"he will not interfere with special counsel Robert Mueller 's Russia investigation .","depth":4},{"id":3,"text":"On Wednesday , Barr met with Senate Judiciary Chairman Lindsey Graham","depth":5},{"id":4,"text":"( R-SC )","depth":5},{"id":5,"text":"ahead of his confirmation hearings ,","depth":5},{"id":6,"text":"which are scheduled for next week .","depth":5},{"id":7,"text":"`` I asked Mr. Barr directly ,","depth":8},{"id":8,"text":"'Do you think","depth":9},{"id":9,"text":"Mr. Mueller is on a witch hunt ? '","depth":9},{"id":10,"text":"He said no , ''","depth":7},{"id":11,"text":"Graham recalled .","depth":6},{"id":12,"text":"`` 'Do you think","depth":8},{"id":13,"text":"he would be fair to the president and the country as a whole ? '","depth":8},{"id":14,"text":"He said yes .","depth":7},{"id":15,"text":"'And do you see any reason","depth":9},{"id":16,"text":"for Mr. Mueller 's investigation to be stopped ? '","depth":9},{"id":17,"text":"He said","depth":9},{"id":18,"text":"no .","depth":9},{"id":19,"text":"'Do you see any reason for a termination","depth":10},{"id":20,"text":"based on cause ? '","depth":10},{"id":21,"text":"He said no .","depth":9},{"id":22,"text":"'Are you committed to making sure","depth":10},{"id":23,"text":"Mr. Mueller can finish his job ? '","depth":10},{"id":24,"text":"'Yes . ' ''","depth":9},{"id":25,"text":"The news comes","depth":5},{"id":26,"text":"as Deputy Attorney General Rod Rosenstein ,","depth":8},{"id":27,"text":"who 's overseeing the investigation ,","depth":8},{"id":28,"text":"announced","depth":7},{"id":29,"text":"he 's stepping down","depth":7},{"id":30,"text":"after Barr is confirmed .","depth":7},{"id":31,"text":"Some Democrats want Barr to recuse himself from the Mueller probe","depth":7},{"id":32,"text":"because of his previous statements","depth":8},{"id":33,"text":"criticizing the investigation .","depth":8},{"id":34,"text":"Specifically , they 're referring to a controversial memo","depth":9},{"id":35,"text":"Barr wrote last year to Rosenstein","depth":10},{"id":36,"text":"calling the probe `` fatally misconceived . '' `` The Senate ... should subject Mr. Barr 's views to the strictest of scrutiny next week","depth":10},{"id":37,"text":"and I still believe ,","depth":9},{"id":38,"text":"after the revelations about Mr. Barr 's unsolicited memo ,","depth":10},{"id":39,"text":"President Trump ought to withdraw this nomination , ''","depth":10},{"id":40,"text":"Senate Minority Leader Chuck Schumer","depth":9},{"id":41,"text":"( D-NY )","depth":9},{"id":42,"text":"said Wednesday .","depth":8},{"id":43,"text":"Likewise , Sen. Richard Blumenthal","depth":8},{"id":44,"text":"( D-CT )","depth":8},{"id":45,"text":"said","depth":7},{"id":46,"text":"the memo was `` deeply worrisome","depth":7},{"id":47,"text":"because in effect he says","depth":9},{"id":48,"text":"the president is above the law ...","depth":9},{"id":49,"text":"that 's incorrect as a matter of law","depth":9},{"id":50,"text":"but certainly for an attorney general to have that position is deeply wrong . ''","depth":9},{"id":51,"text":"However , Graham says","depth":7},{"id":52,"text":"Democrats ' fears are unfounded ,","depth":7},{"id":53,"text":"noting","depth":7},{"id":54,"text":"that Barr and Mueller are good friends of more than 20 years","depth":8},{"id":55,"text":"and their wives attend a Bible study together .","depth":8},{"id":56,"text":"`` I can assure you","depth":7},{"id":57,"text":"he has a very high opinion of Mr. Mueller","depth":8},{"id":58,"text":"and he is committed to letting Mr. Mueller finish his job , ''","depth":8},{"id":59,"text":"the South Carolina lawmaker said .","depth":6}],"relations":[{"parent":119,"left":0,"right":118,"relation":"organization","nuclearity":"SN"},{"parent":118,"left":65,"right":117,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":61,"right":64,"relation":"context","nuclearity":"NS"},{"parent":61,"left":1,"right":2,"relation":"attribution","nuclearity":"SN"},{"parent":64,"left":62,"right":63,"relation":"same-unit","nuclearity":"NN"},{"parent":62,"left":3,"right":4,"relation":"restatement","nuclearity":"NS"},{"parent":63,"left":5,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":117,"left":88,"right":116,"relation":"joint","nuclearity":"NN"},{"parent":88,"left":82,"right":87,"relation":"context","nuclearity":"NS"},{"parent":82,"left":69,"right":81,"relation":"joint","nuclearity":"NN"},{"parent":69,"left":68,"right":11,"relation":"attribution","nuclearity":"NS"},{"parent":68,"left":67,"right":10,"relation":"topic","nuclearity":"SN"},{"parent":67,"left":7,"right":66,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":8,"right":9,"relation":"attribution","nuclearity":"SN"},{"parent":81,"left":71,"right":80,"relation":"joint","nuclearity":"NN"},{"parent":71,"left":70,"right":14,"relation":"topic","nuclearity":"SN"},{"parent":70,"left":12,"right":13,"relation":"attribution","nuclearity":"SN"},{"parent":80,"left":74,"right":79,"relation":"joint","nuclearity":"NN"},{"parent":74,"left":72,"right":73,"relation":"topic","nuclearity":"SN"},{"parent":72,"left":15,"right":16,"relation":"purpose","nuclearity":"NS"},{"parent":73,"left":17,"right":18,"relation":"attribution","nuclearity":"SN"},{"parent":79,"left":76,"right":78,"relation":"joint","nuclearity":"NN"},{"parent":76,"left":75,"right":21,"relation":"topic","nuclearity":"SN"},{"parent":75,"left":19,"right":20,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":77,"right":24,"relation":"topic","nuclearity":"SN"},{"parent":77,"left":22,"right":23,"relation":"attribution","nuclearity":"SN"},{"parent":87,"left":25,"right":86,"relation":"same-unit","nuclearity":"NN"},{"parent":86,"left":84,"right":85,"relation":"attribution","nucleari