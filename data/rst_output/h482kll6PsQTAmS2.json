arity":"SN"},{"parent":332,"left":331,"right":156,"relation":"same-unit","nuclearity":"NN"},{"parent":331,"left":154,"right":155,"relation":"elaboration","nuclearity":"NS"},{"parent":353,"left":343,"right":352,"relation":"elaboration","nuclearity":"NS"},{"parent":343,"left":336,"right":342,"relation":"joint","nuclearity":"NN"},{"parent":336,"left":157,"right":335,"relation":"causal","nuclearity":"NS"},{"parent":335,"left":158,"right":334,"relation":"purpose","nuclearity":"NS"},{"parent":334,"left":159,"right":160,"relation":"elaboration","nuclearity":"NS"},{"parent":342,"left":339,"right":341,"relation":"joint","nuclearity":"NN"},{"parent":339,"left":337,"right":338,"relation":"attribution","nuclearity":"SN"},{"parent":337,"left":161,"right":162,"relation":"elaboration","nuclearity":"NS"},{"parent":338,"left":163,"right":164,"relation":"joint","nuclearity":"NN"},{"parent":341,"left":165,"right":340,"relation":"elaboration","nuclearity":"NS"},{"parent":340,"left":166,"right":167,"relation":"elaboration","nuclearity":"NS"},{"parent":352,"left":349,"right":351,"relation":"elaboration","nuclearity":"NS"},{"parent":349,"left":345,"right":348,"relation":"attribution","nuclearity":"SN"},{"parent":345,"left":168,"right":344,"relation":"attribution","nuclearity":"SN"},{"parent":344,"left":169,"right":170,"relation":"attribution","nuclearity":"SN"},{"parent":348,"left":346,"right":347,"relation":"same-unit","nuclearity":"NN"},{"parent":346,"left":171,"right":172,"relation":"elaboration","nuclearity":"NS"},{"parent":347,"left":173,"right":174,"relation":"attribution","nuclearity":"SN"},{"parent":351,"left":350,"right":177,"relation":"attribution","nuclearity":"NS"},{"parent":350,"left":175,"right":176,"relation":"attribution","nuclearity":"SN"},{"parent":360,"left":359,"right":180,"relation":"joint","nuclearity":"NN"},{"parent":359,"left":178,"right":179,"relation":"elaboration","nuclearity":"NS"}]}