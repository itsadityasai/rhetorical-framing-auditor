{"article_id":"L3SyrrnJli5vjqTx","edus":[{"id":0,"text":"President Trump is threatening to veto the omnibus spending bill","depth":8},{"id":1,"text":"the Senate passed overnight","depth":8},{"id":2,"text":"- despite indicating support for it in the last two days -","depth":7},{"id":3,"text":"because he says","depth":7},{"id":4,"text":"it does n't protect Dreamers","depth":8},{"id":5,"text":"or fully fund his border wall .","depth":8},{"id":6,"text":"The president 's veto threat suddenly makes a government shutdown ,","depth":8},{"id":7,"text":"which seemed to be a crisis","depth":9},{"id":8,"text":"averted early Friday morning ,","depth":9},{"id":9,"text":"much more likely .","depth":7},{"id":10,"text":"Government funding runs out at midnight .","depth":6},{"id":11,"text":"If he follows through ,","depth":5},{"id":12,"text":"this would be Mr. Trump 's first veto","depth":6},{"id":13,"text":"since taking office .","depth":6},{"id":14,"text":"I am considering a VETO of the Omnibus Spending Bill","depth":5},{"id":15,"text":"based on the fact","depth":7},{"id":16,"text":"that the 800,000 plus DACA recipients have been totally abandoned by the Democrats","depth":8},{"id":17,"text":"( not even mentioned in Bill )","depth":8},{"id":18,"text":"and the BORDER WALL ,","depth":8},{"id":19,"text":"which is desperately needed for our National Defense ,","depth":8},{"id":20,"text":"is not fully funded .","depth":7},{"id":21,"text":"- Donald J. Trump","depth":6},{"id":22,"text":"( @ realDonaldTrump )","depth":6},{"id":23,"text":"March 23 , 2018","depth":5},{"id":24,"text":"The White House insisted repeatedly Thursday","depth":7},{"id":25,"text":"that","depth":8},{"id":26,"text":"even though the legislation did n't fund Mr. Trump 's border wall","depth":10},{"id":27,"text":"- the president has requested $ 25 billion","depth":11},{"id":28,"text":"and the legislation only provides about $ 1.6 billion -","depth":11},{"id":29,"text":"that the president still supported the bill .","depth":9},{"id":30,"text":"On Thursday afternoon , Office of Management and Budget Director Mick Mulvaney said","depth":8},{"id":31,"text":"Mr. Trump would sign the bill .","depth":8},{"id":32,"text":"`` The president will sign the bill","depth":9},{"id":33,"text":"because it funds his priorities , ''","depth":9},{"id":34,"text":"Mulvaney told reporters Thursday afternoon .","depth":8},{"id":35,"text":"And Mr. Trump had indicated his support earlier this week , too .","depth":6},{"id":36,"text":"Got $ 1.6 Billion","depth":9},{"id":37,"text":"to start Wall on Southern Border ,","depth":9},{"id":38,"text":"rest will be forthcoming .","depth":8},{"id":39,"text":"Most importantly , got $ 700 Billion","depth":9},{"id":40,"text":"to rebuild our Military , $ 716 Billion next year ...","depth":10},{"id":41,"text":"most ever .","depth":10},{"id":42,"text":"Had to waste money on Dem giveaways","depth":9},{"id":43,"text":"in order to take care of military pay increase and new equipment .","depth":9},{"id":44,"text":"- Donald J. Trump","depth":6},{"id":45,"text":"( @ realDonaldTrump )","depth":6},{"id":46,"text":"March 22 , 2018","depth":5},{"id":47,"text":"Sen. Tim Kaine , D-Va. , poked at Mr. Trump 's famous `` Art of the Deal '' book .","depth":5},{"id":48,"text":"`` It 's like art of the deal wrecker ,","depth":7},{"id":49,"text":"that 's my reaction , ''","depth":7},{"id":50,"text":"Kaine told reporters on Capitol Hill Friday .","depth":6},{"id":51,"text":"But some were supportive of Mr. Trump 's veto consideration .","depth":5},{"id":52,"text":"Sen. Bob Corker , chairman of the Senate Foreign Relations committee , urged the president to follow through over concerns","depth":9},{"id":53,"text":"about spending","depth":10},{"id":54,"text":"`` throwing our children under the bus .","depth":10},{"id":55,"text":"'' Please do , Mr. President .","depth":10},{"id":56,"text":"I am just down the street","depth":11},{"id":57,"text":"and will bring you a pen .","depth":11},{"id":58,"text":"The spending levels","depth":13},{"id":59,"text":"without any offsets","depth":13},{"id":60,"text":"are grotesque ,","depth":12},{"id":61,"text":"throwing all of our children under the bus .","depth":11},{"id":62,"text":"Totally irresponsible .","depth":10},{"id":63,"text":"https : //t.co/np7BmP1AkB","depth":8},{"id":64,"text":"- Senator Bob Corker","depth":9},{"id":65,"text":"( @ SenBobCorker )","depth":9},{"id":66,"text":"March 23 , 2018","depth":6},{"id":67,"text":"The conservative House Freedom Caucus has voiced its opposition to the bill ,","depth":2},{"id":68,"text":"based on increased spending levels .","depth":2}],"relations":[{"parent":137,"left":135,"right":136,"relation":"adversative","nuclearity":"NN"},{"parent":135,"left":92,"right":134,"relation":"elaboration","nuclearity":"NS"},{"parent":92,"left":82,"right":91,"relation":"explanation","nuclearity":"NS"},{"parent":82,"left":79,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":74,"right":78,"relation":"causal","nuclearity":"NS"},{"parent":74,"left":71,"right":73,"relation":"explanation","nuclearity":"NS"},{"parent":71,"left":70,"right":2,"relation":"adversative","nuclearity":"NS"},{"parent":70,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":3,"right":72,"relation":"attribution","nuclearity":"SN"},{"parent":72,"left":4,"right":5,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":77,"right":10,"relation":"explanation","nuclearity":"NS"},{"parent":77,"left":76,"right":9,"relation":"same-unit","nuclearity":"NN"},{"parent":76,"left":6,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":11,"right":80,"relation":"condition","nuclearity":"SN"},{"parent":80,"left":12,"right":13,"relation":"context","nuclearity":"NS"},{"parent":91,"left":88,"right":90,"relation":"attribution","nuclearity":"NS"},{"parent":88,"left":14,"right":87,"relation":"elabor