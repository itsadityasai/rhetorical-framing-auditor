lation":"joint","nuclearity":"NN"},{"parent":284,"left":62,"right":63,"relation":"mode","nuclearity":"SN"},{"parent":286,"left":65,"right":66,"relation":"joint","nuclearity":"NN"},{"parent":447,"left":425,"right":446,"relation":"joint","nuclearity":"NN"},{"parent":425,"left":316,"right":424,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":308,"right":315,"relation":"evaluation","nuclearity":"NS"},{"parent":308,"left":300,"right":307,"relation":"joint","nuclearity":"NN"},{"parent":300,"left":67,"right":299,"relation":"context","nuclearity":"SN"},{"parent":299,"left":296,"right":298,"relation":"joint","nuclearity":"NN"},{"parent":296,"left":293,"right":295,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":291,"right":292,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":68,"right":69,"relation":"attribution","nuclearity":"SN"},{"parent":292,"left":70,"right":71,"relation":"joint","nuclearity":"NN"},{"parent":295,"left":72,"right":294,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":73,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":75,"right":297,"relation":"attribution","nuclearity":"SN"},{"parent":297,"left":76,"right":77,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":305,"right":306,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":304,"right":83,"relation":"attribution","nuclearity":"NS"},{"parent":304,"left":303,"right":82,"relation":"same-unit","nuclearity":"NN"},{"parent":303,"left":78,"right":302,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":79,"right":301,"relation":"attribution","nuclearity":"SN"},{"parent":301,"left":80,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":84,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":315,"left":312,"right":314,"relation":"evaluation","nuclearity":"NS"},{"parent":312,"left":86,"right":311,"relation":"condition","nuclearity":"SN"},{"parent":311,"le