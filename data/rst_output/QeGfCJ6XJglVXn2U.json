","nuclearity":"NN"},{"parent":282,"left":119,"right":281,"relation":"elaboration","nuclearity":"NS"},{"parent":281,"left":120,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":290,"right":293,"relation":"elaboration","nuclearity":"NS"},{"parent":290,"left":285,"right":289,"relation":"attribution","nuclearity":"NS"},{"parent":285,"left":124,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":126,"right":288,"relation":"context","nuclearity":"NS"},{"parent":288,"left":286,"right":287,"relation":"same-unit","nuclearity":"NN"},{"parent":286,"left":127,"right":128,"relation":"elaboration","nuclearity":"NS"},{"parent":287,"left":129,"right":130,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":131,"right":292,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":132,"right":291,"relation":"attribution","nuclearity":"SN"},{"parent":291,"left":133,"right":134,"relation":"purpose","nuclearity":"NS"},{"parent":298,"left":135,"right":297,"relation":"attribution","nuclearity":"SN"},{"parent":297,"left":136,"right":137,"relation":"joint","nuclearity":"NN"},{"parent":329,"left":312,"right":328,"relation":"joint","nuclearity":"NN"},{"parent":312,"left":138,"right":311,"relation":"context","nuclearity":"SN"},{"parent":311,"left":301,"right":310,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":139,"right":300,"relation":"attribution","nuclearity":"SN"},{"parent":300,"left":140,"right":141,"relation":"condition","nuclearity":"SN"},{"parent":310,"left":304,"right":309,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":303,"right":145,"relation":"attribution","nuclearity":"NS"},{"parent":303,"left":302,"right":144,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":142,"right":143,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":307,"right":308,"relation":"evaluation","nuclearity":"NS"},{"parent":307,"left":146,"right":306,"relation":"adversative","n