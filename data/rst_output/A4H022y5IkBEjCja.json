{"article_id":"A4H022y5IkBEjCja","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"President Trump took to Twitter on Saturday morning","depth":6},{"id":2,"text":"to claim","depth":7},{"id":3,"text":"the media ignored some good news about his administration .","depth":7},{"id":4,"text":"\" The media has not reported","depth":8},{"id":5,"text":"that the National Debt in my first month went down by $ 12 billion vs a $ 200 billion increase in Obama first mo , \"","depth":8},{"id":6,"text":"he tweeted .","depth":7},{"id":7,"text":"In a follow-up tweet , he added :","depth":7},{"id":8,"text":"\" Great optimism for future of U.S. business , AND JOBS ,","depth":9},{"id":9,"text":"with the DOW having an 11th straight record close .","depth":9},{"id":10,"text":"Big tax & regulation cuts coming ! \"","depth":8},{"id":11,"text":"Trump did n't indicate","depth":6},{"id":12,"text":"where he got the numbers ,","depth":6},{"id":13,"text":"but some of his supporters have been making the same argument .","depth":5},{"id":14,"text":"The Gateway Pundit , a far-right website , published an article Thursday","depth":6},{"id":15,"text":"citing figures from the Treasury Department","depth":7},{"id":16,"text":"that show","depth":8},{"id":17,"text":"the national debt stood at $ 19,947 billion the day","depth":11},{"id":18,"text":"Trump took office","depth":11},{"id":19,"text":"but fell to $ 19,935 billion by Feb. 21","depth":10},{"id":20,"text":"- a drop of $ 12 billion .","depth":9},{"id":21,"text":"While it ' s true that the debt probably ticked down ,","depth":8},{"id":22,"text":"\" this is mostly due to the federal government rebalancing its intra-governmental holdings , \"","depth":8},{"id":23,"text":"the publication reported .","depth":7},{"id":24,"text":"\" Debt outstanding to the public has barely budged since Inauguration Day . ''","depth":6},{"id":25,"text":"In addition , the federal government is still operating under the budget","depth":6},{"id":26,"text":"passed","depth":7},{"id":27,"text":"before Trump came into office ,","depth":7},{"id":28,"text":"so","depth":7},{"id":29,"text":"even if the overall debt decreased ,","depth":8},{"id":30,"text":"his administration had little to do with it ,","depth":8},{"id":31,"text":"the publication said .","depth":6},{"id":32,"text":"Senate confirms deficit hawk Mick Mulvaney as Trump budget chief","depth":4},{"id":33,"text":"Trump pick for budget director backs Medicare changes ,","depth":5},{"id":34,"text":"promises debt cuts","depth":5},{"id":35,"text":"\" Finally , \" the Business Insider noted ,","depth":5},{"id":36,"text":"\" the economic circumstances during his and Obama 's first month in office are vastly different","depth":6},{"id":37,"text":"and make the comparison totally off base . \"","depth":6},{"id":38,"text":"When Obama took office in January 2009 ,","depth":6},{"id":39,"text":"the country was in the midst of the worst financial crisis since the Great Depression .","depth":7},{"id":40,"text":"The US economy lost 702,000 jobs in February 2009 and 832,000 in March 2009 ,","depth":9},{"id":41,"text":"GDP growth collapsed ,","depth":10},{"id":42,"text":"and foreclosures soared . \" In response to this crisis , Obama did what presidents typically do during recessions :","depth":10},{"id":43,"text":"took on debt","depth":9},{"id":44,"text":"to stimulate the economy . \"","depth":9},{"id":45,"text":"The Congressional Budget Office projected","depth":7},{"id":46,"text":"national debt will grow by $ 9.4 trillion over the next decade ,","depth":8},{"id":47,"text":"even without further spending .","depth":8},{"id":48,"text":"But ,","depth":9},{"id":49,"text":"\" based on his campaign pledges ,","depth":11},{"id":50,"text":"many analysts say","depth":11},{"id":51,"text":"Trump ' s policies would be likely to significantly widen the budget deficit , \"","depth":10},{"id":52,"text":"the Council on Foreign Relations reported Friday .","depth":8},{"id":53,"text":"The report cited Trump ' s promises","depth":8},{"id":54,"text":"to forgo any cuts to entitlements ,","depth":9},{"id":55,"text":"rebuild the military ,","depth":10},{"id":56,"text":"spend $ 1 trillion on infrastructure","depth":11},{"id":57,"text":"and cut corporate and individual taxes .","depth":11}],"relations":[{"parent":115,"left":0,"right":114,"relation":"organization","nuclearity":"SN"},{"parent":114,"left":88,"right":113,"relation":"elaboration","nuclearity":"NS"},{"parent":88,"left":70,"right":87,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":67,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":60,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":1,"right":59,"relation":"purpose","nuclearity":"NS"},{"parent":59,"left":2,"right":3,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":62,"right":65,"relation":"joint","nuclearity":"NN"},{"parent":62,"left":61,"right":6,"relation":"attribution","nuclearity":"NS"},{"parent":61,"left":4,"right":5,"relation":"attribution","nuclearity":"SN"},{"parent":65,"left":7,"right":64,"relation":"attribution","nuclearity":"SN"},{"parent":64,"left":63,"right":10,"relation":"joint","nuclearity":"NN"},{"parent":63,"left":8,"right":9,"relation":"explanation","nuclearity":"NS"},{"parent":69,"left":68,"right":13,"relation":"adversative","nuclearity":"NN"},{"parent":68,"left":11,"right":12,"relation":"attribution","nuclearity":"SN"},{"parent":87,"left":80,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":76,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":14,"right":75,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":15,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":16,"right":73,"relation":"attribution","nuclearity":"SN"},{"parent":73,"left":72,"right":20,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":71,"right":19,"relation":"adversative","nuclearity":"SN"},{"parent"