{"article_id":"6wtbEhtrYKfHoXoN","edus":[{"id":0,"text":"Unemployment Rate Drops To 7.7 Percent ,","depth":2},{"id":1,"text":"As Economy Adds 146,000 Jobs","depth":2},{"id":2,"text":"The unemployment rate dropped to 7.7 percent in November ,","depth":6},{"id":3,"text":"the Bureau of Labor Statistics says .","depth":6},{"id":4,"text":"That 's a four-year low .","depth":5},{"id":5,"text":"The economy added 146,000 jobs ,","depth":5},{"id":6,"text":"beating expectations .","depth":5},{"id":7,"text":"Surprisingly the BLS said","depth":6},{"id":8,"text":"that Hurricane Sandy `` did not substantively impact the national employment and unemployment estimates for November . ''","depth":6},{"id":9,"text":"The BLS adds","depth":6},{"id":10,"text":"that employment increased `` in retail trade , professional and business services , and health care . ''","depth":6},{"id":11,"text":"Now , the headline from The Wall Street Journal is that this report from the BLS is the `` least important jobs report in 5 years . ''","depth":5},{"id":12,"text":"Why ?","depth":6},{"id":13,"text":"First , the November data is `` extremely noisy . ''","depth":7},{"id":14,"text":"Even without Hurricane Sandy ,","depth":9},{"id":15,"text":"the Journal points out ,","depth":9},{"id":16,"text":"the report includes increased hiring for the holidays as well as the jobs of poll workers during the election .","depth":9},{"id":17,"text":"Speak","depth":10},{"id":18,"text":"ng of which this report comes after the elections ,","depth":11},{"id":19,"text":"o the political ramifications are less urgent .","depth":11},{"id":20,"text":"he bottom line ,","depth":6},{"id":21,"text":"ne economist","depth":8},{"id":22,"text":"loomberg spoke to","depth":8},{"id":23,"text":"aid ,","depth":7},{"id":24,"text":"s that the country is making progress on the jobs market ,","depth":6},{"id":25,"text":"ven if `` it 's not as fast","depth":7},{"id":26,"text":"s policy makers would like . ''","depth":7},{"id":27,"text":"` The unemployment rate in November was forecast to hold at 7.9 percent ,","depth":7},{"id":28,"text":"ccording to the","depth":8},{"id":29,"text":"Bloomberg ] survey median .","depth":8},{"id":30,"text":"rojections ranged from 7.9 percent to 8.1 percent . ``","depth":6},{"id":31,"text":"he poll of households ,","depth":9},{"id":32,"text":"sed to calculate the jobless rate ,","depth":9},{"id":33,"text":"howed","depth":8},{"id":34,"text":"hat 369,000 people were not at work","depth":10},{"id":35,"text":"ecause of bad weather","depth":10},{"id":36,"text":"uring the survey week .","depth":9},{"id":37,"text":"he average of the last 10 Novembers was 70,000 .","depth":8},{"id":38,"text":"he Labor Department said","depth":7},{"id":39,"text":"t conducted the survey a week earlier than typical","depth":8},{"id":40,"text":"ecause of the Thanksgiving holiday . ''","depth":8},{"id":41,"text":"s with all these things , this good report comes with many caveats .","depth":4},{"id":42,"text":"e 've already touched upon the `` noise . ''","depth":5},{"id":43,"text":"he Washington Post has five other caveats .","depth":6},{"id":44,"text":"n important one","depth":8},{"id":45,"text":"hat blunts the good news in this report","depth":8},{"id":46,"text":"s that many Americans dropped out of the job market .","depth":7}],"relations":[{"parent":93,"left":48,"right":92,"relation":"organization","nuclearity":"SN"},{"parent":48,"left":0,"right":1,"relation":"context","nuclearity":"NS"},{"parent":92,"left":65,"right":91,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":52,"right":64,"relation":"joint","nuclearity":"NN"},{"parent":52,"left":50,"right":51,"relation":"joint","nuclearity":"NN"},{"parent":50,"left":49,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":49,"left":2,"right":3,"relation":"attribution","nuclearity":"NS"},{"parent":51,"left":5,"right":6,"relation":"causal","nuclearity":"NS"},{"parent":64,"left":55,"right":63,"relation":"elaboration","nuclearity":"NS"},{"