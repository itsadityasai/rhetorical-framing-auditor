{"article_id":"QEGpKeys8Hb7E4wa","edus":[{"id":0,"text":"The Cleveland man","depth":6},{"id":1,"text":"who kidnapped three women","depth":7},{"id":2,"text":"and sexually assaulted them for nearly a decade in his basement","depth":7},{"id":3,"text":"was found dead in his jail cell Tuesday night after an apparent suicide .","depth":5},{"id":4,"text":"A statement from the Ohio Department of Corrections said","depth":6},{"id":5,"text":"Ariel Castro , 53 , was found hanging in his cell at the Correctional Reception Center in the town of Orient at 9:20 p.m. local time .","depth":6},{"id":6,"text":"After prison medical staff attempted to perform life-saving measures ,","depth":6},{"id":7,"text":"Castro was transferred to The Ohio State University Wexner Medical Center in Columbus ,","depth":7},{"id":8,"text":"where he was pronounced dead at 10:52 p.m .","depth":7},{"id":9,"text":"Castro 's death is being investigated by the Ohio State Police and the Department of Corrections .","depth":4},{"id":10,"text":"According to the statement from the latter ,","depth":8},{"id":11,"text":"Castro was being kept in protective custody ,","depth":9},{"id":12,"text":"isolated from other inmates due to his high profile ,","depth":10},{"id":13,"text":"and was subject to checks every 30 minutes .","depth":10},{"id":14,"text":"He was in the cell by himself","depth":8},{"id":15,"text":"when he was found .","depth":8},{"id":16,"text":"Department spokeswoman JoEllen Smith told the Associated Press","depth":7},{"id":17,"text":"that Castro was not on suicide watch ,","depth":8},{"id":18,"text":"which entails constant surveillance .","depth":8},{"id":19,"text":"An Ohio coroner confirmed reports","depth":7},{"id":20,"text":"that Castro did indeed commit suicide","depth":8},{"id":21,"text":"by hanging himself , apparently with a bed sheet ,","depth":8},{"id":22,"text":"Reuters reported .","depth":6},{"id":23,"text":"Castro 's attorneys tried unsuccessfully to have a psychological examination of Castro done at the Cuyahoga County Jail ,","depth":6},{"id":24,"text":"where Castro was housed","depth":6},{"id":25,"text":"before he was turned over to state authorities","depth":6},{"id":26,"text":"following his conviction ,","depth":6},{"id":27,"text":"his attorney , Jaye Schlachet , told The Associated Press early Wednesday .","depth":4},{"id":28,"text":"Schlachet said","depth":4},{"id":29,"text":"he could not immediately comment further .","depth":4},{"id":30,"text":"Castro , a former school bus driver , was sentenced to life in prison plus 1,000 years on August 1","depth":6},{"id":31,"text":"for kidnapping and sexually assaulting Amanda Berry , Michelle Knight , and Gina DeJesus","depth":7},{"id":32,"text":"while holding them captive in his house .","depth":7},{"id":33,"text":"He even fathered a daughter with Berry ,","depth":6},{"id":34,"text":"but was barred from seeing the child","depth":7},{"id":35,"text":"after a judge rejected his request for visitation rights as a consequence of his sentence .","depth":7},{"id":36,"text":"Investigators say","depth":6},{"id":37,"text":"the women were bound with chains ,","depth":7},{"id":38,"text":"repeatedly raped","depth":8},{"id":39,"text":"and deprived of food and bathroom facilities .","depth":8},{"id":40,"text":"Knight told investigators","depth":7},{"id":41,"text":"she was beaten and starved several times","depth":8},{"id":42,"text":"to force her to miscarry .","depth":8},{"id":43,"text":"In a rambling statement , he told the judge","depth":8},{"id":44,"text":"he was not a monster ,","depth":9},{"id":45,"text":"but a man","depth":10},{"id":46,"text":"suffering from a pornography addiction ,","depth":10},{"id":47,"text":"saying","depth":8},{"id":48,"text":"`` I 'm not a monster .","depth":9},{"id":49,"text":"I 'm sick . ''","depth":9},{"id":50,"text":"Knight was the only one of the three","depth":5},{"id":51,"text":"who appeared in court at his sentencing .","depth":5},{"id":52,"text":"`` You took 11 years of my life away ,","depth":7},{"id":53,"text":"and I have got it back , ''","depth":7},{"id":54,"text":"she said in the hushed courtroom .","depth":6},{"id":55,"text":"`` I spent 11 years in hell .","depth":6},{"id":56,"text":"Now your hell is just beginning . ''","depth":6},{"id":57,"text":"The three women were kidnapped between 2002 and 2004 .","depth":5},{"id":58,"text":"DeJesus was 14 at the time of her abduction ,","depth":6},{"id":59,"text":"while Berry was 16","depth":7},{"id":60,"text":"and Knight was 20 years old .","depth":7},{"id":61,"text":"They escaped May 6 ,","depth":6},{"id":62,"text":"when one of the women broke down part of a door","depth":7},{"id":63,"text":"and yelled to neighbors for help .","depth":7},{"id":64,"text":"Castro was arrested that evening .","depth":5},{"id":65,"text":"In an interview last month after Castro 's conviction , Schlachet and attorney Craig Weintraub said","depth":4},{"id":66,"text":"their client clearly fit the profile of sociopathic disorder","depth":5},{"id":67,"text":"and that they hoped","depth":6},{"id":68,"text":"researchers would study him for clues","depth":7},{"id":69,"text":"that could be used","depth":8},{"id":70,"text":"to stop other predators .","depth":8}],"relations":[{"parent":141,"left":100,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":93,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":93,"left":79,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":74,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":73,"right":3,"relation":"same-unit","nuclearity":"NN"},{"parent":73,"left":0,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":1,"right":2,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":75,"right":77,"relation":"joint","nuclearity":"NN"},{"parent":75,"left":4,"right":5,"relation":"attribution","nuclearity":"SN"},{"parent":77,"left":6,"right":76,"relation":"joint","nuclearity":"NN"},{"paren