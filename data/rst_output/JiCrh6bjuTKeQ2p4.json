nit","nuclearity":"NN"},{"parent":280,"left":88,"right":89,"relation":"elaboration","nuclearity":"NS"},{"parent":284,"left":282,"right":283,"relation":"attribution","nuclearity":"SN"},{"parent":282,"left":91,"right":92,"relation":"context","nuclearity":"NS"},{"parent":283,"left":93,"right":94,"relation":"elaboration","nuclearity":"NS"},{"parent":310,"left":293,"right":309,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":288,"right":292,"relation":"joint","nuclearity":"NN"},{"parent":288,"left":95,"right":287,"relation":"causal","nuclearity":"NS"},{"parent":287,"left":286,"right":98,"relation":"joint","nuclearity":"NN"},{"parent":286,"left":96,"right":97,"relation":"purpose","nuclearity":"NS"},{"parent":292,"left":289,"right":291,"relation":"adversative","nuclearity":"SN"},{"parent":289,"left":99,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":101,"right":290,"relation":"elaboration","nuclearity":"NS"},{"parent":290,"left":102,"right":103,"relation":"joint","nuclearity":"NN"},{"parent":309,"left":299,"right":308,"relation":"joint","nuclearity":"NN"},{"parent":299,"left":298,"right":110,"relation":"causal","nuclearity":"NS"},{"parent":298,"left":295,"right":297,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":104,"right":294,"relation":"context","nuclearity":"NS"},{"parent":294,"left":105,"right":106,"relation":"purpose","nuclearity":"NS"},{"parent":297,"left":107,"right":296,"relation":"attribution","nuclearity":"SN"},{"parent":296,"left":108,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":308,"left":305,"right":307,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":111,"right":304,"relation":"context","nuclearity":"NS"},{"parent":304,"left":112,"right":303,"relation":"context","nuclearity":"SN"},{"parent":303,"left":300,"right":302,"relation":"same-unit","nuclearity":"NN"},{"parent":300,"left":113,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":1