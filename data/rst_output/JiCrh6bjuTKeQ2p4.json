n":"elaboration","nuclearity":"NS"},{"parent":232,"left":231,"right":43,"relation":"condition","nuclearity":"NS"},{"parent":231,"left":41,"right":42,"relation":"purpose","nuclearity":"NS"},{"parent":388,"left":245,"right":387,"relation":"joint","nuclearity":"NN"},{"parent":245,"left":243,"right":244,"relation":"adversative","nuclearity":"NN"},{"parent":243,"left":239,"right":242,"relation":"explanation","nuclearity":"NS"},{"parent":239,"left":44,"right":45,"relation":"elaboration","nuclearity":"NS"},{"parent":242,"left":241,"right":49,"relation":"attribution","nuclearity":"NS"},{"parent":241,"left":240,"right":48,"relation":"same-unit","nuclearity":"NN"},{"parent":240,"left":46,"right":47,"relation":"elaboration","nuclearity":"NS"},{"parent":244,"left":50,"right":51,"relation":"attribution","nuclearity":"SN"},{"parent":387,"left":263,"right":386,"relation":"joint","nuclearity":"NN"},{"parent":263,"left":253,"right":262,"relation":"joint","nuclearity":"NN"},{"parent":253,"left":246,"right":252,"relation":"elaboration","nuclearity":"NS"},{"parent":246,"left":52,"right":53,"relation":"mode","nuclearity":"NS"},{"parent":252,"left":54,"right":251,"relation":"adversative","nuclearity":"SN"},{"parent":251,"left":248,"right":250,"relation":"attribution","nuclearity":"NS"},{"parent":248,"left":55,"right":247,"relation":"joint","nuclearity":"NN"},{"parent":247,"left":56,"right":57,"relation":"restatement","nuclearity":"NN"},{"parent":250,"left":58,"right":249,"relation":"elaboration","nuclearity":"NS"},{"parent":249,"left":59,"right":60,"relation":"elaboration","nuclearity":"NS"},{"parent":262,"left":254,"right":261,"relation":"joint","nuclearity":"NN"},{"parent":254,"left":61,"right":62,"relation":"elaboration","nuclearity":"NS"},{"parent":261,"left":257,"right":260,"relation":"elaboration","nuclearity":"NS"},{"parent":257,"left":63,"right":256,"relation":"context","nuclearity":"SN"},{"parent":256,"left":64,"right":255,"relation":"attribution","nuclearity":"SN"},{"parent":25