ion":"adversative","nuclearity":"SN"},{"parent":233,"left":94,"right":232,"relation":"attribution","nuclearity":"SN"},{"parent":232,"left":95,"right":231,"relation":"explanation","nuclearity":"NS"},{"parent":231,"left":96,"right":97,"relation":"condition","nuclearity":"SN"},{"parent":236,"left":98,"right":235,"relation":"explanation","nuclearity":"NS"},{"parent":235,"left":234,"right":101,"relation":"explanation","nuclearity":"SN"},{"parent":234,"left":99,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":242,"left":102,"right":241,"relation":"attribution","nuclearity":"SN"},{"parent":241,"left":240,"right":107,"relation":"evaluation","nuclearity":"NS"},{"parent":240,"left":103,"right":239,"relation":"elaboration","nuclearity":"NS"},{"parent":239,"left":104,"right":238,"relation":"context","nuclearity":"NS"},{"parent":238,"left":105,"right":106,"relation":"explanation","nuclearity":"NS"},{"parent":273,"left":248,"right":272,"relation":"joint","nuclearity":"NN"},{"parent":248,"left":244,"right":247,"relation":"same-unit","nuclearity":"NN"},{"parent":244,"left":108,"right":109,"relation":"same-unit","nuclearity":"NN"},{"parent":247,"left":110,"right":246,"relation":"joint","nuclearity":"NN"},{"parent":246,"left":111,"right":245,"relation":"elaboration","nuclearity":"NS"},{"parent":245,"left":112,"right":113,"relation":"attribution","nuclearity":"SN"},{"parent":272,"left":114,"right":271,"relation":"joint","nuclearity":"NN"},{"parent":271,"left":267,"right":270,"relation":"evaluation","nuclearity":"NS"},{"parent":267,"left":253,"right":266,"relation":"joint","nuclearity":"NN"},{"parent":253,"left":115,"right":252,"relation":"explanation","nuclearity":"NS"},{"parent":252,"left":250,"right":251,"relation":"elaboration","nuclearity":"NS"},{"parent":250,"left":249,"right":118,"relation":"attribution","nuclearity":"NS"},{"parent":249,"left":116,"right":117,"relation":"adversative","nuclearity":"NS"},{"parent":251,"left":119,"right":120,"relation":"attribution