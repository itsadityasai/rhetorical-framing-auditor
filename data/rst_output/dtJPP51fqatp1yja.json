{"article_id":"dtJPP51fqatp1yja","edus":[{"id":0,"text":"President Donald Trump said Monday","depth":5},{"id":1,"text":"that he rejected a compromise plan","depth":7},{"id":2,"text":"to reopen the government temporarily ,","depth":7},{"id":3,"text":"so he could continue negotiating a border wall with his Democratic congressional foes .","depth":6},{"id":4,"text":"En route to a speech to the American Farm Bureau Federation ' s convention in New Orleans , Trump blamed the Democrats for the shutdown .","depth":4},{"id":5,"text":"No negotiations have been scheduled","depth":4},{"id":6,"text":"since he walked out of a session Wednesday .","depth":4},{"id":7,"text":"Trump said","depth":6},{"id":8,"text":"he rejected a plan from Sen. Lindsey Graham , R-S.C. ,","depth":7},{"id":9,"text":"because he wants a permanent fix for border security ,","depth":8},{"id":10,"text":"including $ 5.7 billion for a U.S.-Mexican border wall .","depth":8},{"id":11,"text":"Graham 's plan would reopen the government for three weeks","depth":6},{"id":12,"text":"while the two sides negotiated .","depth":6},{"id":13,"text":"`` I want to get it solved , ''","depth":5},{"id":14,"text":"Trump said .","depth":6},{"id":15,"text":"`` I do n't want to just delay it . ''","depth":6},{"id":16,"text":"On the shutdown 's 24th day , a record , Trump said ,","depth":4},{"id":17,"text":"`` I do n't know","depth":5},{"id":18,"text":"if we 're close on a deal . ''","depth":5},{"id":19,"text":"Earlier in the morning , on Twitter , Trump blamed Democratic leaders Sen. Charles Schumer and House Speaker Nancy Pelosi for the shutdown ,","depth":5},{"id":20,"text":"saying","depth":6},{"id":21,"text":"they should sign on to his wall plan .","depth":6},{"id":22,"text":"`` Nancy and Cryin ' Chuck can end the Shutdown in 15 minutes , ''","depth":6},{"id":23,"text":"Trump said .","depth":6},{"id":24,"text":"`` At this point it has become their , and the Democrats , fault ! ''","depth":5},{"id":25,"text":"Schumer , Pelosi and other Democrats said","depth":5},{"id":26,"text":"the shutdown is the result of Trump 's insistence on a wall","depth":6},{"id":27,"text":"they said","depth":7},{"id":28,"text":"would be ineffective .","depth":7},{"id":29,"text":"They noted","depth":5},{"id":30,"text":"he rejected compromises","depth":6},{"id":31,"text":"that would have reopened the government .","depth":6},{"id":32,"text":"In a tweeted response to Trump , Pelosi said Monday","depth":5},{"id":33,"text":"that Democrats are pushing their own plan","depth":7},{"id":34,"text":"to reopen the government","depth":8},{"id":35,"text":"while border security negotiations continue ,","depth":8},{"id":36,"text":"but Trump and the Republican-run Senate are blocking it .","depth":6},{"id":37,"text":"`` The truth ? ''","depth":6},{"id":38,"text":"Pelosi tweeted .","depth":6},{"id":39,"text":"`` Republicans started the # TrumpShutdown -","depth":7},{"id":40,"text":"and Democrats are working","depth":8},{"id":41,"text":"to end it .","depth":8},{"id":42,"text":"@ realDonaldTrump , it ' s time for you to stop standing in the way","depth":9},{"id":43,"text":"of re-opening the government .","depth":9},{"id":44,"text":"Let the Senate vote !","depth":8},{"id":45,"text":"# EndTheShutdown . ''","depth":7},{"id":46,"text":"Back at the White House , Trump again declared","depth":6},{"id":47,"text":"he has the authority","depth":8},{"id":48,"text":"to declare a national emergency on the border ,","depth":9},{"id":49,"text":"which would allow him to use defense money for a wall - a move","depth":9},{"id":50,"text":"that would trigger lawsuits from Democrats","depth":8},{"id":51,"text":"who said","depth":9},{"id":52,"text":"Trump lacks the legal authority","depth":10},{"id":53,"text":"to declare an emergency in this case .","depth":10},{"id":54,"text":"Since raising the possibility last week ,","depth":8},{"id":55,"text":"Trump said","depth":9},{"id":56,"text":"he wants to hold off any declaration ,","depth":9},{"id":57,"text":"saying","depth":8},{"id":58,"text":"he and Congress should work out the wall dispute .","depth":8},{"id":59,"text":"`` I 'm not looking to call a national emergency , ''","depth":7},{"id":60,"text":"Trump said Monday .","depth":7},{"id":61,"text":"In blaming the Democrats ,","depth":6},{"id":62,"text":"Trump stressed","depth":7},{"id":63,"text":"that the party controls the House of Representatives","depth":8},{"id":64,"text":"and has the votes","depth":9},{"id":65,"text":"to block action in the Senate with a filibuster .","depth":9},{"id":66,"text":"`` The Democrats have to do something , ''","depth":7},{"id":67,"text":"Trump said .","depth":7},{"id":68,"text":"`` We need their votes .","depth":7},{"id":69,"text":"Otherwise , we ca n't solve it","depth":8},{"id":70,"text":"without their votes . ''","depth":8}],"relations":[{"parent":141,"left":89,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":77,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":75,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":74,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":0,"right":73,"relation":"attribution","nuclearity":"SN"},{"parent":73,"left":72,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":72,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":5,"right":6,"relation":"context","nuclearity":"NS"},{"parent":88,"left":85,"right":87,"relation":"joint","nuclearity":"NN"},{"parent":85,"left":82,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":80,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":7,"right":79,"relation":"attribution","nuclearity":"SN"},{"parent":79,"left":8,"right":78,"relation":"explanation","nuclearity":"NS"},{"parent":78,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":11,"right":12,"relation":"context","nuclearity":"NS"},{"parent":84,"left"