t":235,"left":230,"right":234,"relation":"elaboration","nuclearity":"NS"},{"parent":230,"left":28,"right":29,"relation":"causal","nuclearity":"NS"},{"parent":234,"left":30,"right":233,"relation":"context","nuclearity":"SN"},{"parent":233,"left":31,"right":232,"relation":"elaboration","nuclearity":"NS"},{"parent":232,"left":32,"right":231,"relation":"purpose","nuclearity":"NS"},{"parent":231,"left":33,"right":34,"relation":"joint","nuclearity":"NN"},{"parent":238,"left":236,"right":237,"relation":"adversative","nuclearity":"NN"},{"parent":236,"left":35,"right":36,"relation":"attribution","nuclearity":"SN"},{"parent":237,"left":37,"right":38,"relation":"elaboration","nuclearity":"NS"},{"parent":407,"left":368,"right":406,"relation":"joint","nuclearity":"NN"},{"parent":368,"left":253,"right":367,"relation":"joint","nuclearity":"NN"},{"parent":253,"left":251,"right":252,"relation":"elaboration","nuclearity":"NS"},{"parent":251,"left":245,"right":250,"relation":"joint","nuclearity":"NN"},{"parent":245,"left":39,"right":244,"relation":"attribution","nuclearity":"SN"},{"parent":244,"left":40,"right":243,"relation":"context","nuclearity":"NS"},{"parent":243,"left":41,"right":42,"relation":"context","nuclearity":"NS"},{"parent":250,"left":248,"right":249,"relation":"attribution","nuclearity":"NS"},{"parent":248,"left":247,"right":46,"relation":"joint","nuclearity":"NN"},{"parent":247,"left":246,"right":45,"relation":"same-unit","nuclearity":"NN"},{"parent":246,"left":43,"right":44,"relation":"elaboration","nuclearity":"NS"},{"parent":249,"left":47,"right":48,"relation":"elaboration","nuclearity":"NS"},{"parent":252,"left":49,"right":50,"relation":"elaboration","nuclearity":"NS"},{"parent":367,"left":295,"right":366,"relation":"joint","nuclearity":"NN"},{"parent":295,"left":271,"right":294,"relation":"joint","nuclearity":"NN"},{"parent":271,"left":265,"right":270,"relation":"joint","nuclearity":"NN"},{"parent":265,"left":262,"right":264,"relation":"adversative","nuclearity":"