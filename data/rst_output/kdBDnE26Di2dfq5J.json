lation":"elaboration","nuclearity":"NS"},{"parent":280,"left":79,"right":279,"relation":"attribution","nuclearity":"SN"},{"parent":279,"left":80,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":286,"right":292,"relation":"elaboration","nuclearity":"NS"},{"parent":286,"left":82,"right":285,"relation":"attribution","nuclearity":"SN"},{"parent":285,"left":83,"right":284,"relation":"adversative","nuclearity":"NN"},{"parent":284,"left":84,"right":283,"relation":"elaboration","nuclearity":"NS"},{"parent":283,"left":85,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":87,"right":291,"relation":"organization","nuclearity":"SN"},{"parent":291,"left":287,"right":290,"relation":"elaboration","nuclearity":"NS"},{"parent":287,"left":88,"right":89,"relation":"condition","nuclearity":"SN"},{"parent":290,"left":288,"right":289,"relation":"same-unit","nuclearity":"NN"},{"parent":288,"left":90,"right":91,"relation":"attribution","nuclearity":"NS"},{"parent":289,"left":92,"right":93,"relation":"purpose","nuclearity":"NS"},{"parent":366,"left":324,"right":365,"relation":"elaboration","nuclearity":"NS"},{"parent":324,"left":304,"right":323,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":299,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":298,"right":98,"relation":"explanation","nuclearity":"NS"},{"parent":298,"left":297,"right":97,"relation":"condition","nuclearity":"SN"},{"parent":297,"left":94,"right":296,"relation":"joint","nuclearity":"NN"},{"parent":296,"left":95,"right":96,"relation":"explanation","nuclearity":"NS"},{"parent":303,"left":99,"right":302,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":100,"right":301,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":300,"right":103,"relation":"same-unit","nuclearity":"NN"},{"parent":300,"left":101,"right":102,"relation":"purpose","nuclearity":"NS"},{"parent":323,"left":309,"right":322,"relation":"elaborat