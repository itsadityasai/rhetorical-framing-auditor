rity":"NS"},{"parent":285,"left":85,"right":284,"relation":"elaboration","nuclearity":"NS"},{"parent":284,"left":283,"right":90,"relation":"attribution","nuclearity":"NS"},{"parent":283,"left":281,"right":282,"relation":"evaluation","nuclearity":"NS"},{"parent":281,"left":86,"right":87,"relation":"joint","nuclearity":"NN"},{"parent":282,"left":88,"right":89,"relation":"attribution","nuclearity":"SN"},{"parent":315,"left":291,"right":314,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":289,"right":290,"relation":"adversative","nuclearity":"NN"},{"parent":289,"left":91,"right":92,"relation":"attribution","nuclearity":"SN"},{"parent":290,"left":93,"right":94,"relation":"attribution","nuclearity":"SN"},{"parent":314,"left":304,"right":313,"relation":"joint","nuclearity":"NN"},{"parent":304,"left":298,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":295,"right":297,"relation":"condition","nuclearity":"NS"},{"parent":295,"left":95,"right":294,"relation":"same-unit","nuclearity":"NN"},{"parent":294,"left":293,"right":99,"relation":"same-unit","nuclearity":"NN"},{"parent":293,"left":96,"right":292,"relation":"attribution","nuclearity":"SN"},{"parent":292,"left":97,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":100,"right":296,"relation":"condition","nuclearity":"NS"},{"parent":296,"left":101,"right":102,"relation":"mode","nuclearity":"NS"},{"parent":303,"left":299,"right":302,"relation":"adversative","nuclearity":"NN"},{"parent":299,"left":103,"right":104,"relation":"attribution","nuclearity":"SN"},{"parent":302,"left":105,"right":301,"relation":"attribution","nuclearity":"SN"},{"parent":301,"left":300,"right":108,"relation":"same-unit","nuclearity":"NN"},{"parent":300,"left":106,"right":107,"relation":"context","nuclearity":"NS"},{"parent":313,"left":109,"right":312,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":307,"right":311,"relation":"elaboration","nuclearity":"NS"},{"parent":307,"lef