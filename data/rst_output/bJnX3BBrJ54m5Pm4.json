{"article_id":"bJnX3BBrJ54m5Pm4","edus":[{"id":0,"text":"President Trump is urging Republicans to vote in South Carolina ' s Democratic primary on Saturday for the weakest candidate","depth":4},{"id":1,"text":"- determining","depth":5},{"id":2,"text":"that is Vermont Sen. Bernie Sanders .","depth":5},{"id":3,"text":"Trump ,","depth":7},{"id":4,"text":"hosting a rally in South Carolina on Friday night ,","depth":7},{"id":5,"text":"asked his crowd to help him pick the recipient of GOP votes in the \" open \" primary .","depth":6},{"id":6,"text":"\" I assume","depth":9},{"id":7,"text":"this is okay from a campaign finance standpoint , \"","depth":9},{"id":8,"text":"Trump joked","depth":8},{"id":9,"text":"before carrying out his \" poll \" on the eve of the primary election .","depth":7},{"id":10,"text":"He asked audience members to cheer for the Democrat","depth":10},{"id":11,"text":"they ' d prefer","depth":10},{"id":12,"text":"be his easiest-to-beat opponent","depth":9},{"id":13,"text":"- Sanders or former Vice President Joe Biden .","depth":8},{"id":14,"text":"Asking one more time for his supporters to cheer for either former vice president Biden or Sanders ,","depth":8},{"id":15,"text":"Trump confirmed :","depth":9},{"id":16,"text":"\" They think","depth":10},{"id":17,"text":"Bernie ' s easier to beat . \"","depth":10},{"id":18,"text":"Sanders , a self-declared socialist , emerged as the front-runner after popular-vote wins in Iowa , New Hampshire , and Nevada .","depth":5},{"id":19,"text":"His potential nomination terrifies many Democrats ,","depth":6},{"id":20,"text":"who fear a Trump landslide .","depth":6},{"id":21,"text":"Biden leads Sanders in South Carolina polls ahead of Saturday voting ,","depth":5},{"id":22,"text":"but Republicans could swing the outcome","depth":6},{"id":23,"text":"and give Sanders momentum ahead of the 14-state Super Tuesday contests next week .","depth":6},{"id":24,"text":"\" Really , we ' re down to two candidates , right ?","depth":7},{"id":25,"text":"Sleepy Joe Biden and Crazy Bernie , \"","depth":7},{"id":26,"text":"Trump said .","depth":6},{"id":27,"text":"\" So this is a poll .","depth":7},{"id":28,"text":"I guarantee you this ,","depth":8},{"id":29,"text":"as much as they hate me...","depth":9},{"id":30,"text":"they ' re gon na put this all over the place .","depth":9},{"id":31,"text":"We have a poll of like 30,000 people . \"","depth":6},{"id":32,"text":"Trump belittled Democrats","depth":7},{"id":33,"text":"running for president ,","depth":7},{"id":34,"text":"saying","depth":7},{"id":35,"text":"that former New York City Mayor Mike Bloomberg \" wishes","depth":8},{"id":36,"text":"he never started . \"","depth":8},{"id":37,"text":"\" Should we include Mini Mike or not ? \"","depth":10},{"id":38,"text":"Trump asked the audience .","depth":10},{"id":39,"text":"\" Nooooo ! \"","depth":10},{"id":40,"text":"they responded .","depth":10},{"id":41,"text":"\" Mini Mike is gone .","depth":10},{"id":42,"text":"I think","depth":11},{"id":43,"text":"he ' s gone .","depth":11},{"id":44,"text":"He doesn ' t have a chance , \"","depth":10},{"id":45,"text":"Trump said .","depth":10},{"id":46,"text":"\" I hear","depth":10},{"id":47,"text":"Mini Mike , by the way , has left .","depth":10},{"id":48,"text":"He ' s basically given up ,","depth":11},{"id":49,"text":"that ' s what I hear .","depth":11},{"id":50,"text":"He gave up .","depth":11},{"id":51,"text":"He gave up .","depth":11},{"id":52,"text":"I hope","depth":9},{"id":53,"text":"what I said keeps him in . \"","depth":9},{"id":54,"text":"Trump omitted from his bash-spree former South Bend , Indiana , Mayor Pete Buttigieg ,","depth":7},{"id":55,"text":"who won the most delegates in Iowa and placed second in New Hampshire .","depth":7},{"id":56,"text":"Trump dismissed outright fellow billionaire Tom Steyer as a \" loser \"","depth":6},{"id":57,"text":"who is \" not that wealthy \"","depth":6},{"id":58,"text":"and said","depth":6},{"id":59,"text":"Sen. Elizabeth Warren of Massachusetts is \" so damn mean . \"","depth":6},{"id":60,"text":"Trump ' s urging echoes past attempts by conservatives","depth":2},{"id":61,"text":"to cross lines en masse","depth":3},{"id":62,"text":"to influence Democratic politics , most significantly radio host Rush Limbaugh ' s \" operation chaos \" in 2008","depth":4},{"id":63,"text":"to extend the primary clash between Barack Obama and Hillary Clinton .","depth":4}],"relations":[{"parent":127,"left":123,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":84,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":66,"right":83,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":0,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":1,"right":2,"relation":"attribution","nuclearity":"SN"},{"parent":83,"left":80,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":68,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":67,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":67,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":71,"right":78,"relation":"joint","nuclearity":"NN"},{"parent":71,"left":70,"right":9,"relation":"joint","nuclearity":"NN"},{"parent":70,"left":69,"right":8,"relation":"attribution","nuclearity":"NS"},{"parent":69,"left":6,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":78,"left":74,"right":77,"relation":"joint","nuclearity":"NN"},{"parent":74,"left":73,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":72,"right":12,"relation":"same-unit","nuclearity":"NN"},{"parent":72,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":14,"right":76,"relation":"context","nuclearity":"SN"},{"parent":76,"left":15,"right":75,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":16,"right":17,"relation":"attribution","nuclearity":"SN"},{"parent":8