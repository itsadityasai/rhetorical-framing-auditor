y":"NN"},{"parent":333,"left":167,"right":168,"relation":"elaboration","nuclearity":"NS"},{"parent":337,"left":336,"right":172,"relation":"elaboration","nuclearity":"NS"},{"parent":336,"left":170,"right":171,"relation":"attribution","nuclearity":"SN"}]}