lation":"adversative","nuclearity":"NN"},{"parent":344,"left":171,"right":343,"relation":"elaboration","nuclearity":"NS"},{"parent":343,"left":342,"right":174,"relation":"same-unit","nuclearity":"NN"},{"parent":342,"left":172,"right":173,"relation":"attribution","nuclearity":"NS"}]}