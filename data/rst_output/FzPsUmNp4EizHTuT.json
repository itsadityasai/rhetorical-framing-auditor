on","nuclearity":"NS"},{"parent":288,"left":287,"right":119,"relation":"context","nuclearity":"SN"},{"parent":287,"left":117,"right":118,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":290,"right":296,"relation":"adversative","nuclearity":"NN"},{"parent":290,"left":121,"right":122,"relation":"attribution","nuclearity":"SN"},{"parent":296,"left":292,"right":295,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":123,"right":291,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":124,"right":125,"relation":"attribution","nuclearity":"SN"},{"parent":295,"left":126,"right":294,"relation":"organization","nuclearity":"SN"},{"parent":294,"left":127,"right":293,"relation":"adversative","nuclearity":"NN"},{"parent":293,"left":128,"right":129,"relation":"elaboration","nuclearity":"NS"},{"parent":330,"left":312,"right":329,"relation":"joint","nuclearity":"NN"},{"parent":312,"left":307,"right":311,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":306,"right":136,"relation":"context","nuclearity":"NS"},{"parent":306,"left":303,"right":305,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":302,"right":132,"relation":"same-unit","nuclearity":"NN"},{"parent":302,"left":130,"right":131,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":304,"right":135,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":133,"right":134,"relation":"adversative","nuclearity":"SN"},{"parent":311,"left":308,"right":310,"relation":"joint","nuclearity":"NN"},{"parent":308,"left":137,"right":138,"relation":"joint","nuclearity":"NN"},{"parent":310,"left":309,"right":141,"relation":"joint","nuclearity":"NN"},{"parent":309,"left":139,"right":140,"relation":"joint","nuclearity":"NN"},{"parent":329,"left":314,"right":328,"relation":"joint","nuclearity":"NN"},{"parent":314,"left":142,"right":313,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":143,"right":144,"relation":"joint","nuclearity":"NN"},{"parent"