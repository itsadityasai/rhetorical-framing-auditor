{"article_id":"9dMrN9a4FngYwlkb","edus":[{"id":0,"text":"The U.S Supreme Court Building in Washington , D.C. , March 18 , 2020","depth":2},{"id":1,"text":"( Tom Brenner/Reuters )","depth":2},{"id":2,"text":"The Supreme Court ruled Monday","depth":7},{"id":3,"text":"that federal sex-based civil rights law protects workers from discrimination on the basis on sexual orientation and gender identity .","depth":7},{"id":4,"text":"The six-to-three decision established","depth":8},{"id":5,"text":"that Title VII of the Civil Rights Act covers sexual orientation as well as an employee ' s sex ,","depth":8},{"id":6,"text":"meaning workers will now be protected in the 29 states","depth":8},{"id":7,"text":"that do not have laws","depth":9},{"id":8,"text":"protecting all LGBTQ employees from job discrimination .","depth":9},{"id":9,"text":"The ruling upheld decisions by lower courts","depth":6},{"id":10,"text":"that concluded","depth":7},{"id":11,"text":"job discrimination on the basis of sexual orientation was included in illegal sex discrimination .","depth":7},{"id":12,"text":"Chief Justice John Roberts joined the court ' s liberal justices","depth":7},{"id":13,"text":"in voting with the majority ,","depth":7},{"id":14,"text":"as did Justice Neil Gorsuch ,","depth":7},{"id":15,"text":"who wrote the opinion for the court .","depth":7},{"id":16,"text":"\" We agree","depth":8},{"id":17,"text":"that homosexuality and transgender status are distinct concepts from sex , \"","depth":8},{"id":18,"text":"Gorsuch wrote in the majority opinion .","depth":7},{"id":19,"text":"\" But ,","depth":7},{"id":20,"text":"as we ' ve seen ,","depth":8},{"id":21,"text":"discrimination","depth":10},{"id":22,"text":"based on homosexuality or transgender status","depth":10},{"id":23,"text":"necessarily entails discrimination","depth":10},{"id":24,"text":"based on sex . \"","depth":10},{"id":25,"text":"The case revolved around two gay men and one transgender individual","depth":5},{"id":26,"text":"who claimed","depth":6},{"id":27,"text":"they faced employment discrimination due to their sexual orientation .","depth":6},{"id":28,"text":"One of the men , Donald Zarda , alleged","depth":6},{"id":29,"text":"that he was fired from his skydiving instructor job on Long Island in 2010","depth":7},{"id":30,"text":"after he told a woman","depth":9},{"id":31,"text":"he was assisting with a parachute jump","depth":9},{"id":32,"text":"that he was gay in an effort","depth":9},{"id":33,"text":"to help her feel more comfortable .","depth":9},{"id":34,"text":"Zarda died in 2014","depth":6},{"id":35,"text":"while his lawsuit was still ongoing .","depth":6},{"id":36,"text":"Justices Samuel Alito and Brett Kavanaugh penned dissents to the decision ,","depth":4},{"id":37,"text":"both accusing the high court of legislating from the bench .","depth":4},{"id":38,"text":"\" There is only one word for what the Court has done today :","depth":7},{"id":39,"text":"legislation , \"","depth":7},{"id":40,"text":"Alito wrote ,","depth":6},{"id":41,"text":"saying","depth":6},{"id":42,"text":"the court has essentially taken the provision on employment discrimination and sexual orientation in the Equality Act ,","depth":8},{"id":43,"text":"which has yet to be passed ,","depth":8},{"id":44,"text":"and \" issued it under the guise of statutory interpretation . \"","depth":7},{"id":45,"text":"\" A more brazen abuse of our authority","depth":8},{"id":46,"text":"to interpret statutes","depth":8},{"id":47,"text":"is hard to recall , \"","depth":7},{"id":48,"text":"Alito wrote ,","depth":6},{"id":49,"text":"adding","depth":6},{"id":50,"text":"that the majority ' s opinion \" sails under a textualist flag ,","depth":7},{"id":51,"text":"but what it actually represents is a theory of statutory interpretation","depth":9},{"id":52,"text":"that Justice Scalia excoriated","depth":9},{"id":53,"text":"- the theory","depth":9},{"id":54,"text":"that courts should ' update ' old statutes","depth":10},{"id":55,"text":"so that they better reflect the current values of society . \"","depth":10}],"relations":[{"parent":111,"left":57,"right":110,"relation":"context","nuclearity":"SN"},{"parent":57,"left":0,"right":1,"relation":"attribution","nuclearity":"NS"},{"parent":110,"left":90,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":90,"left":79,"right":89,"relation":"context","nuclearity":"NS"},{"parent":79,"left":66,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":63,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":58,"right":62,"relation":"elaboration","nuclearity":"NS"},{"parent":58,"left":2,"right":3,"relation":"attribution","nuclearity":"SN"},{"parent":62,"left":59,"right":61,"relation":"causal","nuclearity":"NS"},{"parent":59,"left":4,"right":5,"relation":"attribution","nuclearity":"SN"},{"parent":61,"left":6,"right":60,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":9,"right":64,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":10,"right":11,"relation":"attribution","nuclearity":"SN"},{"parent":78,"left":69,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":67,"right":68,"relation":"joint","nuclearity":"NN"},{"parent":67,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":14,"right":15,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":71,"right":76,"relation":"adversative","nuclearity":"SN"},{"parent":71,"left":70,"right":18,"relation":"attribution","nuclearity":"NS"},{"parent":70,"left":16,"right":17,"relation":"attribution","nuclearity":"SN"},{"parent":76,"left":19,"right":75,"relation":"same-unit","nuclearity":"NN"},{"parent":75,"left":20,"right":74,"relation":"explanation","nuclearity":"SN"},{"parent":74,"left":72,"right":73,"relation":"same-unit","nuclearity":"NN"},{"parent":72,"left":21,"right":22,"relation":"elaboration","nucleari