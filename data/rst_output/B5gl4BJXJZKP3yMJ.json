{"article_id":"B5gl4BJXJZKP3yMJ","edus":[{"id":0,"text":"Florida Gov . Rick Scott said Sunday","depth":4},{"id":1,"text":"that he 's won his closely contested Senate race against Democratic Sen. Bill Nelson","depth":6},{"id":2,"text":"and that his opponent is `` committing fraud '' in an effort","depth":7},{"id":3,"text":"to steal the race from him","depth":7},{"id":4,"text":"and is a `` sore loser . ''","depth":5},{"id":5,"text":"`` Sen. Nelson is trying to commit fraud","depth":5},{"id":6,"text":"to win this election , ''","depth":5},{"id":7,"text":"Scott told host Chris Wallace on `` Fox News Sunday . ''","depth":4},{"id":8,"text":"Florida 's Senate race is one of three statewide contests","depth":5},{"id":9,"text":"headed to an automatic recount ,","depth":5},{"id":10,"text":"after the unofficial deadline","depth":6},{"id":11,"text":"for counties","depth":7},{"id":12,"text":"to report results","depth":7},{"id":13,"text":"passed at noon Saturday .","depth":5},{"id":14,"text":"Scott 's lead over Nelson has narrowed since election night .","depth":5},{"id":15,"text":"Before the recount was ordered ,","depth":6},{"id":16,"text":"he remained in front by just over 12,000 votes","depth":7},{"id":17,"text":"as Democrat-rich counties like Broward County continued to report additional numbers .","depth":7},{"id":18,"text":"Scott repeated his allegations Sunday ,","depth":8},{"id":19,"text":"without evidence ,","depth":8},{"id":20,"text":"that fraud is behind the increase in votes for Nelson ;","depth":7},{"id":21,"text":"both Scott and President Donald Trump have accused Democrats of trying to `` steal '' the election .","depth":6},{"id":22,"text":"Scott ' s comments ,","depth":9},{"id":23,"text":"stopping short of actually accusing Nelson of committing fraud directly ,","depth":9},{"id":24,"text":"concern two issues","depth":9},{"id":25,"text":"that surfaced after Election Day .","depth":9},{"id":26,"text":"In one case , Nelson ' s team of lawyers objected to Palm Beach County ' s election canvassing board from canceling a ballot","depth":9},{"id":27,"text":"cast by a noncititzen ,","depth":10},{"id":28,"text":"who is barred from voting .","depth":10},{"id":29,"text":"In another case , Nelson ' s lawyers are asking a judge to allow all absentee ballots to count ,","depth":10},{"id":30,"text":"including those","depth":11},{"id":31,"text":"where the signature on the mail-in envelope doesn ' t match the signature of the voter in file .","depth":11},{"id":32,"text":"The signature-match rule is designed","depth":11},{"id":33,"text":"to prevent people from fraudulently casting a ballot on behalf of another ,","depth":11},{"id":34,"text":"but the rule had led to tens of thousands of ballots","depth":13},{"id":35,"text":"cast by lawful voters","depth":13},{"id":36,"text":"to be canceled","depth":12},{"id":37,"text":"- including former Congressman and 2016 US Senate candidate Patrick Murphy .","depth":11},{"id":38,"text":"The governor also said","depth":9},{"id":39,"text":"he has asked the Florida Department of Law Enforcement to look into potential fraud .","depth":9},{"id":40,"text":"The department and the secretary of state , both agencies","depth":11},{"id":41,"text":"Scott oversees as governor ,","depth":11},{"id":42,"text":"have both previously said","depth":10},{"id":43,"text":"there is no evidence of fraud .","depth":9},{"id":44,"text":"Nelson and his legal team have insisted","depth":8},{"id":45,"text":"that the increase in votes for the incumbent is simply due to the fact","depth":9},{"id":46,"text":"that more votes were being counted .","depth":9},{"id":47,"text":"COUNTDOWN TO 2020","depth":3},{"id":48,"text":"The race for 2020 starts now .","depth":4},{"id":49,"text":"Stay in the know .","depth":6},{"id":50,"text":"Follow our presidential election coverage .","depth":6},{"id":51,"text":"Email Sign Up","depth":6},{"id":52,"text":"By signing up","depth":8},{"id":53,"text":"you agree to receive email newsletters or alerts from .","depth":8},{"id":54,"text":"You can unsubscribe at any time .","depth":7},{"id":55,"text":"As the recount begins ,","depth":5},{"id":56,"text":"Scott said","depth":6},{"id":57,"text":"he 's `` already won the race two times ''","depth":7},{"id":58,"text":"and intends to head to Washington","depth":8},{"id":59,"text":"to be sworn in as the state 's junior senator .","depth":8},{"id":60,"text":"Wallace said","depth":5},{"id":61,"text":"Nelson was also asked to appear on the show","depth":6},{"id":62,"text":"but declined .","depth":6},{"id":63,"text":"The Senate stands at 51 Republicans to 46 Democrats , with races in Arizona","depth":5},{"id":64,"text":"( where Democrat Kyrsten Sinema leads Republican Martha McSally )","depth":5},{"id":65,"text":"and Mississippi","depth":6},{"id":66,"text":"( which is headed to a runoff later this month )","depth":6},{"id":67,"text":"also still to be resolved .","depth":5}],"relations":[{"parent":135,"left":114,"right":134,"relation":"elaboration","nuclearity":"NS"},{"parent":114,"left":75,"right":113,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":72,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":0,"right":71,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":70,"right":4,"relation":"joint","nuclearity":"NN"},{"parent":70,"left":1,"right":69,"relation":"joint","nuclearity":"NN"},{"parent":69,"left":2,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":74,"left":73,"right":7,"relation":"attribution","nuclearity":"NS"},{"parent":73,"left":5,"right":6,"relation":"purpose","nuclearity":"NS"},{"parent":113,"left":80,"right":112,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":76,"right":79,"relation":"context","nuclearity":"NS"},{"parent":76,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":78,"right":13,"relation":"same-unit","nuclearity":"NN"},{"parent":78,"left":10,"right":77,"relation":"elaboration","nuclearity":"NS"},{"pare