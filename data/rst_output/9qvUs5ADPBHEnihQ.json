{"article_id":"9qvUs5ADPBHEnihQ","edus":[{"id":0,"text":"Mark Judge , the high school friend of Supreme Court nominee Brett Kavanaugh","depth":7},{"id":1,"text":"whom","depth":9},{"id":2,"text":"Dr. Christine Blasey Ford has said","depth":9},{"id":3,"text":"was present","depth":9},{"id":4,"text":"when she was allegedly sexually assaulted by Kavanaugh ,","depth":9},{"id":5,"text":"said in a letter to the Senate Judiciary Committee","depth":6},{"id":6,"text":"that he would cooperate with any law enforcement agency","depth":6},{"id":7,"text":"that would `` confidentially investigate '' sexual misconduct allegations against him and Kavanaugh .","depth":6},{"id":8,"text":"Judge also said","depth":5},{"id":9,"text":"he `` categorically '' denies sexual misconduct allegations","depth":7},{"id":10,"text":"made by Julie Swetnick .","depth":7},{"id":11,"text":"In a sworn statement","depth":8},{"id":12,"text":"released Wednesday ,","depth":8},{"id":13,"text":"Swetnick accused Kavanaugh and Judge of excessive drinking and inappropriate treatment of women in the early 1980s , among other accusations .","depth":7},{"id":14,"text":"This comes","depth":5},{"id":15,"text":"after Republican Sen. Jeff Flake called for a delay in a floor vote in the Senate on Kavanaugh 's nomination","depth":6},{"id":16,"text":"until after the FBI conducts a week-long investigation .","depth":6},{"id":17,"text":"Democrats in the Senate have been calling for an FBI investigation into Ford 's allegations","depth":5},{"id":18,"text":"since they first came to light earlier in September .","depth":5},{"id":19,"text":"When Ford came public with her allegations","depth":5},{"id":20,"text":"naming Judge and Kavanaugh specifically ,","depth":5},{"id":21,"text":"Judge released a statement through his lawyer","depth":6},{"id":22,"text":"saying","depth":7},{"id":23,"text":"that he did not recall the incident .","depth":7},{"id":24,"text":"He also said","depth":7},{"id":25,"text":"that he `` never saw Brett act in the manner","depth":8},{"id":26,"text":"Dr. Ford describes . ''","depth":8},{"id":27,"text":"He reiterated that statement in another letter","depth":8},{"id":28,"text":"sent to the Judiciary Committee on Thursday .","depth":8},{"id":29,"text":"He said","depth":8},{"id":30,"text":"that he did `` not want to comment about these events publicly , ''","depth":9},{"id":31,"text":"and that he did `` not recall the events","depth":10},{"id":32,"text":"described by Dr. Ford in her testimony . ''","depth":10},{"id":33,"text":"Despite Democrats ' calls","depth":5},{"id":34,"text":"for Judge to be brought before the Senate Judiciary Committee","depth":6},{"id":35,"text":"to testify as a witness ,","depth":6},{"id":36,"text":"Republicans declined to bring him before the committee .","depth":4},{"id":37,"text":"Judge , the author of a memoir called `` Wasted :","depth":4},{"id":38,"text":"Tales of a Gen X Drunk , ''","depth":4},{"id":39,"text":"has struggled with alcohol addiction .","depth":3},{"id":40,"text":"In her testimony before the Senate Thursday , Ford said","depth":4},{"id":41,"text":"that Kavanaugh and Judge had brought her into a room at a house party in the summer of 1982 .","depth":4},{"id":42,"text":"She said","depth":5},{"id":43,"text":"that Kavanaugh had groped her ,","depth":6},{"id":44,"text":"grinded against her ,","depth":7},{"id":45,"text":"attempted to remove her clothes","depth":8},{"id":46,"text":"and covered her mouth with his hand","depth":9},{"id":47,"text":"as she attempted to shout .","depth":9},{"id":48,"text":"Meanwhile , she said","depth":6},{"id":49,"text":"that Judge stood nearby","depth":7},{"id":50,"text":"and laughed .","depth":7},{"id":51,"text":"`` Indelible in the hippocampus is the laughter .","depth":8},{"id":52,"text":"The uproarious laughter between the two , and their having fun at my expense , ''","depth":8},{"id":53,"text":"Ford said of her enduring memory of the incident .","depth":7},{"id":54,"text":"`` I was underneath one of them","depth":8},{"id":55,"text":"while the two laughed .","depth":8},{"id":56,"text":"Two friends","depth":8},{"id":57,"text":"having a really good time with one another . ''","depth":8}],"relations":[{"parent":115,"left":94,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":76,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":71,"right":75,"relation":"context","nuclearity":"NS"},{"parent":71,"left":65,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":63,"right":64,"relation":"attribution","nuclearity":"SN"},{"parent":63,"left":62,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":62,"left":0,"right":61,"relation":"elaboration","nuclearity":"NS"},{"parent":61,"left":59,"right":60,"relation":"same-unit","nuclearity":"NN"},{"parent":59,"left":1,"right":2,"relation":"attribution","nuclearity":"NS"},{"parent":60,"left":3,"right":4,"relation":"context","nuclearity":"NS"},{"parent":64,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":8,"right":69,"relation":"attribution","nuclearity":"SN"},{"parent":69,"left":66,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":67,"right":13,"relation":"same-unit","nuclearity":"NN"},{"parent":67,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":73,"right":74,"relation":"context","nuclearity":"NS"},{"parent":73,"left":14,"right":72,"relation":"context","nuclearity":"NS"},{"parent":72,"left":15,"right":16,"relation":"context","nuclearity":"NS"},{"parent":74,"left":17,"right":18,"relation":"context","nuclearity":"NS"},{"parent":93,"left":89,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":77,"right":88,"relation":"context","nuclearity":"SN"},{"parent":77,"left":19,"right":20,"relation":"elaboration","nuclearity":"NS"},{"parent":88,"left":79,"right":87,"relation":"el