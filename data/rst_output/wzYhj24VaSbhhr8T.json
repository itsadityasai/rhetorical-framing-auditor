{"article_id":"wzYhj24VaSbhhr8T","edus":[{"id":0,"text":"Two more people corroborated some of Tara Reade ' s claims","depth":5},{"id":1,"text":"that the former Vice President Joe Biden sexually assaulted her 27 years ago","depth":6},{"id":2,"text":"when she was a staffer in his Senate office ,","depth":6},{"id":3,"text":"according to a report .","depth":4},{"id":4,"text":"One person ,","depth":10},{"id":5,"text":"who knew Reade in 1993 ,","depth":10},{"id":6,"text":"told the Associated Press","depth":9},{"id":7,"text":"that Reade mentioned the alleged assault","depth":9},{"id":8,"text":"when it happened .","depth":9},{"id":9,"text":"The second person ,","depth":9},{"id":10,"text":"who met Reade a decade after the alleged assault ,","depth":9},{"id":11,"text":"confirmed having a conversation with Reade in 2007 or 2008","depth":9},{"id":12,"text":"in which Reade talked about experiencing sexual harassment from Biden","depth":10},{"id":13,"text":"while working in his Senate office .","depth":10},{"id":14,"text":"Both sources spoke anonymously","depth":8},{"id":15,"text":"to protect their families ' privacy ,","depth":8},{"id":16,"text":"the report said .","depth":7},{"id":17,"text":"That makes four people","depth":7},{"id":18,"text":"who have backed Reade ' s","depth":7},{"id":19,"text":"some details of Reade ' s claims .","depth":6},{"id":20,"text":"Lynda LaCasse , a former neighbor of Reade ' s in California , said","depth":6},{"id":21,"text":"Reade shared details about the alleged assault in the 1990s ,","depth":6},{"id":22,"text":"while Lorraine Sanchez , a former colleague , told Business Insider","depth":6},{"id":23,"text":"that Reade complained to her about being sexually harassed by her former boss in Washington .","depth":6},{"id":24,"text":"Reade was among eight women","depth":4},{"id":25,"text":"who claimed","depth":5},{"id":26,"text":"Biden made them feel uncomfortable with inappropriate displays of affection .","depth":5},{"id":27,"text":"In an interview with the AP","depth":8},{"id":28,"text":"published on Saturday ,","depth":8},{"id":29,"text":"Reade said","depth":7},{"id":30,"text":"she filed a limited report with a congressional personnel office","depth":7},{"id":31,"text":"but it did not explicitly accuse Biden of sexual assault or harassment .","depth":7},{"id":32,"text":"\" I remember talking about him wanting me to serve drinks","depth":9},{"id":33,"text":"because he liked my legs","depth":10},{"id":34,"text":"and thought","depth":11},{"id":35,"text":"I was pretty","depth":11},{"id":36,"text":"and it made me uncomfortable , \"","depth":8},{"id":37,"text":"Reade said in the interview .","depth":7},{"id":38,"text":"\" I know","depth":7},{"id":39,"text":"that I was too scared","depth":8},{"id":40,"text":"to write about the sexual assault . \"","depth":8},{"id":41,"text":"Although she did not use the phrase \" sexual harassment \" in the complaint ,","depth":5},{"id":42,"text":"she did use the words \" uncomfortable \" and \" retaliation . \"","depth":5},{"id":43,"text":"Biden , the presumptive Democratic presidential nominee , denied","depth":4},{"id":44,"text":"the incident ever happened during an interview Friday on MSNBC ' s \" Morning Joe . \"","depth":4},{"id":45,"text":"\" It is not true .","depth":6},{"id":46,"text":"I ' m saying it unequivocally -","depth":7},{"id":47,"text":"it never happened .","depth":7},{"id":48,"text":"It didn ' t .","depth":6},{"id":49,"text":"It never happened , \"","depth":6},{"id":50,"text":"Biden said .","depth":4},{"id":51,"text":"He also said","depth":4},{"id":52,"text":"Reade did not raise concerns with supervisors or senior staffers at the time .","depth":4},{"id":53,"text":"\" News organizations","depth":7},{"id":54,"text":"that have talked with literally dozens of former staffers","depth":7},{"id":55,"text":"have not found one","depth":8},{"id":56,"text":"- not one -","depth":8},{"id":57,"text":"who corroborated her allegations in any way , \"","depth":7},{"id":58,"text":"he wrote in the statement","depth":6},{"id":59,"text":"released before the interview .","depth":6},{"id":60,"text":"\" Indeed , many of them spoke to the culture of an office","depth":6},{"id":61,"text":"that would not have tolerated harassment in any way","depth":7},{"id":62,"text":"- as indeed I would not have , \"","depth":7},{"id":63,"text":"he added .","depth":5}],"relations":[{"parent":127,"left":106,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":106,"left":87,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":87,"left":67,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":66,"right":3,"relation":"attribution","nuclearity":"NS"},{"parent":66,"left":0,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":1,"right":2,"relation":"context","nuclearity":"NS"},{"parent":86,"left":82,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":79,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":76,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":71,"right":75,"relation":"joint","nuclearity":"NN"},{"parent":71,"left":69,"right":70,"relation":"attribution","nuclearity":"SN"},{"parent":69,"left":68,"right":6,"relation":"same-unit","nuclearity":"NN"},{"parent":68,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":7,"right":8,"relation":"context","nuclearity":"NS"},{"parent":75,"left":72,"right":74,"relation":"same-unit","nuclearity":"NN"},{"parent":72,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":11,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":12,"right":13,"relation":"context","nuclearity":"NS"},{"parent":78,"left":77,"right":16,"relation":"attribution","nuclearity":"NS"},{"parent":77,"left":14,"right":15,"relation":"purpose","nuclearity":"NS"},{"parent":81,"left":80,"right":19,"relation":"same-unit","nuclearity":"NN"},{"parent"