h":23},{"id":111,"text":"Somalia South Africa Spain Sri Lanka Sudan Suriname Svalbard and Jan Mayen Islands","depth":23},{"id":112,"text":"Swaziland Sweden Switzerland Syrian Arab Republic Taiwan Tajikistan Tanzania , United Republic of Thailand Timor-Leste Togo Tokelau Tonga Trinidad and Tobago Tunisia Turkey Turkmenistan Turks and Caicos Islands","depth":23},{"id":113,"text":"Tuvalu Uganda Ukraine United Arab Emirates United Kingdom Virgin Islands","depth":22},{"id":114,"text":"( U.S. )","depth":22},{"id":115,"text":"Virgin Islands","depth":20},{"id":116,"text":"( British )","depth":20},{"id":117,"text":"Uruguay Uzbekistan","depth":19},{"id":118,"text":"Vanuatu Venezuela Viet Nam Wallis and Futuna Islands","depth":20},{"id":119,"text":"Western Sahara Yemen Zambia Zimbabwe","depth":20},{"id":120,"text":"Please enter a valid email address .","depth":9},{"id":121,"text":"Please select your country .","depth":9},{"id":122,"text":"I can confirm","depth":10},{"id":123,"text":"I have read and accept the Terms Of Use .","depth":10},{"id":124,"text":"Please check","depth":10},{"id":125,"text":"to proceed .","depth":10},{"id":126,"text":"Sign Up Now","depth":6},{"id":127,"text":"You may unsubscribe from email communication at any time .","depth":8},{"id":128,"text":"See our Privacy Policy for further details .","depth":8},{"id":129,"text":"Thank you !","depth":7},{"id":130,"text":"For your security , we 've sent a confirmation email to the address","depth":8},{"id":131,"text":"you entered .","depth":8},{"id":132,"text":"Click the link","depth":8},{"id":133,"text":"to confirm your subscription","depth":9},{"id":134,"text":"and begin receiving our newsletters .","depth":9},{"id":135,"text":"If you do n't get the confirmation within 10 minutes ,","depth":7},{"id":136,"text":"please check your spam folder .","depth":7},{"id":137,"text":"\" Once we become intolerant of differences","depth":6},{"id":138,"text":"then we are intolerant with America , \"","depth":6},{"id":139,"text":"he said .","depth":5},{"id":140,"text":"Here ' s what to know about the uptick in possible anti-Semitic attacks in New York City .","depth":5},{"id":141,"text":"A suspect was apprehended","depth":9},{"id":142,"text":"shortly after breaking into the home of a rabbi","depth":10},{"id":143,"text":"who was celebrating the seventh night of Hanukkah .","depth":10},{"id":144,"text":"The suspect stabbed five people","depth":11},{"id":145,"text":"before fleeing the scene ,","depth":11},{"id":146,"text":"police told reporters Saturday night .","depth":10},{"id":147,"text":"Two of the five victims remain hospitalized ,","depth":10},{"id":148,"text":"according to officials Sunday morning .","depth":10},{"id":149,"text":"Ramapo Police Chief Brad Weidel said","depth":9},{"id":150,"text":"the suspect is being charged with five counts of attempted murder and one count of burglary .","depth":9},{"id":151,"text":"He will be arraigned in Ramapo Town Court Sunday morning .","depth":8},{"id":152,"text":"Police arrested a woman Friday morning","depth":11},{"id":153,"text":"who said","depth":12},{"id":154,"text":"she slapped three other women between the ages of 22 to 31","depth":13},{"id":155,"text":"because she thought","depth":14},{"id":156,"text":"the women were Jewish ,","depth":14},{"id":157,"text":"NYPD Chief of Detectives Rodney Harrison told reporters Friday .","depth":10},{"id":158,"text":"The incident happened just past midnight in the Crown Heights neighborhood of Brooklyn .","depth":9},{"id":159,"text":"The Associated Press has since identified the woman as 30-year-old Tiffany Harris .","depth":9},{"id":160,"text":"The AP reported Saturday","depth":11},{"id":161,"text":"that Harris was released without bail","depth":12},{"id":162,"text":"after being arraigned on hate crime charges .","depth":12},{"id":163,"text":"Both Harris and her lawyer have declined to comment to reporters ,","depth":11},{"id":164,"text":"the AP says .","depth":11},{"id":165,"text":"Shortly before , on Dec. 26 , a 34-year-old Jewish woman was slapped in the face with a shopping bag by a 42-year-old woman in the Gravesend neighborhood of Brooklyn .","depth":12},{"id":166,"text":"The 42-year-old used explicit language","depth":15},{"id":167,"text":"that targeted the Jewish woman ,","depth":15},{"id":168,"text":"Harrison said Friday .","depth":14},{"id":169,"text":"The victim was with her 3-year-old child","depth":14},{"id":170,"text":"when the attack happened .","depth":14},{"id":171,"text":"The alleged perpetrator was also charged with committing a hate crime ,","depth":12},{"id":172,"text":"according to Harrison .","depth":12},{"id":173,"text":"Several other incidents are still being investigated as possible hate crimes ,","depth":11},{"id":174,"text":"Harrison told reporters on Friday .","depth":11},{"id":175,"text":"Three attacks occurred on Dec. 24 within hours of each other","depth":13},{"id":176,"text":"he said .","depth":13},{"id":177,"text":"That afternoon , a Jewish man was walking down a street in Crown Heights","depth":15},{"id":178,"text":"when a group began taunting him","depth":16},{"id":179,"text":"and one threw a slushy at him .","depth":16},{"id":180,"text":"Police are still searching for the perpetrator .","depth":14},{"id":181,"text":"That same day in Crown Heights , a 56-year-old man was approached from behind in Crown Heights","depth":15},{"id":182,"text":"and struck in the back of the head by one person","depth":15},{"id":183,"text":"while another filmed .","depth":14},{"id":184,"text":"Police are investigated by the NYPD hate crimes task force .","depth":11},{"id":185,"text":"Police said","depth":12},{"id":186,"text":"another man that day was struck in the face","depth":13},{"id":187,"text":"causing a laceration on his lip .","depth":13},{"id":188,"text":"The suspect fled on foot","depth":12},{"id":189,"text":"but was later apprehended","depth":13},{"id":190,"text":"and taken to a hospital for a psychological evaluation .","depth":13},{"id":191,"text":"Police are still investigating two other possible anti-Semitic attacks","depth":11},{"id":192,"text":"that occurred on Dec. 23 and Dec. 13 ,","depth":11},{"id":193,"text":"Harrison told reporters Friday .","depth":10},{"id":194,"text":"One involves an incident of harassment on Dec. 13","depth":10},{"id":195,"text":"where the victim was chased down a street","depth":11},{"id":196,"text":"while others yelled at him .","depth":11}],"relations":[{"parent":393,"left":254,"right":392,"relation":"elaboration","nuclearity":"NS"},{"parent":254,"left":213,"right":253,"relation":"elaboration","nuclearity":"NS"},{"parent":213,"left":203,"right":212,"relation":"elaboration","nuclearity":"NS"},{"parent":203,"left":200,"right":202,"relation":"elaboration","nuclearity":"NS"},{"parent":200,"left":0,"right":199,"relation":"context","nuclearity":"NS"},{"parent":199,"left":198,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":198,"left":1,"right":2,"relation":"causal","nuclearity":"NS"},{"parent":202,"left":201,"right":6,"relation":"attribution","nuclearity":"NS"},{"parent":201,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":212,"left":7,"right":211,"relation":"elaboration","nuclearity":"NS"},{"parent":211,"left":208,"right":210,"relation":"elaboration","nuclearity":"NS"},{"parent":208,"left":205,"right":207,"relation":"elaboration","nuclearity":"NS"},{"parent":205,"left":8,"right":204,"relation":"attribution","nuclearity":"NS"},{"parent":204,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":207,"left":11,"right":206,"relation":"elaboration","nuclearity":"NS"},{"parent":206,"left":12,"right":13,"relation":"joint","nuclearity":"NN"},{"parent":210,"left":14,"right":209,"relation":"elaboration","nuclearity":"NS"},{"parent":209,"left":15,"right":16,"relation":"adversative","nuclearity":"NN"},{"parent":253,"left":224,"right":252,"relation":"elaboration","nuclearity":"NS"},{"parent":224,"left":219,"right":223,"relation