{"article_id":"81bzAPJBQ5RzWpcP","edus":[{"id":0,"text":"President Donald Trump ,","depth":8},{"id":1,"text":"referencing a North Korean state media report ,","depth":8},{"id":2,"text":"tweeted Friday evening","depth":7},{"id":3,"text":"North Korea has agreed to suspend all nuclear weapons testing","depth":7},{"id":4,"text":"and close its testing site .","depth":7},{"id":5,"text":"\" North Korea has agreed to suspend all Nuclear Tests","depth":8},{"id":6,"text":"and close up a major test site , \"","depth":8},{"id":7,"text":"Trump tweeted Friday .","depth":7},{"id":8,"text":"\" This is very good news for North Korea and the World","depth":8},{"id":9,"text":"- big progress !","depth":8},{"id":10,"text":"Look forward to our Summit . \"","depth":7},{"id":11,"text":"North Korea has agreed to suspend all Nuclear Tests","depth":6},{"id":12,"text":"and close up a major test site .","depth":6},{"id":13,"text":"This is very good news for North Korea and the World","depth":7},{"id":14,"text":"- big progress !","depth":7},{"id":15,"text":"Look forward to our Summit .","depth":6},{"id":16,"text":"- Donald J. Trump","depth":5},{"id":17,"text":"( @ realDonaldTrump )","depth":5},{"id":18,"text":"April 20 , 2018","depth":4},{"id":19,"text":"\" The nuclear test and the intercontinental ballistic missile test will be discontinued , \"","depth":7},{"id":20,"text":"the Korean Central News Agency reported Friday ,","depth":7},{"id":21,"text":"delivering a clear message from North Korean leader Kim Jong Un .","depth":6},{"id":22,"text":"\" North Korea ' s nuclear test center will be discarded","depth":6},{"id":23,"text":"in order to ensure the transparency of the suspension of the nuclear test . \"","depth":6},{"id":24,"text":"North Korea is closing the Punggye-ri Nuclear Test Site ,","depth":6},{"id":25,"text":"where North Korea has tested a total of six nuclear weapons ,","depth":7},{"id":26,"text":"including a thermonuclear bomb ,","depth":7},{"id":27,"text":"the country is apparently announcing to the world .","depth":5},{"id":28,"text":"The U.S. and North Korea are already in direct talks in preparation for a meeting between Trump and Kim","depth":6},{"id":29,"text":"- an unprecedented summit .","depth":6},{"id":30,"text":"CIA Director Mike Pompeo recently made a secret trip to North Korea","depth":6},{"id":31,"text":"to meet with Kim himself .","depth":6},{"id":32,"text":"North Korea has reportedly agreed to the denuclearization of the Korean Peninsula ,","depth":7},{"id":33,"text":"pleasing the Trump administration ,","depth":7},{"id":34,"text":"but there may be a disconnect","depth":9},{"id":35,"text":"when it comes to what exactly this means ,","depth":9},{"id":36,"text":"North Korean state media reports indicate .","depth":8},{"id":37,"text":"\" We will never use nuclear weapons","depth":11},{"id":38,"text":"unless there is a nuclear threat or nuclear provocation to our country ,","depth":11},{"id":39,"text":"and in any case , we will not transfer nuclear weapons and nuclear technology , \"","depth":10},{"id":40,"text":"KCNA reported ,","depth":9},{"id":41,"text":"suggesting","depth":9},{"id":42,"text":"the North intends to remain a nuclear weapons state","depth":10},{"id":43,"text":"but act responsibly .","depth":10},{"id":44,"text":"In the report , Kim expressed the need for \" global nuclear disarmament \" - a possible reference to past statements","depth":6},{"id":45,"text":"indicating","depth":7},{"id":46,"text":"North Korea would only completely disarm","depth":8},{"id":47,"text":"when the U.S. agrees to do the same .","depth":8},{"id":48,"text":"North Korea ' s decision","depth":6},{"id":49,"text":"to suspend nuclear testing","depth":6},{"id":50,"text":"could signal","depth":5},{"id":51,"text":"Pyongyang is satisfied with the state of its nuclear capabilities ,","depth":4},{"id":52,"text":"which could mean","depth":4},{"id":53,"text":"the North is much more capable","depth":5},{"id":54,"text":"than previously acknowledged ,","depth":5},{"id":55,"text":"some Korea watchers are noting .","depth":2}],"relations":[{"parent":111,"left":103,"right":110,"relation":"elaboration","nuclearity":"NS"},{"parent":103,"left":74,"right":102,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":71,"right":73,"relation":"attribution","nuclearity":"NS"},{"parent":71,"left":66,"right":70,"relation":"evaluation","nuclearity":"NS"},{"parent":66,"left":60,"right":65,"relation":"evaluation","nuclearity":"NS"},{"parent":60,"left":58,"right":59,"relation":"attribution","nuclearity":"SN"},{"parent":58,"left":57,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":57,"left":0,"right":1,"relation":"mode","nuclearity":"NS"},{"parent":59,"left":3,"right":4,"relation":"joint","nuclearity":"NN"},{"parent":65,"left":62,"right":64,"relation":"evaluation","nuclearity":"NS"},{"parent":62,"left":61,"right":7,"relation":"attribution","nuclearity":"NS"},{"parent":61,"left":5,"right":6,"relation":"joint","nuclearity":"NN"},{"parent":64,"left":63,"right":10,"relation":"joint","nuclearity":"NN"},{"parent":63,"left":8,"right":9,"relation":"restatement","nuclearity":"NN"},{"parent":70,"left":67,"right":69,"relation":"evaluation","nuclearity":"NS"},{"parent":67,"left":11,"right":12,"relation":"joint","nuclearity":"NN"},{"parent":69,"left":68,"right":15,"relation":"joint","nuclearity":"NN"},{"parent":68,"left":13,"right":14,"relation":"restatement","nuclearity":"NN"},{"parent":73,"left":72,"right":18,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":16,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":82,"right":101,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":78,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":76,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":75,"right":21,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":19,"right":20,"relation":"attribution","nuclearity":"NS"},{"parent":77,"l