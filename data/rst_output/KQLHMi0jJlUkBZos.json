rent":436,"left":361,"right":435,"relation":"joint","nuclearity":"NN"},{"parent":361,"left":340,"right":360,"relation":"joint","nuclearity":"NN"},{"parent":340,"left":321,"right":339,"relation":"joint","nuclearity":"NN"},{"parent":321,"left":307,"right":320,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":302,"right":306,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":31,"right":301,"relation":"organization","nuclearity":"SN"},{"parent":301,"left":298,"right":300,"relation":"restatement","nuclearity":"NN"},{"parent":298,"left":32,"right":33,"relation":"topic","nuclearity":"SN"},{"parent":300,"left":299,"right":36,"relation":"explanation","nuclearity":"NS"},{"parent":299,"left":34,"right":35,"relation":"organization","nuclearity":"SN"},{"parent":306,"left":37,"right":305,"relation":"organization","nuclearity":"SN"},{"parent":305,"left":304,"right":41,"relation":"explanation","nuclearity":"NS"},{"parent":304,"left":303,"right":40,"relation":"joint","nuclearity":"NN"},{"parent":303,"left":38,"right":39,"relation":"topic","nuclearity":"SN"},{"parent":320,"left":316,"right":319,"relation":"context","nuclearity":"SN"},{"parent":316,"left":312,"right":315,"relation":"joint","nuclearity":"NN"},{"parent":312,"left":308,"right":311,"relation":"organization","nuclearity":"SN"},{"parent":308,"left":42,"right":43,"relation":"organization","nuclearity":"SN"},{"parent":311,"left":44,"right":310,"relation":"joint","nuclearity":"NN"},{"parent":310,"left":309,"right":47,"relation":"context","nuclearity":"NS"},{"parent":309,"left":45,"right":46,"relation":"organization","nuclearity":"SN"},{"parent":315,"left":313,"right":314,"relation":"context","nuclearity":"SN"},{"parent":313,"left":48,"right":49,"relation":"organization","nuclearity":"SN"},{"parent":314,"left":50,"right":51,"relation":"restatement","nuclearity":"NN"},{"parent":319,"left":52,"right":318,"relation":"attribution","nuclearity":"SN"},{"parent":318,"left":53,"right":317,"relation":"purpose","nucleari