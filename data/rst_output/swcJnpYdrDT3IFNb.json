ent":289,"left":286,"right":288,"relation":"condition","nuclearity":"SN"},{"parent":286,"left":68,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":288,"left":70,"right":287,"relation":"elaboration","nuclearity":"NS"},{"parent":287,"left":71,"right":72,"relation":"purpose","nuclearity":"NS"},{"parent":294,"left":73,"right":293,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":74,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":298,"right":313,"relation":"organization","nuclearity":"SN"},{"parent":298,"left":76,"right":77,"relation":"organization","nuclearity":"SN"},{"parent":313,"left":78,"right":312,"relation":"joint","nuclearity":"NN"},{"parent":312,"left":79,"right":311,"relation":"joint","nuclearity":"NN"},{"parent":311,"left":80,"right":310,"relation":"joint","nuclearity":"NN"},{"parent":310,"left":81,"right":309,"relation":"joint","nuclearity":"NN"},{"parent":309,"left":82,"right":308,"relation":"joint","nuclearity":"NN"},{"parent":308,"left":83,"right":307,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":84,"right":306,"relation":"joint","nuclearity":"NN"},{"parent":306,"left":299,"right":305,"relation":"joint","nuclearity":"NN"},{"parent":299,"left":85,"right":86,"relation":"joint","nuclearity":"NN"},{"parent":305,"left":87,"right":304,"relation":"joint","nuclearity":"NN"},{"parent":304,"left":88,"right":303,"relation":"joint","nuclearity":"NN"},{"parent":303,"left":89,"right":302,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":90,"right":301,"relation":"joint","nuclearity":"NN"},{"parent":301,"left":91,"right":300,"relation":"joint","nuclearity":"NN"},{"parent":300,"left":92,"right":93,"relation":"joint","nuclearity":"NN"},{"parent":441,"left":317,"right":440,"relation":"context","nuclearity":"SN"},{"parent":317,"left":316,"right":96,"relation":"joint","nuclearity":"NN"},{"parent":316,"left":94,"right":95,"relation":"joint","nuclearity":"NN"},{"parent":440,"left":349,"right":439,"