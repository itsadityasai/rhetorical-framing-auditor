{"article_id":"HhJCUi2KWSco6GXD","edus":[{"id":0,"text":"The new poll ,","depth":7},{"id":1,"text":"conducted for the Democratic group Focus on Rural America by party pollster David Binder ,","depth":7},{"id":2,"text":"found Buttigieg leading the field with 19 percent of the vote .","depth":6},{"id":3,"text":"Sanders trailed with 17 percent of the vote , a statistically insignificant disadvantage .","depth":5},{"id":4,"text":"Both gained 3 points since the last Focus on Rural America poll ,","depth":5},{"id":5,"text":"conducted in early January .","depth":5},{"id":6,"text":"Warren is the top second choice among voters ,","depth":5},{"id":7,"text":"taking 20 percent","depth":6},{"id":8,"text":"and suggesting","depth":7},{"id":9,"text":"she may have the strongest upside potential .","depth":7},{"id":10,"text":"Seventeen percent each said","depth":7},{"id":11,"text":"Biden and Klobuchar were their second choices ,","depth":7},{"id":12,"text":"and 13 percent said","depth":7},{"id":13,"text":"Sanders would be number two on their list","depth":8},{"id":14,"text":"if their chosen candidate is not viable .","depth":8},{"id":15,"text":"Buttigieg clocked in fifth , at 10 percent .","depth":5},{"id":16,"text":"The race remains in flux even hours before Iowans head to the caucuses .","depth":3},{"id":17,"text":"Only 51 percent of Iowa voters said","depth":5},{"id":18,"text":"they were completely certain","depth":6},{"id":19,"text":"to stick with their chosen candidates .","depth":6},{"id":20,"text":"\" If anyone tells you","depth":7},{"id":21,"text":"they know what ' s going to happen tonight ,","depth":7},{"id":22,"text":"they ' re making it up , \"","depth":6},{"id":23,"text":"said Jeff Link , the co-founder of the rural group .","depth":5},{"id":24,"text":"Buttigieg ,","depth":7},{"id":25,"text":"who has stumped at a frenetic pace across Iowa in recent months ,","depth":7},{"id":26,"text":"has the highest favorable rating among state Democratic voters .","depth":6},{"id":27,"text":"Sixty-nine percent said","depth":6},{"id":28,"text":"they see him favorably , just above the 68 percent","depth":7},{"id":29,"text":"who said the same about Warren .","depth":7},{"id":30,"text":"More than 6 in 10 Iowa Democrats see Biden","depth":6},{"id":31,"text":"( 62 percent ) ,","depth":6},{"id":32,"text":"Klobuchar","depth":7},{"id":33,"text":"( 63 percent )","depth":7},{"id":34,"text":"and Sanders","depth":8},{"id":35,"text":"( 64 percent )","depth":8},{"id":36,"text":"favorably .","depth":7},{"id":37,"text":"The least-favorably viewed Democratic presidential candidate ,","depth":6},{"id":38,"text":"the poll found ,","depth":6},{"id":39,"text":"is the one","depth":6},{"id":40,"text":"who is not competing for Iowa ' s votes .","depth":6},{"id":41,"text":"Just 30 percent of Iowa Democrats said","depth":6},{"id":42,"text":"they had a favorable impression of former New York City Mayor Mike Bloomberg ,","depth":7},{"id":43,"text":"who has poured millions into television ads in every state except Iowa .","depth":7},{"id":44,"text":"Fifty percent said","depth":6},{"id":45,"text":"they see Bloomberg unfavorably .","depth":6},{"id":46,"text":"The poll ,","depth":7},{"id":47,"text":"conducted Jan. 28-30 ,","depth":7},{"id":48,"text":"surveyed 300 likely caucusgoers","depth":6},{"id":49,"text":"and reports a margin of error of plus or minus 5.7 percentage points .","depth":5},{"id":50,"text":"That high margin means all four of the top contenders have a realistic shot","depth":5},{"id":51,"text":"at winning the caucuses .","depth":5},{"id":52,"text":"The high number of undecided and potentially persuadable voters ,","depth":6},{"id":53,"text":"coupled with the realignment","depth":7},{"id":54,"text":"allowed after a first round of voting ,","depth":7},{"id":55,"text":"means the actual winner is likely to finish with somewhere north of 30 percent of the delegate vote ,","depth":5},{"id":56,"text":"Link said .","depth":4}],"relations":[{"parent":113,"left":80,"righ