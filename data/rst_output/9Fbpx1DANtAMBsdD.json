tion":"elaboration","nuclearity":"NS"},{"parent":311,"left":154,"right":155,"relation":"joint","nuclearity":"NN"},{"parent":316,"left":313,"right":315,"relation":"restatement","nuclearity":"NN"},{"parent":313,"left":156,"right":157,"relation":"attribution","nuclearity":"SN"},{"parent":315,"left":314,"right":160,"relation":"joint","nuclearity":"NN"},{"parent":314,"left":158,"right":159,"relation":"attribution","nuclearity":"SN"}]}