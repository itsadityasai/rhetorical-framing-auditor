{"article_id":"sjSWPWZ7Qoz3BZsf","edus":[{"id":0,"text":"Story highlights","depth":1},{"id":1,"text":"Vice President Biden tells CNN 's `` New Day ''","depth":5},{"id":2,"text":"he 'll decide on a presidential bid in mid-2015","depth":5},{"id":3,"text":"Biden sounds raring to go ,","depth":6},{"id":4,"text":"but his words hint","depth":7},{"id":5,"text":"Hillary Clinton has the edge","depth":7},{"id":6,"text":"Among Democrats , Biden looks good against candidate ABC","depth":7},{"id":7,"text":"( Anybody But Clinton )","depth":7},{"id":8,"text":"If he runs","depth":8},{"id":9,"text":"and wins in 2016 ,","depth":8},{"id":10,"text":"Biden would be the oldest","depth":8},{"id":11,"text":"to begin a presidency","depth":8},{"id":12,"text":"Vice President Joe Biden sounded like someone","depth":8},{"id":13,"text":"who wants to be President","depth":8},{"id":14,"text":"when he spoke to CNN 's `` New Day '' on Friday .","depth":7},{"id":15,"text":"He talked about America 's potential and its role as a global leader , as well as his commitment to helping the middle class .","depth":7},{"id":16,"text":"He never mentioned the overwhelming early favorite for the 2016 Democratic nomination","depth":8},{"id":17,"text":"-- former Secretary of State Hillary Clinton .","depth":8},{"id":18,"text":"Clearly Biden , the longtime senator","depth":7},{"id":19,"text":"who now is the White House conduit to blue-collar union workers essential to Democratic support ,","depth":7},{"id":20,"text":"is seriously considering a presidential run .","depth":6},{"id":21,"text":"Asked by CNN 's Kate Bolduan","depth":7},{"id":22,"text":"when he would decide ,","depth":7},{"id":23,"text":"Biden answered","depth":7},{"id":24,"text":"a realistic timetable would be the summer of 2015 .","depth":7},{"id":25,"text":"That response , and a closer look at Biden 's words Friday , also show","depth":6},{"id":26,"text":"that","depth":7},{"id":27,"text":"if Clinton decides to run","depth":9},{"id":28,"text":"-- as expected --","depth":9},{"id":29,"text":"then Biden will step aside .","depth":8},{"id":30,"text":"JUST WATCHED","depth":8},{"id":31,"text":"Biden :","depth":10},{"id":32,"text":"LaGuardia a 'third world country '","depth":10},{"id":33,"text":"Replay More Videos ...","depth":9},{"id":34,"text":"MUST WATCH Biden :","depth":9},{"id":35,"text":"LaGuardia a 'third world country '","depth":9},{"id":36,"text":"03:21","depth":8},{"id":37,"text":"JUST WATCHED","depth":10},{"id":38,"text":"Biden :","depth":11},{"id":39,"text":"No reason","depth":12},{"id":40,"text":"not to run in 2016","depth":12},{"id":41,"text":"Replay More Videos ...","depth":9},{"id":42,"text":"MUST WATCH Biden :","depth":10},{"id":43,"text":"No reason","depth":11},{"id":44,"text":"not to run in 2016","depth":11},{"id":45,"text":"01:40","depth":9},{"id":46,"text":"JUST WATCHED Biden :","depth":11},{"id":47,"text":"Lots of Democrats still like us","depth":11},{"id":48,"text":"Replay More Videos ...","depth":10},{"id":49,"text":"MUST WATCH Biden :","depth":11},{"id":50,"text":"Lots of Democrats still like us","depth":11},{"id":51,"text":"01:32","depth":10},{"id":52,"text":"JUST WATCHED Biden :","depth":12},{"id":53,"text":"NY airport a 'third world country '","depth":12},{"id":54,"text":"Replay More Videos ...","depth":11},{"id":55,"text":"MUST WATCH Biden :","depth":11},{"id":56,"text":"NY airport a 'third world country ' 00:49","depth":11},{"id":57,"text":"`` He is effectively saying ,","depth":11},{"id":58,"text":"look ,","depth":12},{"id":59,"text":"it depends on what Hillary Clinton decides to do , ''","depth":12},{"id":60,"text":"noted Gloria Borger , CNN 's chief political analyst .","depth":10},{"id":61,"text":"Here are some of Biden 's remarks in the interview with Bolduan , and a look at what he was really saying :","depth":9},{"id":62,"text":"1 ) `` There may be reasons","depth":11},{"id":63,"text":"I do n't run ,","depth":11},{"id":64,"text":"but there 's no obvious reason for me","depth":11},{"id":65,"text":"why I think","depth":12},{"id":66,"text":"I should not run . ''","depth":12},{"id":67,"text":"Biden is hedging his bets .","depth":9},{"id":68,"text":"He acknowledges","depth":12},{"id":69,"text":"it may not happen ,","depth":12},{"id":70,"text":"but makes clear","depth":12},{"id":71,"text":"the reason wo n't be","depth":13},{"id":72,"text":"because he does n't want to","depth":14},{"id":73,"text":"or is n't qualified for the job .","depth":14},{"id":74,"text":"That 's another way","depth":11},{"id":75,"text":"of saying","depth":12},{"id":76,"text":"there are circumstances beyond his control ,","depth":13},{"id":77,"text":"meaning a Clinton decision","depth":14},{"id":78,"text":"to enter the race .","depth":14},{"id":79,"text":"Supporters are already raising money for the former first lady and senator","depth":8},{"id":80,"text":"who served with Biden in President Barack Obama 's Cabinet","depth":9},{"id":81,"text":"and would be the nation 's first woman President .","depth":9},{"id":82,"text":"Clinton has said","depth":9},{"id":83,"text":"she will make up her mind sometime in 2014 .","depth":9},{"id":84,"text":"Polls show her with a commanding lead over other possible Democratic contenders ,","depth":9},{"id":85,"text":"including Biden .","depth":9},{"id":86,"text":"Biden 's answer","depth":11},{"id":87,"text":"when Bolduan asks for a timetable for his decision","depth":11},{"id":88,"text":"is the clearest signal","depth":10},{"id":89,"text":"that his choice depends on whether Clinton runs .","depth":9},{"id":90,"text":"To Peter Hamby , CNN Digital 's national political reporter , waiting until the middle of 2015","depth":12},{"id":91,"text":"-- just six months or so before the Iowa caucuses --","depth":12},{"id":92,"text":"would be way too late","depth":11},{"id":93,"text":"to take on Clinton .","depth":10},{"id":94,"text":"`` If these guys are going to get in","depth":13},{"id":95,"text":"and run for president ,","depth":14},{"id":96,"text":"whoever it is ,","depth":15},{"id":97,"text":"challenging Hillary Clinton ,","depth":15},{"id":98,"text":"they really have to start laying groundwork , ''","depth":12},{"id":99,"text":"Hamby said .","depth":11},{"id":100,"text":"`` They have to raise money","depth":11},{"id":101,"text":"and hire staff","depth":12},{"id":102,"text":"and recruit volunteers in these early states . ''","depth":12},{"id":103,"text":"As vice president , Biden has the advantage of constant media focus","depth":9},{"id":104,"text":"if desired ,","depth":9},{"id":105,"text":"which would help him maintain a high profile","depth":9},{"id":106,"text":"without some of the normal steps","depth":10},{"id":107,"text":"of mounting a presidential campaign .","depth":10},{"id":108,"text":"That could help","depth":9},{"id":109,"text":"if Clinton does n't run","depth":10},{"id":110,"text":"and lesser-known contenders such as Maryland Gov . Martin O'Malle y enter the race .","depth":10},{"id":111,"text":"However , Biden 's lag","depth":10},{"id":112,"text":"in announcing his candidacy","depth":10},{"id":113,"text":"would leave him at a huge disadvantage against a Clinton campaign","depth":10},{"id":114,"text":"expected to have the backing of the party machinery .","depth":10},{"id":115,"text":"3 ) `` Am I the best qualified person","depth":7},{"id":116,"text":"to focus on the two things","depth":9},{"id":117,"text":"I 've spent my whole life on","depth":9},{"id":118,"text":"-- give ordinary people a fighting chance","depth":10},{"id":119,"text":"to make it","depth":10},{"id":120,"text":"and a sound foreign policy","depth":10},{"id":121,"text":"that 's based on national interest of the United States ,","depth":11},{"id":122,"text":"where we not only are known for the power of our military , but the power of our example . ''","depth":11},{"id":123,"text":"JUST WATCHED","depth":8},{"id":124,"text":"Why Rand Paul criticized Bill Clinton","depth":8},{"id":125,"text":"Replay More Videos ...","depth":8},{"id":126,"text":"MUST WATCH","depth":9},{"id":127,"text":"Why Rand Paul criticized Bill Clinton","depth":9},{"id":128,"text":"07:30","depth":6},{"id":129,"text":"Biden lays out his rationale","depth":8},{"id":130,"text":"for running ,","depth":8},{"id":131,"text":"stressing his two major strengths as a candidate","depth":8},{"id":132,"text":"-- foreign policy and working-class ties .","depth":8},{"id":133,"text":"As the former chairman of the Senate Foreign Relations Committee , Biden has the necessary foreign policy credentials , particularly against candidate ABC","depth":11},{"id":134,"text":"( Anybody But Clinton ) .","depth":11},{"id":135,"text":"However , her four years as secretary of state negates some or all of a Biden advantage .","depth":10},{"id":136,"text":"On appealing to middle class workers , Biden showed his strength in the 2010 and 2012 elections","depth":11},{"id":137,"text":"when he went to states such as Ohio","depth":12},{"id":138,"text":"where Obama was less popular .","depth":12},{"id":139,"text":"In Clinton , though , he would face the wife of former President Bill Clinton ,","depth":11},{"id":140,"text":"who remains extremely popular among traditional Democratic constituencies .","depth":11},{"id":141,"text":"In Friday 's interview , Biden did n't mention Hillary Clinton by name ,","depth":9},{"id":142,"text":"but she is the biggest factor","depth":10},{"id":143,"text":"in whether he goes for it .","depth":10},{"id":144,"text":"4 ) `` It does n't mean I 'm the only guy","depth":11},{"id":145,"text":"that can do it ,","depth":11},{"id":146,"text":"but if no one else","depth":12},{"id":147,"text":"I think","depth":14},{"id":148,"text":"can","depth":14},{"id":149,"text":"and I think","depth":14},{"id":150,"text":"I can ,","depth":14},{"id":151,"text":"then I will .","depth":11},{"id":152,"text":"If I do n't","depth":10},{"id":153,"text":"I wo n't . ''","depth":10},{"id":154,"text":"The vice president sums up his future decision with two qualifiers","depth":9},{"id":155,"text":"-- that no else runs","depth":11},{"id":156,"text":"who can do what he can ,","depth":11},{"id":157,"text":"and that he still thinks","depth":11},{"id":158,"text":"he can deliver the goods .","depth":11},{"id":159,"text":"Biden could decide","depth":7},{"id":160,"text":"that he is better qualified than Clinton on what he considers the key issues ,","depth":7},{"id":161,"text":"but he would have to think twice","depth":7},{"id":162,"text":"if her already anticipated campaign has started strongly","depth":8},{"id":163,"text":"and generated initial momentum .","depth":8},{"id":164,"text":"If he were to run","depth":8},{"id":165,"text":"and win in 2016 ,","depth":8},{"id":166,"text":"Biden would be 74","depth":9},{"id":167,"text":"when he took office ,","depth":9},{"id":168,"text":"making him the oldest ever","depth":9},{"id":169,"text":"to begin a presidency .","depth":9},{"id":170,"text":"By the end of his first term , he would be the oldest U.S. President in history .","depth":6},{"id":171,"text":"So","depth":7},{"id":172,"text":"while he remains energetic and passionate ,","depth":8},{"id":173,"text":"talking about getting his Corvette Z06 from zero to 60 in 3.4 seconds ,","depth":8},{"id":174,"text":"the clock is ticking","depth":7},{"id":175,"text":"and Biden knows it .","depth":7}],"relations":[{"parent":351,"left":0,"right":350,"relation":"organization","nuclearity":"SN"},{"parent":350,"left":204,"right":349,"relation":"joint","nuclearity":"NN"},{"parent":204,"left":186,"right":203,"relation":"elaboration","nuclearity":"NS"},{"parent":186,"left":177,"right":185,"relation":"context","nuclearity":"SN"},{"parent":177,"left":1,"right":2,"relation":"attribution","nuclearity":"SN"},{"parent":185,"left":179,"right":184,"relation":"elaboration","nuclearity":"NS"},{"parent":179,"left":3,"right":178,"relation":"adversative","nuclearity":"NN"},{"parent":178,"left":4,"right":5,"relation":"attribution","nuclearity":"SN"},{"parent":184,"left":180,"right"