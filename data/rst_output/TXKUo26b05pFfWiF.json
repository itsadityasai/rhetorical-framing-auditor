{"article_id":"TXKUo26b05pFfWiF","edus":[{"id":0,"text":"President Trump continued to express his dissatisfaction with Senate Republicans","depth":2},{"id":1,"text":"after their latest attempt","depth":4},{"id":2,"text":"to repeal and replace the Affordable Care Act","depth":4},{"id":3,"text":"failed .","depth":3},{"id":4,"text":"Interested in Donald Trump ?","depth":4},{"id":5,"text":"Add Donald Trump as an interest","depth":5},{"id":6,"text":"to stay up to date on the latest Donald Trump news , video , and analysis from .","depth":5},{"id":7,"text":"Add Interest","depth":3},{"id":8,"text":"In a series of tweets this morning , the president encouraged the Senate to change its rules","depth":7},{"id":9,"text":"to require just a 51-vote majority","depth":8},{"id":10,"text":"to pass future legislation .","depth":8},{"id":11,"text":"If Republicans are going to pass great future legislation in the Senate ,","depth":8},{"id":12,"text":"they must immediately go to a 51 vote majority , not senseless 60 ...","depth":8},{"id":13,"text":"- Donald J. Trump","depth":9},{"id":14,"text":"( @ realDonaldTrump )","depth":9},{"id":15,"text":"July 28 , 2017 ...","depth":8},{"id":16,"text":"Even though parts of healthcare could pass at 51 ,","depth":8},{"id":17,"text":"some really good things need 60 .","depth":8},{"id":18,"text":"So many great future bills & budgets need 60 votes ....","depth":7},{"id":19,"text":"- Donald J. Trump","depth":8},{"id":20,"text":"( @ realDonaldTrump )","depth":8},{"id":21,"text":"July 28 , 2017","depth":7},{"id":22,"text":"Senate Majority Leader Mitch McConnell previously signaled","depth":7},{"id":23,"text":"that he would not support changing the Senate rules .","depth":7},{"id":24,"text":"`` There is an overwhelming majority on a bipartisan basis ,","depth":9},{"id":25,"text":"not interested in changing the way","depth":10},{"id":26,"text":"the Senate operates on the legislative calendar .","depth":10},{"id":27,"text":"And , that will not happen , ''","depth":8},{"id":28,"text":"McConnell said at a press conference in May .","depth":7},{"id":29,"text":"The suggestion from the president comes","depth":7},{"id":30,"text":"just hours after the Senate narrowly voted down the so-called `` skinny repeal '' version of the Republican health care bill .","depth":7},{"id":31,"text":"The plan","depth":11},{"id":32,"text":"-- which would have repealed some parts of the Affordable Care Act , like the individual and employer mandates --","depth":11},{"id":33,"text":"was voted down 51-49 early Friday morning .","depth":10},{"id":34,"text":"Three Republican senators , John McCain of Arizona , Lisa Murkowski of Alaska and Susan Collins of Maine , voted against the bill along with the entire Democratic caucus .","depth":9},{"id":35,"text":"In the immediate aftermath of the bill 's defeat , the president reacted to the news","depth":12},{"id":36,"text":"by targeting those Republicans","depth":13},{"id":37,"text":"that voted against the bill .","depth":13},{"id":38,"text":"3 Republicans and 48 Democrats let the American people down .","depth":11},{"id":39,"text":"As I said from the beginning ,","depth":12},{"id":40,"text":"let ObamaCare implode ,","depth":13},{"id":41,"text":"then deal .","depth":13},{"id":42,"text":"Watch !","depth":11},{"id":43,"text":"- Donald J. Trump","depth":10},{"id":44,"text":"( @ realDonaldTrump )","depth":10},{"id":45,"text":"July 28 , 2017","depth":7},{"id":46,"text":"McConnell admitted last night","depth":6},{"id":47,"text":"that Senate Republicans will likely have to move on to other legislative issues .","depth":6},{"id":48,"text":"`` I regret","depth":7},{"id":49,"text":"that our efforts were simply not enough this time , ''","depth":7},{"id":50,"text":"McConnell said on the Senate floor .","depth":6},{"id":51,"text":"Senate Minority Leader Chuck Schumer said","depth":6},{"id":52,"text":"that Democrats are ready to work with Republicans on future health care legislation .","depth":6},{"id":53,"text":"\" We can work together .","depth":8},{"id":54,"text":"Our country demands it , \"","depth":8},{"id":55,"text":"Schumer said .","depth":7},{"id":56,"text":"\" Let ' s give it a shot . \"","depth":6}],"relations":[{"parent":113,"left":60,"right":112,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":0,"right":59,"relation":"context","nuclearity":"NS"},{"parent":59,"left":58,"right":3,"relation":"same-unit","nuclearity":"NN"},{"parent":58,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":112,"left":63,"right":111,"relation":"organization","nuclearity":"SN"},{"parent":63,"left":62,"right":7,"relation":"context","nuclearity":"NS"},{"parent":62,"left":4,"right":61,"relation":"condition","nuclearity":"SN"},{"parent":61,"left":5,"right":6,"relation":"purpose","nuclearity":"NS"},{"parent":111,"left":100,"right":110,"relation":"joint","nuclearity":"NN"},{"parent":100,"left":76,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":70,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":65,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":8,"right":64,"relation":"purpose","nuclearity":"NS"},{"parent":64,"left":9,"right":10,"relation":"purpose","nuclearity":"NS"},{"parent":69,"left":66,"right":68,"relation":"attribution","nuclearity":"NS"},{"parent":66,"left":11,"right":12,"relation":"condition","nuclearity":"SN"},{"parent":68,"left":67,"right":15,"relation":"context","nuclearity":"NS"},{"parent":67,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":72,"right":74,"relation":"attribution","nuclearity":"NS"},{"parent":72,"left":71,"right":18,"relation":"explanation","nuclearity":"NS"},{"parent":71,"left":16,"right":17,"relation":"adversative","nuclearity":"SN"},{"parent":74,"left":73,"right":21,"relation":"context","nuclearity":"NS"},{"parent":73,"left":19,"right":20,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":82,"right":98,"