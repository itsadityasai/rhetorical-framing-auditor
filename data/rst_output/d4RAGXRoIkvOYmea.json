{"article_id":"d4RAGXRoIkvOYmea","edus":[{"id":0,"text":"Boris Johnson 's decision","depth":10},{"id":1,"text":"to suspend Parliament for five weeks","depth":10},{"id":2,"text":"was unlawful ,","depth":9},{"id":3,"text":"the Supreme Court has ruled .","depth":8},{"id":4,"text":"Judges said","depth":8},{"id":5,"text":"it was wrong to stop MPs carrying out duties in the run-up to the Brexit deadline on 31 October .","depth":8},{"id":6,"text":"The PM ,","depth":9},{"id":7,"text":"who has faced calls to resign ,","depth":9},{"id":8,"text":"said","depth":8},{"id":9,"text":"he `` profoundly disagreed '' with the ruling","depth":8},{"id":10,"text":"but would `` respect '' it .","depth":8},{"id":11,"text":"The Labour conference finished early","depth":7},{"id":12,"text":"following the ruling","depth":7},{"id":13,"text":"and MPs are returning to Westminster","depth":7},{"id":14,"text":"ready for Parliament to reconvene on Wednesday .","depth":7},{"id":15,"text":"A senior government official said","depth":11},{"id":16,"text":"the prime minister spoke to the Queen after the Supreme Court ruling ,","depth":11},{"id":17,"text":"but would not reveal the details of the conversation .","depth":10},{"id":18,"text":"It comes","depth":10},{"id":19,"text":"after the court ruled","depth":11},{"id":20,"text":"it was impossible to conclude","depth":12},{"id":21,"text":"there had been any reason","depth":14},{"id":22,"text":"`` let alone a good reason -","depth":14},{"id":23,"text":"to advise Her Majesty to prorogue Parliament for five weeks '' .","depth":13},{"id":24,"text":"Mr Johnson ,","depth":11},{"id":25,"text":"who returns to London from New York on Wednesday ,","depth":11},{"id":26,"text":"also chaired a 30-minute phone call with his cabinet .","depth":10},{"id":27,"text":"A source told the BBC","depth":10},{"id":28,"text":"that the Leader of the Commons Jacob Rees-Mogg said to other cabinet ministers on the call","depth":11},{"id":29,"text":"that the action by the court had amounted to a `` constitutional coup '' .","depth":11},{"id":30,"text":"The prime minister insisted","depth":11},{"id":31,"text":"he wanted to outline his government 's policies in a Queen 's Speech on 14 October ,","depth":12},{"id":32,"text":"and","depth":13},{"id":33,"text":"to do that ,","depth":14},{"id":34,"text":"Parliament must be prorogued","depth":15},{"id":35,"text":"and a new session started .","depth":15},{"id":36,"text":"But critics said","depth":11},{"id":37,"text":"he was trying to stop MPs scrutinising his Brexit plans","depth":12},{"id":38,"text":"and the suspension was far longer than necessary .","depth":12},{"id":39,"text":"During a speech in New York , the PM said","depth":10},{"id":40,"text":"he `` refused to be deterred '' from getting on with `` an exciting and dynamic domestic agenda '' ,","depth":11},{"id":41,"text":"and","depth":12},{"id":42,"text":"to do that","depth":13},{"id":43,"text":"he would need a Queen 's Speech .","depth":13},{"id":44,"text":"The court ruling does not prevent him from proroguing again","depth":10},{"id":45,"text":"in order to hold one ,","depth":10},{"id":46,"text":"as long as it does not stop Parliament carrying out its duties `` without reasonable justification '' .","depth":9},{"id":47,"text":"A No 10 source said","depth":8},{"id":48,"text":"the Supreme Court had `` made a serious mistake","depth":10},{"id":49,"text":"in extending its reach to these political matters '' ,","depth":10},{"id":50,"text":"and had `` made it clear","depth":10},{"id":51,"text":"that its reasons [ were ] connected to the Parliamentary disputes over , and timetable for '' Brexit .","depth":10},{"id":52,"text":"But Supreme Court president Lady Hale emphasised in the ruling","depth":9},{"id":53,"text":"that the case was `` not about when and on what terms '' the UK left the EU","depth":10},{"id":54,"text":"- it was about the decision","depth":11},{"id":55,"text":"to suspend Parliament .","depth":11},{"id":56,"text":"Delivering the justices ' conclusions ,","depth":11},{"id":57,"text":"she said :","depth":11},{"id":58,"text":"`` The decision","depth":13},{"id":59,"text":"to advise Her Majesty to prorogue Parliament","depth":13},{"id":60,"text":"was unlawful","depth":12},{"id":61,"text":"because it had the effect","depth":12},{"id":62,"text":"of frustrating or preventing the ability of Parliament","depth":13},{"id":63,"text":"to carry out its constitutional functions","depth":14},{"id":64,"text":"without reasonable justification . ''","depth":14},{"id":65,"text":"Lady Hale said","depth":10},{"id":66,"text":"the unanimous decision of the 11 justices meant","depth":12},{"id":67,"text":"Parliament had effectively not been prorogued -","depth":12},{"id":68,"text":"the decision was null and of no effect .","depth":11},{"id":69,"text":"Speaker of the Commons John Bercow said","depth":7},{"id":70,"text":"MPs needed to return `` in light of the explicit judgement '' ,","depth":7},{"id":71,"text":"and he had `` instructed the House of Commons authorities to prepare ... for the resumption of business '' from 11:30 BST on Wednesday .","depth":7},{"id":72,"text":"He said","depth":8},{"id":73,"text":"prime minister 's questions would not go ahead ,","depth":9},{"id":74,"text":"but there would be `` full scope '' for urgent questions , ministerial statements and applications for emergency debates .","depth":9},{"id":75,"text":"Short of the inscrutable Lady Hale , with the giant diamond spider on her lapel ,","depth":6},{"id":76,"text":"declaring Boris Johnson to be Pinocchio ,","depth":6},{"id":77,"text":"this judgement is just about as bad for the government","depth":6},{"id":78,"text":"as it gets .","depth":6},{"id":79,"text":"Mr Johnson is ,","depth":7},{"id":80,"text":"as is abundantly clear ,","depth":8},{"id":81,"text":"prepared to run a general election campaign","depth":9},{"id":82,"text":"that pits Parliament against the people .","depth":9},{"id":83,"text":"And so what ,","depth":8},{"id":84,"text":"according to that view of the world ,","depth":8},{"id":85,"text":"if that includes the judges as part of the establishment","depth":8},{"id":86,"text":"standing in his way ?","depth":8},{"id":87,"text":"But there is a difference","depth":7},{"id":88,"text":"between being ruthless and reckless .","depth":7},{"id":89,"text":"And the scope and strength of this judgement can not just be dismissed","depth":7},{"id":90,"text":"as some pesky judges","depth":8},{"id":91,"text":"sticking their noses in .","depth":8},{"id":92,"text":"Reacting to the ruling ,","depth":6},{"id":93,"text":"Mr Johnson said","depth":7},{"id":94,"text":"it was an `` unusual judgement '' ,","depth":7},{"id":95,"text":"adding :","depth":7},{"id":96,"text":"`` The prerogative of prorogation has been used for centuries","depth":8},{"id":97,"text":"without this kind of challenge .","depth":8},{"id":98,"text":"`` There are a lot of people","depth":9},{"id":99,"text":"who basically want to stop this country from coming out of the EU","depth":9},{"id":100,"text":"and we have a Parliament","depth":9},{"id":101,"text":"that is unable to be prorogued","depth":10},{"id":102,"text":"and does n't want to have an election .","depth":10},{"id":103,"text":"I think","depth":8},{"id":104,"text":"it is time we took things forward . ''","depth":8},{"id":105,"text":"The PM said","depth":6},{"id":106,"text":"getting a deal was `` not made much easier with these sort of things in Parliament or the courts '' ,","depth":6},{"id":107,"text":"but insisted","depth":6},{"id":108,"text":"the UK would still leave on 31 October .","depth":6},{"id":109,"text":"Labour leader Jeremy Corbyn was due to close the Labour Party conference in Brighton with a speech on Wednesday ,","depth":6},{"id":110,"text":"but brought it forward to Tuesday afternoon","depth":7},{"id":111,"text":"so he could return to Westminster .","depth":7},{"id":112,"text":"He told cheering delegates :","depth":6},{"id":113,"text":"`` Tomorrow Parliament will return .","depth":8},{"id":114,"text":"The government will be held to account for what it has done .","depth":8},{"id":115,"text":"Boris Johnson has been found to have misled the country .","depth":8},{"id":116,"text":"This unelected prime minister should now resign . ''","depth":8},{"id":117,"text":"Lawyers for the government had argued","depth":9},{"id":118,"text":"the decision","depth":11},{"id":119,"text":"to prorogue","depth":11},{"id":120,"text":"was one for Parliament , not the courts .","depth":10},{"id":121,"text":"But the justices disagreed ,","depth":10},{"id":122,"text":"unanimously deciding","depth":12},{"id":123,"text":"it was `` justiciable '' ,","depth":12},{"id":124,"text":"and there was `` no doubt","depth":12},{"id":125,"text":"that the courts have jurisdiction","depth":13},{"id":126,"text":"to decide upon the existence and limits of a prerogative power '' .","depth":13},{"id":127,"text":"The court also criticised the length of the suspension ,","depth":10},{"id":128,"text":"with Lady Hale saying","depth":11},{"id":129,"text":"it was `` impossible for us to conclude , on the evidence","depth":13},{"id":130,"text":"which has been put before us ,","depth":13},{"id":131,"text":"that there was any reason","depth":14},{"id":132,"text":"- let alone a good reason -","depth":14},{"id":133,"text":"to advise Her Majesty to prorogue Parliament for five weeks '' .","depth":13},{"id":134,"text":"A spokesperson from the Attorney General 's office said","depth":10},{"id":135,"text":"the government had acted in `` good faith and in the belief","depth":11},{"id":136,"text":"that its approach was both lawful and constitutional '' .","depth":11},{"id":137,"text":"`` These are complex matters","depth":12},{"id":138,"text":"on which senior and distinguished lawyers have disagreed , ''","depth":12},{"id":139,"text":"a statement said .","depth":11},{"id":140,"text":"`` The Divisional Court","depth":13},{"id":141,"text":"led by the Lord Chief Justice","depth":13},{"id":142,"text":"agreed unanimously with the government 's legal position ,","depth":13},{"id":143,"text":"as did the Outer House in Scotland .","depth":13},{"id":144,"text":"`` We are disappointed","depth":13},{"id":145,"text":"that in the end the Supreme Court took a different view .","depth":13},{"id":146,"text":"We respect the judgment of the Supreme Court . ''","depth":12},{"id":147,"text":"It is worth just taking a breath","depth":10},{"id":148,"text":"and considering","depth":11},{"id":149,"text":"that a prime minister of the United Kingdom has been found by the highest court in the land to have acted unlawfully","depth":13},{"id":150,"text":"in shutting down the sovereign body in our constitution , Parliament , at a time of national crisis .","depth":13},{"id":151,"text":"The court may have fallen short","depth":17},{"id":152,"text":"of saying","depth":18},{"id":153,"text":"Boris Johnson had an improper motive","depth":19},{"id":154,"text":"of stymieing or frustrating parliamentary scrutiny ,","depth":19},{"id":155,"text":"but the damage is done ,","depth":16},{"id":156,"text":"he has been found to have acted unlawfully","depth":16},{"id":157,"text":"and stopped Parliament from doing its job","depth":17},{"id":158,"text":"without any legal justification .","depth":17},{"id":159,"text":"And the court has quashed both his advice to the Queen and the Order in Council","depth":15},{"id":160,"text":"which officially suspended parliament .","depth":15},{"id":161,"text":"That means Parliament was never prorogued","depth":14},{"id":162,"text":"and so we assume","depth":15},{"id":163,"text":"that MPs are free to re-enter the Commons .","depth":15},{"id":164,"text":"This is the most dramatic example yet of independent judges , through the mechanism of judicial review , stopping the government in its tracks","depth":11},{"id":165,"text":"because what it has done is unlawful .","depth":11},{"id":166,"text":"Be you ever so mighty ,","depth":11},{"id":167,"text":"the law is above you","depth":13},{"id":168,"text":"-","depth":13},{"id":169,"text":"even if you are the prime minister .","depth":12},{"id":170,"text":"Unprecedented , extraordinary , ground breaking -","depth":7},{"id":171,"text":"it is difficult to overestimate the constitutional and political significance of today 's ruling .","depth":7},{"id":172,"text":"The ruling was made after a three-day hearing at the Supreme Court last week","depth":10},{"id":173,"text":"which dealt with two appeals","depth":11},{"id":174,"text":"- one from campaigner and businesswoman Gina Miller , the second from the government .","depth":11},{"id":175,"text":"Mrs Miller was appealing against the English High Court 's decision","depth":12},{"id":176,"text":"that the prorogation was `` purely political ''","depth":13},{"id":177,"text":"and not a matter for the courts .","depth":13},{"id":178,"text":"The government was appealing against the ruling by Scotland 's Court of Session","depth":13},{"id":179,"text":"that the prorogation was `` unlawful ''","depth":14},{"id":180,"text":"and had been used","depth":15},{"id":181,"text":"to `` stymie '' Parliament .","depth":15},{"id":182,"text":"The court ruled in favour of Mrs Miller 's appeal and against the government 's .","depth":12},{"id":183,"text":"Speaking outside the court ,","depth":13},{"id":184,"text":"Mrs Miller said","depth":13},{"id":185,"text":"the ruling `` speaks volumes '' .","depth":12},{"id":186,"text":"`` This prime minister must open the doors of Parliament tomorrow .","depth":12},{"id":187,"text":"MPs must get back","depth":14},{"id":188,"text":"and be brave and bold in holding this unscrupulous government to account , ''","depth":14},{"id":189,"text":"she added .","depth":13},{"id":190,"text":"The SNP 's Joanna Cherry ,","depth":13},{"id":191,"text":"who led the Scottish case ,","depth":13},{"id":192,"text":"called for Mr Johnson to resign","depth":12},{"id":193,"text":"as a result of the ruling .","depth":11},{"id":194,"text":"`` The highest court in the United Kingdom has unanimously found","depth":13},{"id":195,"text":"that his advice","depth":15},{"id":196,"text":"to prorogue this Parliament ,","depth":15},{"id":197,"text":"his advice","depth":16},{"id":198,"text":"given to Her Majesty the Queen ,","depth":16},{"id":199,"text":"was unlawful , ''","depth":15},{"id":200,"text":"she said .","depth":12},{"id":201,"text":"`` His position is untenable","depth":12},{"id":202,"text":"and he should have the guts , for once , to do the decent thing","depth":13},{"id":203,"text":"and resign . ''","depth":13},{"id":204,"text":"Former Prime Minister Sir John Major","depth":14},{"id":205,"text":"- one of the sponsors of the prorogation appeal -","depth":14},{"id":206,"text":"said","depth":13},{"id":207,"text":"it gave him `` no pleasure to be pitted against a government and prime minister of my own party '' .","depth":13},{"id":208,"text":"`` No prime minister must ever treat the monarch or Parliament in this way again . ''","depth":13},{"id":209,"text":"Mr Johnson was backed by US President Donald Trump at a joint press conference at the United Nations in New York .","depth":12},{"id":210,"text":"`` I 'll tell you ,","depth":15},{"id":211,"text":"I know him well ,","depth":15},{"id":212,"text":"he 's not going anywhere , ''","depth":14},{"id":213,"text":"said Mr Trump ,","depth":14},{"id":214,"text":"after a US reporter quizzed the prime minister","depth":15},{"id":215,"text":"on whether he was going to resign .","depth":15},{"id":216,"text":"But reaction at home was far more negative .","depth":11},{"id":217,"text":"Scotland 's First Minister , the SNP 's Nicola Sturgeon , said","depth":14},{"id":218,"text":"the ruling was the most significant constitutional judgement in her lifetime ,","depth":15},{"id":219,"text":"and it would be `` unthinkable '' for Mr Johnson to remain in office .","depth":15},{"id":220,"text":"Wales ' First Minister , Labour 's Mark Drakeford , said","depth":14},{"id":221,"text":"the court 's decision had been a `` victory for the rule of law ''","depth":15},{"id":222,"text":"and the PM had `` tried to play fast and loose with our constitution '' .","depth":15},{"id":223,"text":"In Northern Ireland , the leader of the DUP , Arlene Foster , said","depth":14},{"id":224,"text":"the ruling must be respected ,","depth":14},{"id":225,"text":"while Sinn Fein 's vice president , Michelle O'Neill , said","depth":14},{"id":226,"text":"Mr Johnson should resign .","depth":14},{"id":227,"text":"Other figures have taken to Twitter","depth":10},{"id":228,"text":"to support the court 's decision ,","depth":11},{"id":229,"text":"including former Tory minister Amber Rudd ,","depth":12},{"id":230,"text":"who resigned her post","depth":14},{"id":231,"text":"- and the party whip -","depth":14},{"id":232,"text":"over the government 's approach to Brexit .","depth":13},{"id":233,"text":"The leader of The Brexit Party , Nigel Farage , said","depth":11},{"id":234,"text":"Mr Johnson must , `` as a matter of honour '' , offer his resignation to MPs in Parliament on Wednesday .","depth":11},{"id":235,"text":"The decision","depth":14},{"id":236,"text":"to prorogue Parliament","depth":14},{"id":237,"text":"had been a `` disaster '' ,","depth":13},{"id":238,"text":"he added ,","depth":12},{"id":239,"text":"and there must be a general election `` before very long","depth":12},{"id":240,"text":"because Parliament and the government have ceased to function '' .","depth":12},{"id":241,"text":"Former Attorney General Dominic Grieve ,","depth":14},{"id":242,"text":"who has been an outspoken critic of the suspension ,","depth":14},{"id":243,"text":"said","depth":13},{"id":244,"text":"he was `` not surprised '' by the judgement","depth":13},{"id":245,"text":"because of the `` gross misbehaviour by the prime minister '' .","depth":13},{"id":246,"text":"He told the BBC 's Victoria Derbyshire programme","depth":12},{"id":247,"text":"he was `` delighted ''","depth":13},{"id":248,"text":"the Supreme Court had `` stopped this unconstitutional act in its tracks '' .","depth":13},{"id":249,"text":"But Tory MP Andrew Bridgen said","depth":12},{"id":250,"text":"the court 's decision was `` the worst possible outcome for our democracy '' and `` an absolute disgrace '' .","depth":12},{"id":251,"text":"He told the same programme :","depth":12},{"id":252,"text":"`` What we 've got is a Parliament","depth":13},{"id":253,"text":"that 's completely out of step with sentiment of the country . ''","depth":13},{"id":254,"text":"Fellow Tory MP and chairman of the pro-Brexit European Research Group Steve Baker said","depth":11},{"id":255,"text":"the ruling was an `` earthquake moment '' .","depth":11},{"id":256,"text":"He described the Commons as a `` rotten Parliament ''","depth":13},{"id":257,"text":"facing a `` crisis '' ,","depth":13},{"id":258,"text":"and called for a general election","depth":12},{"id":259,"text":"so a government with a majority could move forward .","depth":11},{"id":260,"text":"Prorogation is a power","depth":10},{"id":261,"text":"that rests with the Queen ,","depth":10},{"id":262,"text":"carried out by her on the advice of the prime minister .","depth":9},{"id":263,"text":"And at the end of August","depth":12},{"id":264,"text":"- shortly before MPs returned from their summer recess -","depth":12},{"id":265,"text":"Mr Johnson called Her Majesty","depth":11},{"id":266,"text":"to advise","depth":11},{"id":267,"text":"she suspend Parliament between 9 September until 14 October .","depth":11},{"id":268,"text":"MPs had been expecting to be in recess for some of these weeks for their party conferences .","depth":10},{"id":269,"text":"But unlike prorogation , a recess must be agreed by a vote ,","depth":11},{"id":270,"text":"and a number of MPs said","depth":12},{"id":271,"text":"they would have voted against it","depth":13},{"id":272,"text":"to ensure","depth":14},{"id":273,"text":"they could scrutinise Mr Johnson 's Brexit plans .","depth":14},{"id":274,"text":"The decision","depth":10},{"id":275,"text":"to prorogue","depth":10},{"id":276,"text":"prompted an uproar from the Commons , especially from MPs","depth":10},{"id":277,"text":"who had planned to take control of Parliament","depth":11},{"id":278,"text":"to force through a law","depth":13},{"id":279,"text":"to block a no-deal Brexit","depth":13},{"id":280,"text":"after Mr Johnson said","depth":13},{"id":281,"text":"the UK would leave the EU with or without a deal on the Halloween deadline .","depth":13},{"id":282,"text":"Despite only sitting for a week ,","depth":9},{"id":283,"text":"they did manage to pass that law ahead of prorogation","depth":10},{"id":284,"text":"and it received royal assent on 9 September .","depth":10},{"id":285,"text":"What questions do you have about the Supreme Court 's decision ?","depth":1}],"relations":[{"parent":571,"left":570,"right":285,"relation":"evaluation","nuclearity":"NS"},{"parent":570,"left":377,"right":569,"relation":"joint","nuclearity":"NN"},{"parent":377,"left":360,"right":376,"relation":"evaluation","nuclearity":"NS"},{"parent":360,"left":300,"right":359,"relation":"elaboration","nuclearity":"NS"},{"parent":300,"left":296,"right":299,"relation":"causal","nuclearity":"NS"},{"parent":296,"left":291,"right":295,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":289,"right":290,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":288,"right":3,"relation":"attribution","nuclearity":"NS"},{"parent":288,"left":287,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":287,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":290,"left":4,"right":5,"relation":"attribution","nuclearity":"SN"},{"parent":295,"left":293,"right":294,"relation":"attribution","nuclearity":"SN"},{"parent":293,"left":292,"right":8,"relation":"same-unit","nuclearity":"NN"},{"parent":292,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":9,"right":10,"relation":"adversative","nuclearity":"NN"},{"parent":299,"left":297,"right":298,"relation":"joint","nuclearity":"NN"},{"parent":297,"left":11,"right":12,"relation":"context","nuclearity":"NS"},{"parent":298,"left":13,"right":14,"relation":"purpose","nuclearity":"NS"},{"parent":359,"left":353,"right":358,"relation":"joint","nuclearity":"NN"},{"parent":353,"left":331,"right":352,"relation":"elaboration","nuclearity":"NS"},{"parent":331,"left":314,"right":330,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":308,"right":313,"relation":"joint","nuclearity":"NN"},{"parent":308,"left":302,"right":307,"relation":"context","nuclearity":"NS"},{"parent":302,"left":301,"right":17,"relation":"joint","nuclearity":"NN"},{"parent":301,"left":15,"right":16,"relation":"attribution","nuclearity":"SN"},{"parent":307,"left":18,"right":306,"relation":"context","nuclearity":"NS"},{"parent":306,"left":19,"right":305,"relation":"attribution","nuclearity":"SN"},{"parent":305,"left":20,"right":304,"relation":"attribution","nuclearity":"SN"},{"parent":304,"left":303,"right":23,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":21,"right":22,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":310,"right":312,"relation":"elaboration","nuclearity":"NS"},{"parent":310,"left":309,"right":26,"relation":"same-unit","nuclearity":"NN"},{"parent":309,"left":24,"right":25,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":27,"right":311,"relation":"attribution","nuclearity":"SN"},{"parent":311,"left":28,"right":29,"relation":"attribution","nuclearity":"SN"},{"parent":330,"left":327,"right":329,"relation":"joint","nuclearity":"NN"},{"parent":327,"left":322,"right":326,"relation":"elaboration","nuclearity":"NS"},{"parent":322,"left":319,"right":321,"relation":"adversative","nuclearity":"SN"},{"parent":319,"left":30,"right":318,"relation":"attribution","nuclearity":"SN"},{"parent":318,"left":31,"right":317,"relation":"context","nuclearity":"SN"},{"parent":317,"left":32,"righ