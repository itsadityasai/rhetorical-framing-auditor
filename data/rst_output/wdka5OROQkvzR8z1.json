{"article_id":"wdka5OROQkvzR8z1","edus":[{"id":0,"text":"FERGUSON , Mo .","depth":1},{"id":1,"text":"( ) -","depth":2},{"id":2,"text":"Missouri ' s governor ordered hundreds more National Guard troops on Tuesday to the St. Louis suburb","depth":12},{"id":3,"text":"rocked by rioting","depth":12},{"id":4,"text":"after a white policeman was cleared in the fatal shooting of an unarmed black teenager ,","depth":11},{"id":5,"text":"while the local mayor said","depth":11},{"id":6,"text":"the governor did not do enough","depth":12},{"id":7,"text":"to protect businesses from looting .","depth":12},{"id":8,"text":"Attorneys for the family of Michael Brown , the 18-year-old","depth":11},{"id":9,"text":"shot to death in Ferguson by officer Darren Wilson in August ,","depth":11},{"id":10,"text":"condemned as biased the grand jury process","depth":11},{"id":11,"text":"that led to Monday ' s decision","depth":12},{"id":12,"text":"not to bring criminal charges against Wilson .","depth":12},{"id":13,"text":"The killing in Ferguson , a predominantly black city with a white-dominated power structure , underscores the sometimes tense nature of U.S. race relations .","depth":8},{"id":14,"text":"Violent protests and looting flared after the St. Louis County grand jury ' s decision ,","depth":10},{"id":15,"text":"with Governor Jay Nixon calling the resulting damage \" heartbreaking . \"","depth":10},{"id":16,"text":"About a dozen Ferguson buildings burned overnight","depth":13},{"id":17,"text":"and 61 people were arrested on charges","depth":14},{"id":18,"text":"including burglary , illegal weapons possession and unlawful assembly ,","depth":14},{"id":19,"text":"police said .","depth":12},{"id":20,"text":"Police said","depth":13},{"id":21,"text":"protesters fired guns at them ,","depth":14},{"id":22,"text":"lit patrol cars on fire","depth":15},{"id":23,"text":"and hurled bricks into their lines .","depth":15},{"id":24,"text":"Police fired tear gas and flash-bang canisters at protesters .","depth":12},{"id":25,"text":"\" Lives and property must be protected .","depth":13},{"id":26,"text":"This community deserves to have peace , \"","depth":13},{"id":27,"text":"Nixon told a news conference ,","depth":12},{"id":28,"text":"saying","depth":13},{"id":29,"text":"about 700 guard troops were deployed on Monday","depth":14},{"id":30,"text":"and hundreds more will be out on Tuesday night","depth":15},{"id":31,"text":"to protect homes and businesses .","depth":15},{"id":32,"text":"He said","depth":13},{"id":33,"text":"there are more than 2,200 guardsmen now in the region .","depth":13},{"id":34,"text":"Criticizing the governor ' s response to the unrest ,","depth":11},{"id":35,"text":"Ferguson Mayor James Knowles said","depth":12},{"id":36,"text":"the National Guard \" was not deployed in enough time","depth":13},{"id":37,"text":"to save all of our businesses . \"","depth":13},{"id":38,"text":"\" The decision","depth":13},{"id":39,"text":"to delay the deployment of the National Guard","depth":13},{"id":40,"text":"is deeply concerning , \"","depth":12},{"id":41,"text":"Knowles told a news conference .","depth":11},{"id":42,"text":"\" We are asking","depth":10},{"id":43,"text":"that the governor make available and deploy all necessary resources","depth":11},{"id":44,"text":"to prevent the further destruction of property and the preservation of life in the city of Ferguson . \"","depth":11},{"id":45,"text":"The unrest came","depth":8},{"id":46,"text":"despite calls by President Barack Obama and others for police and protesters to exercise restraint .","depth":8},{"id":47,"text":"Police had been preparing for months","depth":8},{"id":48,"text":"but admitted","depth":9},{"id":49,"text":"they were overtaken by the violent events","depth":10},{"id":50,"text":"that unfolded .","depth":10},{"id":51,"text":"The grand jury decision also shifted the legal spotlight to the ongoing U.S. Justice Department investigation","depth":11},{"id":52,"text":"into whether Wilson violated Brown ' s civil rights","depth":13},{"id":53,"text":"by intentionally using excessive force","depth":13},{"id":54,"text":"and whether Ferguson police systematically violate people ' s rights","depth":13},{"id":55,"text":"by using excessive force or discrimination .","depth":13},{"id":56,"text":"Obama was briefed about the situation in Ferguson by Attorney General Eric Holder ,","depth":11},{"id":57,"text":"White House spokesman Eric Schultz said .","depth":11},{"id":58,"text":"A day after the grand jury ' s decision ,","depth":10},{"id":59,"text":"protests were held in major U.S. cities","depth":11},{"id":60,"text":"including Atlanta , Baltimore , Chicago , Philadelphia and Washington .","depth":11},{"id":61,"text":"Michael Brown Sr. holds his wife Cal Brown during a news conference with civil rights activist Rev . Al Sharpton in Ferguson , November 25 , 2014 .","depth":9},{"id":62,"text":"/Adrees","depth":9},{"id":63,"text":"Latif","depth":7},{"id":64,"text":"Brown family lawyer Benjamin Crump said","depth":9},{"id":65,"text":"the grand jury proceedings were unfair","depth":10},{"id":66,"text":"because the prosecutor in the case had a conflict of interest","depth":11},{"id":67,"text":"and Wilson was not properly cross-examined .","depth":11},{"id":68,"text":"\" The process should be indicted , \"","depth":10},{"id":69,"text":"Crump told a news conference ,","depth":10},{"id":70,"text":"adding","depth":10},{"id":71,"text":"that the family wants police to be equipped with body video cameras","depth":11},{"id":72,"text":"to provide an indisputable account of their actions .","depth":11},{"id":73,"text":"\" This is going to happen again , \"","depth":9},{"id":74,"text":"said Ferguson area resident James Hall , 56 ,","depth":10},{"id":75,"text":"as he walked past a building","depth":11},{"id":76,"text":"smoldering from a blaze","depth":12},{"id":77,"text":"set during the street protests .","depth":12},{"id":78,"text":"\" If they had charged him with something ,","depth":10},{"id":79,"text":"this would not have happened to Ferguson , \"","depth":10},{"id":80,"text":"he said .","depth":9},{"id":81,"text":"Although no serious injuries were reported ,","depth":7},{"id":82,"text":"St. Louis County Police Chief Jon Belmar said","depth":8},{"id":83,"text":"the rioting on Monday night and early Tuesday morning was \" much worse \" than the disturbances","depth":9},{"id":84,"text":"that erupted in the immediate aftermath of the August shooting .","depth":9},{"id":85,"text":"In the city of St. Louis ,","depth":8},{"id":86,"text":"where windows were broken","depth":9},{"id":87,"text":"and traffic was briefly stopped on a major highway overnight ,","depth":9},{"id":88,"text":"Police Chief Sam Dotson vowed a stronger response on Tuesday night .","depth":7},{"id":89,"text":"Schools in Ferguson and its surrounding cities were closed on Tuesday","depth":7},{"id":90,"text":"and city offices in Ferguson were also shut .","depth":7},{"id":91,"text":"About 1,000 demonstrators gathered outside the Thomas F. Eagleton U.S . Courthouse in St. Louis","depth":8},{"id":92,"text":"blocking an interstate ramp","depth":9},{"id":93,"text":"and chanting ,","depth":10},{"id":94,"text":"\" This what democracy looks like. \"","depth":10},{"id":95,"text":"They were confronted by a line of riot police","depth":8},{"id":96,"text":"and there was no major violence .","depth":8},{"id":97,"text":"Wilson ,","depth":7},{"id":98,"text":"who could have faced charges","depth":8},{"id":99,"text":"ranging from involuntary manslaughter to first-degree murder ,","depth":8},{"id":100,"text":"offered thanks to his supporters ,","depth":6},{"id":101,"text":"saying","depth":6},{"id":102,"text":"\" your dedication is amazing , \" in a letter","depth":8},{"id":103,"text":"attributed to him","depth":8},{"id":104,"text":"posted on a Facebook page for those","depth":8},{"id":105,"text":"who have rallied to his side .","depth":8},{"id":106,"text":"Attorneys for Wilson ,","depth":8},{"id":107,"text":"who was placed on administrative leave since the shooting ,","depth":8},{"id":108,"text":"said","depth":7},{"id":109,"text":"he was following his training and the law","depth":7},{"id":110,"text":"when he shot Brown .","depth":7},{"id":111,"text":"Wilson told the grand jury","depth":8},{"id":112,"text":"that Brown had tried to grab his gun","depth":9},{"id":113,"text":"and he felt","depth":11},{"id":114,"text":"his life was in danger","depth":11},{"id":115,"text":"when he fired ,","depth":10},{"id":116,"text":"according to documents","depth":8},{"id":117,"text":"released by prosecutors .","depth":8},{"id":118,"text":"\" I said ,","depth":10},{"id":119,"text":"' Get back","depth":11},{"id":120,"text":"or I ' m going to shoot you , ' \"","depth":11},{"id":121,"text":"Wilson said ,","depth":9},{"id":122,"text":"according to the documents .","depth":8},{"id":123,"text":"\" He immediately grabs my gun","depth":8},{"id":124,"text":"and says ,","depth":9},{"id":125,"text":"' You are too much of a pussy","depth":10},{"id":126,"text":"to shoot me . ' \"","depth":10}],"relations":[{"parent":253,"left":0,"right":252,"relation":"organization","nuclearity":"SN"},{"parent":252,"left":1,"right":251,"relation":"organization","nuclearity":"SN"},{"parent":251,"left":221,"right":250,"relation":"elaboration","nuclearity":"NS"},{"parent":221,"left":205,"right":220,"relation":"elaboration","nuclearity":"NS"},{"parent":205,"left":175,"right":204,"relation":"elaboration","nuclearity":"NS"},{"parent":175,"left":169,"right":174,"relation":"elaboration","nuclearity":"NS"},{"parent":169,"left":138,"right":168,"relation":"elaboration","nuclearity":"NS"},{"parent":138,"left":137,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":137,"left":132,"right":136,"relation":"elaboration","nuclearity":"NS"},{"parent":132,"left":129,"right":131,"relation":"adversative","nuclearity":"NN"},{"parent":129,"left":128,"right":4,"relation":"context","nuclearity":"NS"},{"parent":128,"le