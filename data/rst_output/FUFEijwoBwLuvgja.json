:27},{"id":140,"text":"Trinidad and Tobago","depth":28},{"id":141,"text":"Tunisia","depth":28},{"id":142,"text":"Turkey","depth":27},{"id":143,"text":"Turkmenistan","depth":28},{"id":144,"text":"Turks and Caicos Islands","depth":28},{"id":145,"text":"Tuvalu","depth":27},{"id":146,"text":"Uganda Ukraine","depth":29},{"id":147,"text":"United Arab Emirates","depth":31},{"id":148,"text":"United Kingdom Virgin Islands","depth":32},{"id":149,"text":"( U.S. )","depth":32},{"id":150,"text":"Virgin Islands","depth":31},{"id":151,"text":"( British )","depth":31},{"id":152,"text":"Uruguay Uzbekistan","depth":29},{"id":153,"text":"Vanuatu","depth":30},{"id":154,"text":"Venezuela Viet Nam","depth":31},{"id":155,"text":"Wallis and Futuna Islands","depth":32},{"id":156,"text":"Western Sahara Yemen","depth":33},{"id":157,"text":"Zambia Zimbabwe","depth":33},{"id":158,"text":"Please enter a valid email address .","depth":6},{"id":159,"text":"Please select your country .","depth":7},{"id":160,"text":"I can confirm","depth":9},{"id":161,"text":"I have read and accept the Terms Of Use .","depth":9},{"id":162,"text":"Please check","depth":9},{"id":163,"text":"to proceed .","depth":9},{"id":164,"text":"Sign Up Now","depth":5},{"id":165,"text":"You may unsubscribe from email communication at any time .","depth":7},{"id":166,"text":"See our Privacy Policy for further details .","depth":7},{"id":167,"text":"Thank you !","depth":6},{"id":168,"text":"For your security , we 've sent a confirmation email to the address","depth":7},{"id":169,"text":"you entered .","depth":7},{"id":170,"text":"Click the link","depth":7},{"id":171,"text":"to confirm your subscription","depth":8},{"id":172,"text":"and begin receiving our newsletters .","depth":8},{"id":173,"text":"If you do n't get the confirmation within 10 minutes ,","depth":6},{"id":174,"text":"please check your spam folder .","depth":6},{"id":175,"text":"But the reaction to the NBA has been more intense","depth":4},{"id":176,"text":"as the world of sports gets dragged into the controversy .","depth":4},{"id":177,"text":"The NBA tried to limit the damage ,","depth":10},{"id":178,"text":"saying in a statement","depth":11},{"id":179,"text":"that Morey ' s comments were \" regrettable . \"","depth":11},{"id":180,"text":"\" We have great respect for the history and culture of China","depth":11},{"id":181,"text":"and hope","depth":12},{"id":182,"text":"that sports and the NBA can be used as a unifying force","depth":13},{"id":183,"text":"to bridge cultural divides","depth":14},{"id":184,"text":"and bring people together , \"","depth":14},{"id":185,"text":"the NBA said .","depth":10},{"id":186,"text":"In the Chinese version of the statement , it added a further comment :","depth":9},{"id":187,"text":"\" We are deeply disappointed about Morey ' s inappropriate comment","depth":10},{"id":188,"text":"and he undoubtedly has hurt Chinese fans ' feelings severely . \"","depth":10},{"id":189,"text":"The NBA ' s response echoed the cautious approach","depth":8},{"id":190,"text":"other companies have been taking in an effort","depth":9},{"id":191,"text":"not to offend China ,","depth":9},{"id":192,"text":"but it immediately generated protests from U.S. politicians .","depth":6},{"id":193,"text":"Cruz , a Texas Republican and longtime Rockets fan , tweeted","depth":7},{"id":194,"text":"that the NBA \" is shamefully retreating \"","depth":7},{"id":195,"text":"and said","depth":7},{"id":196,"text":"he was \" proud \" to see Morey ' s original comment .","depth":7},{"id":197,"text":"Both Democratic presidential candidates from Texas also blasted the NBA ,","depth":8},{"id":198,"text":"with Beto O ' Rourke calling the apology \" an embarrassment \"","depth":9},{"id":199,"text":"and Julian Castro saying","depth":10},{"id":200,"text":"the U.S. can ' t allow American citizens \" to be bullied by an authoritarian government .","depth":10},{"id":201,"text":"\" We ' re better than this ;","depth":8},{"id":202,"text":"human rights shouldn ' t be for sale","depth":9},{"id":203,"text":"& the NBA shouldn ' t be assisting Chinese communist censorship .","depth":9},{"id":204,"text":"- Ted Cruz","depth":7},{"id":205,"text":"( @ tedcruz )","depth":7},{"id":206,"text":"October 7 , 2019","depth":5},{"id":207,"text":"Tony Fratto , former White House deputy press secretary under George W. Bush and founder of Hamilton Place Strategies in Washington , tweeted","depth":5},{"id":208,"text":"that the NBA \" crossed the line","depth":6},{"id":209,"text":"to stand with China and against American values . \"","depth":6},{"id":210,"text":"Stepping in","depth":7},{"id":211,"text":"to try to bridge the gap","depth":7},{"id":212,"text":"was Joe Tsai , co-founder of Alibaba","depth":7},{"id":213,"text":"who this summer became the owner of the Brooklyn Nets .","depth":7},{"id":214,"text":"In an open letter on Facebook , Tsai attempted to explain China ' s anger to Western audiences .","depth":7},{"id":215,"text":"Tsai called the Hong Kong protests a separatist movement ,","depth":8},{"id":216,"text":"saying","depth":9},{"id":217,"text":"support for such movements is a \" third-rail \" issue in China","depth":10},{"id":218,"text":"as its citizens stand united","depth":11},{"id":219,"text":"when it comes to the nation ' s territorial integrity .","depth":11},{"id":220,"text":"\" I don ' t know Daryl personally , \"","depth":8},{"id":221,"text":"Tsai wrote of Morey .","depth":8},{"id":222,"text":"\" I will take at face value his subsequent apology","depth":9},{"id":223,"text":"that he was not as well informed","depth":10},{"id":224,"text":"as he should have been .","depth":10},{"id":225,"text":"But the hurt","depth":10},{"id":226,"text":"that this incident has caused","depth":10},{"id":227,"text":"will take a long time to repair . \"","depth":9},{"id":228,"text":"The issue is particularly sensitive for the Rockets","depth":6},{"id":229,"text":"because the team has worked hard","depth":7},{"id":230,"text":"to establish a loyal fan base in China .","depth":7},{"id":231,"text":"The Rockets have more ties to China than most NBA teams .","depth":6},{"id":232,"text":"Yao Ming , arguably the greatest Chinese basketball player","depth":9},{"id":233,"text":"who now leads the Chinese Basketball Association ,","depth":9},{"id":234,"text":"starred for the Rockets for many years","depth":8},{"id":235,"text":"and was the first Chinese player","depth":8},{"id":236,"text":"inducted into the NBA ' s Hall of Fame .","depth":8},{"id":237,"text":"The CBA , in a statement Sunday on its official microblog account , said","depth":7},{"id":238,"text":"the association is \" strongly opposed \" to Morey ' s comment","depth":8},{"id":239,"text":"and will halt communications and cooperation with the club .","depth":8},{"id":240,"text":"It canceled four games with the NBA minor league","depth":7},{"id":241,"text":"scheduled for later this month .","depth":7},{"id":242,"text":"Hu Xijin , editor-in-chief of the Global Times , a tabloid","depth":8},{"id":243,"text":"run by the People ' s Daily , the Communist Party ' s flagship newspaper ,","depth":8},{"id":244,"text":"laid out the Rockets ' dilemma in a tweet :","depth":7},{"id":245,"text":"\" Daryl Morey has the right","depth":9},{"id":246,"text":"to express his values ,","depth":9},{"id":247,"text":"and Chinese fans of the Houston Rockets have the right","depth":9},{"id":248,"text":"to abandon this team , \"","depth":9},{"id":249,"text":"he wrote .","depth":7}],"relations":[{"parent":499,"left":424,"right":498,"relation":"joint","nuclearity":"NN"},{"parent":424,"left":318,"right":423,"relation":"joint","nuclearity":"NN"},{"parent":318,"left":313,"right":317,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":292,"right":312,"relation":"joint","nuclearity":"NN"},{"parent":292,"left":280,"right":291,"relation":"elaboration","nuclearity":"NS"},{"parent":280,"left":271,"right":279,"relation":"elaboration","nuclearity":"NS"},{"parent":271,"left":261,"r