{"article_id":"dEFPVQ3dzwDuMIBu","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"The FBI has officially concluded its investigation into allegations of sexual assault and misconduct against Judge Brett Kavanaugh ,","depth":6},{"id":2,"text":"and so far the impact of the FBI report appears to be positive for the nominee .","depth":6},{"id":3,"text":"The report is being closely guarded","depth":6},{"id":4,"text":"with each senator being given one hour","depth":7},{"id":5,"text":"to review it in a secure room .","depth":7},{"id":6,"text":"Senate Democrats are blasting the Kavanaugh report ,","depth":6},{"id":7,"text":"calling it incomplete","depth":7},{"id":8,"text":"and saying","depth":8},{"id":9,"text":"the agency may have been constrained by White House .","depth":8},{"id":10,"text":"But key Senate swing voter Sen. Susan Collins","depth":9},{"id":11,"text":"( R-ME )","depth":9},{"id":12,"text":"says","depth":8},{"id":13,"text":"it appears to have been a very thorough report .","depth":7},{"id":14,"text":"And Sen. Jeff Flake","depth":11},{"id":15,"text":"( R-AZ ) ,","depth":11},{"id":16,"text":"who forced Republican leaders to authorize the renewed FBI investigation ,","depth":10},{"id":17,"text":"has reportedly said","depth":9},{"id":18,"text":"the report reveals `` no additional corroborating information . ''","depth":8},{"id":19,"text":"Senate Judiciary Committee Chairman Chuck Grassley","depth":10},{"id":20,"text":"( R-IA )","depth":10},{"id":21,"text":"says","depth":9},{"id":22,"text":"the FBI report `` found no hint of misconduct '' by the Supreme Court nominee .","depth":8},{"id":23,"text":"The countdown to the crucial Senate vote is on","depth":7},{"id":24,"text":"after Senate Majority Leader Mitch McConnell","depth":9},{"id":25,"text":"( R-KY )","depth":9},{"id":26,"text":"announced","depth":8},{"id":27,"text":"the vote","depth":8},{"id":28,"text":"to confirm Kavanaugh to the Supreme Court","depth":8},{"id":29,"text":"will proceed .","depth":7},{"id":30,"text":"Democrat senators are not satisfied","depth":8},{"id":31,"text":"that the investigation was thorough enough .","depth":8},{"id":32,"text":"They 're complaining loudly","depth":8},{"id":33,"text":"that the FBI did n't interview Kavanaugh 's accuser , Dr. Christine Blasey Ford .","depth":9},{"id":34,"text":"They used her Senate testimony instead .","depth":9},{"id":35,"text":"Still , the White House reportedly does n't believe","depth":7},{"id":36,"text":"the FBI probe supports the sexual misconduct claims against Kavanaugh .","depth":7},{"id":37,"text":"Meanwhile , tension mounts on Capitol Hill","depth":6},{"id":38,"text":"where police have stepped up security","depth":8},{"id":39,"text":"and are now having to escort some lawmakers","depth":9},{"id":40,"text":"because many senators","depth":11},{"id":41,"text":"- especially Republicans -","depth":11},{"id":42,"text":"have been concerned about protesters .","depth":10},{"id":43,"text":"`` You guys do , like , invade my comfort zone .","depth":9},{"id":44,"text":"It 's intense ! ''","depth":9},{"id":45,"text":"Sen. Lisa Murkowski","depth":10},{"id":46,"text":"( R-AK )","depth":10},{"id":47,"text":"told some protesters .","depth":9},{"id":48,"text":"On Wednesday , police arrested a Democratic intern","depth":7},{"id":49,"text":"accused of posting the personal information","depth":9},{"id":50,"text":"- home addresses and phone numbers -","depth":9},{"id":51,"text":"of three Republican senators .","depth":8},{"id":52,"text":"That exposure of private information took place during the Kavanaugh hearings .","depth":6},{"id":53,"text":"The decision","depth":6},{"id":54,"text":"to confirm Judge Kavanaugh","depth":6},{"id":55,"text":"comes down to a handful of senators","depth":7},{"id":56,"text":"who could vote either way :","depth":7},{"id":57,"text":"Republicans Lisa Murkowski , Susan Collins . and Jeff Flake ; and Democrats Joe Manchin","depth":8},{"id":58,"text":"( D-WV )","depth":8},{"id":59,"text":"and Heidi Heitkamp","depth":8},{"id":60,"text":"( D-ND ) .","depth":8},{"id":61,"text":"All of them condemned comments","depth":6},{"id":62,"text":"the president made about Dr. Ford 's testimony against Kavanaugh at a political rally in Mississippi Tuesday night .","depth":6},{"id":63,"text":"`` How did you get home ?","depth":9},{"id":64,"text":"I do n't remember .","depth":9},{"id":65,"text":"How 'd you get there ?","depth":10},{"id":66,"text":"I do n't remember .","depth":10},{"id":67,"text":"Where 's the place ?","depth":10},{"id":68,"text":"I do n't remember , ''","depth":10},{"id":69,"text":"Trump said in what some critics are calling a mocking account of Ford 's testimony .","depth":7},{"id":70,"text":"Sen. Collins responded to the incident ,","depth":8},{"id":71,"text":"saying ,","depth":9},{"id":72,"text":"`` The president 's comments were just plain wrong . ''","depth":9},{"id":73,"text":"Another swing vote , Sen. Flake , said ,","depth":9},{"id":74,"text":"`` To discuss something this sensitive at a political rally is just not right ,","depth":11},{"id":75,"text":"is just not right .","depth":11},{"id":76,"text":"I wish","depth":12},{"id":77,"text":"he had n't of done it .","depth":12},{"id":78,"text":"I just say","depth":12},{"id":79,"text":"it 's kind of appalling . ''","depth":12},{"id":80,"text":"Even the president 's close ally , Sen. Lindsey Graham","depth":12},{"id":81,"text":"( R-SC ) ,","depth":12},{"id":82,"text":"said","depth":11},{"id":83,"text":"he would tell him to `` knock it off , ''","depth":11},{"id":84,"text":"though he was quick to defend Kavanaugh .","depth":11},{"id":85,"text":"`` I do n't like what the president said last night .","depth":10},{"id":86,"text":"I 'm the first person","depth":12},{"id":87,"text":"to say","depth":13},{"id":88,"text":"I wanted to hear from Dr. Ford .","depth":13},{"id":89,"text":"I thought","depth":13},{"id":90,"text":"she was handled respectfully .","depth":13},{"id":91,"text":"I think","depth":15},{"id":92,"text":"Kavanaugh was treated like crap .","depth":15},{"id":93,"text":"( audience boos )","depth":14},{"id":94,"text":"Yeah , well boo yourselves . ''","depth":13},{"id":95,"text":"The president 's comments may not have any impact on the swing senators ' votes .","depth":4},{"id":96,"text":"For Manchin and Heitkamp , the upcoming midterms play the biggest role .","depth":7},{"id":97,"text":"They 're facing tough reelection battles ,","depth":8},{"id":98,"text":"and voters in their states support Kavanaugh .","depth":8},{"id":99,"text":"But the two swing Democrats may wait","depth":7},{"id":100,"text":"to see which way the three moderate Republicans go .","depth":7},{"id":101,"text":"The Senate vote","depth":7},{"id":102,"text":"to confirm Kavanaugh","depth":7},{"id":103,"text":"is expected to come as soon as this weekend .","depth":6}],"relations":[{"parent":207,"left":0,"right":206,"relation":"organization","nuclearity":"SN"},{"parent":206,"left":155,"right":205,"relation":"joint","nuclearity":"NN"},{"parent":155,"left":125,"right":154,"relation":"joint","nuclearity":"NN"},{"parent":125,"left":108,"right":124,"relation":"adversative","nuclearity":"NN"},{"parent":108,"left":105,"right":107,"relation":"context","nuclearity":"NS"},{"parent":105,"left":1,"right":2,"relation":"evaluation","nuclearity":"NS"},{"parent":107,"left":3,"right":106,"relation":"joint","nuclearity":"NN"},{"parent":106,"left":4,"right":5,"relation":"purpose","nuclearity":"NS"},{"parent":124,"left":111,"right":123,"relation":"adversative","nuclearity":"NN"},{"parent":111,"left":6,"right":110,"relation":"elaboration","nuclearity":"NS"},{"parent":110,"left":7,"right":109,"relation":"joint","nuclearity":"NN"},{"parent":109,"left":8,"right":9,"relation":"attribution","nuclearity":"SN"},{"parent":123,"left":114,"right":122,"relation":"joint","nuclearity":"NN"},{"parent":114,"left":113,"right":13,"relation":"attribution","nuclearity":"SN"},{"parent":113,"left":112,"right":12,"relation":"same-unit"