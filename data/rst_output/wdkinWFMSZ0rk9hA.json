{"article_id":"wdkinWFMSZ0rk9hA","edus":[{"id":0,"text":"Former U.S. ambassador to Ukraine Marie Yovanovitch , arrives on Capitol Hill , Friday , Oct. 11 , 2019 , in Washington ,","depth":4},{"id":1,"text":"as she is scheduled to testify before congressional lawmakers on Friday as part of the House impeachment inquiry into President Donald Trump .","depth":4},{"id":2,"text":"( AP Photo/J . Scott Applewhite )","depth":3},{"id":3,"text":"Former U.S. ambassador to Ukraine Marie Yovanovitch , arrives on Capitol Hill , Friday , Oct. 11 , 2019 , in Washington ,","depth":4},{"id":4,"text":"as she is scheduled to testify before congressional lawmakers on Friday as part of the House impeachment inquiry into President Donald Trump .","depth":4},{"id":5,"text":"( AP Photo/J . Scott Applewhite )","depth":3},{"id":6,"text":"WASHINGTON","depth":5},{"id":7,"text":"( AP ) -","depth":5},{"id":8,"text":"Testifying in defiance of President Donald Trump ' s ban ,","depth":8},{"id":9,"text":"former U.S . Ambassador to Ukraine Marie Yovanovitch told House impeachment investigators Friday","depth":8},{"id":10,"text":"that Trump himself had pressured the State Department to oust her from her post and get her out of the country .","depth":7},{"id":11,"text":"Yovanovitch told lawmakers","depth":9},{"id":12,"text":"investigating Trump ' s dealings with Ukraine","depth":9},{"id":13,"text":"that there was a \" concerted campaign \" against her","depth":9},{"id":14,"text":"based on \" unfounded and false claims by people with clearly questionable motives . \"","depth":9},{"id":15,"text":"The diplomat was recalled from Kyiv","depth":8},{"id":16,"text":"as Rudy Giuliani","depth":10},{"id":17,"text":"- who is Trump ' s personal attorney","depth":11},{"id":18,"text":"and has no official role in the U.S. government -","depth":11},{"id":19,"text":"pressed Ukrainian officials to investigate baseless corruption allegations against Democrat Joe Biden and his son Hunter ,","depth":10},{"id":20,"text":"who was involved with a gas company there .","depth":10},{"id":21,"text":"Yovanovitch testified behind closed doors Friday for more than nine hours as part of the House Democrats ' impeachment investigation .","depth":7},{"id":22,"text":"Her prepared remarks were obtained by The .","depth":7},{"id":23,"text":"She left","depth":7},{"id":24,"text":"without answering questions .","depth":7},{"id":25,"text":"New York Rep. Sean Patrick Maloney , a Democrat , said","depth":5},{"id":26,"text":"Yovanovitch occasionally had to leave the room","depth":6},{"id":27,"text":"because she was overcome with emotion","depth":7},{"id":28,"text":"as she was \" recounting how she was thrown to the wolves \" in Ukraine .","depth":7},{"id":29,"text":"\" It is clear to me that she was fired","depth":6},{"id":30,"text":"because she was a thorn in the side of those","depth":7},{"id":31,"text":"who sought to use the Ukrainian government for their own political and financial gain","depth":8},{"id":32,"text":"- and that includes President Trump , \"","depth":8},{"id":33,"text":"Maloney said .","depth":5},{"id":34,"text":"Lawmakers","depth":8},{"id":35,"text":"leaving the meeting","depth":8},{"id":36,"text":"would not provide specifics from the confidential deposition .","depth":7},{"id":37,"text":"But they indicated","depth":7},{"id":38,"text":"that Yovanovitch was providing information","depth":8},{"id":39,"text":"that would help with the impeachment inquiry .","depth":8},{"id":40,"text":"\" It was compelling ,","depth":11},{"id":41,"text":"it was impactful ,","depth":12},{"id":42,"text":"it was powerful","depth":12},{"id":43,"text":"and I just feel grateful for the opportunity","depth":11},{"id":44,"text":"to have received that information , \"","depth":11},{"id":45,"text":"said Democratic Rep. Denny Heck ,","depth":10},{"id":46,"text":"who flew in from Washington state for the interview .","depth":10},{"id":47,"text":"He said","depth":9},{"id":48,"text":"the eight hours","depth":11},{"id":49,"text":"he was there","depth":11},{"id":50,"text":"\" went like a New York second .","depth":10},{"id":51,"text":"\" Yovanovitch \" set a very powerful , courageous example , \"","depth":8},{"id":52,"text":"said Democratic Rep. Tom Malinowski of New Jersey .","depth":8},{"id":53,"text":"Republicans","depth":12},{"id":54,"text":"leaving the meeting","depth":12},{"id":55,"text":"focused their criticism on Democrats ,","depth":11},{"id":56,"text":"arguing","depth":11},{"id":57,"text":"that the president ' s lawyers should be able to attend the hearings","depth":12},{"id":58,"text":"and cross examine witnesses .","depth":12},{"id":59,"text":"\" This process is a joke ,","depth":11},{"id":60,"text":"and the consequences are huge , \"","depth":11},{"id":61,"text":"said New York Rep. Lee Zeldin .","depth":10},{"id":62,"text":"Republican Rep. Jim Jordan of Ohio defended Yovanovitch ' s removal from Ukraine ,","depth":9},{"id":63,"text":"saying","depth":10},{"id":64,"text":"the president is entitled to have the ambassador","depth":11},{"id":65,"text":"he wants .","depth":11},{"id":66,"text":"The former ambassador said","depth":12},{"id":67,"text":"she was fired from her post","depth":12},{"id":68,"text":"after insisting","depth":12},{"id":69,"text":"that Giuliani ' s requests to Ukrainian officials for investigations be relayed through official channels ,","depth":12},{"id":70,"text":"according to a former diplomat","depth":12},{"id":71,"text":"who has spoken with her .","depth":12},{"id":72,"text":"That former diplomat spoke on condition of anonymity","depth":12},{"id":73,"text":"to disclose the private conversation .","depth":12},{"id":74,"text":"Trump , in a July 25 phone call , told Ukrainian President Volodymyr Zelenskiy","depth":13},{"id":75,"text":"that Yovanovitch was \" bad news , \"","depth":13},{"id":76,"text":"according to a partial transcript","depth":13},{"id":77,"text":"released by the White House .","depth":13},{"id":78,"text":"Neither Giuliani nor Trump has publicly specified their objections to her .","depth":11},{"id":79,"text":"She said in her statement Friday","depth":12},{"id":80,"text":"that she was abruptly told this spring to depart Ukraine \" on the next plane. \" She left her post in May","depth":13},{"id":81,"text":"and was later told the president had lost confidence in her","depth":14},{"id":82,"text":"and had been pressuring State Department officials for many months to remove her ,","depth":14},{"id":83,"text":"she said .","depth":11},{"id":84,"text":"Democrats","depth":12},{"id":85,"text":"leading the investigation","depth":12},{"id":86,"text":"said","depth":11},{"id":87,"text":"they subpoenaed Yovanovitch on Friday morning","depth":11},{"id":88,"text":"after learning late Thursday night","depth":12},{"id":89,"text":"that the State Department had directed her not to appear .","depth":12},{"id":90,"text":"Trump has forbidden all government employees to cooperate ,","depth":11},{"id":91,"text":"and Yovanovitch remains employed by the State Department .","depth":11},{"id":92,"text":"She is doing a fellowship at Georgetown University .","depth":10},{"id":93,"text":"Her testimony in the face of Trump ' s opposition won ' t be the last","depth":8},{"id":94,"text":"as the congressional panels hold a flurry of depositions","depth":9},{"id":95,"text":"to investigate the president ' s efforts","depth":10},{"id":96,"text":"to jump-start foreign investigations","depth":11},{"id":97,"text":"that could help his 2020 reelection campaign .","depth":11},{"id":98,"text":"House Speaker Nancy Pelosi has said","depth":9},{"id":99,"text":"she wants the committees to move \" expeditiously \"","depth":9},{"id":100,"text":"as they decide","depth":9},{"id":101,"text":"whether to move forward with a formal impeachment vote .","depth":9},{"id":102,"text":"Polls show","depth":7},{"id":103,"text":"the nation now generally split","depth":8},{"id":104,"text":"as to whether Trump should be impeached and removed from office .","depth":8},{"id":105,"text":"On Monday , Fiona Hill , a former White House adviser","depth":8},{"id":106,"text":"who focused on Russia ,","depth":8},{"id":107,"text":"is expected to appear ,","depth":7},{"id":108,"text":"and three current State Department officials are tentatively scheduled next week .","depth":7},{"id":109,"text":"They include Gordon Sondland ,","depth":8},{"id":110,"text":"who was blocked from appearing this week","depth":9},{"id":111,"text":"but whose attorney said","depth":10},{"id":112,"text":"he would testify next Thursday .","depth":10},{"id":113,"text":"As for Yovanovitch ' s dealing with pressure from Washington , the former diplomat","depth":10},{"id":114,"text":"who spoke with her","depth":10},{"id":115,"text":"said","depth":9},{"id":116,"text":"the ambassador refused to do \" all this offline , personal , informal stuff \"","depth":9},{"id":117,"text":"and made clear","depth":10},{"id":118,"text":"that the U.S. government had formal ways","depth":11},{"id":119,"text":"to request foreign governments ' help with investigations .","depth":11},{"id":120,"text":"The State Department traditionally relies on mutual legal assistance treaties ,","depth":8},{"id":121,"text":"under which U.S. and foreign officials agree to exchange evidence and information in criminal investigations .","depth":8},{"id":122,"text":"In her statement to lawmakers , Yovanovitch said","depth":7},{"id":123,"text":"that \" false narratives \" had resulted from \" an unfortunate alliance between Ukrainians","depth":9},{"id":124,"text":"who continue to operate within a corrupt system ,","depth":9},{"id":125,"text":"and Americans","depth":9},{"id":126,"text":"who either did not understand that corrupt system ,","depth":10},{"id":127,"text":"or who may have chosen , for their own purposes , to ignore it . \"","depth":10},{"id":128,"text":"She said","depth":7},{"id":129,"text":"she had only \" minimal contacts \" with Giuliani","depth":9},{"id":130,"text":"- three","depth":10},{"id":131,"text":"that she could recall -","depth":10},{"id":132,"text":"and none","depth":9},{"id":133,"text":"related to \" the events at issue. \"","depth":9},{"id":134,"text":"She speculated","depth":7},{"id":135,"text":"that \" individuals","depth":9},{"id":136,"text":"who have been named in the press as contacts of Mr. Giuliani \"","depth":9},{"id":137,"text":"may have believed","depth":9},{"id":138,"text":"their personal financial ambitions were stymied by U.S. anti-corruption policy .","depth":9},{"id":139,"text":"Two Florida businessmen","depth":10},{"id":140,"text":"tied to Giuliani","depth":10},{"id":141,"text":"were arrested on Thursday","depth":9},{"id":142,"text":"and are facing federal charges of campaign finance violations .","depth":8},{"id":143,"text":"An indictment","depth":10},{"id":144,"text":"filed in the case","depth":10},{"id":145,"text":"alleges","depth":9},{"id":146,"text":"that the men ,","depth":11},{"id":147,"text":"who were raising campaign funds for a U.S. congressman ,","depth":11},{"id":148,"text":"asked him for help","depth":10},{"id":149,"text":"in removing Yovanovitch , at least partly at the request of Ukrainian government officials .","depth":9},{"id":150,"text":"The New York Times reported Friday","depth":8},{"id":151,"text":"that Giuliani is being investigated by federal prosecutors in New York for possible lobbying violations .","depth":8},{"id":152,"text":"One of the Times ' anonymous sources said","depth":8},{"id":153,"text":"the investigation is related to Giuliani ' s efforts","depth":9},{"id":154,"text":"to undermine Yovanovitch .","depth":9},{"id":155,"text":"Yovanovitch also said in her statement","depth":8},{"id":156,"text":"that she had never met Hunter Biden","depth":9},{"id":157,"text":"and that Joe Biden , the former vice president , had never spoken to her about his son or the gas company","depth":10},{"id":158,"text":"with which he was involved .","depth":10},{"id":159,"text":"State Department officials have said previously","depth":9},{"id":160,"text":"that Secretary of State Mike Pompeo had tried to protect her","depth":10},{"id":161,"text":"but was forced to concede","depth":11},{"id":162,"text":"when he realized","depth":12},{"id":163,"text":"the White House was intent on removing her .","depth":12},{"id":164,"text":"Four current and former officials said","depth":10},{"id":165,"text":"Pompeo arranged for her to have a \" soft landing \" after her recall from Kyiv .","depth":10},{"id":166,"text":"The officials spoke on condition of anonymity","depth":10},{"id":167,"text":"to describe the confidential arrangement .","depth":10},{"id":168,"text":"She met with the House Intelligence , Foreign Affairs and Oversight and Reform committees Friday","depth":9},{"id":169,"text":"despite Trump ' s declaration earlier this week","depth":10},{"id":170,"text":"that he would block all officials from testifying in the impeachment probe .","depth":10},{"id":171,"text":"Trump lambastes the investigation daily","depth":9},{"id":172,"text":"and now contends","depth":10},{"id":173,"text":"it is illegitimate","depth":11},{"id":174,"text":"because the full House has not voted on it .","depth":11},{"id":175,"text":"Despite the officials ' expected testimony next week ,","depth":9},{"id":176,"text":"former Ambassador Sondland ' s attorney said","depth":10},{"id":177,"text":"he would not be able to produce documents","depth":12},{"id":178,"text":"\" concerning his official responsibilities , \"","depth":12},{"id":179,"text":"as they are controlled by the State Department .","depth":11},{"id":180,"text":"Democrats want to ask Sondland about text messages","depth":10},{"id":181,"text":"released last week","depth":10},{"id":182,"text":"that show him and two other U.S. diplomats","depth":11},{"id":183,"text":"acting as intermediaries","depth":11},{"id":184,"text":"as Trump urged Ukraine to investigate Ukraine ' s involvement in the 2016 U.S. election and Hunter Biden ' s involvement with a gas company there .","depth":10}],"relations":[{"parent":369,"left":190,"right":368,"relation":"context","nuclearity":"SN"},{"parent":190,"left":187,"right":189,"relation":"joint","nuclearity":"NN"},{"parent":187,"left":186,"right":2,"relation":"attribution","nuclearity":"NS"},{"parent":186,"left":0,"right":1,"relation":"context","nuclearity":"NS"},{"parent":189,"left":188,"right":5,"relation":"attribution","nuclearity":"NS"},{"parent":188,"left":3,"right":4,"relation":"context","nuclearity":"NS"},{"parent":368,"left":217,"right":367,"relation":"elaboration","nuclearity":"NS"},{"parent":217,"left":208,"right":216,"relation":"elaboration","nuclearity":"NS"},{"parent":208,"left":191,"right":207,"relation":"organization","nuclearity":"SN"},{"parent":191,"left":6,"right":7,"relation":"explanation","nuclearity":"NS"},{"parent":207,"left":203,"right":206,"relation":"elaboration","nuclearity":"NS"},{"parent":203,"left":193,"right":202,"relation":"elaboration","nuclearity":"NS"},{"parent":193,"left":192,"right":10,"relation":"attribution","nuclearity":"SN"},{"parent":192,"left":8,"right":9,"relation":"context","nuclearity":"SN"},{"parent":202,"left":196,"right":201,"relation":"context","nuclearity":"NS"},{"parent":196,"left":194,"right":195,"relation":"attribution","nuclearity":"SN"},{"parent":194,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":195,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":201,"left":15,"right":200,"relation":"context","nuclearity":"NS"},{"parent":200,"left":198,"right":199,"relation":"same-unit","nuclearity":"NN"},{"parent":198,"left":16,"right":197,"relation":"elaboration","nuclearity":"NS"},{"parent":197,"left":17,"right":18,"relation":"joint","nuclearity":"NN"},{"parent":199,"left":19,"right":20,"relation":"elaboration","nuclearity":"NS"},{"parent":206,"left":204,"right":205,"relation":"elaboration","nuclearity":"NS"},{"parent":204,"left":21,"right":22,"relation":"elaboration","nuclearity":"NS"},{"parent":205,"l