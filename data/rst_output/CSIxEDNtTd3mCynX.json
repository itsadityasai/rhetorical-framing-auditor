{"article_id":"CSIxEDNtTd3mCynX","edus":[{"id":0,"text":"Rep. Paul Ryan said Sunday","depth":3},{"id":1,"text":"that the proposed budget","depth":6},{"id":2,"text":"he ' s planning to roll out this week","depth":6},{"id":3,"text":"calls for repealing President Obama ' s health care overhaul","depth":5},{"id":4,"text":"and that Republicans did not lose the argument on Medicare in the 2012 election .","depth":4},{"id":5,"text":"\" Yes , our budget does propose repealing ' Obamacare ' and replacing it with a better system , \"","depth":3},{"id":6,"text":"Mr. Ryan , Wisconsin Republican and chairman of the House Budget Committee , said on \" Fox News Sunday . \"","depth":3},{"id":7,"text":"Mr. Ryan conceded","depth":5},{"id":8,"text":"that the $ 600 billion in revenues","depth":7},{"id":9,"text":"that came from the fiscal cliff deal and the $ 716 billion in Medicare spending reductions in the health care overhaul","depth":7},{"id":10,"text":"will help reduce the country ' s long-term fiscal woes","depth":6},{"id":11,"text":"-","depth":5},{"id":12,"text":"but","depth":6},{"id":13,"text":"he said","depth":8},{"id":14,"text":"there ' s an important distinction .","depth":8},{"id":15,"text":"\" You have to remember :","depth":9},{"id":16,"text":"All that money","depth":12},{"id":17,"text":"taken from Medicare","depth":12},{"id":18,"text":"was to pay for Obamacare , \"","depth":11},{"id":19,"text":"he said .","depth":10},{"id":20,"text":"\" We say ,","depth":10},{"id":21,"text":"we get rid of Obamacare ,","depth":11},{"id":22,"text":"we end the raid ,","depth":12},{"id":23,"text":"and we apply those savings to Medicare","depth":13},{"id":24,"text":"to make Medicare more solvent","depth":14},{"id":25,"text":"and extend the solvency of the Medicare trust fund ,","depth":14},{"id":26,"text":"and we don ' t want to refight the fiscal cliff . \"","depth":9},{"id":27,"text":"With a Democratic Senate and Mr. Obama ' s veto pen , however , that prospect is a nonstarter .","depth":4},{"id":28,"text":"Host Chris Wallace said flatly","depth":6},{"id":29,"text":"that repealing Obamacare is not going to happen .","depth":6},{"id":30,"text":"\" Well , we believe","depth":9},{"id":31,"text":"it should , \"","depth":9},{"id":32,"text":"Mr. Ryan replied .","depth":8},{"id":33,"text":"\" That ' s the point -","depth":9},{"id":34,"text":"this is what budgeting ' s all about , Chris .","depth":9},{"id":35,"text":"It ' s about making tough choices","depth":9},{"id":36,"text":"to fix our country ' s problems .","depth":9},{"id":37,"text":"We believe","depth":7},{"id":38,"text":"that Obamacare is a program","depth":8},{"id":39,"text":"that will not work . \"","depth":8},{"id":40,"text":"Mr. Ryan , the 2012 Republican vice presidential nominee , also pushed back","depth":5},{"id":41,"text":"when Mr. Wallace said","depth":6},{"id":42,"text":"Mr. Obama ' s team think","depth":8},{"id":43,"text":"they won the issue last year","depth":8},{"id":44,"text":"and that they think","depth":8},{"id":45,"text":"it ' s one of the reasons","depth":9},{"id":46,"text":"they won the election .","depth":9},{"id":47,"text":"\" I would argue against your premise","depth":7},{"id":48,"text":"that we lost this issue in the campaign , \"","depth":7},{"id":49,"text":"Mr. Ryan said .","depth":6},{"id":50,"text":"\" We won the senior vote .","depth":5},{"id":51,"text":"I did dozens of Medicare town hall meetings [ in ] states like Florida ,","depth":5},{"id":52,"text":"explaining how these are the best reforms","depth":6},{"id":53,"text":"to save and strengthen the Medicare program ,","depth":6},{"id":54,"text":"and we ' re very confident","depth":6},{"id":55,"text":"that this is the way to go .","depth":6},{"id":56,"text":"It has bipartisan support ,","depth":7},{"id":57,"text":"it ' s an idea","depth":8},{"id":58,"text":"that came from Democrats in the first place ,","depth":8},{"id":59,"text":"and we think","depth":7},{"id":60,"text":"it ' s really the best way to go . \"","depth":7}],"relations":[{"parent":121,"left":67,"right":120,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":65,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":0,"right":64,"relation":"attribution","nuclearity":"SN"},{"parent":64,"left":63,"right":4,"relation":"joint","nuclearity":"NN"},{"parent":63,"left":62,"right":3,"relation":"same-unit","nuclearity":"NN"},{"parent":62,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":5,"right":6,"relation":"attribution","nuclearity":"NS"},{"parent":120,"left":99,"right":119,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":86,"right":98,"relation":"adversative","nuclearity":"SN"},{"parent":86,"left":70,"right":85,"relation":"adversative","nuclearity":"SN"},{"parent":70,"left":7,"right":69,"relation":"attribution","nuclearity":"SN"},{"parent":69,"left":68,"right":10,"relation":"same-unit","nuclearity":"NN"},{"parent":68,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":85,"left":11,"right":84,"relation":"adversative","nuclearity":"NN"},{"parent":84,"left":12,"right":83,"relation":"same-unit","nuclearity":"NN"},{"parent":83,"left":71,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":13,"right":14,"relation":"attribution","nuclearity":"SN"},{"parent":82,"left":75,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":15,"right":74,"relation":"organization","nuclearity":"SN"},{"parent":74,"left":73,"right":19,"relation":"attribution","nuclearity":"NS"},{"parent":73,"left":72,"right":18,"relation":"same-unit","nuclearity":"NN"},{"parent":72,"left":16,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":80,"right":26,"relation":"adversative","nuclearity":"NN"},{"parent":80,"left":20,"right":79,"relation":"attribution","nuclearity":"SN"},{"parent":79,"left":21,"right":78,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":22,"right":77,"relation":"joint","nucle