{"article_id":"DfumECjSsidJGBJM","edus":[{"id":0,"text":"Actor Jussie Smollett claimed to be the victim of a racist and homophobic attack","depth":5},{"id":1,"text":"because he was dissatisfied with his salary on the hip-hop TV drama `` Empire , ''","depth":5},{"id":2,"text":"Chicago 's police chief said on Thursday .","depth":4},{"id":3,"text":"Smollett , a 36-year-old black , openly gay actor , has been arrested","depth":5},{"id":4,"text":"after he was charged with lying to police in connection with the alleged attack on Jan. 29 .","depth":5},{"id":5,"text":"`` Smollett took advantage of the pain and anger of racism","depth":8},{"id":6,"text":"to promote his career , ''","depth":8},{"id":7,"text":"Chicago Police Superintendent Eddie Johnson told a news conference ,","depth":7},{"id":8,"text":"adding","depth":7},{"id":9,"text":"that the actor paid $ 3,500 to two brothers","depth":8},{"id":10,"text":"to stage the supposed hate crime .","depth":8},{"id":11,"text":"`` This stunt was orchestrated by Smollett","depth":7},{"id":12,"text":"because he was dissatisfied with this salary .","depth":7},{"id":13,"text":"He concocted a story","depth":8},{"id":14,"text":"about being attacked , ''","depth":8},{"id":15,"text":"Johnson said .","depth":8},{"id":16,"text":"`` We gave him the benefit of the doubt . ''","depth":8},{"id":17,"text":"Smollett had claimed","depth":5},{"id":18,"text":"that two apparent supporters of U.S. President Donald Trump had struck him ,","depth":6},{"id":19,"text":"put a noose around his neck","depth":7},{"id":20,"text":"and poured an unknown substance over him .","depth":7},{"id":21,"text":"The Cook County State 's Attorney 's Office approved felony criminal charges against Smollett for disorderly conduct and filing a false police report ,","depth":6},{"id":22,"text":"police said on Wednesday .","depth":6},{"id":23,"text":"He has a bond hearing","depth":6},{"id":24,"text":"scheduled for later on Thursday .","depth":6},{"id":25,"text":"Last week , police arrested two brothers","depth":7},{"id":26,"text":"who were recognized from surveillance footage of the area","depth":8},{"id":27,"text":"where Smollett said","depth":9},{"id":28,"text":"the attack occurred .","depth":9},{"id":29,"text":"One of the brothers worked with Smollett on `` Empire , ''","depth":7},{"id":30,"text":"according to police and their lawyer .","depth":7},{"id":31,"text":"Police released the brothers two days later without charges .","depth":5},{"id":32,"text":"They confessed","depth":6},{"id":33,"text":"and became cooperating witnesses ,","depth":6},{"id":34,"text":"Johnson said .","depth":5},{"id":35,"text":"Since the alleged attack , Smollett had received support on social media ,","depth":4},{"id":36,"text":"including from several celebrities and Democratic presidential candidates .","depth":4},{"id":37,"text":"But others were skeptical of the incident ,","depth":6},{"id":38,"text":"which","depth":8},{"id":39,"text":"Smollett said","depth":8},{"id":40,"text":"occurred around 2 a.m. on a Chicago street during one of the city 's coldest weeks in recent history .","depth":7},{"id":41,"text":"In an interview with `` Good Morning America '' last week , Smollett said","depth":6},{"id":42,"text":"he was angry","depth":8},{"id":43,"text":"that some people questioned his story ,","depth":8},{"id":44,"text":"and he suggested","depth":8},{"id":45,"text":"the disbelief might come from racial bias .","depth":8},{"id":46,"text":"Officials from 20th Century Fox Television ,","depth":6},{"id":47,"text":"which airs `` Empire , ''","depth":6},{"id":48,"text":"did not immediately respond to requests for comment .","depth":5},{"id":49,"text":"`` How can an individual","depth":6},{"id":50,"text":"who has been embraced by the city of Chicago","depth":6},{"id":51,"text":"turn around","depth":5},{"id":52,"text":"and slap everyone in this city in the face","depth":5},{"id":53,"text":"by making these false claims ? ''","depth":5},{"id":54,"text":"the police superintendent said .","depth":3}],"relations":[{"parent":109,"left":89,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":71,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":57,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":57,"left":56,"right":2,"relation":"attribution","nuclearity":"NS"},{"parent":56,"left":0,"right":1,"relation":"causal","nuclearity":"NS"},{"parent":70,"left":58,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":58,"left":3,"right":4,"relation":"context","nuclearity":"NS"},{"parent":69,"left":63,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":60,"right":62,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":59,"right":7,"relation":"attribution","nuclearity":"NS"},{"parent":59,"left":5,"right":6,"relation":"purpose","nuclearity":"NS"},{"parent":62,"left":8,"right":61,"relation":"attribution","nuclearity":"SN"},{"parent":61,"left":9,"right":10,"relation":"purpose","nuclearity":"NS"},{"parent":68,"left":64,"right":67,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":11,"right":12,"relation":"explanation","nuclearity":"NS"},{"parent":67,"left":65,"right":66,"relation":"attribution","nuclearity":"NS"},{"parent":65,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":15,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":88,"left":78,"right":87,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":74,"right":77,"relation":"causal","nuclearity":"NS"},{"parent":74,"left":17,"right":73,"relation":"attribution","nuclearity":"SN"},{"parent":73,"left":18,"right":72,"relation":"joint","nuclearity":"NN"},{"parent":72,"left":19,"right":20,"relation":"joint","nuclearity":"NN"},{"parent":77,"left":75,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":21,"right":22,"relation":"attribution","nuclearity":"NS"},{"parent":76,"left":23,"right":24,"relation":"elaboration