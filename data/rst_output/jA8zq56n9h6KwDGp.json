left":86,"right":253,"relation":"elaboration","nuclearity":"NS"},{"parent":253,"left":87,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":281,"left":277,"right":280,"relation":"elaboration","nuclearity":"NS"},{"parent":277,"left":259,"right":276,"relation":"elaboration","nuclearity":"NS"},{"parent":259,"left":89,"right":258,"relation":"elaboration","nuclearity":"NS"},{"parent":258,"left":256,"right":257,"relation":"context","nuclearity":"NS"},{"parent":256,"left":90,"right":91,"relation":"attribution","nuclearity":"SN"},{"parent":257,"left":92,"right":93,"relation":"joint","nuclearity":"NN"},{"parent":276,"left":271,"right":275,"relation":"elaboration","nuclearity":"NS"},{"parent":271,"left":264,"right":270,"relation":"joint","nuclearity":"NN"},{"parent":264,"left":261,"right":263,"relation":"attribution","nuclearity":"SN"},{"parent":261,"left":260,"right":96,"relation":"same-unit","nuclearity":"NN"},{"parent":260,"left":94,"right":95,"relation":"elaboration","nuclearity":"NS"},{"parent":263,"left":97,"right":262,"relation":"elaboration","nuclearity":"NS"},{"parent":262,"left":98,"right":99,"relation":"joint","nuclearity":"NN"},{"parent":270,"left":265,"right":269,"relation":"elaboration","nuclearity":"NS"},{"parent":265,"left":100,"right":101,"relation":"attribution","nuclearity":"SN"},{"parent":269,"left":102,"right":268,"relation":"attribution","nuclearity":"SN"},{"parent":268,"left":103,"right":267,"relation":"explanation","nuclearity":"NS"},{"parent":267,"left":104,"right":266,"relation":"joint","nuclearity":"NN"},{"parent":266,"left":105,"right":106,"relation":"mode","nuclearity":"NS"},{"parent":275,"left":107,"right":274,"relation":"attribution","nuclearity":"SN"},{"parent":274,"left":108,"right":273,"relation":"elaboration","nuclearity":"NS"},{"parent":273,"left":109,"right":272,"relation":"attribution","nuclearity":"SN"},{"parent":272,"left":110,"right":111,"relation":"purpose","nuclearity":"NS"},{"parent":280,"left":278,"right":279,"relation":"same-unit","nuclearity":"NN"},{"parent":278,"left":112,"right":113,"relation":"elaboration","nuclearity":"NS"},{"parent":279,"left":114,"right":115,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":285,"right":297,"relation":"joint","nuclearity":"NN"},{"parent":285,"left":116,"right":284,"relation":"elaboration","nuclearity":"NS"},{"parent":284,"left":117,"right":283,"relation":"joint","nuclearity":"NN"},{"parent":283,"left":118,"right":119,"relation":"attribution","nuclearity":"SN"},{"parent":297,"left":290,"right":296,"relation":"joint","nuclearity":"NN"},{"parent":290,"left":286,"right":289,"relation":"elaboration","nuclearity":"NS"},{"parent":286,"left":120,"right":121,"relation":"attribution","nuclearity":"NS"},{"parent":289,"left":122,"right":288,"relation":"attribution","nuclearity":"SN"},{"parent":288,"left":123,"right":287,"relation":"adversative","nuclearity":"NN"},{"parent":287,"left":124,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":296,"left":293,"right":295,"relation":"joint","nuclearity":"NN"},{"parent":293,"left":126,"right":292,"relation":"attribution","nuclearity":"SN"},{"parent":292,"left":127,"right":291,"relation":"purpose","nuclearity":"NS"},{"parent":291,"left":128,"right":129,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":294,"right":132,"relation":"attribution","nuclearity":"NS"},{"parent":294,"left":130,"right":131,"relation":"purpose","nuclearity":"NS"},{"parent":333,"left":306,"right":332,"relation":"joint","nuclearity":"NN"},{"parent":306,"left":303,"right":305,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":133,"right":302,"relation":"adversative","nuclearity":"SN"},{"parent":302,"left":134,"right":301,"relation":"attribution","nuclearity":"SN"},{"parent":301,"left":135,"right":300,"relation":"joint","nuclearity":"NN"},{"parent":300,"left":136,"right":137,"relation":"condition","nuclearity":"NS"},{"parent":305,"left":138,"right":304,"relation":"attribution","nuclearity":"SN"},{"parent":304,"left":139,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":332,"left":312,"right":331,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":308,"right":311,"relation":"elaboration","nuclearity":"NS"},{"parent":308,"left":307,"right":143,"relation":"adversative","nuclearity":"SN"},{"parent":307,"left":141,"right":142,"relation":"elaboration","nuclearity":"NS"},{"parent":311,"left":144,"right":310,"relation":"joint","nuclearity":"NN"},{"parent":310,"left":145,"right":309,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":146,"right":147,"relation":"organization","nuclearity":"SN"},{"parent":331,"left":316,"right":330,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":148,"right":315,"relation":"context","nuclearity":"NS"},{"parent":315,"left":314,"right":152,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":149,"right":313,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":150,"right":151,"relation":"purpose","nuclearity":"NS"},{"parent":330,"left":320,"right":329,"relation":"elaboration","nuclearity":"NS"},{"parent":320,"left":153,"right":319,"relation":"mode","nuclearity":"NS"},{"parent":319,"left":154,"right":318,"relation":"attribution","nuclearity":"SN"},{"parent":318,"left":155,"right":317,"relation":"condition","nuclearity":"NS"},{"parent":317,"left":156,"right":157,"relation":"elaboration","nuclearity":"NS"},{"parent":329,"left":324,"right":328,"relation":"joint","nuclearity":"NN"},{"parent":324,"left":321,"right":323,"relation":"topic","nuclearity":"SN"},{"parent":321,"left":158,"right":159,"relation":"attribution","nuclearity":"SN"},{"parent":323,"left":160,"right":322,"relation":"attribution","nuclearity":"SN"},{"parent":322,"left":161,"right":162,"relation":"condition","nuclearity":"SN"},{"parent":328,"left":326,"right":327,"relation":"context","nuclearity":"SN"},{"parent":326,"left":163,"right":325,"relation":"attribution","nuclearity":"SN"},{"parent":325,"left":164,"right":165,"relation":"purpose","nuclearity":"NS"},{"parent":327,"left":166,"right":167,"relation":"attribution","nuclearity":"SN"},{"parent":337,"left":168,"right":169,"relation":"elaboration","nuclearity":"NS"}]}