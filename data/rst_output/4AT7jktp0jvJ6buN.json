{"article_id":"4AT7jktp0jvJ6buN","edus":[{"id":0,"text":"Articles of impeachment delivered to Senate ,","depth":4},{"id":1,"text":"triggering historic trial of President Trump","depth":4},{"id":2,"text":"Speaker Nancy Pelosi said","depth":8},{"id":3,"text":"the House was holding the president `` accountable . ''","depth":8},{"id":4,"text":"House Speaker Nancy Pelosi on Wednesday formally set in motion the process","depth":9},{"id":5,"text":"of sending the articles of impeachment against President Donald Trump to the Senate ,","depth":9},{"id":6,"text":"triggering a historic trial","depth":9},{"id":7,"text":"set to begin on Thursday .","depth":9},{"id":8,"text":"At an `` engrossment '' signing ceremony for the House resolution","depth":9},{"id":9,"text":"naming the seven impeachment managers","depth":10},{"id":10,"text":"-- the lawmakers","depth":11},{"id":11,"text":"who will present the House case as prosecutors at the trial --","depth":11},{"id":12,"text":"Pelosi said","depth":8},{"id":13,"text":"the House was doing its `` constitutional duty . ''","depth":7},{"id":14,"text":"House Speaker Nancy Pelosi of Calif. , speaks","depth":7},{"id":15,"text":"before she signs the resolution","depth":8},{"id":16,"text":"to transmit the two articles of impeachment against President Donald Trump to the Senate for trial on Capitol Hill in Washington , Jan. 15 , 2020 .","depth":8},{"id":17,"text":"Susan Walsh/AP","depth":6},{"id":18,"text":"`` Today , we will make history , ''","depth":8},{"id":19,"text":"she said ,","depth":8},{"id":20,"text":"`` when we walk down --","depth":9},{"id":21,"text":"when the managers walk the hall ,","depth":9},{"id":22,"text":"they will cross a threshold in history ,","depth":9},{"id":23,"text":"delivering articles of impeachment against the president of the United States for abuse of power and obstruction of the House . ''","depth":9},{"id":24,"text":"The two U.S House of Representatives articles of impeachment of President Donald Trump await the signature of House Speaker Nancy Pelosi before an engrossment ceremony at the U.S. Capitol in Washington , Jan. 15 , 2020 .","depth":7},{"id":25,"text":"Leah Millis/Reuters","depth":7},{"id":26,"text":"After signing the resolution ,","depth":10},{"id":27,"text":"she handed out the pens","depth":12},{"id":28,"text":"she used","depth":12},{"id":29,"text":"to the managers .","depth":11},{"id":30,"text":"Then ,","depth":10},{"id":31,"text":"marking the somber nature of the occasion ,","depth":11},{"id":32,"text":"the managers silently walked the articles , in two blue folders , across the Capitol from the House to the Senate ,","depth":12},{"id":33,"text":"where the House clerk announced their arrival .","depth":12},{"id":34,"text":"The Senate will formally accept them on Thursday .","depth":8},{"id":35,"text":"Senate Majority Leader Mitch McConnell announced","depth":8},{"id":36,"text":"that the Senate would convene at noon","depth":9},{"id":37,"text":"after which the managers will read the articles aloud ,","depth":10},{"id":38,"text":"Chief Justice John Roberts will be sworn in","depth":11},{"id":39,"text":"and he , in turn , will swear in senators","depth":12},{"id":40,"text":"to serve as jurors in the case .","depth":12},{"id":41,"text":"`` Let me close with this , ''","depth":8},{"id":42,"text":"McConnell said .","depth":8},{"id":43,"text":"`` This is a difficult time for our country .","depth":9},{"id":44,"text":"But this is precisely the kind of time","depth":10},{"id":45,"text":"for which the framers created the Senate .","depth":10},{"id":46,"text":"I am confident","depth":9},{"id":47,"text":"this body can rise above short-termism and factional fever","depth":10},{"id":48,"text":"and serve the long-term best interests of our nation .","depth":10},{"id":49,"text":"Earlier Wednesday , the House voted 228-193 to formally send the impeachment charges against President Trump to the Senate","depth":7},{"id":50,"text":"to begin the third presidential impeachment trial in American history .","depth":7},{"id":51,"text":"The House resolution officially appoints the seven managers ,","depth":8},{"id":52,"text":"named by Pelosi Wednesday morning .","depth":8},{"id":53,"text":"In the morning ,","depth":9},{"id":54,"text":"shortly after being named an impeachment manager ,","depth":9},{"id":55,"text":"House Judiciary Chairman Jerry Nadler submitted the text of a resolution","depth":9},{"id":56,"text":"that spells out the managers ' duties .","depth":9},{"id":57,"text":"The House of Representatives discusses the resolution","depth":6},{"id":58,"text":"to transmit articles of impeachment against President Donald Trump to the Senate , in Washington , Jan. 15 , 2020 .","depth":6},{"id":59,"text":"During the short floor debate before the vote , Minority Leader Kevin McCarthy took aim at the managers","depth":7},{"id":60,"text":"appointed by Pelosi ,","depth":7},{"id":61,"text":"as they sat in front of him ,","depth":7},{"id":62,"text":"listening .","depth":7},{"id":63,"text":"`` By selecting this particular batch of managers ,","depth":9},{"id":64,"text":"the speaker has further proven","depth":10},{"id":65,"text":"she 's not interested in winning the minds , the hearts , or even following the Constitution , ''","depth":10},{"id":66,"text":"he said ,","depth":9},{"id":67,"text":"calling out Nadler , and House Intelligence Chairman Adam Schiff , specifically .","depth":9},{"id":68,"text":"He criticized Pelosi 's comments this morning","depth":10},{"id":69,"text":"about Trump being impeached `` forever , ''","depth":10},{"id":70,"text":"accusing her of playing politics . `` The speaker said ,","depth":12},{"id":71,"text":"'The President is impeached forever .","depth":12},{"id":72,"text":"' Is this what this is all about ? ''","depth":11},{"id":73,"text":"he said .","depth":10},{"id":74,"text":"Pelosi pumped her fist in the air","depth":9},{"id":75,"text":"as McCarthy quoted her .","depth":9},{"id":76,"text":"There were about 140 members of the public","depth":7},{"id":77,"text":"watching from the galleries .","depth":7},{"id":78,"text":"House Speaker Nancy Pelosi speaks on the floor of the House of Representatives","depth":7},{"id":79,"text":"as lawmakers take up a resolution","depth":8},{"id":80,"text":"to transmit impeachment articles against President Donald Trump to the U.S. Senate , in Washington , Jan. 15 , 2020 .","depth":8},{"id":81,"text":"When it was her turn ,","depth":8},{"id":82,"text":"Pelosi ,","depth":11},{"id":83,"text":"standing next to a poster","depth":12},{"id":84,"text":"showing the American flag and a quote from the Pledge of Allegiance ,","depth":12},{"id":85,"text":"ended debate","depth":10},{"id":86,"text":"by denouncing Trump 's actions","depth":10},{"id":87,"text":"and defending the timing of the impeachment proceedings in the House .","depth":10},{"id":88,"text":"`` It is a fact","depth":10},{"id":89,"text":"that","depth":11},{"id":90,"text":"once somebody is impeached ,","depth":12},{"id":91,"text":"they are always impeached .","depth":12},{"id":92,"text":"It can not be erased .","depth":9},{"id":93,"text":"I know","depth":11},{"id":94,"text":"you do n't like hearing that , ''","depth":11},{"id":95,"text":"Pelosi said to McCarthy .","depth":10},{"id":96,"text":"`` They would have liked us to send this over on Christmas Eve","depth":11},{"id":97,"text":"so they could dismiss it .","depth":11},{"id":98,"text":"Perhaps they do n't know","depth":11},{"id":99,"text":"that dismissal is a cover-up . ''","depth":11},{"id":100,"text":"President Trump ,","depth":12},{"id":101,"text":"participating in a signing ceremony of an agreement between the United States and China at the White House ,","depth":12},{"id":102,"text":"observed some Republicans in the audience","depth":11},{"id":103,"text":"and directed them to go vote against the resolution .","depth":10},{"id":104,"text":"`` It 's on the impeachment hoax , ''","depth":10},{"id":105,"text":"Trump said of the resolution .","depth":10},{"id":106,"text":"`` It 's not going to matter '","depth":10},{"id":107,"text":"cause it 's going very well ,","depth":10},{"id":108,"text":"but I 'd rather have you voting","depth":10},{"id":109,"text":"than sitting here","depth":11},{"id":110,"text":"listening to me introduce you .","depth":11},{"id":111,"text":"They have a hoax going on over there ,","depth":9},{"id":112,"text":"let 's take care of it . '' `` Resolved ,","depth":9},{"id":113,"text":"That Mr. Schiff , Mr. Nadler , Ms. Lofgren , Mr. Jeffries , Mrs. Demings , Mr. Crow , and Ms. Garcia of Texas are appointed managers","depth":11},{"id":114,"text":"to conduct the impeachment trial against Donald John Trump , President of the United States ,","depth":11},{"id":115,"text":"that a message be sent to the Senate","depth":12},{"id":116,"text":"to inform the Senate of these appointments ,","depth":12},{"id":117,"text":"and that the managers","depth":14},{"id":118,"text":"so appointed","depth":14},{"id":119,"text":"may , in connection with the preparation and the conduct of the trial , exhibit the articles of impeachment to the Senate","depth":13},{"id":120,"text":"and take all other actions necessary... , ''","depth":12},{"id":121,"text":"the resolution states ,","depth":10},{"id":122,"text":"formally naming each impeachment manager .","depth":10},{"id":123,"text":"The resolution goes on to authorize `` employing legal , clerical , and other necessary assistants","depth":9},{"id":124,"text":"and incurring such other expenses","depth":11},{"id":125,"text":"as may be necessary ,","depth":11},{"id":126,"text":"to be paid from amounts available to the Committee on the Judiciary under applicable expense resolutions or from the applicable accounts of the House of Representatives . ''","depth":10},{"id":127,"text":"In other words , the costs of the House participation in the Senate trial will be covered by the Judiciary Committee .","depth":8},{"id":128,"text":"The measure also authorizes `` sending for persons and papers , and filing with the Secretary of the Senate , on the part of the House of Representatives , any pleadings , in conjunction with or subsequent to , the exhibition of the articles of impeachment","depth":8},{"id":129,"text":"that the managers consider necessary . ''","depth":8},{"id":130,"text":"Pelosi will sign the bill at a 5 p.m. engrossing ceremony in the Capitol ,","depth":5},{"id":131,"text":"before the managers carry out the ritual","depth":6},{"id":132,"text":"of marching across the Capitol","depth":7},{"id":133,"text":"to present the bill to the Senate secretary .","depth":7},{"id":134,"text":"House Speaker Nancy Pelosi of Calif. , speaks during a news conference","depth":4},{"id":135,"text":"to announce impeachment managers on Capitol Hill in Washington , Wednesday , Jan. 15 , 2020 .","depth":4},{"id":136,"text":"Susan Walsh/AP","depth":3},{"id":137,"text":"Earlier ,","depth":9},{"id":138,"text":"as she named the managers ,","depth":10},{"id":139,"text":"Pelosi , with Schiff and Nadler at her side , began","depth":10},{"id":140,"text":"by saying","depth":9},{"id":141,"text":"`` an impeachment will last forever . ''","depth":9},{"id":142,"text":"Schiff and Nadler will be two of the mangers ,","depth":8},{"id":143,"text":"Schiff designated by Pelosi as the lead manager .","depth":8},{"id":144,"text":"`` This is a very important day for us , ''","depth":11},{"id":145,"text":"she said .","depth":11},{"id":146,"text":"`` Time has been our friend in all this , ''","depth":12},{"id":147,"text":"she added ,","depth":12},{"id":148,"text":"noting what she called the new `` incriminating '' evidence","depth":13},{"id":149,"text":"that has surfaced in the month since the House impeachment vote on Dec. 18 ,","depth":13},{"id":150,"text":"including new documents from Lev Parnas , an associate of Rudy Giuliani , the president 's personal lawyer .","depth":12},{"id":151,"text":"Schiff said","depth":10},{"id":152,"text":"that bombshell new evidence ,","depth":12},{"id":153,"text":"revealed by the House just Tuesday night ,","depth":12},{"id":154,"text":"must be considered by the Senate .","depth":11},{"id":155,"text":"Schiff added","depth":11},{"id":156,"text":"that documents will be just as important as any witnesses ,","depth":11},{"id":157,"text":"citing a letter","depth":12},{"id":158,"text":"Giuliani sent Ukrainian President Volodymyr Zelenskiy","depth":12},{"id":159,"text":"and what it said","depth":12},{"id":160,"text":"about his having Trump 's blessing .","depth":12},{"id":161,"text":"`` If the Senate wants to see the evidence ,","depth":11},{"id":162,"text":"they should demand to see the documents , ''","depth":11},{"id":163,"text":"he said .","depth":10},{"id":164,"text":"Democrats further pushed back on the comparison to the Clinton trial precedent ,","depth":9},{"id":165,"text":"pointing to the fact","depth":10},{"id":166,"text":"that during Clinton , the Senate had the full record","depth":11},{"id":167,"text":"thanks to the Starr investigation and the House investigation .","depth":11},{"id":168,"text":"Nadler also batted down the early suggestion from Republicans","depth":11},{"id":169,"text":"that former Vice President Joe Biden 's son , Hunter Biden , should be called ,","depth":11},{"id":170,"text":"saying","depth":11},{"id":171,"text":"he would n't be considered a relevant witness .","depth":11},{"id":172,"text":"`` It 's important for the president to know","depth":12},{"id":173,"text":"and Vladimir Putin to know","depth":12},{"id":174,"text":"that the American voters decide who are president is .","depth":11},{"id":175,"text":"We would n't be in this situation","depth":12},{"id":176,"text":"had we not waited","depth":13},{"id":177,"text":"and insist","depth":14},{"id":178,"text":"that there be witnesses","depth":15},{"id":179,"text":"and we see documentation , ''","depth":15},{"id":180,"text":"Pelosi said .","depth":11},{"id":181,"text":"Other managers","depth":9},{"id":182,"text":"Pelosi named","depth":9},{"id":183,"text":"were Reps. Hakeem Jeffries of New York , Val Demings of Florida , House Administration Committee Chair Zoe Lofgren of California , Sylvia Garcia of Texas and Jason Crow of Colorado .","depth":8},{"id":184,"text":"Pelosi said","depth":9},{"id":185,"text":"she chose members of Congress with experience as litigators","depth":10},{"id":186,"text":"who are comfortable in a courtroom setting","depth":11},{"id":187,"text":"and making a strong , evidence-based case .","depth":11},{"id":188,"text":"`` The emphasis is making the strongest possible case","depth":10},{"id":189,"text":"to protect and defend our Constitution ,","depth":11},{"id":190,"text":"to seek the truth for the American people , ''","depth":11},{"id":191,"text":"she said .","depth":9},{"id":192,"text":"When asked about the delay","depth":11},{"id":193,"text":"in transferring the articles ,","depth":11},{"id":194,"text":"Schiff said","depth":11},{"id":195,"text":"the extra time helped Democrats make the case for a trial in the Senate","depth":11},{"id":196,"text":"after Senate Majority Leader Mitch McConnell initially said","depth":10},{"id":197,"text":"he would support efforts","depth":11},{"id":198,"text":"to dismiss the case .","depth":11},{"id":199,"text":"`` If McConnell makes this the first trial in history","depth":11},{"id":200,"text":"without witnesses","depth":11},{"id":201,"text":"it will be exposed for what it is","depth":11},{"id":202,"text":"and that 's an effort","depth":12},{"id":203,"text":"to cover up for the president , ''","depth":12},{"id":204,"text":"Schiff said .","depth":9},{"id":205,"text":"`` It is essential we bring this impeachment","depth":9},{"id":206,"text":"to stop the president from rigging the next election , ''","depth":9},{"id":207,"text":"Nadler said .","depth":8},{"id":208,"text":"Pelosi ended the announcement","depth":7},{"id":209,"text":"by warning","depth":8},{"id":210,"text":"that","depth":9},{"id":211,"text":"should the Senate fall short of a full trial ,","depth":10},{"id":212,"text":"it would n't overshadow the House 's impeachment vote","depth":11},{"id":213,"text":"- just the third in American history .","depth":11},{"id":214,"text":"`` He has been held accountable .","depth":8},{"id":215,"text":"He has been impeached forever .","depth":9},{"id":216,"text":"They can never erase that , ''","depth":9},{"id":217,"text":"Pelosi said .","depth":7},{"id":218,"text":"There have been 20 presidential impeachment managers in American history ;","depth":6},{"id":219,"text":"all of them have been white men .","depth":6},{"id":220,"text":"House Speaker Nancy Pelosi announces the House of Representatives managers for the Senate impeachment trial of President Donald Trump during a news conference at the U.S. Capitol in Washington , Jan. 15 , 2020 .","depth":7},{"id":221,"text":"Joshua Roberts/Reuters","depth":7},{"id":222,"text":"Pelosi 's team has three women :","depth":8},{"id":223,"text":"Demings , Lofgren and Sylvia Garcia .","depth":8},{"id":224,"text":"There are two freshman lawmakers on the team :","depth":11},{"id":225,"text":"Crow , a former Army Ranger and lawyer , and Garcia .","depth":11},{"id":226,"text":"Crow helped write the pivotal Washington Post op-ed with other freshman in September in favor of impeachment","depth":11},{"id":227,"text":"that was seen as turning the tide in favor of impeachment in the caucus .","depth":11},{"id":228,"text":"He 's the only manager","depth":10},{"id":229,"text":"who is not a member of the Judiciary or Intelligence Committees .","depth":10},{"id":230,"text":"Demings , the former police chief of Orlando , is on both panels .","depth":9},{"id":231,"text":"Lofgren is a veteran of three impeachments :","depth":10},{"id":232,"text":"She was a Judiciary Committee staffer during Watergate ,","depth":11},{"id":233,"text":"and served on the panel during Clinton 's impeachment .","depth":11},{"id":234,"text":"Though the House voted to impeach Trump in December ,","depth":12},{"id":235,"text":"charging him with abuse of power and obstruction of Congress ,","depth":12},{"id":236,"text":"Pelosi withheld delivering the charges to the Senate ,","depth":11},{"id":237,"text":"saying","depth":11},{"id":238,"text":"she wanted McConnell to first outline the rules of the trial and commit to bringing key witnesses before the Senate","depth":12},{"id":239,"text":"to testify ,","depth":13},{"id":240,"text":"including former White House National Security Adviser John Bolton .","depth":13},{"id":241,"text":"While McConnell resisted Pelosi 's pressure campaign ,","depth":11},{"id":242,"text":"a number of Senate Republicans have expressed interest","depth":12},{"id":243,"text":"in voting","depth":13},{"id":244,"text":"to hear from witnesses after the initial opening arguments .","depth":13},{"id":245,"text":"And McConnell has ruled out dismissing the charges against Trump at the start of proceedings , a move","depth":11},{"id":246,"text":"that Democrats feared","depth":12},{"id":247,"text":"would circumvent an airing of the charges against the president .","depth":12},{"id":248,"text":"`` The American people deserve the truth ,","depth":10},{"id":249,"text":"and the Constitution demands a trial , ''","depth":10},{"id":250,"text":"Pelosi wrote in a statement","depth":10},{"id":251,"text":"released on Tuesday .","depth":10},{"id":252,"text":"Shortly after word came about the planned House vote ,","depth":8},{"id":253,"text":"McConnell took to the Senate floor","depth":9},{"id":254,"text":"to lambaste what he called an `` arbitrary '' month-long delay","depth":11},{"id":255,"text":"in sending over the articles .","depth":11},{"id":256,"text":"The delay has impacted the plans of the several Senate Democrats","depth":12},{"id":257,"text":"running for president ,","depth":12},{"id":258,"text":"forcing them to adjust their campaign schedules","depth":12},{"id":259,"text":"leading up to the Iowa caucuses early next month .","depth":12},{"id":260,"text":"McConnell said","depth":7},{"id":261,"text":"arguments in the Senate trial are expected to begin next Tuesday .","depth":7},{"id":262,"text":"Removal from office would require 67 senators","depth":7},{"id":263,"text":"voting in favor of conviction ,","depth":7},{"id":264,"text":"constituting a simple majority of the body .","depth":6},{"id":265,"text":"That means at least 20 Republicans would need to turn against the president ,","depth":6},{"id":266,"text":"assuming","depth":7},{"id":267,"text":"all Democrats vote to convict .","depth":7}],"relations":[{"parent":535,"left":401,"right":534,"relation":"elaboration","nuclearity":"NS"},{"parent":401,"left":316,"right":400,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":269,"right":315,"relation":"elaboration","nuclearity":"NS"},{"parent":269,"left":0,"right":1,"relation":"causal","nuclearity":"NS"},{"parent":315,"left":284,"right":314,"relation":"elaboration","nuclearity":"NS"},{"parent":284,"left":280,"right":283,"relation":"elaboration","nuclearity":"NS"},{"parent":280,"left":274,"right":279,"relation":"elaboration","nuclearity":"NS"},{"parent":274,"left":270,"right":273,"relation":"explanation","nuclearity":"NS"},{"parent":270,"left":2,"right":3,"relation":"attribution","nuclearity":"SN"},{"parent":273,"left":271,"right":272,"relation":"causal","nuclearity":"NS"},{"parent":271,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":272,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":279,"left":278,"right":13,"relation":"attribution","nuclearity":"SN"},{"parent":278,"left":277,"right":12,"relation":"same-unit","nuclearity":"NN"},{"parent":277,"left":8,"right":276,"relation":"elaboration","nuclearity":"NS"},{"parent":276,"left":9,"right":275,"relation":"elaboration","nuclearity":"NS"},{"parent":275,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":283,"left":282,"right":17,"relation":"attribution","nuclearity":"NS"},{"parent":282,"left":14,"right":281,"relation":"context","nuclearity":"NS"},{"parent":281,"left":15,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":291,"right":313,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":289,"right":290,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":285,"right":288,"relation":"same-unit","nuclearity":"NN"},{"parent":285,"left":18,"right":19,"relation":"attribution","nuclearity":"NS"},{"parent":288,"left":286,"right":287,"relation":"context","nuclearity":"SN"},{"parent":286,"left":20,"right":21,"relation":"restatement","nuclearity":"NN"},{"parent":287,"left":22,"right":23,"relation":"causal","nuclearity":"NS"},{"parent":290,"left":24,"right":25,"relation":"attribution","nuclearity":"NS"},{"parent":313,"left":305,"right":312,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":299,"right":304,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":298,"right":34,"relation":"joint","nuclearity":"NN"},{"parent":298,"left":294,"right":297,"relation":"joint","nuclearity":"NN"},{"parent":294,"left":26,"right":293,"relation":"context","nuclearity":"SN"},{"parent":293,"left":292,"right":29,"relation":"same-unit","nuclearity":"NN"},{"parent":292,"left":27,"right":28,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":30,"right":296,"relation":"same-unit","nuclearity":"NN"},{"parent":296,"left":31,"right":295,"relation":"mode","nuclearity":"SN"},{"parent":295,"left":32,"right":33,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":35,"right":303,"relation":"attribution","nuclearity":"SN"},{"parent":303,"left":36,"right":302,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":37,"right":301,"relation":"joint","nuclearity":"NN"},{"parent":301,"left":38,"right":300,"relation":"joint","nuclearity":"NN"},{"parent":300,"left":39,"right":40,"relation":"purpose","nuclearity":"NS"},{"parent":312,"left":306,"right":311,"relation":"joint","nuclearity":"NN"},{"parent":306,"left":