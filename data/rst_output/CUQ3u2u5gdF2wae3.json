:337,"left":162,"right":336,"relation":"attribution","nuclearity":"SN"},{"parent":336,"left":163,"right":335,"relation":"condition","nuclearity":"NS"},{"parent":335,"left":164,"right":334,"relation":"elaboration","nuclearity":"NS"},{"parent":334,"left":165,"right":166,"relation":"attribution","nuclearity":"SN"},{"parent":352,"left":344,"right":351,"relation":"elaboration","nuclearity":"NS"},{"parent":344,"left":341,"right":343,"relation":"attribution","nuclearity":"SN"},{"parent":341,"left":340,"right":169,"relation":"same-unit","nuclearity":"NN"},{"parent":340,"left":167,"right":168,"relation":"elaboration","nuclearity":"NS"},{"parent":343,"left":170,"right":342,"relation":"attribution","nuclearity":"SN"},{"parent":342,"left":171,"right":172,"relation":"elaboration","nuclearity":"NS"},{"parent":351,"left":345,"right":350,"relation":"elaboration","nuclearity":"NS"},{"parent":345,"left":173,"right":174,"relation":"joint","nuclearity":"NN"},{"parent":350,"left":349,"right":180,"relation":"elaboration","nuclearity":"NS"},{"parent":349,"left":348,"right":179,"relation":"attribution","nuclearity":"NS"},{"parent":348,"left":346,"right":347,"relation":"causal","nuclearity":"SN"},{"parent":346,"left":175,"right":176,"relation":"elaboration","nuclearity":"NS"},{"parent":347,"left":177,"right":178,"relation":"attribution","nuclearity":"SN"}]}