{"article_id":"b3DhaGiNRxNghtpX","edus":[{"id":0,"text":"Sen. Elizabeth Warren called out Facebook on Monday","depth":4},{"id":1,"text":"for taking down campaign advertisement videos","depth":5},{"id":2,"text":"that propose big breakups for major tech companies .","depth":5},{"id":3,"text":"Warren announced her plan last week","depth":6},{"id":4,"text":"titled , \" Here ' s How We Can Break Up Big Tech \" ,","depth":6},{"id":5,"text":"which focuses on breaking up \" anti-competitive \" mergers ,","depth":6},{"id":6,"text":"including Facebook ' s acquisitions of WhatsApp and Instagram .","depth":6},{"id":7,"text":"The Facebook advertisements","depth":8},{"id":8,"text":"that Warren posted on Friday ,","depth":8},{"id":9,"text":"specifically target the company for their past privacy actions and power .","depth":7},{"id":10,"text":"\" Three companies have vast power over our economy and our democracy .","depth":10},{"id":11,"text":"Facebook , Amazon , and Google , \"","depth":10},{"id":12,"text":"the ad read","depth":9},{"id":13,"text":"according to Politico .","depth":8},{"id":14,"text":"\" We all use them .","depth":8},{"id":15,"text":"But in their rise to power , they ' ve bulldozed competition ,","depth":9},{"id":16,"text":"used our private information for profit ,","depth":10},{"id":17,"text":"and tilted the playing field in their favor . \"","depth":10},{"id":18,"text":"Facebook soon took three of the ads down with messages","depth":7},{"id":19,"text":"stating ,","depth":8},{"id":20,"text":"\" This ad was taken down","depth":9},{"id":21,"text":"because it goes against Facebook ' s advertising policies . \"","depth":9},{"id":22,"text":"A Facebook spokesperson later confirmed to Politico","depth":8},{"id":23,"text":"the advertisements were taken down","depth":9},{"id":24,"text":"because they contained the company ' s logo ,","depth":10},{"id":25,"text":"which violated their policy","depth":10},{"id":26,"text":"but added ,","depth":8},{"id":27,"text":"\" In the interest","depth":10},{"id":28,"text":"of allowing robust debate ,","depth":10},{"id":29,"text":"we are restoring the ads . \"","depth":9},{"id":30,"text":"Warren tweeted her frustrations toward the company","depth":6},{"id":31,"text":"and reiterated the example of their ability","depth":8},{"id":32,"text":"to censor her post","depth":8},{"id":33,"text":"as her inspirations for the proposal .","depth":7},{"id":34,"text":"\" Curious why I think","depth":10},{"id":35,"text":"[ Facebook ] has too much power ?","depth":10},{"id":36,"text":"Let ' s start with their ability","depth":11},{"id":37,"text":"to shut down a debate","depth":12},{"id":38,"text":"over whether [ Facebook ] has too much power .","depth":12},{"id":39,"text":"Thanks for restoring my posts .","depth":10},{"id":40,"text":"But I want a social media marketplace","depth":9},{"id":41,"text":"that isn ' t dominated by a single censor , \"","depth":9},{"id":42,"text":"she said .","depth":7},{"id":43,"text":"Curious why I think","depth":9},{"id":44,"text":"FB has too much power ?","depth":9},{"id":45,"text":"Let 's start with their ability","depth":9},{"id":46,"text":"to shut down a debate","depth":10},{"id":47,"text":"over whether FB has too much power .","depth":10},{"id":48,"text":"Thanks for restoring my posts .","depth":8},{"id":49,"text":"But I want a social media marketplace","depth":9},{"id":50,"text":"that is n't dominated by a single censor .","depth":9},{"id":51,"text":"# BreakUpBigTech","depth":4},{"id":52,"text":"https : //t.co/UPS6dozOxn","depth":4},{"id":53,"text":"- Elizabeth Warren","depth":6},{"id":54,"text":"( @ ewarren )","depth":6},{"id":55,"text":"March 11 , 2019","depth":5},{"id":56,"text":"Warren most recently took to Twitter on Monday ,","depth":2},{"id":57,"text":"posting a video of her talking to supporters in Long Island City","depth":3},{"id":58,"text":"where she compared the \" Hunger Games \" to the system","depth":4},{"id":59,"text":"of how Amazon and other big companies pit areas against each other for the most financial gain .","depth":4}],"relations":[{"parent":119,"left":115,"right":118,"relation":"elaboration","nuclearity":"NS"},{"parent":115,"left":89,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":62,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":62,"left":0,"right":61,"relation":"causal","nuclearity":"NS"},{"parent":61,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":88,"left":65,"right":87,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":63,"right":64,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":5,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":87,"left":75,"right":86,"relation":"joint","nuclearity":"NN"},{"parent":75,"left":67,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":66,"right":9,"relation":"same-unit","nuclearity":"NN"},{"parent":66,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":70,"right":73,"relation":"joint","nuclearity":"NN"},{"parent":70,"left":69,"right":13,"relation":"attribution","nuclearity":"NS"},{"parent":69,"left":68,"right":12,"relation":"attribution","nuclearity":"NS"},{"parent":68,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":14,"right":72,"relation":"adversative","nuclearity":"SN"},{"parent":72,"left":15,"right":71,"relation":"joint","nuclearity":"NN"},{"parent":71,"left":16,"right":17,"relation":"joint","nuclearity":"NN"},{"parent":86,"left":78,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":18,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":19,"right":76,"relation":"attribution","nuclearity":"SN"},{"parent":76,"left":20,"right":21,"relation":"explanation","nuclearity":"NS"},{"parent":85,"left":81,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":81,