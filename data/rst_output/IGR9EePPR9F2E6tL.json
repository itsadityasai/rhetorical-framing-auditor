{"article_id":"IGR9EePPR9F2E6tL","edus":[{"id":0,"text":"President Trump took to Twitter","depth":2},{"id":1,"text":"to express his frustration over North Korea 's latest missile test","depth":3},{"id":2,"text":"and called on the country 's longtime ally China to intervene .","depth":3},{"id":3,"text":"Interested in Donald Trump ?","depth":4},{"id":4,"text":"Add Donald Trump as an interest","depth":5},{"id":5,"text":"to stay up to date on the latest Donald Trump news , video , and analysis from .","depth":5},{"id":6,"text":"Add Interest","depth":3},{"id":7,"text":"`` North Korea has just launched another missile .","depth":8},{"id":8,"text":"Does this guy have anything better to do with his life ? ''","depth":8},{"id":9,"text":"he tweeted late Monday ,","depth":7},{"id":10,"text":"presumably referring to North Korean leader Kim Jong Un .","depth":6},{"id":11,"text":"`` Hard to believe","depth":7},{"id":12,"text":"that South Korea ... and Japan will put up with this much longer . ''","depth":7},{"id":13,"text":"Trump went on to suggest","depth":9},{"id":14,"text":"that China ,","depth":11},{"id":15,"text":"which shares a border with North Korea ,","depth":11},{"id":16,"text":"could do something .","depth":10},{"id":17,"text":"`` Perhaps China will put a heavy move on North Korea","depth":10},{"id":18,"text":"and end this nonsense once and for all , ''","depth":10},{"id":19,"text":"he wrote .","depth":9},{"id":20,"text":"North Korea has just launched another missile .","depth":10},{"id":21,"text":"Does this guy have anything better to do with his life ?","depth":10},{"id":22,"text":"Hard to believe that South Korea .....","depth":10},{"id":23,"text":"- Donald J. Trump","depth":12},{"id":24,"text":"( @ realDonaldTrump )","depth":12},{"id":25,"text":"July 4 , 2017","depth":11},{"id":26,"text":".... and Japan will put up with this much longer .","depth":10},{"id":27,"text":"Perhaps China will put a heavy move on North Korea","depth":11},{"id":28,"text":"and end this nonsense once and for all !","depth":11},{"id":29,"text":"- Donald J. Trump","depth":11},{"id":30,"text":"( @ realDonaldTrump )","depth":11},{"id":31,"text":"July 4 , 2017","depth":10},{"id":32,"text":"The tweet ,","depth":6},{"id":33,"text":"sent in two parts at 10:24 p.m . ET Monday ,","depth":6},{"id":34,"text":"came before the Pentagon publicly confirmed the missile test .","depth":5},{"id":35,"text":"Trump also tweeted about North Korea late last month ,","depth":7},{"id":36,"text":"when he acknowledged","depth":8},{"id":37,"text":"that China 's efforts","depth":10},{"id":38,"text":"to `` help with North Korea ''","depth":10},{"id":39,"text":"had `` not worked out . ''","depth":9},{"id":40,"text":"Months earlier , he said","depth":8},{"id":41,"text":"he discovered","depth":9},{"id":42,"text":"that `` it 's not so easy '' for China","depth":11},{"id":43,"text":"- North Korea 's main trade partner -","depth":11},{"id":44,"text":"to rein in the country 's leadership .","depth":10},{"id":45,"text":"`` After listening","depth":12},{"id":46,"text":"[ to Chinese President Xi Jinping ]","depth":12},{"id":47,"text":"for 10 minutes ,","depth":11},{"id":48,"text":"I realized","depth":10},{"id":49,"text":"that not - it 's not so easy .","depth":9},{"id":50,"text":"You know ,","depth":12},{"id":51,"text":"I felt pretty strongly","depth":12},{"id":52,"text":"that they have -","depth":12},{"id":53,"text":"that they had a tremendous power over China , ''","depth":12},{"id":54,"text":"Trump said in an April interview with The Wall Street Journal .","depth":10},{"id":55,"text":"`` I actually do think","depth":11},{"id":56,"text":"they do have an economic power ,","depth":12},{"id":57,"text":"and they have certainly a border power to an extent ,","depth":13},{"id":58,"text":"but they also -","depth":14},{"id":59,"text":"a lot of goods come in .","depth":14},{"id":60,"text":"But it 's not what you would think .","depth":11},{"id":61,"text":"It 's not what you would think . ''","depth":11},{"id":62,"text":"U.S. , South Korean and Japanese officials on Monday said","depth":7},{"id":63,"text":"North Korea launched an intermediate-range missile","depth":8},{"id":64,"text":"that flew for about 40 minutes","depth":9},{"id":65,"text":"and reached an altitude of about 1,500 miles .","depth":9},{"id":66,"text":"North Korea later claimed","depth":9},{"id":67,"text":"that the missile was a longer-range intercontinental ballistic missile ,","depth":10},{"id":68,"text":"which ,","depth":11},{"id":69,"text":"if confirmed ,","depth":12},{"id":70,"text":"would be the country 's first such test .","depth":12},{"id":71,"text":"ICBMs ,","depth":10},{"id":72,"text":"which are capable of carrying nuclear weapons ,","depth":10},{"id":73,"text":"typically have a minimum range of about 3,400 miles .","depth":9},{"id":74,"text":"The United States had not confirmed the missile type as of early this morning .","depth":7},{"id":75,"text":"Trump last week warned North Korea","depth":9},{"id":76,"text":"that he and allied foreign leaders have lost patience with the regime ,","depth":10},{"id":77,"text":"which has continually defied international calls","depth":11},{"id":78,"text":"for it to dismantle its nuclear program and halt its missile tests .","depth":11},{"id":79,"text":"The era of strategic patience with the North Korea regime has failed .","depth":10},{"id":80,"text":"That patience is over .","depth":10},{"id":81,"text":"We are working closely with ....","depth":9},{"id":82,"text":"pic.twitter.com/nCZ51HnIdx","depth":7},{"id":83,"text":"- Donald J. Trump","depth":8},{"id":84,"text":"( @ realDonaldTrump )","depth":8},{"id":85,"text":"June 30 , 2017","depth":7},{"id":86,"text":"Speak","depth":8},{"id":87,"text":"ng at a news conference with South Korean President Moon Jae-in on Friday ,","depth":10},{"id":88,"text":"rump called the North Korean regime `` reckless and brutal ''","depth":10},{"id":89,"text":"nd said","depth":10},{"id":90,"text":"ts `` nuclear and ballistic missile programs require a determined response . ''","depth":10},{"id":91,"text":"` The era of strategic patience with the North Korean regime has failed .","depth":10},{"id":92,"text":"any years it has failed , ''","depth":10},{"id":93,"text":"e said .","depth":9},{"id":94,"text":"` Frankly , that patience is over . ''","depth":8},{"id":95,"text":"rump added","depth":7},{"id":96,"text":"hat the United States is working with South Korea , Japan and other partners `` on a range of diplomatic , security and economic measures","depth":8},{"id":97,"text":"o protect our allies and our own citizens from this menace","depth":9},{"id":98,"text":"nown as North Korea . ''","depth":9}],"relations":[{"parent":197,"left":101,"right":196,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":0,"right":100,"relation":"purpose","nuclearity":"NS"},{"parent":100,"left":1,"right":2,"relation":"joint","nuclearity":"NN"},{"parent":196,"left":104,"right":195,"relation":"organization","nuclearity":"SN"},{"parent":104,"left":103,"right":6,"relation":"context","nuclearity":"NS"},{"parent":103,"left":3,"right":102,"relation":"topic","nuclearity":"SN"},{"parent":102,"left":4,"right":5,"relation":"purpose","nuclearity":"NS"},{"parent":195,"left":131,"right":194,"relation":"elaboration","nuclearity":"NS"},{"parent":131,"left":128,"right":130,"relation":"elaboration","nuclearity":"NS"},{"parent":128,"left":107,"right":127,"relation":"joint","nuclearity":"NN"},{"parent":107,"left":106,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":106,"left":105,"right":9,"relation":"attribution","nuclearity":"NS"},{"parent":105,"left":7,"right":8,"relation":"context","nuclearity":"SN"},{"parent":127,"left":108,"right":126,"relation":"joint","nuclearity":"NN"},{"parent":108,"left":11,"right":12,"relation":"attribution","nuclearity":"SN"},{"parent":126,"left":114,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":114,"left":111,"right":113,"relation":"elaboration","nu