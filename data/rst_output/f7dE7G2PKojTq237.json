{"article_id":"f7dE7G2PKojTq237","edus":[{"id":0,"text":"U.S. Economy Added 157,000 Jobs In July ;","depth":2},{"id":1,"text":"Unemployment Dips To 3.9 Percent","depth":2},{"id":2,"text":"The economy continued to add jobs at a steady pace last month ,","depth":5},{"id":3,"text":"and the unemployment rate remained low .","depth":5},{"id":4,"text":"Analysts have been looking for signs","depth":6},{"id":5,"text":"that wage growth might pick up ,","depth":6},{"id":6,"text":"but it held steady , too .","depth":5},{"id":7,"text":"Payrolls grew by a lower-than-expected 157,000 in July ,","depth":10},{"id":8,"text":"and the unemployment rate edged down to 3.9 percent ,","depth":11},{"id":9,"text":"as projected ,","depth":11},{"id":10,"text":"the Labor Department said Friday .","depth":9},{"id":11,"text":"However , payrolls were revised upward by 59,000 for the prior two months .","depth":10},{"id":12,"text":"They grew 248,000 in June , up from the previously reported 213,000 , and 268,000 in May ,","depth":11},{"id":13,"text":"compared with the 244,000 last reported .","depth":11},{"id":14,"text":"Over the prior 12 months , payrolls have been growing an average 203,000 per month .","depth":9},{"id":15,"text":"Manufacturing jobs grew by 37,000 in July ,","depth":8},{"id":16,"text":"jobs in professional and business services were up 51,000 ,","depth":9},{"id":17,"text":"and leisure and hospitality jobs rose 40,000 .","depth":9},{"id":18,"text":"Private analysts had estimated","depth":9},{"id":19,"text":"that about 190,000 jobs were added in July ,","depth":9},{"id":20,"text":"and they had expected the unemployment rate to inch down to 3.9 percent from June 's 4 percent .","depth":8},{"id":21,"text":"Before this year , the last time","depth":10},{"id":22,"text":"the jobless rate was this low","depth":10},{"id":23,"text":"was in 2000 .","depth":9},{"id":24,"text":"In July , average hourly earnings increased by 7 cents , to $ 27.05 .","depth":9},{"id":25,"text":"That level is up 2.7 percent over the prior year , the same as June 's pace .","depth":9},{"id":26,"text":"With the economy at full employment and hiring managers","depth":8},{"id":27,"text":"struggling to fill open positions ,","depth":8},{"id":28,"text":"wages normally would be expected to start rising at a faster rate .","depth":7},{"id":29,"text":"But ,","depth":9},{"id":30,"text":"as NPR 's Yuki Noguchi reports ,","depth":10},{"id":31,"text":"`` some economists say","depth":11},{"id":32,"text":"that should add up to wage growth rates of about 3.5 percent .","depth":11},{"id":33,"text":"Instead , wages are increasing at a 2.7 percent annual rate . ''","depth":8},{"id":34,"text":"And","depth":8},{"id":35,"text":"when factoring in the cost of living ,","depth":9},{"id":36,"text":"those increases look even weaker .","depth":9},{"id":37,"text":"It 's no wonder","depth":6},{"id":38,"text":"that more jobs are available .","depth":6},{"id":39,"text":"The economy picked up dramatically in the second quarter .","depth":7},{"id":40,"text":"The 4.1 percent pace","depth":9},{"id":41,"text":"- lifted by jumps in consumer spending and exports -","depth":9},{"id":42,"text":"was the strongest in nearly four years .","depth":8},{"id":43,"text":"Some economists said","depth":8},{"id":44,"text":"those were temporary factors -","depth":9},{"id":45,"text":"boosted by the Republican tax cuts and increased export shipments ahead of retaliatory tariffs by China on U.S. agricultural products .","depth":9},{"id":46,"text":"But President Trump called the numbers `` very sustainable , ''","depth":8},{"id":47,"text":"adding :","depth":9},{"id":48,"text":"`` This is n't a one-time shot .","depth":10},{"id":49,"text":"... Next quarter ,","depth":12},{"id":50,"text":"I think","depth":12},{"id":51,"text":"it 's going to be outstanding . ''","depth":11},{"id":52,"text":"This week , the Federal Reserve noted","depth":5},{"id":53,"text":"that the labor market has `` continued to strengthen ''","depth":6},{"id":54,"text":"and that the economy overall has also been strong .","depth":6},{"id":55,"text":"`` Job gains have been strong , on average , in recent months ,","depth":6},{"id":56,"text":"and the unemployment rate has stayed low , ''","depth":6},{"id":57,"text":"it said .","depth":5},{"id":58,"text":"The central bank decided to keep interest rates unchanged ,","depth":4},{"id":59,"text":"but it has signaled","depth":5},{"id":60,"text":"that it will hike them twice more this year .","depth":5}],"relations":[{"parent":121,"left":62,"right":120,"relation":"organization","nuclearity":"SN"},{"parent":62,"left":0,"right":1,"relation":"joint","nuclearity":"NN"},{"parent":120,"left":111,"right":119,"relation":"elaboration","nuclearity":"NS"},{"parent":111,"left":66,"right":110,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":63,"right":65,"relation":"context","nuclearity":"NS"},{"parent":63,"left":2,"right":3,"relation":"joint","nuclearity":"NN"},{"parent":65,"left":64,"right":6,"relation":"adversative","nuclearity":"NN"},{"parent":64,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":110,"left":95,"right":109,"relation":"evaluation","nuclearity":"NS"},{"parent":95,"left":84,"right":94,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":76,"right":83,"relation":"context","nuclearity":"NS"},{"parent":76,"left":73,"right":75,"relation":"joint","nuclearity":"NN"},{"parent":73,"left":69,"right":72,"relation":"adversative","nuclearity":"NN"},{"parent":69,"left":68,"right":10,"relation":"attribution","nuclearity":"NS"},{"parent":68,"left":7,"right":67,"relation":"joint","nuclearity":"NN"},{"parent":67,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":71,"right":14,"relation":"joint","nuclearity":"NN"},{"parent":71,"left":11,"right":70,"relation":"joint","nuclearity":"NN"},{"parent":70,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":15,"right":74,"relation":"joint","nu