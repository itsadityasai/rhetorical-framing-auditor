{"article_id":"rvgJVGY6NF64P46J","edus":[{"id":0,"text":"LISTEN TO ARTICLE 2:01","depth":1},{"id":1,"text":"SHARE THIS ARTICLE","depth":3},{"id":2,"text":"Share Tweet","depth":4},{"id":3,"text":"Post","depth":5},{"id":4,"text":"Email Amazon.com","depth":5},{"id":5,"text":"Inc. is eliminating monthly bonuses and stock awards for warehouse workers and other hourly employees","depth":6},{"id":6,"text":"after the company pledged this week to raise pay to at least $ 15 an hour .","depth":6},{"id":7,"text":"Warehouse workers for the e-commerce giant in the U.S. were eligible in the past for monthly bonuses","depth":9},{"id":8,"text":"that could total hundreds of dollars per month","depth":9},{"id":9,"text":"as well as stock awards ,","depth":8},{"id":10,"text":"said two people familiar with Amazon ' s pay policies .","depth":7},{"id":11,"text":"The company informed those employees Wednesday","depth":8},{"id":12,"text":"that it ' s eliminating both of those compensation categories","depth":9},{"id":13,"text":"to help pay for the raises ,","depth":9},{"id":14,"text":"the people said .","depth":7},{"id":15,"text":"Amazon received plaudits","depth":6},{"id":16,"text":"when it announced Monday","depth":7},{"id":17,"text":"that the company would raise its minimum pay .","depth":7},{"id":18,"text":"The pay increase warded off criticism from politicians and activists ,","depth":7},{"id":19,"text":"and put the company in a good position","depth":8},{"id":20,"text":"to recruit temporary workers for the important holiday shopping season .","depth":8},{"id":21,"text":"Even after the elimination of bonuses and stock awards , hourly operations and customer-service workers will see their total compensation increase ,","depth":9},{"id":22,"text":"the company said in a statement .","depth":9},{"id":23,"text":"\" In addition ,","depth":10},{"id":24,"text":"because it ' s no longer incentive-based ,","depth":11},{"id":25,"text":"the compensation will be more immediate and predictable , \"","depth":11},{"id":26,"text":"Amazon said .","depth":9},{"id":27,"text":"Workers","depth":10},{"id":28,"text":"whose pay was already above $ 15 per hour","depth":10},{"id":29,"text":"will get hourly raises of $ 1 ,","depth":9},{"id":30,"text":"according to two people familiar with the matter","depth":9},{"id":31,"text":"who asked not to be identified","depth":10},{"id":32,"text":"discussing the company ' s compensation practices .","depth":10},{"id":33,"text":"Some long-time workers expressed frustration","depth":6},{"id":34,"text":"that their raises are small","depth":6},{"id":35,"text":"compared with newly hired workers","depth":6},{"id":36,"text":"who will see hourly pay bumps of as much as 40 percent .","depth":6},{"id":37,"text":"A higher hourly wage","depth":8},{"id":38,"text":"that new workers immediately receive","depth":8},{"id":39,"text":"is a better recruiting tool in a tight labor market than stock options","depth":9},{"id":40,"text":"that take years to materialize ,","depth":9},{"id":41,"text":"especially in the warehousing industry","depth":9},{"id":42,"text":"that sees high turnover ,","depth":9},{"id":43,"text":"said David DeBoskey , an accounting professor at San Diego State University .","depth":6},{"id":44,"text":"Amazon said","depth":7},{"id":45,"text":"it will hire 100,000 seasonal workers for the holiday crush this year ,","depth":8},{"id":46,"text":"and temporary workers don ' t get stock .","depth":8},{"id":47,"text":"\" In a tight labor market ,","depth":10},{"id":48,"text":"when you ' re the leader","depth":11},{"id":49,"text":"paying $ 15 an hour ,","depth":11},{"id":50,"text":"that ' s a big advantage , \"","depth":9},{"id":51,"text":"DeBoskey said .","depth":8},{"id":52,"text":"\" They probably realized","depth":8},{"id":53,"text":"people weren ' t applying for warehouse jobs for the stock options . \"","depth":8}],"relations":[{"parent":107,"left":0,"right":106,"relation":"organization","nuclearity":"SN"},{"parent":106,"left":57,"right":