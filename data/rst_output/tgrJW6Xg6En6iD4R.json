{"article_id":"tgrJW6Xg6En6iD4R","edus":[{"id":0,"text":"Opposition to the 2010 health care law has been above 50 percent for over a year .","depth":4},{"id":1,"text":"And that continues to be true ,","depth":5},{"id":2,"text":"as the latest national poll finds","depth":6},{"id":3,"text":"voters oppose the law by a 52-41 percent margin .","depth":6},{"id":4,"text":"Support for Obamacare has been as high as 43 percent","depth":7},{"id":5,"text":"( May 2014 )","depth":7},{"id":6,"text":"and gone as low as 36 percent","depth":7},{"id":7,"text":"( January 2014 ) .","depth":7},{"id":8,"text":"The number","depth":8},{"id":9,"text":"opposing the law","depth":8},{"id":10,"text":"has ranged from 49 percent","depth":8},{"id":11,"text":"( June 2012 )","depth":8},{"id":12,"text":"to a record-high 59 percent","depth":7},{"id":13,"text":"( January 2014 ) .","depth":7},{"id":14,"text":"As in the past , the new poll shows","depth":6},{"id":15,"text":"that most Democrats favor Obamacare","depth":8},{"id":16,"text":"( 74 percent ) ,","depth":8},{"id":17,"text":"while most Republicans","depth":9},{"id":18,"text":"( 84 percent )","depth":9},{"id":19,"text":"and independents","depth":10},{"id":20,"text":"( 61 percent )","depth":10},{"id":21,"text":"are against it .","depth":9},{"id":22,"text":"Voters in every age group are more likely to oppose the law","depth":8},{"id":23,"text":"than favor it , with one exception :","depth":8},{"id":24,"text":"those ages 65 and over .","depth":7},{"id":25,"text":"And that group only favors it by two percentage points .","depth":6},{"id":26,"text":"President Obama receives higher job approval ratings on health care than on almost any other issue :","depth":5},{"id":27,"text":"42 percent of voters approve ,","depth":7},{"id":28,"text":"while 53 percent disapprove .","depth":7},{"id":29,"text":"That ' s up from a record-low 36 percent approval in March .","depth":6},{"id":30,"text":"His highest approval on health care came two years ago ,","depth":5},{"id":31,"text":"when 48 percent approved and 47 percent disapproved","depth":6},{"id":32,"text":"( September 2012 ) .","depth":6},{"id":33,"text":"And where is Obama doing best now ?","depth":4},{"id":34,"text":"It ' s the economy ,","depth":6},{"id":35,"text":"although even here his ratings are under water :","depth":7},{"id":36,"text":"43 percent approve vs. 51 percent disapprove .","depth":7},{"id":37,"text":"Approval of Obama ' s performance is below 40 percent on all other issues","depth":7},{"id":38,"text":"tested in the poll ,","depth":7},{"id":39,"text":"and goes as low as 30 percent approval on the Israeli-Palestinian conflict .","depth":6},{"id":40,"text":"The poll is based on landline and cell phone interviews with 1,001 randomly chosen registered voters nationwide","depth":3},{"id":41,"text":"and was conducted under the joint direction of Anderson Robbins Research","depth":5},{"id":42,"text":"( D )","depth":5},{"id":43,"text":"and Shaw & Company Research","depth":6},{"id":44,"text":"( R )","depth":6},{"id":45,"text":"from August 10-12 , 2014 .","depth":5},{"id":46,"text":"The full poll has a margin of sampling error of plus or minus three percentage points .","depth":2}],"relations":[{"parent":93,"left":86,"right":92,"relation":"context","nuclearity":"NS"},{"parent":86,"left":72,"right":85,"relation":"joint","nuclearity":"NN"},{"parent":72,"left":50,"right":71,"relation":"context","nuclearity":"NS"},{"parent":50,"left":0,"right":49,"relation":"context","nuclearity":"SN"},{"parent":49,"left":1,"right":48,"relation":"explanation","nuclearity":"NS"},{"parent":48,"left":2,"right":3,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":59,"right":70,"relation":"joint","nuclearity":"NN"},{"parent":59,"left":53,"right":58,"relation":"joint","nuclearity":"NN"},{"parent":53,"left":51,"right":52,"relation":"same-unit","nuclearity":"NN"},{"parent":51,"left":4,"right":5,"relation":"context","nuclearity":"NS"},{"parent":52,"left":6,"right":7,"relation":"expla