lation":"purpose","nuclearity":"NS"},{"parent":282,"left":78,"right":79,"relation":"attribution","nuclearity":"SN"},{"parent":292,"left":82,"right":291,"relation":"attribution","nuclearity":"SN"},{"parent":291,"left":83,"right":290,"relation":"same-unit","nuclearity":"NN"},{"parent":290,"left":289,"right":88,"relation":"condition","nuclearity":"SN"},{"parent":289,"left":288,"right":87,"relation":"elaboration","nuclearity":"NS"},{"parent":288,"left":84,"right":287,"relation":"elaboration","nuclearity":"NS"},{"parent":287,"left":85,"right":86,"relation":"attribution","nuclearity":"SN"},{"parent":295,"left":294,"right":91,"relation":"elaboration","nuclearity":"NS"},{"parent":294,"left":89,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":416,"left":399,"right":415,"relation":"joint","nuclearity":"NN"},{"parent":399,"left":310,"right":398,"relation":"joint","nuclearity":"NN"},{"parent":310,"left":308,"right":309,"relation":"causal","nuclearity":"NS"},{"parent":308,"left":92,"right":307,"relation":"context","nuclearity":"SN"},{"parent":307,"left":305,"right":306,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":303,"right":304,"relation":"attribution","nuclearity":"SN"},{"parent":303,"left":302,"right":95,"relation":"same-unit","nuclearity":"NN"},{"parent":302,"left":93,"right":94,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":96,"right":97,"relation":"attribution","nuclearity":"SN"},{"parent":306,"left":98,"right":99,"relation":"attribution","nuclearity":"SN"},{"parent":309,"left":100,"right":101,"relation":"joint","nuclearity":"NN"},{"parent":398,"left":344,"right":397,"relation":"elaboration","nuclearity":"NS"},{"parent":344,"left":332,"right":343,"relation":"elaboration","nuclearity":"NS"},{"parent":332,"left":312,"right":331,"relation":"adversative","nuclearity":"SN"},{"parent":312,"left":102,"right":311,"relation":"attribution","nuclearity":"SN"},{"parent":311,"left":103,"right":104,"relation":"purpose","nuclearity":"