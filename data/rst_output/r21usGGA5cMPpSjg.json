{"article_id":"r21usGGA5cMPpSjg","edus":[{"id":0,"text":"Adult film star Stormy Daniels sued President Trump on Tuesday ,","depth":5},{"id":1,"text":"claiming","depth":7},{"id":2,"text":"the nondisclosure agreement","depth":9},{"id":3,"text":"she signed","depth":9},{"id":4,"text":"isn ' t valid","depth":8},{"id":5,"text":"because it lacks Trump ' s signature .","depth":6},{"id":6,"text":"Daniels ,","depth":6},{"id":7,"text":"whose real name is Stephanie Clifford ,","depth":6},{"id":8,"text":"filed the lawsuit in Los Angeles Superior Court .","depth":5},{"id":9,"text":"The complaint ,","depth":8},{"id":10,"text":"which was posted online by her lawyer , Michael Avenatti ,","depth":8},{"id":11,"text":"alleges","depth":7},{"id":12,"text":"the \" Hush Agreement \"","depth":10},{"id":13,"text":"- as it ' s referred to in the lawsuit -","depth":11},{"id":14,"text":"Daniels signed","depth":11},{"id":15,"text":"regarding her relationship with Trump","depth":9},{"id":16,"text":"is invalid","depth":8},{"id":17,"text":"because he never signed it himself .","depth":7},{"id":18,"text":"Daniels and Trump ' s personal lawyer , Michael Cohen , signed the non-disclosure agreement on Oct. 28 , 2016 ,","depth":7},{"id":19,"text":"the suit said .","depth":7},{"id":20,"text":"Trump was elected president less than two weeks later .","depth":6},{"id":21,"text":"A copy of the agreement shows","depth":6},{"id":22,"text":"Daniels ,","depth":8},{"id":23,"text":"identified as \" Peggy Peterson , \"","depth":8},{"id":24,"text":"signed the paperwork ,","depth":7},{"id":25,"text":"but Trump ,","depth":7},{"id":26,"text":"identified as \" David Dennison , \"","depth":7},{"id":27,"text":"did not .","depth":6},{"id":28,"text":"STORMY DANIELS CLAIMS","depth":4},{"id":29,"text":"SHE 'S FREE TO TALK ABOUT TRUMP AFTER PAYMENT ADMISSION","depth":4},{"id":30,"text":"The lawsuit claims","depth":6},{"id":31,"text":"the two had an \" intimate relationship \" during the summer of 2006 in Lake Tahoe ,","depth":7},{"id":32,"text":"and it continued \" well into the year 2007. \"","depth":7},{"id":33,"text":"Daniels and Trump reportedly met at least once \" in a bungalow at the Beverly Hills Hotel \" during this time .","depth":5},{"id":34,"text":"Cohen admitted last month","depth":8},{"id":35,"text":"that he paid Daniels $ 130,000 out of his own pocket in October 2016","depth":9},{"id":36,"text":"to keep mum about her relationship with Trump .","depth":9},{"id":37,"text":"He said","depth":9},{"id":38,"text":"the payment was lawful","depth":10},{"id":39,"text":"and not a campaign contribution or campaign expenditure \" by anyone . \"","depth":10},{"id":40,"text":"\" Neither the Trump Organization nor the Trump campaign was a party to the transaction with Ms. Clifford ,","depth":10},{"id":41,"text":"and neither reimbursed me for the payment , either directly or indirectly , \"","depth":10},{"id":42,"text":"a statement from Cohen read .","depth":9},{"id":43,"text":"After Cohen released that statement ,","depth":8},{"id":44,"text":"Daniels said","depth":9},{"id":45,"text":"the \" hush agreement \" was invalid .","depth":9},{"id":46,"text":"\" Everything is off now ,","depth":9},{"id":47,"text":"and Stormy is going to tell her story , \"","depth":9},{"id":48,"text":"Daniels ' manager , Gina Rodriguez , said .","depth":8},{"id":49,"text":"Trump vehemently denies the affair ,","depth":7},{"id":50,"text":"Cohen has said .","depth":7},{"id":51,"text":"A recent statement","depth":9},{"id":52,"text":"attributed to Daniels","depth":9},{"id":53,"text":"also denied the encounter ,","depth":8},{"id":54,"text":"though she later seemed to challenge","depth":8},{"id":55,"text":"whether the statement originated from her .","depth":8},{"id":56,"text":"TRUMP 'S LAWYER 'S PAYMENT TO PORN STAR STORMY DANIELS WAS REPORTED AS SUSPICIOUS BY BANK","depth":2},{"id":57,"text":"The adult film actress first detailed her account of an alleged extramarital affair with Trump in 2011 on the celebrity website The Dirty ,","depth":4},{"id":58,"text":"and it was picked up before the 2016 election by The Smoking Gun .","depth":4},{"id":59,"text":"In Touch Weekly published a 2011 interview last month","depth":4},{"id":60,"text":"in which the actress","depth":7},{"id":61,"text":"- whom","depth":9},{"id":62,"text":"the magazine said","depth":9},{"id":63,"text":"passed a polygraph exam -","depth":8},{"id":64,"text":"claimed","depth":6},{"id":65,"text":"the two had sex on one occasion","depth":6},{"id":66,"text":"and described subsequent in-person meetings , phone calls and discussions about a possible TV appearance .","depth":6}],"relations":[{"parent":133,"left":122,"right":132,"relation":"context","nuclearity":"NS"},{"parent":122,"left":94,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":75,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":72,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":0,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":70,"right":5,"relation":"explanation","nuclearity":"NS"},{"parent":70,"left":1,"right":69,"relation":"attribution","nuclearity":"SN"},{"parent":69,"left":68,"right":4,"relation":"same-unit","nuclearity":"NN"},{"parent":68,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":73,"right":8,"relation":"same-unit","nuclearity":"NN"},{"parent":73,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":93,"left":86,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":86,"left":83,"right":85,"relation":"context","nuclearity":"NS"},{"parent":83,"left":77,"right":82,"relation":"attribution","nuclearity":"SN"},{"parent":77,"left":76,"right":11,"relation":"same-unit","nuclearity":"NN"},{"parent":76,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":81,"right":17,"relation":"explanation","nuclearity":"NS"},{"parent":81,"left":80,"right":16,"relation":"same-un