:115,"right":116,"relation":"restatement","nuclearity":"NN"},{"parent":251,"left":117,"right":118,"relation":"joint","nuclearity":"NN"},{"parent":265,"left":259,"right":264,"relation":"elaboration","nuclearity":"NS"},{"parent":259,"left":258,"right":124,"relation":"attribution","nuclearity":"NS"},{"parent":258,"left":119,"right":257,"relation":"attribution","nuclearity":"SN"},{"parent":257,"left":256,"right":123,"relation":"explanation","nuclearity":"NS"},{"parent":256,"left":255,"right":122,"relation":"same-unit","nuclearity":"NN"},{"parent":255,"left":120,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":264,"left":263,"right":130,"relation":"organization","nuclearity":"SN"},{"parent":263,"left":125,"right":262,"relation":"attribution","nuclearity":"SN"},{"parent":262,"left":261,"right":129,"relation":"same-unit","nuclearity":"NN"},{"parent":261,"left":126,"right":260,"relation":"elaboration","nuclearity":"NS"},{"parent":260,"left":127,"right":128,"relation":"condition","nuclearity":"NS"},{"parent":281,"left":274,"right":280,"relation":"elaboration","nuclearity":"NS"},{"parent":274,"left":131,"right":273,"relation":"attribution","nuclearity":"SN"},{"parent":273,"left":132,"right":272,"relation":"explanation","nuclearity":"NS"},{"parent":272,"left":133,"right":271,"relation":"attribution","nuclearity":"SN"},{"parent":271,"left":134,"right":135,"relation":"condition","nuclearity":"NS"},{"parent":280,"left":136,"right":279,"relation":"same-unit","nuclearity":"NN"},{"parent":279,"left":277,"right":278,"relation":"context","nuclearity":"SN"},{"parent":277,"left":275,"right":276,"relation":"same-unit","nuclearity":"NN"},{"parent":275,"left":137,"right":138,"relation":"purpose","nuclearity":"NS"},{"parent":276,"left":139,"right":140,"relation":"purpose","nuclearity":"NS"},{"parent":278,"left":141,"right":142,"relation":"attribution","nuclearity":"SN"}]}