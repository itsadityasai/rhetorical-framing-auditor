:290,"left":288,"right":289,"relation":"same-unit","nuclearity":"NN"},{"parent":288,"left":87,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":89,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":292,"right":94,"relation":"attribution","nuclearity":"NS"},{"parent":292,"left":92,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":343,"left":313,"right":342,"relation":"joint","nuclearity":"NN"},{"parent":313,"left":305,"right":312,"relation":"adversative","nuclearity":"NN"},{"parent":305,"left":299,"right":304,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":297,"right":298,"relation":"same-unit","nuclearity":"NN"},{"parent":297,"left":95,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":97,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":301,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":300,"right":101,"relation":"same-unit","nuclearity":"NN"},{"parent":300,"left":99,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":302,"right":104,"relation":"attribution","nuclearity":"NS"},{"parent":302,"left":102,"right":103,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":308,"right":311,"relation":"evaluation","nuclearity":"NS"},{"parent":308,"left":105,"right":307,"relation":"elaboration","nuclearity":"NS"},{"parent":307,"left":106,"right":306,"relation":"evaluation","nuclearity":"SN"},{"parent":306,"left":107,"right":108,"relation":"purpose","nuclearity":"NS"},{"parent":311,"left":109,"right":310,"relation":"explanation","nuclearity":"NS"},{"parent":310,"left":309,"right":112,"relation":"same-unit","nuclearity":"NN"},{"parent":309,"left":110,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":342,"left":325,"right":341,"relation":"joint","nuclearity":"NN"},{"parent":325,"left":317,"right":324,"relation":"elaboration","nuclearity":"NS"},{"parent":317,"left":3