aboration","nuclearity":"NS"},{"parent":265,"left":264,"right":30,"relation":"context","nuclearity":"NS"},{"parent":264,"left":28,"right":29,"relation":"context","nuclearity":"NS"},{"parent":283,"left":271,"right":282,"relation":"organization","nuclearity":"SN"},{"parent":271,"left":270,"right":36,"relation":"context","nuclearity":"NS"},{"parent":270,"left":269,"right":35,"relation":"context","nuclearity":"NS"},{"parent":269,"left":268,"right":34,"relation":"organization","nuclearity":"SN"},{"parent":268,"left":267,"right":33,"relation":"explanation","nuclearity":"SN"},{"parent":267,"left":31,"right":32,"relation":"attribution","nuclearity":"NS"},{"parent":282,"left":275,"right":281,"relation":"organization","nuclearity":"SN"},{"parent":275,"left":37,"right":274,"relation":"organization","nuclearity":"SN"},{"parent":274,"left":272,"right":273,"relation":"organization","nuclearity":"SN"},{"parent":272,"left":38,"right":39,"relation":"restatement","nuclearity":"NN"},{"parent":273,"left":40,"right":41,"relation":"elaboration","nuclearity":"NS"},{"parent":281,"left":42,"right":280,"relation":"attribution","nuclearity":"SN"},{"parent":280,"left":276,"right":279,"relation":"joint","nuclearity":"NN"},{"parent":276,"left":43,"right":44,"relation":"attribution","nuclearity":"SN"},{"parent":279,"left":45,"right":278,"relation":"attribution","nuclearity":"SN"},{"parent":278,"left":46,"right":277,"relation":"joint","nuclearity":"NN"},{"parent":277,"left":47,"right":48,"relation":"purpose","nuclearity":"NS"},{"parent":294,"left":290,"right":293,"relation":"elaboration","nuclearity":"NS"},{"parent":290,"left":286,"right":289,"relation":"elaboration","nuclearity":"NS"},{"parent":286,"left":285,"right":51,"relation":"attribution","nuclearity":"NS"},{"parent":285,"left":49,"right":50,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":52,"right":288,"relation":"attribution","nuclearity":"SN"},{"parent":288,"left":53,"right":287,"relation":"attribution","nuclearity":"SN"