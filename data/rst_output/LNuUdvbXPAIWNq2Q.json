ation","nuclearity":"NS"},{"parent":238,"left":231,"right":237,"relation":"explanation","nuclearity":"NS"},{"parent":231,"left":106,"right":230,"relation":"elaboration","nuclearity":"NS"},{"parent":230,"left":107,"right":108,"relation":"purpose","nuclearity":"NS"},{"parent":237,"left":235,"right":236,"relation":"context","nuclearity":"NS"},{"parent":235,"left":234,"right":113,"relation":"same-unit","nuclearity":"NN"},{"parent":234,"left":109,"right":233,"relation":"elaboration","nuclearity":"NS"},{"parent":233,"left":110,"right":232,"relation":"elaboration","nuclearity":"NS"},{"parent":232,"left":111,"right":112,"relation":"joint","nuclearity":"NN"},{"parent":236,"left":114,"right":115,"relation":"attribution","nuclearity":"SN"},{"parent":247,"left":239,"right":246,"relation":"evaluation","nuclearity":"NS"},{"parent":239,"left":116,"right":117,"relation":"elaboration","nuclearity":"NS"},{"parent":246,"left":118,"right":245,"relation":"elaboration","nuclearity":"NS"},{"parent":245,"left":240,"right":244,"relation":"adversative","nuclearity":"SN"},{"parent":240,"left":119,"right":120,"relation":"elaboration","nuclearity":"NS"},{"parent":244,"left":241,"right":243,"relation":"elaboration","nuclearity":"NS"},{"parent":241,"left":121,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":243,"left":123,"right":242,"relation":"joint","nuclearity":"NN"},{"parent":242,"left":124,"right":125,"relation":"purpose","nuclearity":"NS"}]}