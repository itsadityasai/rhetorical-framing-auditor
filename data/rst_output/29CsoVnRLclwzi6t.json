{"article_id":"29CsoVnRLclwzi6t","edus":[{"id":0,"text":"After four close-yet-devastating losses in the 2017 special elections ,","depth":5},{"id":1,"text":"Democrats have begun to express doubts in House Minority Leader Nancy Pelosi 's ability","depth":6},{"id":2,"text":"to help the party retake control of Congress .","depth":6},{"id":3,"text":"Speaking to reporters","depth":7},{"id":4,"text":"following Jon Ossoff 's loss in the Georgia Sixth ,","depth":7},{"id":5,"text":"Democratic congressmen said","depth":7},{"id":6,"text":"that Pelosi 's reign was hampering their chances","depth":8},{"id":7,"text":"of winning .","depth":8},{"id":8,"text":"Republicans and GOP donors made ads during the heated campaign","depth":8},{"id":9,"text":"that explicitly tied Ossoff to Pelosi 's leadership .","depth":8},{"id":10,"text":"\" It makes it a heck of a lot harder , \"","depth":9},{"id":11,"text":"Rep. Tim Ryan , D-Ohio , said of Pelosi ' s stature in GOP ads .","depth":9},{"id":12,"text":"\" That approach still has a little bit of punch to it .","depth":9},{"id":13,"text":"It still moves voters . \"","depth":9},{"id":14,"text":"Ryan ,","depth":10},{"id":15,"text":"who ran a bid","depth":11},{"id":16,"text":"to usurp Pelosi 's leadership role after the 2016 elections ,","depth":11},{"id":17,"text":"said","depth":9},{"id":18,"text":"that regular voters no longer feel connected to the Democratic Party .","depth":8},{"id":19,"text":"\" I think","depth":11},{"id":20,"text":"you ' d have to be an idiot","depth":12},{"id":21,"text":"to think","depth":13},{"id":22,"text":"we could win the House with Pelosi at the top , \"","depth":13},{"id":23,"text":"Rep. Filemon Vela , D-Texas , said ,","depth":11},{"id":24,"text":"per Politico .","depth":11},{"id":25,"text":"Vela had supported Pelosi in her leadership race against Ryan .","depth":9},{"id":26,"text":"\" Nancy Pelosi is not the only reason","depth":11},{"id":27,"text":"that Ossoff lost .","depth":11},{"id":28,"text":"But she certainly is one of the reasons , \"","depth":10},{"id":29,"text":"he said .","depth":9},{"id":30,"text":"Pelosi 's top aide , Drew Hammill , told The New York Times","depth":5},{"id":31,"text":"that any Democratic leader would be a target .","depth":5},{"id":32,"text":"\" Republicans blew through millions","depth":8},{"id":33,"text":"to keep a ruby red seat","depth":8},{"id":34,"text":"and in their desperate rush","depth":9},{"id":35,"text":"to stop the hemorrhaging ,","depth":9},{"id":36,"text":"they ' ve returned to demonizing the party ' s strongest fund-raiser and consensus builder , \"","depth":8},{"id":37,"text":"he said .","depth":6},{"id":38,"text":"\" They don ' t have Clinton or Obama ,","depth":6},{"id":39,"text":"so this is what they do . \"","depth":6},{"id":40,"text":"New York magazine 's Jonathan Chait called the latest backlash against Pelosi possibly the `` worst Democratic freak-out ever . ''","depth":3},{"id":41,"text":"Chait noted","depth":4},{"id":42,"text":"that the results from the special elections show","depth":6},{"id":43,"text":"that Democrats have gained some ground on Republicans ,","depth":6},{"id":44,"text":"turning in strong showings in districts","depth":6},{"id":45,"text":"that no Democrat should even have a chance","depth":7},{"id":46,"text":"of competing .","depth":7},{"id":47,"text":"Even if Democrats are struggling to connect with voters ,","depth":3},{"id":48,"text":"there are Democratic members of Congress","depth":4},{"id":49,"text":"who do not pin the special election losses on party leadership .","depth":4},{"id":50,"text":"\" I don ' t think","depth":5},{"id":51,"text":"people got up in the morning","depth":6},{"id":52,"text":"and said ,","depth":7},{"id":53,"text":"' Boy , I ' m going to make it though this rainstorm","depth":8},{"id":54,"text":"so I can vote against Nancy Pelosi , ' \"","depth":8},{"id":55,"text":"Rep. Anna G. Eshoo , D-Calif. , said ,","depth":5},{"id":56,"text":"per The Washington Post .","depth":5},{"id":57,"text":"\" I don ' t think","depth":5},{"id":58,"text":"that ' s what motivates people .","depth":5},{"id":59,"text":"I really don ' t . \"","depth":4}],"relations":[{"parent":119,"left":106,"right":118,"relation":"elaboration","nuclearity":"NS"},{"parent":106,"left":99,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":89,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":62,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":62,"left":0,"right":61,"relation":"causal","nuclearity":"SN"},{"parent":61,"left":1,"right":2,"relation":"purpose","nuclearity":"NS"},{"parent":88,"left":66,"right":87,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":63,"right":65,"relation":"context","nuclearity":"SN"},{"parent":63,"left":3,"right":4,"relation":"context","nuclearity":"NS"},{"parent":65,"left":5,"right":64,"relation":"attribution","nuclearity":"SN"},{"parent":64,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":87,"left":71,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":67,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":68,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":10,"right":11,"relation":"attribution","nuclearity":"NS"},{"parent":69,"left":12,"right":13,"relation":"joint","nuclearity":"NN"},{"parent":86,"left":75,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":74,"right":18,"relation":"attribution","nuclearity":"SN"},{"parent":74,"left":73,"right":17,"relation":"same-unit","nuclearity":"NN"},{"parent":73,"left":14,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":15,"right":16,"relation":"purpose","nuclearity":"NS"},{"parent":85,"left":81,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":80,"right":25,"relation":"context","nuclearity":"NS"},{