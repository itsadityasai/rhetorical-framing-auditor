t":148,"right":306,"relation":"organization","nuclearity":"SN"},{"parent":306,"left":302,"right":305,"relation":"joint","nuclearity":"NN"},{"parent":302,"left":149,"right":150,"relation":"joint","nuclearity":"NN"},{"parent":305,"left":151,"right":304,"relation":"same-unit","nuclearity":"NN"},{"parent":304,"left":152,"right":303,"relation":"context","nuclearity":"SN"},{"parent":303,"left":153,"right":154,"relation":"elaboration","nuclearity":"NS"},{"parent":317,"left":313,"right":316,"relation":"context","nuclearity":"SN"},{"parent":313,"left":155,"right":312,"relation":"attribution","nuclearity":"SN"},{"parent":312,"left":156,"right":311,"relation":"purpose","nuclearity":"NS"},{"parent":311,"left":157,"right":158,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":159,"right":315,"relation":"attribution","nuclearity":"SN"},{"parent":315,"left":160,"right":314,"relation":"purpose","nuclearity":"NS"},{"parent":314,"left":161,"right":162,"relation":"elaboration","nuclearity":"NS"}]}