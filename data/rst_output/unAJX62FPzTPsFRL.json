{"article_id":"unAJX62FPzTPsFRL","edus":[{"id":0,"text":"BIRMINGHAM , Ala.","depth":1},{"id":1,"text":"( ) -","depth":2},{"id":2,"text":"Dogged by accusations of sexual misconduct toward teenagers ,","depth":5},{"id":3,"text":"Republican U.S. Senate candidate Roy Moore cast himself as a staunch ally of President Donald Trump at a rally on the eve of Tuesday ' s election in Alabama .","depth":5},{"id":4,"text":"Despite Trump ' s endorsement for Moore ,","depth":7},{"id":5,"text":"some polls suggest","depth":8},{"id":6,"text":"Democrat Doug Jones , 63 , a former U.S. attorney , could pull off an upset victory","depth":9},{"id":7,"text":"by becoming the first non-Republican","depth":10},{"id":8,"text":"to be sent to the Senate by deeply conservative Alabama in two decades .","depth":10},{"id":9,"text":"Steve Bannon , Trump ' s former chief strategist and executive at the right-wing Breitbart News site , joined Moore in Midland City for the Monday night rally ,","depth":7},{"id":10,"text":"labeled a \" Drain the Swamp \" event , in an echo of Trump ' s 2016 campaign pledge","depth":8},{"id":11,"text":"to get rid of Washington insiders .","depth":8},{"id":12,"text":"\" I want to make America great again with President Trump , \"","depth":7},{"id":13,"text":"Moore said .","depth":7},{"id":14,"text":"\" I want America great ,","depth":8},{"id":15,"text":"but I want America good ,","depth":8},{"id":16,"text":"and she can ' t be good","depth":8},{"id":17,"text":"until we go back to God . \"","depth":8},{"id":18,"text":"Moore , a 70-year-old conservative Christian and former Alabama Supreme Court chief justice , has been accused by several women of pursuing them","depth":8},{"id":19,"text":"when they were teenagers","depth":9},{"id":20,"text":"and he was in his 30s ,","depth":9},{"id":21,"text":"including one woman","depth":8},{"id":22,"text":"who said","depth":9},{"id":23,"text":"he tried to initiate sexual contact with her","depth":10},{"id":24,"text":"when she was 14 .","depth":10},{"id":25,"text":"Moore has denied any misconduct .","depth":7},{"id":26,"text":"has not independently verified any of the accusations .","depth":7},{"id":27,"text":"The sexual misconduct accusations prompted many senior Republicans ,","depth":8},{"id":28,"text":"including Senate Majority Leader Mitch McConnell ,","depth":8},{"id":29,"text":"to distance themselves from Moore .","depth":7},{"id":30,"text":"\" There ' s a special place in hell for Republicans","depth":9},{"id":31,"text":"who should know better , \"","depth":9},{"id":32,"text":"Bannon told the rally ,","depth":8},{"id":33,"text":"framing the Alabama election as a showdown between establishment elites and populist power .","depth":7},{"id":34,"text":"A Fox News Poll","depth":12},{"id":35,"text":"conducted on Thursday","depth":13},{"id":36,"text":"and released on Monday","depth":13},{"id":37,"text":"put Jones ahead of Moore ,","depth":11},{"id":38,"text":"with Jones potentially taking 50 percent of the vote","depth":11},{"id":39,"text":"and Moore 40 percent .","depth":11},{"id":40,"text":"Fox said","depth":10},{"id":41,"text":"8 percent of voters were undecided","depth":11},{"id":42,"text":"and 2 percent supported another candidate .","depth":11},{"id":43,"text":"An average of recent polls by the RealClearPolitics website showed Moore ahead by a slight margin of 2.2 percentage points .","depth":8},{"id":44,"text":"Trump taped a \" robo-call \"","depth":10},{"id":45,"text":"that the campaign has rolled out","depth":10},{"id":46,"text":"urging voters to back the Republican candidate","depth":10},{"id":47,"text":"in order to help support the president ' s agenda .","depth":10},{"id":48,"text":"Democrats also made robo-calls","depth":9},{"id":49,"text":"using two of their party ' s own big guns","depth":10},{"id":50,"text":"- former President Barack Obama and former Vice President Joe Biden .","depth":10},{"id":51,"text":"Jones has said","depth":9},{"id":52,"text":"he wanted to be a \" voice for reason \" for Alabama","depth":9},{"id":53,"text":"and has touted a record","depth":9},{"id":54,"text":"that includes prosecuting former Ku Klux Klan members responsible for the 1963 bombing of a black church in Birmingham","depth":10},{"id":55,"text":"in which four girls were killed .","depth":10},{"id":56,"text":"Jones has spent the past week rallying African-Americans , the most reliably Democratic voters in the state ,","depth":10},{"id":57,"text":"and hammering Moore in television ads .","depth":10},{"id":58,"text":"He has told supporters","depth":10},{"id":59,"text":"that his campaign is a chance","depth":11},{"id":60,"text":"to be on the \" right side of history for the state of Alabama . \"","depth":11},{"id":61,"text":"If Jones wins on Tuesday ,","depth":10},{"id":62,"text":"Republicans would control the Senate by a slim 51-49 margin ,","depth":10},{"id":63,"text":"giving Democrats much-needed momentum ahead of the November 2018 congressional elections ,","depth":10},{"id":64,"text":"when control of both chambers of Congress will be at stake .","depth":10},{"id":65,"text":"Moore ' s campaign has cast Jones as a liberal out of step with Alabama voters ,","depth":8},{"id":66,"text":"seizing on the Democrat ' s support of abortion rights .","depth":8},{"id":67,"text":"Many Republican officials in Alabama ,","depth":11},{"id":68,"text":"including Governor Kay Ivey ,","depth":11},{"id":69,"text":"say","depth":10},{"id":70,"text":"they will vote for Moore .","depth":9},{"id":71,"text":"But the state ' s senior Republican senator , Richard Shelby , said","depth":9},{"id":72,"text":"he did not vote for Moore","depth":11},{"id":73,"text":"and instead backed a write-in candidate on his absentee ballot ,","depth":11},{"id":74,"text":"telling CNN","depth":11},{"id":75,"text":"that Alabama \" deserves better \" than Moore .","depth":11},{"id":76,"text":"Moore ,","depth":10},{"id":77,"text":"who was twice removed from the state Supreme Court","depth":11},{"id":78,"text":"for refusing to abide by federal law ,","depth":11},{"id":79,"text":"may find a chilly reception in Washington","depth":10},{"id":80,"text":"if he wins .","depth":10},{"id":81,"text":"Republican leaders have said","depth":9},{"id":82,"text":"Moore could face an ethics investigation","depth":10},{"id":83,"text":"if Alabama voters send him to the U.S. Senate .","depth":10},{"id":84,"text":"Democrats have signaled","depth":8},{"id":85,"text":"they may use Moore ' s election","depth":9},{"id":86,"text":"to tar Republicans as insensitive to women ' s concerns at a time","depth":10},{"id":87,"text":"when allegations of sexual harassment have caused many prominent men","depth":12},{"id":88,"text":"working in politics , entertainment , media and business","depth":12},{"id":89,"text":"to lose their jobs .","depth":11}],"relations":[{"parent":179,"left":0,"right":178,"relation":"organization","nuclearity":"SN"},{"parent":178,"left":1,"right":177,"relation":"organization","nuclearity":"SN"},{"parent":177,"left":105,"right":176,"relation":"elaboration","nuclearity":"NS"},{"parent":105,"left":91,"right":104,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":2,"right":3,"relation":"context","nuclearity":"SN"},{"parent":104,"left":98,"right":103,"relation":"elaboration","nuclearity":"NS"},{"parent":98,"left":95,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":95,"left":4,"right":94,"relation":"adversative","nuclearity":"SN"},{"parent":94,"left":5,"right":93,"relation":"attribution","nuclearity":"SN"},{"parent":93,"left":6,"right":92,"relation":"explanation","nuclearity":"NS"},{"parent":92,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":97,"left":9,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":96,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":103,"left":99,"right":102,"relation":"joint","nuclearity":"NN"},{"parent":99,"left":12,"right":13,"relation":"attribution","nuclearity":"NS"},{"