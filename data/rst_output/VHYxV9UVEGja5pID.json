{"article_id":"VHYxV9UVEGja5pID","edus":[{"id":0,"text":"President Trump","depth":1},{"id":1,"text":"Donald John TrumpTrump faces high stakes","depth":6},{"id":2,"text":"in meeting with Erdoğan amid impeachment drama","depth":6},{"id":3,"text":"Democrats worry","depth":6},{"id":4,"text":"they do n't have right candidate","depth":7},{"id":5,"text":"to beat Trump","depth":7},{"id":6,"text":"Trump threatening to fire Mulvaney :","depth":5},{"id":7,"text":"report","depth":5},{"id":8,"text":"MORE declared in an interview","depth":7},{"id":9,"text":"aired Sunday","depth":7},{"id":10,"text":"that the European Union","depth":9},{"id":11,"text":"( EU )","depth":9},{"id":12,"text":"`` is a foe ''","depth":8},{"id":13,"text":"because of its economic policies .","depth":7},{"id":14,"text":"Asked by CBS News 's Jeff Glor what he considers his biggest foe globally ,","depth":7},{"id":15,"text":"Trump cited the EU and its trade practices","depth":8},{"id":16,"text":"before mentioning Russia and China .","depth":8},{"id":17,"text":"`` I think","depth":9},{"id":18,"text":"we have a lot of foes .","depth":9},{"id":19,"text":"I think","depth":10},{"id":20,"text":"the European Union is a foe ,","depth":11},{"id":21,"text":"what they do to us in trade .","depth":11},{"id":22,"text":"Now you would n't think of the European Union ,","depth":11},{"id":23,"text":"but they 're a foe , ''","depth":11},{"id":24,"text":"Trump said from his golf course in Scotland .","depth":10},{"id":25,"text":"`` Russia is foe in certain respects .","depth":8},{"id":26,"text":"China is a foe economically ,","depth":11},{"id":27,"text":"certainly they are a foe .","depth":11},{"id":28,"text":"But that does n't mean they are bad , ''","depth":11},{"id":29,"text":"he continued .","depth":11},{"id":30,"text":"`` It does n't mean anything .","depth":10},{"id":31,"text":"It means that they are competitive .","depth":11},{"id":32,"text":"They want to do well","depth":12},{"id":33,"text":"and we want to do well . ''","depth":12},{"id":34,"text":"Trump in recent months has antagonized longtime U.S. allies","depth":7},{"id":35,"text":"- targeting Canada , the European Union and the United Kingdom in interviews and trade policy .","depth":7},{"id":36,"text":"Trump has also railed against EU trade policies for months .","depth":7},{"id":37,"text":"His administration earlier this year implemented steep tariffs on imports from the EU ,","depth":8},{"id":38,"text":"prompting retaliatory measures from the European governing body .","depth":8},{"id":39,"text":"Trump on Sunday suggested","depth":9},{"id":40,"text":"it was difficult for him to take a harsh stance against the European Union","depth":10},{"id":41,"text":"because `` both my parents '' were born there .","depth":10},{"id":42,"text":"While his mother was born in Scotland ,","depth":10},{"id":43,"text":"his father , Frederick Trump , was born in New York .","depth":10},{"id":44,"text":"Trump 's paternal grandfather was born in Germany .","depth":9},{"id":45,"text":"`` You know","depth":12},{"id":46,"text":"I love those countries .","depth":13},{"id":47,"text":"I respect the leaders of those countries , ''","depth":13},{"id":48,"text":"Trump told CBS .","depth":11},{"id":49,"text":"`` But , in a trade sense , they 've really taken advantage of us ,","depth":11},{"id":50,"text":"and many of those countries are in NATO","depth":12},{"id":51,"text":"and they were n't paying their bills . ''","depth":12},{"id":52,"text":"NATO members do not pay bills to the organization or to any one country .","depth":9},{"id":53,"text":"Instead , they are responsible","depth":9},{"id":54,"text":"for allocating a certain amount of their budget toward defense spending .","depth":9},{"id":55,"text":"Countries have agreed to spend 2 percent of their respective gross domestic product by 2024 .","depth":7},{"id":56,"text":"However , Trump upended that agreement during last week 's summit ,","depth":8},{"id":57,"text":"first saying","depth":11},{"id":58,"text":"that countries should increase the goal to 4 percent .","depth":11},{"id":59,"text":"Not even the U.S. currently meets that percentage .","depth":10},{"id":60,"text":"He later demanded","depth":10},{"id":61,"text":"that NATO members meet the 2 percent threshold `` immediately ''","depth":11},{"id":62,"text":"rather than gradually raise their contributions .","depth":11},{"id":63,"text":"The president has raised eyebrows in recent weeks","depth":3},{"id":64,"text":"as he ratchets up attacks on European allies ,","depth":4},{"id":65,"text":"while showing reluctance","depth":5},{"id":66,"text":"to criticize Russian President Vladimir Putin ,","depth":6},{"id":67,"text":"whom he is scheduled to meet on Monday .","depth":6}],"relations":[{"parent":135,"left":0,"right":134,"relation":"organization","nuclearity":"SN"},{"parent":134,"left":129,"right":133,"relation":"context","nuclearity":"NS"},{"parent":129,"left":74,"right":128,"relation":"organization","nuclearity":"SN"},{"parent":74,"left":72,"right":73,"relation":"adversative","nuclearity":"SN"},{"parent":72,"left":69,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":3,"right":70,"relation":"attribution","nuclearity":"SN"},{"parent":70,"left":4,"right":5,"relation":"purpose","nuclearity":"NS"},{"parent":73,"left":6,"right":7,"relation":"attribution","nuclearity":"NS"},{"parent":128,"left":99,"right":127,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":79,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":75,"right":78,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":77,"right":13,"relation":"explanation","nuclearity":"NS"},{"parent":77,"left":76,"right":12,"relation":"same-unit","nuclearity":"NN"},{"parent":76,"left":10,"right":11,"relation":"restatement","nuclearity":"NS"},{"parent":9