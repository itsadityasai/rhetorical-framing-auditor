{"article_id":"RDRu1nH9nMwIT4Xf","edus":[{"id":0,"text":"The Trump administration has refused to respond to a request from Congress","depth":8},{"id":1,"text":"to provide a report","depth":9},{"id":2,"text":"determining who killed the Saudi journalist Jamal Khashoggi .","depth":9},{"id":3,"text":"Senators wrote in October","depth":8},{"id":4,"text":"demanding","depth":9},{"id":5,"text":"the murder be investigated","depth":10},{"id":6,"text":"and that the White House give more information .","depth":10},{"id":7,"text":"An administration official said","depth":7},{"id":8,"text":"the president was within his rights","depth":8},{"id":9,"text":"to decline to act .","depth":8},{"id":10,"text":"Khashoggi was killed","depth":8},{"id":11,"text":"after entering the Saudi consulate in Istanbul in October last year .","depth":8},{"id":12,"text":"He was a strong critic of the Saudi government .","depth":7},{"id":13,"text":"His body was reportedly dismembered","depth":7},{"id":14,"text":"and has still not been found .","depth":7},{"id":15,"text":"US intelligence officials have reportedly said","depth":7},{"id":16,"text":"such an operation would have needed the approval of Crown Prince Mohammed bin Salman .","depth":7},{"id":17,"text":"And on Saturday Baroness Helena Kennedy , member of a UN team of international experts","depth":10},{"id":18,"text":"who visited Turkey","depth":11},{"id":19,"text":"to investigate the murder ,","depth":11},{"id":20,"text":"told the BBC","depth":9},{"id":21,"text":"the murder was planned at the highest level .","depth":8},{"id":22,"text":"But Saudi officials insist","depth":8},{"id":23,"text":"he was murdered by a `` rogue '' team of Saudi agents","depth":9},{"id":24,"text":"not acting on the prince 's orders .","depth":9},{"id":25,"text":"An administration statement said","depth":7},{"id":26,"text":"Mr Trump `` maintains his discretion","depth":8},{"id":27,"text":"to decline to act on congressional committee requests","depth":9},{"id":28,"text":"when appropriate '' .","depth":9},{"id":29,"text":"However , Democratic senators told the New York Times","depth":8},{"id":30,"text":"the president was in breach of the so-called Magnitsky Act ,","depth":9},{"id":31,"text":"which requires a response within 120 days to requests from Senate committee leaders .","depth":9},{"id":32,"text":"That deadline passed on Friday .","depth":7},{"id":33,"text":"Please upgrade your browser","depth":4},{"id":34,"text":"to view this content .","depth":4},{"id":35,"text":"Timeline :","depth":4},{"id":36,"text":"Jamal Khashoggi 's death hide","depth":4},{"id":37,"text":"How the story unfolded","depth":6},{"id":38,"text":"What happened next ?","depth":6},{"id":39,"text":"Show all","depth":5},{"id":40,"text":"Was this timeline useful ?","depth":6},{"id":41,"text":"Yes No","depth":6},{"id":42,"text":"Thank you for your feedback .","depth":6},{"id":43,"text":"Share this chatbot .","depth":6},{"id":44,"text":"Secretary of State Mike Pompeo has written to Senate leaders","depth":4},{"id":45,"text":"describing actions","depth":5},{"id":46,"text":"taken against individuals .","depth":5},{"id":47,"text":"However , the documents do not indicate","depth":5},{"id":48,"text":"who was responsible for Khashoggi 's death ,","depth":6},{"id":49,"text":"as demanded by the senators .","depth":6},{"id":50,"text":"The US has imposed sanctions on 17 Saudi officials ,","depth":5},{"id":51,"text":"including Saud al-Qahtani , a former adviser to the crown prince","depth":6},{"id":52,"text":"who ,","depth":8},{"id":53,"text":"it alleged ,","depth":8},{"id":54,"text":"was `` part of the planning and execution of the operation ''","depth":8},{"id":55,"text":"that led to Khashoggi 's murder .","depth":8},{"id":56,"text":"But Mr Trump has faced criticism from senators","depth":3},{"id":57,"text":"for failing to condemn the crown prince directly .","depth":3}],"relations":[{"parent":115,"left":101,"right":114,"relation":"joint","nuclearity":"NN"},{"parent":101,"left"