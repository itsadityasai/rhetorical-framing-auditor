{"article_id":"KahnvD6c91igQEBM","edus":[{"id":0,"text":"CHARLESTON , S.C.","depth":1},{"id":1,"text":"( ) -","depth":2},{"id":2,"text":"The white former policeman","depth":9},{"id":3,"text":"caught on video shooting an unarmed black man in the back","depth":10},{"id":4,"text":"after a 2015 traffic stop in South Carolina","depth":10},{"id":5,"text":"was sentenced on Thursday to 20 years in prison ,","depth":8},{"id":6,"text":"with a federal judge ruling","depth":8},{"id":7,"text":"that the killing amounted to murder .","depth":8},{"id":8,"text":"The decision came","depth":7},{"id":9,"text":"a year after Michael Slager ' s state murder trial for the death of 50-year-old Walter Scott ended with a deadlocked jury .","depth":7},{"id":10,"text":"Slager , 36 , is one of the few police officers in recent years in the United States","depth":6},{"id":11,"text":"to receive prison time for an on-duty shooting .","depth":6},{"id":12,"text":"\" Everyone recognizes","depth":7},{"id":13,"text":"that this was a tragedy , \"","depth":7},{"id":14,"text":"U.S. District Judge David Norton told a Charleston courtroom","depth":7},{"id":15,"text":"packed with members of both men ' s families .","depth":7},{"id":16,"text":"\" What ' s just for the Scott family is not necessarily just for the Slager family ,","depth":8},{"id":17,"text":"and what ' s just for the Slager family is not necessarily just for the Scott family , \"","depth":8},{"id":18,"text":"he said .","depth":7},{"id":19,"text":"\" It ' s a zero-sum game . \"","depth":6},{"id":20,"text":"Slager was a patrolman in North Charleston","depth":7},{"id":21,"text":"when he pulled over Scott , a father of four , for a broken brake light on April 4 , 2015 .","depth":7},{"id":22,"text":"He said","depth":7},{"id":23,"text":"he opened fire","depth":8},{"id":24,"text":"because he felt threatened","depth":9},{"id":25,"text":"after the motorist tried to take his stun gun during a struggle .","depth":9},{"id":26,"text":"Yet he pleaded guilty in May to violating Scott ' s civil rights","depth":8},{"id":27,"text":"by using excessive force , a charge","depth":9},{"id":28,"text":"that carried a possible lifetime prison sentence .","depth":9},{"id":29,"text":"Slager shot at Scott eight times ,","depth":9},{"id":30,"text":"hitting him five times .","depth":9},{"id":31,"text":"State prosecutors dropped the murder charge in exchange for the federal plea .","depth":8},{"id":32,"text":"\" I wish","depth":9},{"id":33,"text":"this never would have happened , \"","depth":9},{"id":34,"text":"said Slager ,","depth":9},{"id":35,"text":"jailed since his plea","depth":10},{"id":36,"text":"and dressed in an inmate ' s gray and white jumpsuit .","depth":10},{"id":37,"text":"\" I wish","depth":9},{"id":38,"text":"I could go back","depth":10},{"id":39,"text":"and change events ,","depth":10},{"id":40,"text":"but I can ' t","depth":9},{"id":41,"text":"and I am very sorry for that . \"","depth":9},{"id":42,"text":"A bystander ' s cellphone video of the shooting drew national attention to the case ,","depth":8},{"id":43,"text":"renewing concerns about police treatment of minorities .","depth":8},{"id":44,"text":"The footage was a centerpiece of the four-day sentence hearing ,","depth":8},{"id":45,"text":"with both prosecutors and defense lawyers arguing","depth":9},{"id":46,"text":"it bolstered their cases .","depth":9},{"id":47,"text":"Norton sided with the government ,","depth":9},{"id":48,"text":"finding","depth":10},{"id":49,"text":"that Slager had committed second-degree murder","depth":11},{"id":50,"text":"and obstructed justice","depth":12},{"id":51,"text":"by lying to investigators","depth":13},{"id":52,"text":"about Scott","depth":14},{"id":53,"text":"trying to grab his Taser .","depth":14},{"id":54,"text":"The judge rejected the defense argument","depth":9},{"id":55,"text":"that Slager was provoked or acted in the heat of passion .","depth":9},{"id":56,"text":"Scott ' s relatives and their lawyers said","depth":9},{"id":57,"text":"the punishment marked a historic moment for justice .","depth":9},{"id":58,"text":"They called on law enforcement to rethink the use of deadly force .","depth":8},{"id":59,"text":"Before court ended ,","depth":7},{"id":60,"text":"several family members told Slager","depth":8},{"id":61,"text":"they had forgiven him .","depth":8},{"id":62,"text":"But their pain has not diminished .","depth":7},{"id":63,"text":"\" We will never be the same again , \"","depth":9},{"id":64,"text":"said Anthony Scott , the motorist ' s older brother .","depth":9},{"id":65,"text":"\" How could someone shoot someone in the back like that","depth":9},{"id":66,"text":"as they were running away ? \"","depth":9}],"relations":[{"parent":133,"left":0,"right":132,"relation":"organization","nuclearity":"SN"},{"parent":132,"left":1,"right":131,"relation":"organization","nuclearity":"SN"},{"parent":131,"left":84,"right":130,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":76,"right":83,"relation":"evaluation","nuclearity":"NS"},{"parent":76,"left":74,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":72,"right":73,"relation":"context","nuclearity":"NS"},{"parent":72,"left":70,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":69,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":69,"left":2,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":3,"right":4,"relation":"context","nuclearity":"NS"},{"parent":71,"left":6,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":73,"left":8,"right":9,"relation":"context","nuclearity":"NS"},{"parent":75,"left":10,"right":11,"relation":"purpose","nuclearity":"NS"},{"parent":83,"left":79,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":77,"right":78,"relation":"attribution","nuclearity":"NS"},{"parent":77,"left":12,"right":13,"relation":"attribution","nuclearity":"SN"},{"parent":78,"left":14,"right":15,"relation":"elabora