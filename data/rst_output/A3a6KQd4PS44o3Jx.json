ight":307,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":305,"right":132,"relation":"attribution","nuclearity":"SN"},{"parent":305,"left":130,"right":131,"relation":"attribution","nuclearity":"SN"},{"parent":307,"left":133,"right":134,"relation":"evaluation","nuclearity":"NS"},{"parent":337,"left":332,"right":336,"relation":"elaboration","nuclearity":"NS"},{"parent":332,"left":331,"right":156,"relation":"elaboration","nuclearity":"NS"},{"parent":331,"left":319,"right":330,"relation":"joint","nuclearity":"NN"},{"parent":319,"left":314,"right":318,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":313,"right":138,"relation":"context","nuclearity":"NS"},{"parent":313,"left":312,"right":137,"relation":"same-unit","nuclearity":"NN"},{"parent":312,"left":135,"right":136,"relation":"elaboration","nuclearity":"NS"},{"parent":318,"left":316,"right":317,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":315,"right":141,"relation":"attribution","nuclearity":"NS"},{"parent":315,"left":139,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":317,"left":142,"right":143,"relation":"elaboration","nuclearity":"NS"},{"parent":330,"left":326,"right":329,"relation":"elaboration","nuclearity":"NS"},{"parent":326,"left":321,"right":325,"relation":"elaboration","nuclearity":"NS"},{"parent":321,"left":144,"right":320,"relation":"attribution","nuclearity":"SN"},{"parent":320,"left":145,"right":146,"relation":"purpose","nuclearity":"NS"},{"parent":325,"left":147,"right":324,"relation":"attribution","nuclearity":"SN"},{"parent":324,"left":148,"right":323,"relation":"causal","nuclearity":"SN"},{"parent":323,"left":322,"right":151,"relation":"same-unit","nuclearity":"NN"},{"parent":322,"left":149,"right":150,"relation":"purpose","nuclearity":"NS"},{"parent":329,"left":328,"right":155,"relation":"attribution","nuclearity":"NS"},{"parent":328,"left":327,"right":154,"relation":"context","nuclearity":"SN"},{"parent":327,"left":152,"right":1