tion","nuclearity":"NS"},{"parent":326,"left":161,"right":162,"relation":"elaboration","nuclearity":"NS"},{"parent":334,"left":332,"right":333,"relation":"elaboration","nuclearity":"NS"},{"parent":332,"left":165,"right":166,"relation":"context","nuclearity":"NS"},{"parent":333,"left":167,"right":168,"relation":"attribution","nuclearity":"SN"}]}