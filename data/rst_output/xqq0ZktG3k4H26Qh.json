{"article_id":"xqq0ZktG3k4H26Qh","edus":[{"id":0,"text":"As negotiators work over the weekend","depth":6},{"id":1,"text":"to resolve Washington ' s budget and debt deadlocks ,","depth":6},{"id":2,"text":"President Obama said Saturday","depth":6},{"id":3,"text":"that he ' s hopeful to end \" the pain of this Republican shutdown \" soon .","depth":6},{"id":4,"text":"In his weekly address , Mr. Obama said","depth":5},{"id":5,"text":"it was a \" positive development \" that House Republicans have offered to raise the nation ' s borrowing limit for six weeks .","depth":5},{"id":6,"text":"\" Once the debt ceiling is raised ,","depth":7},{"id":7,"text":"and the shutdown is over ,","depth":7},{"id":8,"text":"there ' s a lot","depth":7},{"id":9,"text":"we can accomplish together , \"","depth":7},{"id":10,"text":"Mr. Obama said .","depth":5},{"id":11,"text":"\" Manufacturing crises","depth":7},{"id":12,"text":"to extract massive concessions","depth":7},{"id":13,"text":"isn ' t how our democracy works ,","depth":6},{"id":14,"text":"and we have to stop it . \"","depth":5},{"id":15,"text":"The administration says","depth":3},{"id":16,"text":"the government will run out of authority","depth":5},{"id":17,"text":"to pay its bills","depth":5},{"id":18,"text":"unless Congress agrees to raise the debt limit by Thursday .","depth":4},{"id":19,"text":"The House and Senate were working Saturday on differing proposals","depth":5},{"id":20,"text":"to raise the debt ceiling","depth":6},{"id":21,"text":"and reopen the government ,","depth":7},{"id":22,"text":"which has been shut down for 12 days .","depth":7},{"id":23,"text":"House Republicans have offered the administration a proposal","depth":6},{"id":24,"text":"that would set up budget talks","depth":6},{"id":25,"text":"and ,","depth":6},{"id":26,"text":"although Mr. Obama hasn ' t accepted it ,","depth":7},{"id":27,"text":"both sides are still talking .","depth":7},{"id":28,"text":"Speaker John A. Boehner was holding a session with GOP lawmakers Saturday","depth":4},{"id":29,"text":"to update them on the status of negotiations .","depth":4},{"id":30,"text":"SEE ALSO :","depth":4},{"id":31,"text":"Shutdown escape :","depth":5},{"id":32,"text":"Bidens retreat to Camp David for three-day holiday weekend","depth":5},{"id":33,"text":"Senate Democrats are considering a plan","depth":7},{"id":34,"text":"that would extend the borrowing limit through the 2014 elections .","depth":7},{"id":35,"text":"Senate Republicans , meanwhile , are working on a proposal","depth":7},{"id":36,"text":"that would increase the borrowing limit until January ,","depth":8},{"id":37,"text":"end the government shutdown","depth":9},{"id":38,"text":"and delay Obamacare ' s tax on medical devices .","depth":9},{"id":39,"text":"Republicans said","depth":7},{"id":40,"text":"Mr. Obama is seeking increased revenue as part of the negotiations ;","depth":7},{"id":41,"text":"the president said in his weekly address","depth":7},{"id":42,"text":"that he wants to cut budget deficits \" in a smarter , balanced way","depth":8},{"id":43,"text":"that lets us afford to invest in the things","depth":9},{"id":44,"text":"we need to grow . \"","depth":9},{"id":45,"text":"As talks continue ,","depth":6},{"id":46,"text":"House Armed Services Chairman Howard \" Buck \" McKeon , California Republican , urged the president to sign interim measures","depth":7},{"id":47,"text":"approved by the House","depth":8},{"id":48,"text":"to reopen some government services ,","depth":9},{"id":49,"text":"including national parks .","depth":9},{"id":50,"text":"\" The House has passed more than a dozen bills","depth":9},{"id":51,"text":"providing funding for things","depth":11},{"id":52,"text":"we can all agree on","depth":11},{"id":53,"text":"- veterans , cancer research , National Guard , national parks , Head Start , food safety , flight safety , border security , nuclear weapon security , and more , \"","depth":10},{"id":54,"text":"Mr. McKeon said in the Republicans ' weekly address .","depth":8},{"id":55,"text":"\" President Obama and Senate Democrats should back these bills immediately . \"","depth":7},{"id":56,"text":"After that ,","depth":8},{"id":57,"text":"Mr. McKeon said ,","depth":8},{"id":58,"text":"\" The president should work with us on plans","depth":9},{"id":59,"text":"to reopen the entire government","depth":9},{"id":60,"text":"and make sure","depth":9},{"id":61,"text":"we do not default on our debts . \"","depth":9}],"relations":[{"parent":123,"left":80,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":76,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":67,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":65,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":63,"right":64,"relation":"context","nuclearity":"SN"},{"parent":63,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":64,"left":2,"right":3,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":4,"right":5,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":71,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":70,"right":10,"relation":"attribution","nuclearity":"NS"},{"parent":70,"left":68,"right":69,"relation":"context","nuclearity":"SN"},{"parent":68,"left":6,"right":7,"relation":"joint","nuclearity":"NN"},{"parent":69,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":73,"right":14,"relation":"joint","nuclearity":"NN"},{"parent":73,"left":72,"right":13,"relation":"same-unit","nuclearity":"NN"},{"parent":72,"left":11,"right":12,"relation":"purpose","nuclearity":"NS"},{"parent":79,"left":15,"right":78,"relation":"attribution","nuclearity":"SN"},{"parent":78,"left":77,"right":18,"relation":"condition","nuclearity":"NS"},{"parent":77,"left":16,"right":17,"relation":"purpose","nuclearity":"NS"},{"parent":122,"left":90,"right":121,"relation":"joint","nuclearity":"NN"},{