ft":138,"right":300,"relation":"attribution","nuclearity":"SN"},{"parent":300,"left":139,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":304,"right":305,"relation":"adversative","nuclearity":"NN"},{"parent":304,"left":141,"right":142,"relation":"attribution","nuclearity":"SN"},{"parent":305,"left":143,"right":144,"relation":"attribution","nuclearity":"SN"},{"parent":310,"left":309,"right":148,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":308,"right":147,"relation":"same-unit","nuclearity":"NN"},{"parent":308,"left":145,"right":146,"relation":"adversative","nuclearity":"NS"},{"parent":338,"left":149,"right":337,"relation":"organization","nuclearity":"SN"},{"parent":337,"left":324,"right":336,"relation":"elaboration","nuclearity":"NS"},{"parent":324,"left":319,"right":323,"relation":"adversative","nuclearity":"SN"},{"parent":319,"left":318,"right":152,"relation":"elaboration","nuclearity":"NS"},{"parent":318,"left":150,"right":151,"relation":"elaboration","nuclearity":"NS"},{"parent":323,"left":321,"right":322,"relation":"causal","nuclearity":"NS"},{"parent":321,"left":153,"right":320,"relation":"elaboration","nuclearity":"NS"},{"parent":320,"left":154,"right":155,"relation":"purpose","nuclearity":"NS"},{"parent":322,"left":156,"right":157,"relation":"mode","nuclearity":"NS"},{"parent":336,"left":330,"right":335,"relation":"joint","nuclearity":"NN"},{"parent":330,"left":158,"right":329,"relation":"elaboration","nuclearity":"NS"},{"parent":329,"left":326,"right":328,"relation":"adversative","nuclearity":"NS"},{"parent":326,"left":325,"right":161,"relation":"joint","nuclearity":"NN"},{"parent":325,"left":159,"right":160,"relation":"purpose","nuclearity":"NS"},{"parent":328,"left":327,"right":164,"relation":"joint","nuclearity":"NN"},{"parent":327,"left":162,"right":163,"relation":"attribution","nuclearity":"SN"},{"parent":335,"left":332,"right":334,"relation":"evaluation","nuclearity":"NS"},{"parent":332,"left":165,"right"