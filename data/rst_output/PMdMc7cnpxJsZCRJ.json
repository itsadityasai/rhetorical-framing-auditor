"},{"parent":343,"left":164,"right":342,"relation":"attribution","nuclearity":"SN"},{"parent":342,"left":165,"right":341,"relation":"elaboration","nuclearity":"NS"},{"parent":341,"left":339,"right":340,"relation":"elaboration","nuclearity":"NS"},{"parent":339,"left":338,"right":172,"relation":"attribution","nuclearity":"NS"},{"parent":338,"left":334,"right":337,"relation":"same-unit","nuclearity":"NN"},{"parent":334,"left":166,"right":167,"relation":"attribution","nuclearity":"NS"},{"parent":337,"left":336,"right":171,"relation":"same-unit","nuclearity":"NN"},{"parent":336,"left":168,"right":335,"relation":"elaboration","nuclearity":"NS"},{"parent":335,"left":169,"right":170,"relation":"elaboration","nuclearity":"NS"},{"parent":340,"left":173,"right":174,"relation":"adversative","nuclearity":"NS"}]}