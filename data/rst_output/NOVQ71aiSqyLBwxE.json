{"article_id":"NOVQ71aiSqyLBwxE","edus":[{"id":0,"text":"The White House celebrated another strong jobs report Friday ,","depth":4},{"id":1,"text":"saying","depth":5},{"id":2,"text":"the 18-year-low in the jobless rate is further proof","depth":6},{"id":3,"text":"that President Trump ' s economic policies are working .","depth":6},{"id":4,"text":"\" We ' ve reached yet one more historic milestone , \"","depth":4},{"id":5,"text":"Mr. Trump said .","depth":4},{"id":6,"text":"Vice President Mike Pence tweeted ,","depth":4},{"id":7,"text":"\" Jobs ! Jobs ! Jobs !","depth":5},{"id":8,"text":"Once again , the economy is growing jobs under @ POTUS Trump . \"","depth":5},{"id":9,"text":"Mr. Pence noted","depth":5},{"id":10,"text":"that employers added 223,000 new jobs in May ,","depth":6},{"id":11,"text":"making it \" 3,405,000 jobs since Election Day . \"","depth":6},{"id":12,"text":"The vice president also noted","depth":7},{"id":13,"text":"that May ' s 3.8 percent unemployment rate was the lowest since April 2000 .","depth":8},{"id":14,"text":"\" And hasn ' t been lower since 1969 , \"","depth":9},{"id":15,"text":"Mr. Pence tweeted .","depth":9},{"id":16,"text":"\" HISTORIC !","depth":6},{"id":17,"text":"The Trump administration will keep fighting","depth":6},{"id":18,"text":"to create even more jobs for the American people ! \"","depth":6},{"id":19,"text":"The strong hiring in May easily beat Wall Street ' s expectations ,","depth":5},{"id":20,"text":"as the unemployment rate fell from 3.9 percent in April .","depth":5},{"id":21,"text":"Stocks rose about 1 percent in early trading Friday on the stronger-than-expected jobs report .","depth":4},{"id":22,"text":"Construction spending also was 6.6 percent higher than the same period last year ,","depth":6},{"id":23,"text":"the Commerce Department reported Friday .","depth":6},{"id":24,"text":"The unemployment rate for blacks fell to 5.9 percent in May ,","depth":6},{"id":25,"text":"reaching the lowest level since 1972 ,","depth":7},{"id":26,"text":"when the government started to record that data .","depth":7},{"id":27,"text":"The White House said","depth":6},{"id":28,"text":"job growth in manufacturing , construction , and mining and logging \" have been especially robust . \"","depth":6},{"id":29,"text":"\" After averaging gains of 27,000 jobs per month during President Obama ' s second term ,","depth":7},{"id":30,"text":"these industries have almost doubled the pace","depth":8},{"id":31,"text":"of hiring to 46,000 jobs per month since January 2017 , \"","depth":8},{"id":32,"text":"the White House said .","depth":6},{"id":33,"text":"Jobs ! Jobs ! Jobs !","depth":7},{"id":34,"text":"Once again , the economy is growing jobs under @ POTUS Trump .","depth":7},{"id":35,"text":"223,000 new jobs in May and 3,405,000 since Election Day .","depth":7},{"id":36,"text":"America is making a comeback .","depth":7},{"id":37,"text":"https : //t.co/ClglV3bBx","depth":5},{"id":38,"text":"8 - Vice President Mike Pence","depth":6},{"id":39,"text":"( @ VP )","depth":6},{"id":40,"text":"June 1 , 2018","depth":5},{"id":41,"text":"At 3.8 % , the unemployment rate has fallen to its lowest point since April 2000 .","depth":6},{"id":42,"text":"And hasn ' t been lower since 1969 .","depth":6},{"id":43,"text":"HISTORIC !","depth":5},{"id":44,"text":"The Trump administration will keep fighting","depth":6},{"id":45,"text":"to create even more jobs for the American people !","depth":6},{"id":46,"text":"https : //t.co/jcP63968cD - Vice President Mike Pence","depth":7},{"id":47,"text":"( @ VP )","depth":7},{"id":48,"text":"June 1 , 2018","depth":6}],"relations":[{"parent":97,"left":67,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":54,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":54,"left":52,"right":53,"relation":"elaboration","nuclearity":"NS"},{"parent":52,"left":0,"right":51,"relation":"elaboration","nuclearity":"NS"},{"parent":51,"left":1,"right":50,"relation":"attri