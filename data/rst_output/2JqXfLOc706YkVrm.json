{"article_id":"2JqXfLOc706YkVrm","edus":[{"id":0,"text":"WASHINGTON --","depth":1},{"id":1,"text":"President Donald Trump is moving forward with one of his most controversial campaign promises","depth":6},{"id":2,"text":"-- building a wall on the U.S.-Mexican border .","depth":6},{"id":3,"text":"He signed two executive orders Wednesday","depth":7},{"id":4,"text":"while attending a ceremony at the Department of Homeland Security .","depth":8},{"id":5,"text":"It was held in honor of retired Gen. John Kelly , the newly confirmed secretary of the department .","depth":8},{"id":6,"text":"The executive orders give a boost to the construction of the wall","depth":7},{"id":7,"text":"and also take away funds for so-called sanctuary cities .","depth":8},{"id":8,"text":"Those are places","depth":9},{"id":9,"text":"where authorities do not take into custody illegal immigrants .","depth":9},{"id":10,"text":"The president announced the news earlier on his personal Twitter account ,","depth":5},{"id":11,"text":"saying ,","depth":7},{"id":12,"text":"`` We will build the wall .","depth":7},{"id":13,"text":"The plan :","depth":7},{"id":14,"text":"a measure","depth":8},{"id":15,"text":"to jumpstart construction . ''","depth":8},{"id":16,"text":"Trump is expected to take decisive action on immigration ,","depth":5},{"id":17,"text":"including a four-month halt on all refugee admissions and a shorter ban on people","depth":6},{"id":18,"text":"coming from Muslim majority countries .","depth":6},{"id":19,"text":"The news comes","depth":5},{"id":20,"text":"as the administration continues to defend the president 's belief","depth":7},{"id":21,"text":"that millions of illegal votes were cast in November .","depth":7},{"id":22,"text":"`` I think","depth":8},{"id":23,"text":"he 's stated his concerns of voter fraud and people","depth":10},{"id":24,"text":"voting illegally during the campaign","depth":10},{"id":25,"text":"and he continues to maintain that belief","depth":10},{"id":26,"text":"based on studies and evidence","depth":11},{"id":27,"text":"that people have presented to him , ''","depth":11},{"id":28,"text":"White House press secretary Sean Spicer told reporters .","depth":7},{"id":29,"text":"The president is also moving ahead on the economy .","depth":5},{"id":30,"text":"On Tuesday , he met with the heads of the big three U.S. car companies and other automobile leaders ,","depth":7},{"id":31,"text":"promising to streamline the environmental permitting process","depth":8},{"id":32,"text":"and make the United States business friendly .","depth":8},{"id":33,"text":"`` We are bringing manufacturing back to the United States big league .","depth":8},{"id":34,"text":"We are reducing taxes very substantially","depth":9},{"id":35,"text":"and we are reducing unnecessary regulations , ''","depth":9},{"id":36,"text":"Trump promised .","depth":7},{"id":37,"text":"In another move","depth":6},{"id":38,"text":"aimed at strengthening the economy ,","depth":6},{"id":39,"text":"Trump signed executive orders","depth":6},{"id":40,"text":"to move forward with construction of the Keystone XL and Dakota Access pipelines .","depth":6},{"id":41,"text":"Trump says","depth":6},{"id":42,"text":"that he 'll soon announce perhaps his most important nominee :","depth":7},{"id":43,"text":"his choice for a new justice on the Supreme Court","depth":8},{"id":44,"text":"to replace the late Antonin Scalia .","depth":8},{"id":45,"text":"`` We have outstanding candidates","depth":7},{"id":46,"text":"and we will pick a truly great Supreme Court Justice , ''","depth":7},{"id":47,"text":"Trump stated .","depth":6},{"id":48,"text":"The leading candidates are three federal judges","depth":6},{"id":49,"text":"who are all strong conservatives .","depth":6},{"id":50,"text":"A top contender right now is Neil Gorsuch ,","depth":7},{"id":51,"text":"who is known as a judge in the mold of Scalia ,","depth":8},{"id":52,"text":"interpreting the Constitution and laws","depth":9},{"id":53,"text":"based on their original meaning .","depth":9},{"id":54,"text":"Also on the short list is William Pryor ,","depth":8},{"id":55,"text":"who once called the Roe vs. Wade decision","depth":10},{"id":56,"text":"legalizing abortion","depth":10},{"id":57,"text":"an `` abomination . ''","depth":9},{"id":58,"text":"Finally , there 's Thomas Hardiman ,","depth":8},{"id":59,"text":"known for his support of gun rights .","depth":8}],"relations":[{"parent":119,"left":0,"right":118,"relation":"organization","nuclearity":"SN"},{"parent":118,"left":87,"right":117,"relation":"joint","nuclearity":"NN"},{"parent":87,"left":74,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":68,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":61,"right":67,"relation":"elaboration","nuclearity":"NS"},{"parent":61,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":63,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":3,"right":62,"relation":"context","nuclearity":"NS"},{"parent":62,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":6,"right":65,"relation":"joint","nuclearity":"NN"},{"parent":65,"left":7,"right":64,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":10,"right":72,"relation":"attribution","nuclearity":"SN"},{"parent":72,"left":69,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":11,"right":12,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":13,"right":70,"relation":"organization","nuclearity":"SN"},{"parent":70,"left":14,"right":15,"relation":"purpose","nuclearity":"NS"},{"parent":86,"left":76,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":16,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":17,"right":18,"relation":"elaboration","nuclearity":"NS"},{"parent":85,"left":19,"right