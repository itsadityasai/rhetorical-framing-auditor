{"article_id":"K2TmpX7etEkDPGEX","edus":[{"id":0,"text":"Story highlights","depth":4},{"id":1,"text":"Snowden is safe","depth":7},{"id":2,"text":"and `` possibly simply relaxing , ''","depth":7},{"id":3,"text":"WikiLeaks spokesman says","depth":7},{"id":4,"text":"Venezuela has n't gotten asylum request","depth":8},{"id":5,"text":"but would consider it ,","depth":8},{"id":6,"text":"leader says","depth":5},{"id":7,"text":"Vladimir Putin says","depth":8},{"id":8,"text":"Russia wo n't hand Snowden over to U.S. authorities","depth":8},{"id":9,"text":"U.S. is asking for help","depth":8},{"id":10,"text":"in detaining former NSA contractor","depth":9},{"id":11,"text":"accused of spilling secrets","depth":9},{"id":12,"text":"Edward Snowden , the former National Security Agency contractor","depth":11},{"id":13,"text":"who spilled U.S. surveillance secrets to the world ,","depth":11},{"id":14,"text":"is a `` free man ''","depth":11},{"id":15,"text":"biding his time in a Moscow airport ,","depth":11},{"id":16,"text":"Russian President Vladimir Putin told reporters Tuesday .","depth":9},{"id":17,"text":"Putin said","depth":9},{"id":18,"text":"Snowden","depth":11},{"id":19,"text":"-- who flew to Moscow from Hong Kong on Sunday --","depth":11},{"id":20,"text":"is in the `` transit area '' of Sheremetyevo International Airport , the zone between arrival gates and Russia 's passport control checkpoints .","depth":10},{"id":21,"text":"While he said","depth":10},{"id":22,"text":"Russia wo n't hand Snowden over to the United States ,","depth":10},{"id":23,"text":"he seemed eager to have the focus of international intrigue off his hands .","depth":9},{"id":24,"text":"`` The sooner he selects his final destination point ,","depth":10},{"id":25,"text":"the better both for us and for himself , ''","depth":10},{"id":26,"text":"Putin said from Finland of Snowden ,","depth":10},{"id":27,"text":"who is wanted by U.S. officials on espionage charges","depth":11},{"id":28,"text":"for disclosing classified details of U.S. surveillance programs .","depth":11},{"id":29,"text":"Putin 's comments end , for now at least , the international pastime of `` Where 's Snowden ? ''","depth":7},{"id":30,"text":"There have been rumors for days","depth":8},{"id":31,"text":"that the former NSA contractor had perhaps duped the world","depth":10},{"id":32,"text":"into thinking","depth":11},{"id":33,"text":"he was in Moscow","depth":12},{"id":34,"text":"to throw pursuers off his trail","depth":12},{"id":35,"text":"as he seeks a safe haven from U.S. prosecution .","depth":9},{"id":36,"text":"Kristinn Hrafnsson","depth":9},{"id":37,"text":"-- a spokesman for WikiLeaks , an organization","depth":10},{"id":38,"text":"that facilitates the anonymous leaking of secret information","depth":11},{"id":39,"text":"and has one of its members with Snowden in Russia --","depth":11},{"id":40,"text":"told CNN 's Wolf Blitzer on Tuesday only","depth":8},{"id":41,"text":"that Snowden `` is in a safe place","depth":8},{"id":42,"text":"and is comfortable","depth":9},{"id":43,"text":"and possibly simply relaxing after a very stressful week . ''","depth":9},{"id":44,"text":"JUST WATCHED Hunting for Edward Snowden","depth":8},{"id":45,"text":"Replay More Videos ...","depth":8},{"id":46,"text":"MUST WATCH Hunting for Edward Snowden","depth":7},{"id":47,"text":"02:08","depth":6},{"id":48,"text":"JUST WATCHED Snowden 's global game of hide and seek","depth":8},{"id":49,"text":"Replay More Videos ...","depth":8},{"id":50,"text":"MUST WATCH Snowden 's global game of hide and seek 00:10","depth":7},{"id":51,"text":"JUST WATCHED","depth":12},{"id":52,"text":"Schumer :","depth":13},{"id":53,"text":"Putin aided ,","depth":14},{"id":54,"text":"abetted Snowden","depth":14},{"id":55,"text":"Replay More Videos ...","depth":11},{"id":56,"text":"MUST WATCH Schumer :","depth":11},{"id":57,"text":"Putin aided , abetted Snowden","depth":11},{"id":58,"text":"04:13","depth":9},{"id":59,"text":"JUST WATCHED","depth":11},{"id":60,"text":"McCain :","depth":13},{"id":61,"text":"Putin 'sticks his thumb ' at us","depth":13},{"id":62,"text":"Replay More Videos ...","depth":12},{"id":63,"text":"MUST WATCH McCain :","depth":12},{"id":64,"text":"Putin 'sticks his thumb ' at us","depth":12},{"id":65,"text":"03:30","depth":11},{"id":66,"text":"Noting","depth":12},{"id":67,"text":"the United States and Russia do not have an extradition agreement ,","depth":12},{"id":68,"text":"Putin said","depth":12},{"id":69,"text":"Snowden ca n't be turned over to U.S. authorities","depth":13},{"id":70,"text":"and has committed no crimes on Russian soil .","depth":13},{"id":71,"text":"But he also said","depth":12},{"id":72,"text":"Russian security forces have not been `` working with '' Snowden","depth":12},{"id":73,"text":"and expressed hope","depth":12},{"id":74,"text":"that the incident would not `` affect the cordial nature of our relations with the U.S. ''","depth":12},{"id":75,"text":"Hrafnsson offered a similar story ,","depth":8},{"id":76,"text":"saying","depth":9},{"id":77,"text":"there 's been `` no cooperation or coordination with the Russian authority ''","depth":10},{"id":78,"text":"before or since Snowden arrived in Moscow .","depth":10},{"id":79,"text":"A senior Obama administration official called Putin 's comments `` potentially positive ''","depth":5},{"id":80,"text":"while reiterating hopes","depth":6},{"id":81,"text":"that Snowden would be expelled from Russia","depth":7},{"id":82,"text":"and returned to the United States .","depth":7},{"id":83,"text":"U.S. officials believe","depth":6},{"id":84,"text":"Russian authorities have a `` clear legal basis","depth":7},{"id":85,"text":"to expel Mr. Snowden ,","depth":8},{"id":86,"text":"based on the status of his travel documents and the pending charges against him , ''","depth":8},{"id":87,"text":"National Security Council spokeswoman Caitlin Hayden said .","depth":5},{"id":88,"text":"Secretary of State John Kerry ,","depth":7},{"id":89,"text":"speaking to reporters","depth":8},{"id":90,"text":"while traveling in Saudi Arabia ,","depth":8},{"id":91,"text":"said","depth":6},{"id":92,"text":"the United States is n't looking to Russia to enforce U.S. law ,","depth":6},{"id":93,"text":"only to `` allow him to be subject to the laws of our land and our Constitution . ''","depth":6},{"id":94,"text":"`` We are not looking for confrontation ,","depth":7},{"id":95,"text":"we 're not ordering anybody , ''","depth":7},{"id":96,"text":"Kerry said .","depth":6},{"id":97,"text":"`` We 're simply requesting under a very normal procedure for the transfer of somebody ,","depth":6},{"id":98,"text":"just as we transferred to Russia seven people in the last two years","depth":8},{"id":99,"text":"that they requested ,","depth":8},{"id":100,"text":"that we did","depth":8},{"id":101,"text":"without any clamor ,","depth":9},{"id":102,"text":"without any rancor ,","depth":11},{"id":103,"text":"without any argument","depth":11},{"id":104,"text":"and according to our sense of the appropriateness","depth":11},{"id":105,"text":"of meeting their request . ''","depth":11},{"id":106,"text":"Snowden left Hong Kong on Sunday","depth":5},{"id":107,"text":"after a couple of weeks spent doling out details of classified U.S. intelligence programs to journalists .","depth":5},{"id":108,"text":"With his passport revoked by U.S. officials ,","depth":5},{"id":109,"text":"Snowden traveled out of the semiautonomous Chinese territory on refugee papers","depth":6},{"id":110,"text":"issued by Ecuador , one of the countries","depth":7},{"id":111,"text":"from which he is seeking asylum .","depth":7},{"id":112,"text":"His travels have sparked international dust-ups ,","depth":5},{"id":113,"text":"with U.S. officials accusing China of making a `` deliberate choice ''","depth":7},{"id":114,"text":"to let Snowden go free","depth":7},{"id":115,"text":"and criticizing Russia","depth":7},{"id":116,"text":"for failing to hand him over in a spirit of international cooperation .","depth":7},{"id":117,"text":"On Tuesday , a Chinese Foreign Ministry spokeswoman rejected the U.S. claims as `` unreasonable , ''","depth":9},{"id":118,"text":"according to the official Xinhua news service .","depth":9},{"id":119,"text":"`` The accusation","depth":12},{"id":120,"text":"that the U.S. side made against the Central Government of China","depth":12},{"id":121,"text":"fell short of proof .","depth":11},{"id":122,"text":"The Chinese side will absolutely not accept it , ''","depth":10},{"id":123,"text":"spokeswoman Hua Chunying said .","depth":9},{"id":124,"text":"Rimsky Yuen Kwok-keung , Hong Kong 's justice secretary , likewise denied","depth":9},{"id":125,"text":"that authorities there intentionally let Snowden leave","depth":10},{"id":126,"text":"before acting on U.S. requests .","depth":10},{"id":127,"text":"`` All along , we acted fully in accordance with the law","depth":10},{"id":128,"text":"and any suggestion","depth":12},{"id":129,"text":"that we have been deliberately letting Mr. Snowden go away","depth":13},{"id":130,"text":"or to do any other thing","depth":14},{"id":131,"text":"to obstruct the normal operation","depth":14},{"id":132,"text":"is totally untrue , ''","depth":11},{"id":133,"text":"Yuen said Tuesday .","depth":9},{"id":134,"text":"Authorities in Hong Kong were seeking answers from U.S. authorities","depth":9},{"id":135,"text":"around when Snowden left ,","depth":9},{"id":136,"text":"the justice secretary added .","depth":8},{"id":137,"text":"Hong Kong Chief Executive Leung Chun-Ying said Monday","depth":8},{"id":138,"text":"that authorities acted independently from Beijing","depth":9},{"id":139,"text":"`` to follow procedural fairness and procedural justice . ''","depth":9},{"id":140,"text":"In Moscow , Russian Foreign Minister Sergey Lavrov called the U.S. complaints `` absolutely groundless and unacceptable . '' `` I want to say , right away ,","depth":7},{"id":141,"text":"that we have nothing to do with Mr. Snowden or his movements around the world , ''","depth":7},{"id":142,"text":"Lavrov said .","depth":6},{"id":143,"text":"JUST WATCHED","depth":6},{"id":144,"text":"Did the U.S. drop the ball on Snowden ?","depth":8},{"id":145,"text":"Replay More Videos ...","depth":8},{"id":146,"text":"MUST WATCH","depth":8},{"id":147,"text":"Did the U.S. drop the ball on Snowden ?","depth":9},{"id":148,"text":"02:00","depth":9},{"id":149,"text":"JUST WATCHED","depth":8},{"id":150,"text":"White House upset about Snowden travels","depth":9},{"id":151,"text":"Replay More Videos ...","depth":10},{"id":152,"text":"MUST WATCH","depth":11},{"id":153,"text":"White House upset about Snowden travels","depth":12},{"id":154,"text":"03:20","depth":12},{"id":155,"text":"JUST WATCHED","depth":9},{"id":156,"text":"We want to know :","depth":10},{"id":157,"text":"Where 's Ed ?","depth":10},{"id":158,"text":"Replay More Videos ...","depth":9},{"id":159,"text":"MUST WATCH","depth":10},{"id":160,"text":"We want to know :","depth":12},{"id":161,"text":"Where 's Ed ?","depth":12},{"id":162,"text":"02:28","depth":11},{"id":163,"text":"The White House is eager to avoid a repeat of what happened in Hong Kong ,","depth":10},{"id":164,"text":"where authorities let Snowden leave","depth":11},{"id":165,"text":"despite a U.S. request for his arrest and extradition .","depth":11},{"id":166,"text":"Washington has described that move as a `` serious setback '' to building trust between the United States and China .","depth":9},{"id":167,"text":"But the Obama administration does n't have much leverage with Moscow ,","depth":10},{"id":168,"text":"said Matthew Rojansky , an expert on U.S. and Russian national security at the Carnegie Endowment for International Peace .","depth":10},{"id":169,"text":"`` We really need Russian cooperation ,","depth":12},{"id":170,"text":"I think ,","depth":12},{"id":171,"text":"much more in most areas","depth":12},{"id":172,"text":"than the Russians need us , ''","depth":12},{"id":173,"text":"he said .","depth":10},{"id":174,"text":"Washington is also telling other countries","depth":13},{"id":175,"text":"where Snowden might end up","depth":13},{"id":176,"text":"-- notably Ecuador ,","depth":13},{"id":177,"text":"which says","depth":14},{"id":178,"text":"it 's analyzing an asylum request from Snowden --","depth":14},{"id":179,"text":"that they should hand him over","depth":12},{"id":180,"text":"if he lands on their soil .","depth":12},{"id":181,"text":"They note","depth":11},{"id":182,"text":"that his U.S. passport has been revoked .","depth":11},{"id":183,"text":"`` The U.S. is advising these governments","depth":11},{"id":184,"text":"that Mr. Snowden is wanted on felony charges","depth":12},{"id":185,"text":"and as such should not be allowed to proceed in any further international travel","depth":13},{"id":186,"text":"other than is necessary","depth":14},{"id":187,"text":"to return him here to the United States , ''","depth":14},{"id":188,"text":"Carney said .","depth":10},{"id":189,"text":"One rumored destination is Venezuela ,","depth":10},{"id":190,"text":"whose leaders have been frequently at odds with Washington in recent years .","depth":10},{"id":191,"text":"According to the AVN state news agency ,","depth":11},{"id":192,"text":"President Nicolas Maduro said Tuesday","depth":12},{"id":193,"text":"his country has not received a formal request for political asylum from Snowden .","depth":12},{"id":194,"text":"But","depth":11},{"id":195,"text":"if it did ,","depth":13},{"id":196,"text":"the government would consider it on humanitarian grounds ,","depth":13},{"id":197,"text":"the agency reports .","depth":12},{"id":198,"text":"In its quest","depth":7},{"id":199,"text":"to get Snowden ,","depth":7},{"id":200,"text":"the United States has limited options .","depth":6},{"id":201,"text":"CNN senior legal analyst Jeffrey Toobin said","depth":6},{"id":202,"text":"the issue now `` is much more of a political and diplomatic matter","depth":8},{"id":203,"text":"than it is a legal matter . ''","depth":8},{"id":204,"text":"`` In an ordinary case , sure , you need a passport","depth":10},{"id":205,"text":"to get around , ''","depth":10},{"id":206,"text":"Toobin said .","depth":9},{"id":207,"text":"`` But here ,","depth":10},{"id":208,"text":"where this case is causing increasing embarrassment for the United States ,","depth":10},{"id":209,"text":"governments","depth":11},{"id":210,"text":"that want the United States to be embarrassed","depth":11},{"id":211,"text":"are only too happy to waive some of the technical legal rules . ''","depth":10},{"id":212,"text":"Snowden has acknowledged","depth":9},{"id":213,"text":"he leaked classified documents about the NSA 's surveillance programs to the Guardian newspaper in Britain and The Washington Post .","depth":9},{"id":214,"text":"The documents revealed the existence of programs","depth":10},{"id":215,"text":"that collect records of domestic telephone calls in the United States","depth":11},{"id":216,"text":"and monitor the Internet activity of people overseas residents .","depth":11},{"id":217,"text":"The disclosures shook the U.S. intelligence community","depth":10},{"id":218,"text":"and raised questions","depth":11},{"id":219,"text":"about whether the NSA is eroding American civil liberties .","depth":11},{"id":220,"text":"Snowden worked as a Hawaii-based computer network administrator for Booz Allen Hamilton , an NSA contractor ,","depth":8},{"id":221,"text":"before he fled to Hong Kong last month with laptops full of confidential information .","depth":8},{"id":222,"text":"The South China Morning Post newspaper published a story Monday","depth":8},{"id":223,"text":"quoting Snowden","depth":9},{"id":224,"text":"as saying","depth":10},{"id":225,"text":"he took the job","depth":11},{"id":226,"text":"to gather evidence on U.S. surveillance programs .","depth":11},{"id":227,"text":"He told the Guardian","depth":9},{"id":228,"text":"that he exposed the surveillance programs","depth":10},{"id":229,"text":"because they pose a threat to democracy ,","depth":10},{"id":230,"text":"but administration officials said","depth":9},{"id":231,"text":"the programs are vital","depth":11},{"id":232,"text":"to preventing terrorist attacks","depth":11},{"id":233,"text":"and are overseen by all three branches of government .","depth":10},{"id":234,"text":"Carney questioned Snowden 's assertion","depth":7},{"id":235,"text":"that he acted in defense of democratic transparency ,","depth":7},{"id":236,"text":"saying","depth":8},{"id":237,"text":"his argument `` is belied by the protectors","depth":10},{"id":238,"text":"he has potentially chosen","depth":10},{"id":239,"text":"-- China , Russia , Ecuador . ''","depth":9},{"id":240,"text":"`` His failures","depth":11},{"id":241,"text":"to criticize these regimes","depth":11},{"id":242,"text":"suggests","depth":10},{"id":243,"text":"that his true motive throughout has been to injure the national security of the United States ,","depth":10},{"id":244,"text":"not to advance Internet freedom and free speech , ''","depth":10},{"id":245,"text":"Carney told reporters .","depth":8},{"id":246,"text":"Snowden is seeking asylum from Ecuador , Iceland and other , unspecified countries ,","depth":7},{"id":247,"text":"a WikiLeaks attorney said Monday .","depth":7},{"id":248,"text":"Ecuador has already given WikiLeaks founder Julian Assange freedom","depth":8},{"id":249,"text":"if he can find a way out of the country 's embassy in London .","depth":8},{"id":250,"text":"In his aslyum request","depth":10},{"id":251,"text":"read by Ecuadorian Foreign Minister Ricardo ,","depth":10},{"id":252,"text":"Snowden compared himself to Pvt . Bradley Manning , the U.S. soldier","depth":10},{"id":253,"text":"accused of leaking classified information through WikiLeaks .","depth":10},{"id":254,"text":"He said","depth":10},{"id":255,"text":"U.S. officials have treated Manning inhumanely","depth":11},{"id":256,"text":"by holding him in solitary confinement ,","depth":11},{"id":257,"text":"and he predicted a similar `` cruel and unusual '' fate for himself","depth":10},{"id":258,"text":"if he falls into U.S. hands .","depth":10},{"id":259,"text":"Snowden has come under some criticism","depth":7},{"id":260,"text":"for seeking out help from nations with questionable histories on free speech and press freedom .","depth":8},{"id":261,"text":"For instance , The Committee","depth":11},{"id":262,"text":"to Protect Journalists","depth":11},{"id":263,"text":"has criticized Ecuadorian President Rafael Correa 's government for pushing legislation","depth":11},{"id":264,"text":"that would roll back press freedoms ,","depth":11},{"id":265,"text":"calling its policies increasingly repressive .","depth":9},{"id":266,"text":"Snowden is n't looking for `` political nirvana , ''","depth":9},{"id":267,"text":"said Glenn Greenwald , the columnist for the Guardian","depth":10},{"id":268,"text":"who broke his revelations .","depth":10},{"id":269,"text":"`` He 's searching for a place","depth":10},{"id":270,"text":"where he can be safe","depth":11},{"id":271,"text":"and remain free","depth":12},{"id":272,"text":"and participate in the debate ,","depth":12},{"id":273,"text":"and Ecuador seems to be the place","depth":11},{"id":274,"text":"he has chosen , ''","depth":11},{"id":275,"text":"Greenwald told CNN 's `` The Lead . ''","depth":10},{"id":276,"text":"Some have speculated","depth":9},{"id":277,"text":"Snowden has `` doomsday insurance '' in the form of even more top-secret U.S. documents","depth":10},{"id":278,"text":"that will go public","depth":11},{"id":279,"text":"if he 's ever detained by U.S. authorities .","depth":11},{"id":280,"text":"Hrafnsson , the WikiLeaks spokesman , said","depth":11},{"id":281,"text":"he did n't know about Snowden 's specific plans ,","depth":11},{"id":282,"text":"but did suggest","depth":11},{"id":283,"text":"more secrets may be revealed .","depth":11},{"id":284,"text":"`` This is simply information","depth":12},{"id":285,"text":"that should be out in the public , ''","depth":12},{"id":286,"text":"he said .","depth":11},{"id":287,"text":"`` There is more to come . ''","depth":10}],"relations":[{"parent":575,"left":393,"right":574,"relation":"elaboration","nuclearity":"NS"},{"parent":393,"left":366,"right":392,"relation":"elaboration","nuclearity":"NS"},{"parent":366,"left":294,"right":365,"relation":"organization","nuclearity":"SN"},{"parent":294,"left":0,"right":293,"relation":"organization","nuclearity":"SN"},{"parent":293,"left":292,"right":6,"relation":"attribution","nuclearity":"NS"},{"parent":292,"left":289,"right":291,"relation":"joint","nuclearity":"NN"},{"parent":289,"left":1,"right":2,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":3,"right":290,"relation":"attribution","nuclearity":"SN"},{"parent":290,"left":4,"right":5,"relation":"adversative","nuclearity":"NN"},{"parent":365,"left":330,"right":364,"relation":"joint","nuclearity":"NN"},{"parent":330,"left":315,"right":329,"relation":"elaboration","nuclearity":"NS"},{"parent":315,"left":298,"right":314,"relation":"organization","nuclearity":"SN"},{"parent":298,"left":295,"right":297,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":7,"right":8,"relation":"attribution","nuclearity":"SN"},{"parent":297,"left":9,"right":296,"relation":"purpose","nuclearity":"NS"},{"parent":296,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":314,"left":306,"right":313,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":302,"right":305,"relation":"same-unit","nuclearity":"NN"},{"parent":302,"left":301,"right":16,"relation":"attribution","nuclearity":"NS"},{"parent":301,"left":299,"right":300,"relation":"same-unit","nuclearity":"NN"},{"parent":299,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":300,"left":14,"right":15,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":17,"right":304,"relation":"attribution",