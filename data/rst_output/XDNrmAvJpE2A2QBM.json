{"article_id":"XDNrmAvJpE2A2QBM","edus":[{"id":0,"text":"WASHINGTON ( ) -","depth":1},{"id":1,"text":"The top U.S. diplomat in Ukraine ,","depth":9},{"id":2,"text":"testifying on Wednesday in the first televised hearing of the impeachment inquiry against President Donald Trump ,","depth":9},{"id":3,"text":"linked him more directly to a pressure campaign on Ukraine","depth":9},{"id":4,"text":"to conduct investigations","depth":10},{"id":5,"text":"that would benefit him politically .","depth":10},{"id":6,"text":"William Taylor was one of two career diplomats","depth":8},{"id":7,"text":"who testified before the House of Representatives Intelligence Committee","depth":9},{"id":8,"text":"as a crucial new phase began in the impeachment inquiry ,","depth":10},{"id":9,"text":"which threatens Trump ' s presidency","depth":11},{"id":10,"text":"even as he seeks re-election in 2020 .","depth":11},{"id":11,"text":"Both Taylor and George Kent testified about the pressure","depth":9},{"id":12,"text":"Trump and allies applied","depth":9},{"id":13,"text":"to get Ukraine to investigate Democratic political rival Joe Biden over his son ' s business dealings in Ukraine .","depth":8},{"id":14,"text":"Their testimony was calm and forceful ,","depth":8},{"id":15,"text":"but it was not clear","depth":9},{"id":16,"text":"whether it would help Democrats break through a partisan divide","depth":10},{"id":17,"text":"and convince more Americans","depth":11},{"id":18,"text":"that the Republican president has committed misdeeds","depth":12},{"id":19,"text":"worthy of ousting him from office .","depth":12},{"id":20,"text":"In a disclosure","depth":10},{"id":21,"text":"that drew the most attention ,","depth":10},{"id":22,"text":"Taylor , acting ambassador to Ukraine , pointed to Trump ' s keen interest","depth":10},{"id":23,"text":"in getting the eastern European ally to investigate Biden , a former vice president ,","depth":10},{"id":24,"text":"and reiterated his understanding","depth":9},{"id":25,"text":"that $ 391 million in U.S. security aid was withheld from Kiev","depth":10},{"id":26,"text":"unless it cooperated .","depth":10},{"id":27,"text":"Taylor said","depth":11},{"id":28,"text":"a member of his staff overheard a July 26 phone call between Trump and Gordon Sondland , a former Trump political donor","depth":13},{"id":29,"text":"appointed as a senior diplomat ,","depth":13},{"id":30,"text":"in which Trump asked about those investigations","depth":13},{"id":31,"text":"and Sondland told him","depth":14},{"id":32,"text":"the Ukrainians were ready to proceed .","depth":14},{"id":33,"text":"After that conversation","depth":13},{"id":34,"text":"- which occurred a day after Trump had asked Ukraine ' s president during a phone call","depth":14},{"id":35,"text":"to conduct the investigations -","depth":14},{"id":36,"text":"the staff member asked Sondland , the U.S. ambassador to the European Union , what Trump thought about Ukraine ,","depth":12},{"id":37,"text":"Taylor said .","depth":11},{"id":38,"text":"\" Ambassador Sondland responded","depth":11},{"id":39,"text":"that President Trump cares more about the investigations of Biden ,","depth":12},{"id":40,"text":"which Giuliani was pressing for , \"","depth":12},{"id":41,"text":"Taylor testified ,","depth":11},{"id":42,"text":"referring to Trump ' s personal lawyer , Rudy Giuliani .","depth":11},{"id":43,"text":"Asked by Adam Schiff , the committee ' s Democratic chairman ,","depth":10},{"id":44,"text":"if that meant","depth":11},{"id":45,"text":"Trump cared more about the investigations than about Ukraine ,","depth":11},{"id":46,"text":"Taylor said :","depth":10},{"id":47,"text":"\" Yes , sir . \"","depth":10},{"id":48,"text":"Taylor ,","depth":10},{"id":49,"text":"who was appointed by Trump in June ,","depth":10},{"id":50,"text":"also said","depth":9},{"id":51,"text":"withholding military aid from Ukraine ,","depth":10},{"id":52,"text":"which has been locked in conflict with Russia","depth":11},{"id":53,"text":"since Moscow annexed the Crimean peninsula in 2014 ,","depth":11},{"id":54,"text":"undermined U.S. strategic interests .","depth":9},{"id":55,"text":"\" It was counterproductive to all of what we had been trying to do .","depth":9},{"id":56,"text":"It was illogical ...","depth":10},{"id":57,"text":"It was crazy , \"","depth":10},{"id":58,"text":"he said .","depth":8},{"id":59,"text":"At a White House news conference with Turkish President Tayyip Erdogan","depth":10},{"id":60,"text":"after the hearing ended ,","depth":10},{"id":61,"text":"Trump said","depth":9},{"id":62,"text":"he knew \" nothing \" about the call with Sondland","depth":9},{"id":63,"text":"that","depth":11},{"id":64,"text":"Taylor said","depth":11},{"id":65,"text":"his aide overheard .","depth":10},{"id":66,"text":"\" It ' s the first time","depth":9},{"id":67,"text":"I heard it , \"","depth":9},{"id":68,"text":"said Trump ,","depth":9},{"id":69,"text":"who has denied any wrongdoing .","depth":9},{"id":70,"text":"David Holmes , a Taylor aide","depth":9},{"id":71,"text":"subpoenaed to testify behind closed doors on Friday in the impeachment inquiry ,","depth":9},{"id":72,"text":"is the staffer","depth":9},{"id":73,"text":"who overheard the call","depth":10},{"id":74,"text":"that Sondland made to Trump from Ukraine ,","depth":10},{"id":75,"text":"said a person familiar with the issue .","depth":7},{"id":76,"text":"Republican lawmakers called Taylor ' s account hearsay","depth":6},{"id":77,"text":"and noted","depth":7},{"id":78,"text":"Ukraine ' s president has not said","depth":8},{"id":79,"text":"he felt pressured by Trump .","depth":8},{"id":80,"text":"With a potential television audience of tens of millions looking on ,","depth":7},{"id":81,"text":"Schiff opened the historic session","depth":8},{"id":82,"text":"- the first impeachment drama in two decades -","depth":8},{"id":83,"text":"in an ornate hearing room","depth":7},{"id":84,"text":"packed with journalists , lawmakers and members of the public .","depth":7},{"id":85,"text":"The contentious hearing lasted 5-1/2 hours .","depth":5},{"id":86,"text":"Schiff and other Democrats accused Trump of abusing his power","depth":7},{"id":87,"text":"while the panel ' s senior Republican , Devin Nunes , denied","depth":8},{"id":88,"text":"that Trump and his aides improperly pressured Ukraine to dig up dirt on Biden , a leading contender for the Democratic nomination for the 2020 election .","depth":8},{"id":89,"text":"Taylor and Kent , the deputy assistant secretary of state for European and Eurasian affairs , detailed the evidence","depth":9},{"id":90,"text":"they saw","depth":9},{"id":91,"text":"that U.S. security aid","depth":10},{"id":92,"text":"- as well as a meeting with Trump at the White House -","depth":10},{"id":93,"text":"was withheld from Ukraine as leverage over Kiev .","depth":9},{"id":94,"text":"\" The questions","depth":12},{"id":95,"text":"presented by this impeachment inquiry","depth":12},{"id":96,"text":"are whether President Trump sought to exploit that ally ' s vulnerability","depth":12},{"id":97,"text":"and invite Ukraine ' s interference in our elections , \"","depth":12},{"id":98,"text":"Schiff said .","depth":10},{"id":99,"text":"\" Our answer to these questions will affect not only the future of this presidency ,","depth":10},{"id":100,"text":"but the future of the presidency itself . \"","depth":10},{"id":101,"text":"Schiff added :","depth":9},{"id":102,"text":"\" If this is not impeachable conduct ,","depth":10},{"id":103,"text":"what is ? \"","depth":10},{"id":104,"text":"This week ' s sessions ,","depth":10},{"id":105,"text":"where Americans are hearing directly for the first time from people","depth":11},{"id":106,"text":"involved in events","depth":12},{"id":107,"text":"that sparked the congressional inquiry ,","depth":12},{"id":108,"text":"may pave the way for the Democratic-led House to approve articles of impeachment","depth":11},{"id":109,"text":"- formal charges -","depth":11},{"id":110,"text":"against Trump .","depth":10},{"id":111,"text":"That would lead to a trial in the Senate","depth":10},{"id":112,"text":"on whether to convict Trump of those charges","depth":11},{"id":113,"text":"and remove him from office .","depth":11},{"id":114,"text":"Republicans control the Senate","depth":10},{"id":115,"text":"and have shown little support for Trump ' s removal .","depth":10},{"id":116,"text":"The inquiry is being conducted","depth":8},{"id":117,"text":"as the 2020 presidential campaign gathers steam .","depth":8},{"id":118,"text":"Opinion polls show","depth":7},{"id":119,"text":"Democrats strongly back impeachment","depth":9},{"id":120,"text":"and Republicans strongly oppose ,","depth":9},{"id":121,"text":"leaving both parties appealing to a small sliver of the public","depth":9},{"id":122,"text":"- independents and others","depth":10},{"id":123,"text":"who have not made up their minds .","depth":10},{"id":124,"text":"Chairman Adam Schiff","depth":9},{"id":125,"text":"( L ) ,","depth":9},{"id":126,"text":"Democrat of California ,","depth":8},{"id":127,"text":"and Ranking Member Devin Nunes","depth":10},{"id":128,"text":"( R ) ,","depth":10},{"id":129,"text":"Republican of California , during the first public hearings","depth":9},{"id":130,"text":"held by the House Permanent Select Committee on Intelligence as part of the impeachment inquiry into U.S. President Donald Trump , on Capitol Hill in Washington , DC , U.S. , November 13 , 2019 .","depth":8},{"id":131,"text":"Saul Loeb/Pool via","depth":6},{"id":132,"text":"During his news conference with Erdogan ,","depth":7},{"id":133,"text":"Trump said","depth":8},{"id":134,"text":"he had been too busy","depth":9},{"id":135,"text":"to watch the hearing .","depth":9},{"id":136,"text":"\" I hear","depth":9},{"id":137,"text":"it ' s a joke , \"","depth":9},{"id":138,"text":"he said .","depth":8},{"id":139,"text":"\" This is a sham","depth":8},{"id":140,"text":"and shouldn ' t be allowed . \"","depth":8},{"id":141,"text":"Nunes accused Democrats of conducting a \" carefully orchestrated smear campaign \"","depth":7},{"id":142,"text":"and said","depth":8},{"id":143,"text":"they had combined with the media and \" partisan bureaucrats \"","depth":9},{"id":144,"text":"to try to overturn the results of the 2016 election","depth":10},{"id":145,"text":"won by Trump .","depth":10},{"id":146,"text":"He hewed to the Republican strategy","depth":7},{"id":147,"text":"of arguing","depth":8},{"id":148,"text":"Trump did nothing wrong","depth":10},{"id":149,"text":"in asking Ukraine ' s new president to investigate Biden ,","depth":10},{"id":150,"text":"calling it \" an impeachment process in search of a crime . \"","depth":9},{"id":151,"text":"The focus of the inquiry is on the July 25 telephone call","depth":8},{"id":152,"text":"in which Trump asked Ukrainian President Volodymyr Zelenskiy to open a corruption investigation into Biden and his son Hunter , and into a discredited theory","depth":9},{"id":153,"text":"that Ukraine , not Russia , meddled in the 2016 U.S. election .","depth":9},{"id":154,"text":"Hunter Biden had been a board member for a Ukrainian energy company","depth":8},{"id":155,"text":"called Burisma .","depth":8},{"id":156,"text":"Democrats say","depth":8},{"id":157,"text":"Trump abused his power","depth":9},{"id":158,"text":"by withholding the security aid to Ukraine","depth":12},{"id":159,"text":"- a vulnerable U.S. ally","depth":13},{"id":160,"text":"facing Russian aggression -","depth":13},{"id":161,"text":"as leverage","depth":11},{"id":162,"text":"to pressure Kiev into conducting the investigations .","depth":10},{"id":163,"text":"The money ,","depth":9},{"id":164,"text":"approved by the U.S. Congress","depth":10},{"id":165,"text":"to help Ukraine combat Russia-backed separatists in the eastern part of the country ,","depth":10},{"id":166,"text":"was later provided to Ukraine .","depth":8},{"id":167,"text":"Both witnesses remained calm and unflappable throughout the marathon session .","depth":6},{"id":168,"text":"Taylor said at the outset :","depth":8},{"id":169,"text":"\" I am not here","depth":9},{"id":170,"text":"to take one side or the other ,","depth":10},{"id":171,"text":"or to advocate for any particular outcome of these proceedings . \"","depth":10},{"id":172,"text":"Republican Jim Jordan , a forceful Trump ally , told Taylor :","depth":9},{"id":173,"text":"\" You ' re their star witness , \"","depth":10},{"id":174,"text":"referring to the Democrats .","depth":10},{"id":175,"text":"\" I don ' t consider myself a star witness for anything , \"","depth":9},{"id":176,"text":"Taylor responded .","depth":9},{"id":177,"text":"Taylor , a former U.S. Army officer , previously served as U.S. ambassador to Ukraine","depth":8},{"id":178,"text":"and is now the chargé d ' affaires of the U.S. Embassy in Kiev .","depth":8},{"id":179,"text":"Kent oversees Ukraine policy at the State Department .","depth":7},{"id":180,"text":"\" I do not believe","depth":8},{"id":181,"text":"the United States should ask other countries to engage in selective , politically associated investigations or prosecutions against opponents of those in power ,","depth":9},{"id":182,"text":"because such selective actions undermine the rule of law regardless of the country , \"","depth":9},{"id":183,"text":"Kent said .","depth":7},{"id":184,"text":"Taylor said","depth":8},{"id":185,"text":"he found two channels of U.S. policy toward Ukraine","depth":9},{"id":186,"text":"- one regular and one \" highly irregular \" -","depth":9},{"id":187,"text":"and recounted","depth":8},{"id":188,"text":"how a Trump meeting with the Ukrainian president was improperly conditioned on Kiev agreeing to investigate Burisma and the debunked notion of Ukrainian interference in the 2016 election .","depth":8},{"id":189,"text":"Taylor said","depth":7},{"id":190,"text":"he became aware","depth":8},{"id":191,"text":"that a hold on the security aid was contingent on Ukraine opening the investigations ,","depth":9},{"id":192,"text":"which was alarming to him","depth":10},{"id":193,"text":"because it entailed \" security assistance to a country at war . \"","depth":10},{"id":194,"text":"Trump has derided some of the current and former U.S. officials","depth":7},{"id":195,"text":"who have appeared before committees as \" Never Trumpers \"","depth":8},{"id":196,"text":"- a term referring to Republican opponents of the president","depth":9},{"id":197,"text":"whom he has called \" human scum . \"","depth":9},{"id":198,"text":"Asked during the hearing","depth":9},{"id":199,"text":"whether they are \" never Trumpers , \"","depth":9},{"id":200,"text":"Taylor responded :","depth":9},{"id":201,"text":"\" No , Sir , \"","depth":9},{"id":202,"text":"and Kent noted","depth":8},{"id":203,"text":"he had worked as a diplomat under presidents of both parties .","depth":8}],"relations":[{"parent":407,"left":0,"right":406,"relation":"organization","nuclearity":"SN"},{"parent":406,"left":326,"right":405,"relation":"elaboration","nuclearity":"NS"},{"parent":326,"left":282,"right":325,"relation":"elaboration","nuclearity":"NS"},{"parent":282,"left":261,"right":281,"relation":"elaboration","nuclearity":"NS"},{"parent":261,"left":222,"right":260,"relation":"elaboration","nuclearity":"NS"},{"parent":222,"left":213,"right":221,"relation":"elaboration","nuclearity":"NS"},{"parent":213,"left":208,"right":212,"relation":"elaboration","nuclearity":"NS"},{"parent":208,"left":205,"right":207,"relation":"same-unit","nuclearity":"NN"},{"parent":205,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":207,"left":3,"right":206,"relation":"purpose","nuclearity":"NS"},{"parent":206,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":212,"left":6,"right":211,"relation":"elaboration","nuclearity":"NS"},{"parent":211,"left":7,"right":210,"relation":"context","nuclearity":"NS"},{"parent":210,"left":8,"right":209,"relation":"elaboration",