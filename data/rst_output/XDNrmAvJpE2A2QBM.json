:288,"left":87,"right":88,"relation":"attribution","nuclearity":"SN"},{"parent":303,"left":293,"right":302,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":290,"right":292,"relation":"attribution","nuclearity":"SN"},{"parent":290,"left":89,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":291,"right":93,"relation":"same-unit","nuclearity":"NN"},{"parent":291,"left":91,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":299,"right":301,"relation":"joint","nuclearity":"NN"},{"parent":299,"left":297,"right":298,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":296,"right":98,"relation":"attribution","nuclearity":"NS"},{"parent":296,"left":294,"right":295,"relation":"same-unit","nuclearity":"NN"},{"parent":294,"left":94,"right":95,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":96,"right":97,"relation":"joint","nuclearity":"NN"},{"parent":298,"left":99,"right":100,"relation":"joint","nuclearity":"NN"},{"parent":301,"left":101,"right":300,"relation":"attribution","nuclearity":"SN"},{"parent":300,"left":102,"right":103,"relation":"condition","nuclearity":"SN"},{"parent":323,"left":317,"right":322,"relation":"elaboration","nuclearity":"NS"},{"parent":317,"left":315,"right":316,"relation":"elaboration","nuclearity":"NS"},{"parent":315,"left":310,"right":314,"relation":"joint","nuclearity":"NN"},{"parent":310,"left":307,"right":309,"relation":"same-unit","nuclearity":"NN"},{"parent":307,"left":104,"right":306,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":105,"right":305,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":106,"right":107,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":308,"right":110,"relation":"same-unit","nuclearity":"NN"},{"parent":308,"left":108,"right":109,"relation":"restatement","nuclearity":"NS"},{"parent":314,"left":312,"right":313,"relation":"adversative","nuclearity":"NS"},{"parent":312,"left":111,"right