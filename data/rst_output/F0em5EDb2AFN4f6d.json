{"article_id":"F0em5EDb2AFN4f6d","edus":[{"id":0,"text":"Job Growth Less Than Expected ,","depth":2},{"id":1,"text":"But Unemployment Hits 5-Year Low","depth":2},{"id":2,"text":"The nation 's unemployment rate slipped to 6.6 percent in January from 6.7 percent a month before ,","depth":11},{"id":3,"text":"but employers added only 113,000 jobs to their payrolls last month ,","depth":12},{"id":4,"text":"the Bureau of Labor Statistics reported Friday morning .","depth":12},{"id":5,"text":"The jobless rate figure was expected .","depth":11},{"id":6,"text":"The job growth number , however , was well below the 185,000","depth":12},{"id":7,"text":"that economists expected .","depth":12},{"id":8,"text":"What 's more , BLS said","depth":11},{"id":9,"text":"it still believes","depth":12},{"id":10,"text":"job growth was even more disappointing in December .","depth":12},{"id":11,"text":"When it initially reported","depth":13},{"id":12,"text":"that only 74,000 jobs had been added to payrolls that month ,","depth":13},{"id":13,"text":"it was hoped the figure might later be revised upward .","depth":12},{"id":14,"text":"But today 's report showed almost no change :","depth":12},{"id":15,"text":"BLS now believes","depth":13},{"id":16,"text":"75,000 jobs were added in December .","depth":13},{"id":17,"text":"The news could add to concerns about a slowdown by the economy , and to some investors ' worries","depth":9},{"id":18,"text":"that the Federal Reserve is moving too quickly","depth":10},{"id":19,"text":"to `` taper '' the amount of stimulus","depth":11},{"id":20,"text":"it is giving the economy .","depth":11},{"id":21,"text":"The Dow Jones industrial average and other indices were up slightly after about one hour of trading in New York .","depth":7},{"id":22,"text":"Investors may have decided","depth":8},{"id":23,"text":"the jobs report is n't so bad .","depth":8},{"id":24,"text":"Dan Greenhaus , chief global strategist at BTIG LLC , tells Bloomberg News","depth":10},{"id":25,"text":"that `` beneath the headlines , stuff was n't terrible . ...","depth":10},{"id":26,"text":"When you dig into the household survey ,","depth":10},{"id":27,"text":"it 's not that bad .","depth":10},{"id":28,"text":"The participation rate went up ,","depth":9},{"id":29,"text":"the labor force went up ,","depth":10},{"id":30,"text":"the level of employment went up . ''","depth":10},{"id":31,"text":"Update at 9:50 a.m . ET .","depth":5},{"id":32,"text":"White House Focuses On Growth In Past 4 Years :","depth":8},{"id":33,"text":"`` Today 's report is another reminder of both the progress","depth":12},{"id":34,"text":"that has been made","depth":12},{"id":35,"text":"and the challenges","depth":12},{"id":36,"text":"that remain , ''","depth":12},{"id":37,"text":"White House economist Jason Furman writes .","depth":10},{"id":38,"text":"`` Businesses have now added 8.5 million jobs over the last 47 months","depth":11},{"id":39,"text":"and the unemployment rate ticked down to its lowest level in more than five years .","depth":11},{"id":40,"text":"But the economy is still healing from the Great Recession","depth":11},{"id":41,"text":"and steps are still needed","depth":12},{"id":42,"text":"to expand economic opportunity . ''","depth":12},{"id":43,"text":"Update at 9:25 a.m . ET .","depth":7},{"id":44,"text":"`` Where Are The Jobs ? ''","depth":9},{"id":45,"text":"Boehner Asks :","depth":9},{"id":46,"text":"`` The American people continue to ask","depth":11},{"id":47,"text":"'where are the jobs ? , '","depth":11},{"id":48,"text":"and the president clearly has no answers , ''","depth":10},{"id":49,"text":"House Speaker John Boehner , R-Ohio , says in a statement","depth":10},{"id":50,"text":"sent to reporters by his office .","depth":10},{"id":51,"text":"The White House usually puts its analysis on its blog .","depth":8},{"id":52,"text":"We 'll add some of that","depth":9},{"id":53,"text":"when its available .","depth":9},{"id":54,"text":"Update at 9:15 a.m . ET .","depth":6},{"id":55,"text":"Although Employers Said","depth":11},{"id":56,"text":"They Added Only 113,000 Jobs ,","depth":11},{"id":57,"text":"638,000 More People Said","depth":11},{"id":58,"text":"They Were Working :","depth":11},{"id":59,"text":"As happens each month ,","depth":13},{"id":60,"text":"the BLS report has some apparently contradictory data .","depth":13},{"id":61,"text":"The figure on job growth","depth":14},{"id":62,"text":"- 113,000 -","depth":14},{"id":63,"text":"is based on a survey of public and private employers .","depth":13},{"id":64,"text":"Another figure , though , appears to show more positive news :","depth":12},{"id":65,"text":"BLS estimates","depth":14},{"id":66,"text":"that 638,000 more people were employed in January than in December .","depth":14},{"id":67,"text":"That figure comes from a survey of households .","depth":13},{"id":68,"text":"One explanation for the divergent views :","depth":11},{"id":69,"text":"434,000 more people said","depth":13},{"id":70,"text":"they were working `` part-time for noneconomic reasons '' in January .","depth":13},{"id":71,"text":"Many also may have taken positions","depth":13},{"id":72,"text":"that employers added to their payrolls in previous months ,","depth":14},{"id":73,"text":"but had n't been filled until January .","depth":14},{"id":74,"text":"Update at 9 a.m . ET .","depth":8},{"id":75,"text":"New Fed Chair Will Get `` Baptism Of Fire '' :","depth":9},{"id":76,"text":"`` These numbers mean","depth":12},{"id":77,"text":"that Janet Yellen could get a baptism of fire","depth":13},{"id":78,"text":"when she gives her inaugural testimony to Congress next week , ''","depth":13},{"id":79,"text":"The Wall Street Journal says in its live blog about the employment report .","depth":11},{"id":80,"text":"It adds that :","depth":11},{"id":81,"text":"`` Ms. Yellen did a masterful job","depth":14},{"id":82,"text":"of getting senators to warm to her during her confirmation hearings .","depth":14},{"id":83,"text":"But now she 's in the job ,","depth":14},{"id":84,"text":"the questions could be tougher .","depth":14},{"id":85,"text":"If anything , the risk is that the soft data wiill nudge the generally dovish new Fed chair to emphasize the Fed 's willingness","depth":14},{"id":86,"text":"to maintain monetary accommodation","depth":14},{"id":87,"text":"and that could stir up some of the Fed 's more conservative critics on the Hill . ''","depth":13},{"id":88,"text":"Yellen is due to testify before the House Committee on Financial Services next Tuesday and before the Senate Banking Committee next Thursday .","depth":8},{"id":89,"text":"Update at 8:55 a.m . ET .","depth":4},{"id":90,"text":"Did Bad Weather Skew The Jobs Figures ?","depth":6},{"id":91,"text":"Here 's some analysis from Kathy Bostjancic , director of macroeconomic analysis at the Conference Board , a business research group .","depth":7},{"id":92,"text":"She points to some reasons","depth":9},{"id":93,"text":"not to be too pessimistic","depth":10},{"id":94,"text":"based on the data in today 's report :","depth":10},{"id":95,"text":"`` A gain of only 113,000 new jobs in January , on the heels of the even slower gain in December , likely sparks uncertainty about the strength of the labor market and direction of the overall U.S. economy .","depth":10},{"id":96,"text":"``","depth":10},{"id":97,"text":"Still , the three-month average of private payroll increase is holding up at 168,000 .","depth":10},{"id":98,"text":"Also , the revisions for 2013 show an adjustment of 509,000 more jobs by December","depth":12},{"id":99,"text":"than previously counted .","depth":12},{"id":100,"text":"`` There is no doubt","depth":13},{"id":101,"text":"that inclement weather in December played a role ,","depth":14},{"id":102,"text":"although construction jobs held up reasonably well in January .","depth":14},{"id":103,"text":"We expect","depth":13},{"id":104,"text":"that an eventual return to more normal weather conditions will allow job gains to rebound back towards their previous 180,000 - 200,000 trend pace . ''","depth":13},{"id":105,"text":"Update at 8:45 a.m . ET .","depth":6},{"id":106,"text":"Rate Is Lowest Since October 2008 :","depth":8},{"id":107,"text":"According to the historical records","depth":11},{"id":108,"text":"kept by BLS ,","depth":11},{"id":109,"text":"the last time","depth":12},{"id":110,"text":"the unemployment rate was lower than 6.6 percent","depth":12},{"id":111,"text":"was in October 2008 ,","depth":12},{"id":112,"text":"when it stood at 6.5 percent .","depth":12},{"id":113,"text":"The rate 's recent peak was in October 2009 ,","depth":10},{"id":114,"text":"when it hit 10 percent .","depth":10},{"id":115,"text":"Officially , the economy slid into recession in December 2007","depth":8},{"id":116,"text":"and did n't emerge from that downturn until June 2009 .","depth":8},{"id":117,"text":"Our original post","depth":7},{"id":118,"text":"- 'Nervousness ' About Economy Ahead Of Today 's Jobs Report -","depth":7},{"id":119,"text":"previewed the report :","depth":6},{"id":120,"text":"As we wait for this morning 's much-anticipated report about job growth and unemployment in January ,","depth":6},{"id":121,"text":"here 's a preview","depth":7},{"id":122,"text":"that draws from the conversation","depth":8},{"id":123,"text":"NPR 's John Ydstie had today with Morning Edition host Renee Montagne .","depth":8},{"id":124,"text":"Economists expect to hear","depth":9},{"id":125,"text":"that job growth was stronger last month than in December ,","depth":9},{"id":126,"text":"John said .","depth":8},{"id":127,"text":"Their prediction :","depth":9},{"id":128,"text":"The Bureau of Labor Statistics will say","depth":12},{"id":129,"text":"about 185,000 jobs were added to public and private payrolls in January .","depth":12},{"id":130,"text":"In its initial report about December , BLS said","depth":13},{"id":131,"text":"just 74,000 jobs were added that month .","depth":13},{"id":132,"text":"That was far fewer than expected .","depth":12},{"id":133,"text":"It 's important to bear in mind , though , that the figure could be revised in today 's report .","depth":10},{"id":134,"text":"If there were about 185,000 more jobs in January than in December ,","depth":10},{"id":135,"text":"that would mean","depth":11},{"id":136,"text":"growth last month was about in line with the average pace over the last 12 months ,","depth":11},{"id":137,"text":"John said .","depth":9},{"id":138,"text":"But","depth":8},{"id":139,"text":"as he added ,","depth":9},{"id":140,"text":"`` there 's nervousness about where we are right now . ''","depth":9},{"id":141,"text":"Manufacturing may be `` losing steam '' in the U.S. and China ,","depth":9},{"id":142,"text":"John said .","depth":9},{"id":143,"text":"There have been currency problems in emerging markets such as Turkey and Argentina .","depth":10},{"id":144,"text":"That has led some investors to pull their money out of those countries","depth":11},{"id":145,"text":"- places","depth":12},{"id":146,"text":"that in recent years had been helping to shore up economic growth around the world .","depth":12},{"id":147,"text":"And financial markets have been worried lately about how the Federal Reserve 's decision","depth":11},{"id":148,"text":"to begin scaling back the amount of stimulus","depth":12},{"id":149,"text":"it gives the economy","depth":12},{"id":150,"text":"will affect growth in coming months .","depth":10},{"id":151,"text":"As we said Thursday ,","depth":6},{"id":152,"text":"economists also expect to hear","depth":7},{"id":153,"text":"that the unemployment rate either stayed at 6.7 percent in January","depth":9},{"id":154,"text":"or perhaps ticked down to 6.6 percent .","depth":9},{"id":155,"text":"A dip might have been at least partly due to a large number of people leaving the labor force ,","depth":9},{"id":156,"text":"either because they retired","depth":10},{"id":157,"text":"or because they gave up looking for work .","depth":10},{"id":158,"text":"The report is due at 8:30 a.m . ET .","depth":4},{"id":159,"text":"We 'll update with highlights and analyses .","depth":4}],"relations":[{"parent":319,"left":161,"right":318,"relation":"organization","nuclearity":"SN"},{"parent":161,"left":0,"right":1,"relation":"adversative","nuclearity":"NN"},{"parent":318,"left":275,"right":317,"relation":"joint","nuclearity":"NN"},{"parent":275,"left":247,"right":274,"relation":"joint","nuclearity":"NN"},{"parent":247,"left":190,"right":246,"relation":"joint","nuclearity":"NN"},{"parent":190,"left":189,"right":31,"relation":"context","nuclearity":"NS"},{"parent":189,"left":180,"right":188,"relation":"evaluation","nuclearity":"NS"},{"parent":180,"left":179,"right":21,"relation":"causal","nuclearity":"NS"},{"parent":179,"left":175,"right":178,"relation":"evaluation","nuclearity":"NS"},{"parent":175,"left":166,"right":174,"relation":"joint","nuclearity":"NN"},{"parent":166,"left":163,"right":165,"relation":"adversative","nuclearity":"NN"},{"parent":163,"left":2,"right":162,"relation":"adversative","nuclearity":"NN"},{"parent":162,"left":3,"right":4,"relation":"attribution","nuclearity":"NS"},{"parent":165,"left":5,"right":164,"relation":"adversative","nuclearity":"NN"},{"parent":164,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":174,"left":168,"right":173,"relation":"elaboration","nuclearity":"NS"},{"parent":168,"left":8,"right":167,"relation":"attribution","nuclearity":"SN"},{"parent":167,"left":9,"right":10,"relation":"attribution","nuclearity":"SN"},{"parent":173,"left":170,"right":172,"relation":"adversative","nuclearity":"NN"},{"parent":170,"left":169,"right":13,"relation":"context","nuclearity":"SN"},{"parent":169,"left":11,"right":12,"relation":"attribution","nuclearity":"SN"},{"parent":172,"left":14,"right":171,"relation":"organization","nuclearity":"SN"},{"parent":171,"left":15,"right":16,"relation":"attribution","nuclearity":"SN"},{"parent":178,"left":17,"right":177,"rela