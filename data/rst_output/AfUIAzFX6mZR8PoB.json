{"article_id":"AfUIAzFX6mZR8PoB","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"Efforts","depth":10},{"id":2,"text":"to pass a short-term spending bill","depth":11},{"id":3,"text":"to avoid a government shutdown","depth":11},{"id":4,"text":"collapsed Thursday","depth":9},{"id":5,"text":"when President Donald Trump said","depth":11},{"id":6,"text":"he would not sign a Senate-approved measure","depth":11},{"id":7,"text":"because it doesn ' t include enough money for a border wall .","depth":10},{"id":8,"text":"\" I ' ve made my position very clear :","depth":12},{"id":9,"text":"Any measure","depth":14},{"id":10,"text":"that funds the government","depth":14},{"id":11,"text":"must include border security , ''","depth":13},{"id":12,"text":"Trump said .","depth":11},{"id":13,"text":"Trump spoke during a signing ceremony for an unrelated farm bill","depth":11},{"id":14,"text":"a few hours after he told House Republican leaders at an emergency Oval Office meeting","depth":12},{"id":15,"text":"that he would not sign the Senate funding proposal .","depth":12},{"id":16,"text":"Hard-line conservatives in the House Freedom Caucus complained","depth":9},{"id":17,"text":"that the legislation does not include $ 5 billion","depth":10},{"id":18,"text":"Trump demands for a wall along the nation ' s southern border .","depth":10},{"id":19,"text":"The spending measure would punt a decision about border wall funding until next year ,","depth":10},{"id":20,"text":"when Democrats will return to power in the House of Representatives ,","depth":10},{"id":21,"text":"making it unlikely that Trump would get the money","depth":10},{"id":22,"text":"he wants .","depth":10},{"id":23,"text":"House Speaker Paul Ryan , R-Wis. , said after the White House meeting","depth":7},{"id":24,"text":"that Republicans \" want to keep the government open ,","depth":8},{"id":25,"text":"but we also want to see an agreement","depth":10},{"id":26,"text":"that protects the border .","depth":10},{"id":27,"text":"We have very serious concerns","depth":10},{"id":28,"text":"about securing our border . \"","depth":10},{"id":29,"text":"The bill ,","depth":9},{"id":30,"text":"which would fund nine federal departments and several smaller agencies at their current levels through Feb. 8 ,","depth":9},{"id":31,"text":"cleared the Senate late Wednesday on a voice vote","depth":8},{"id":32,"text":"and was likely to win approval in the House .","depth":7},{"id":33,"text":"Funding","depth":9},{"id":34,"text":"to keep the government open","depth":9},{"id":35,"text":"will lapse at midnight Friday","depth":8},{"id":36,"text":"unless Congress and the White House reach a deal","depth":8},{"id":37,"text":"to extend it .","depth":8},{"id":38,"text":"At the White House ceremony , Trump expressed hope","depth":6},{"id":39,"text":"that Congress could come up with an acceptable bill .","depth":6},{"id":40,"text":"\" We ' ll see what we can do ,","depth":8},{"id":41,"text":"but hopefully that will all come together , ''","depth":8},{"id":42,"text":"he said .","depth":7},{"id":43,"text":"He downplayed the use of the term `` wall , ''","depth":8},{"id":44,"text":"using the phrases `` physical barriers '' and `` steel slats . ''","depth":8},{"id":45,"text":"But he also said ,","depth":8},{"id":46,"text":"`` Walls work ,","depth":9},{"id":47,"text":"whether we like it or not . ''","depth":9},{"id":48,"text":"More :","depth":4},{"id":49,"text":"A look at what services will","depth":7},{"id":50,"text":"- and wo n't -","depth":7},{"id":51,"text":"be interrupted","depth":6},{"id":52,"text":"if there is a government shutdown","depth":5},{"id":53,"text":"Earlier Thursday , Trump tweeted about his demands for border wall money","depth":5},{"id":54,"text":"but did not specifically comment on the Senate 's short-term bill","depth":6},{"id":55,"text":"to keep the government in business through early February .","depth":6},{"id":56,"text":"\" When I begrudgingly signed the Omnibus Bill ,","depth":8},{"id":57,"text":"I was promised the Wall and Border Security by leadership .","depth":8},{"id":58,"text":"Would be done by end of year","depth":9},{"id":59,"text":"( NOW ) .","depth":9},{"id":60,"text":"It didn ' t happen !","depth":8},{"id":61,"text":"We foolishly fight for Border Security for other countries","depth":8},{"id":62,"text":"- but not for our beloved U.S.A.","depth":8},{"id":63,"text":"Not good ! \"","depth":7},{"id":64,"text":"he wrote .","depth":5},{"id":65,"text":"After Trump 's meeting with House Republicans , White House spokeswoman Sarah Sanders issued a statement","depth":6},{"id":66,"text":"that `` not surprisingly , they all feel strongly about Border Security","depth":7},{"id":67,"text":"- stopping the flow of drugs ,","depth":8},{"id":68,"text":"stopping human trafficking ,","depth":9},{"id":69,"text":"and stopping terrorism . ''","depth":9},{"id":70,"text":"`` We protect nations all over the world ,","depth":8},{"id":71,"text":"but Democrats are unwilling to protect our nation , ''","depth":8},{"id":72,"text":"she said .","depth":7},{"id":73,"text":"`` We urgently need funding for border security","depth":7},{"id":74,"text":"and that includes a wall . ''","depth":7},{"id":75,"text":"Conservatives in the House Freedom Caucus urged Trump to fight for border wall funding","depth":10},{"id":76,"text":"and to veto any spending measure","depth":11},{"id":77,"text":"that doesn ' t include the money .","depth":11},{"id":78,"text":"Freedom Caucus members Mark Meadows of North Carolina and Jim Jordan of Ohio were among the Republicans at the White House meeting with Trump .","depth":9},{"id":79,"text":"The spending bill could be the last chance","depth":12},{"id":80,"text":"to win the funding ,","depth":12},{"id":81,"text":"Freedom Caucus members argued ,","depth":11},{"id":82,"text":"because the House will fall under Democratic control in January","depth":11},{"id":83,"text":"and Rep. Nancy Pelosi , D-Calif. , is likely to become speaker .","depth":11},{"id":84,"text":"\" We ' ve been telling the American public","depth":12},{"id":85,"text":"that we were going to fight .","depth":12},{"id":86,"text":"They have no reason","depth":12},{"id":87,"text":"to believe us now , \"","depth":12},{"id":88,"text":"said Rep. Paul Gosar , R-Ariz. , a Freedom Caucus member .","depth":10},{"id":89,"text":"Republican congressional leaders said","depth":11},{"id":90,"text":"the short-term spending measure is the only way","depth":12},{"id":91,"text":"to avoid a government shutdown","depth":13},{"id":92,"text":"heading into the holidays .","depth":13},{"id":93,"text":"`` We don ' t want to end this year the way","depth":13},{"id":94,"text":"we began it ,","depth":13},{"id":95,"text":"with another government shutdown , \"","depth":12},{"id":96,"text":"said Senate Majority Leader Mitch McConnell , R-Ky. ,","depth":12},{"id":97,"text":"who pushed the temporary bill .","depth":12},{"id":98,"text":"Gosar countered","depth":10},{"id":99,"text":"that a government shutdown over the holidays may actually show","depth":11},{"id":100,"text":"\" we don ' t need all this big government . \"","depth":11},{"id":101,"text":"Freedom Caucus member Scott Perry , R-Pa. , said ,","depth":10},{"id":102,"text":"\" We made a promise to the American people","depth":13},{"id":103,"text":"to secure the border .","depth":13},{"id":104,"text":"This is our last chance .","depth":12},{"id":105,"text":"Nancy Pelosi will not do this . \"","depth":11},{"id":106,"text":"Pelosi and Senate Minority Leader Charles Schumer , D-N.Y. , said","depth":12},{"id":107,"text":"Democrats have no intention","depth":13},{"id":108,"text":"of approving money for a border wall .","depth":13},{"id":109,"text":"`` In terms of wall funding , that ' s a nonstarter , ''","depth":12},{"id":110,"text":"Pelosi said .","depth":12},{"id":111,"text":"Conservatives are `` angry and mad ,","depth":13},{"id":112,"text":"so they pound their fist on the table .","depth":13},{"id":113,"text":"... Their anger will result in a Trump shutdown , but not a Trump wall , ''","depth":12},{"id":114,"text":"Schumer said .","depth":11},{"id":115,"text":"Unless the funding is extended ,","depth":7},{"id":116,"text":"nine departments and several smaller agencies will run out of money","depth":9},{"id":117,"text":"and will be forced to close their doors .","depth":9},{"id":118,"text":"As many as 800,000 federal employees would be placed on furlough","depth":9},{"id":119,"text":"or would have to work","depth":10},{"id":120,"text":"without pay .","depth":10},{"id":121,"text":"Congress is scrambling to pass a short-term spending bill","depth":8},{"id":122,"text":"because lawmakers still haven ' t passed seven of the 12 appropriations bills","depth":11},{"id":123,"text":"needed to fund the government for the fiscal year","depth":12},{"id":124,"text":"that began Oct. 1 .","depth":12},{"id":125,"text":"The seven remaining bills would fund nine departments","depth":12},{"id":126,"text":"- Agriculture , Commerce , Justice , Homeland Security , Interior , State , Transportation , Treasury and Housing and Urban Development -","depth":12},{"id":127,"text":"as well as several smaller agencies .","depth":11},{"id":128,"text":"Those are the departments and agencies","depth":10},{"id":129,"text":"that would be affected by a government shutdown .","depth":10},{"id":130,"text":"House Appropriations Committee Chairman Rodney Frelinghuysen , R-N.J. , said","depth":9},{"id":131,"text":"that","depth":10},{"id":132,"text":"although he would have preferred to pass all seven of the bills ,","depth":11},{"id":133,"text":"\" there is still a broad ideological divide","depth":12},{"id":134,"text":"when it comes to our borders .","depth":12},{"id":135,"text":"\" A short-term bill would give the White House and lawmakers time","depth":10},{"id":136,"text":"\" to come to a responsible compromise","depth":11},{"id":137,"text":"that puts the security of our nation first , ''","depth":11},{"id":138,"text":"he said .","depth":9},{"id":139,"text":"More :","depth":9},{"id":140,"text":"Another government shutdown ?","depth":9},{"id":141,"text":"Congress has until Dec. 21 to pass a spending bill","depth":9},{"id":142,"text":"to keep the lights on","depth":9},{"id":143,"text":"More :","depth":9},{"id":144,"text":"The Ghost of Shutdowns","depth":9},{"id":145,"text":"Past haunts latest talks","depth":9},{"id":146,"text":"to keep the federal government open","depth":9}],"relations":[{"parent":293,"left":0,"right":292,"relation":"organization","nuclearity":"SN"},{"parent":292,"left":198,"right":291,"relation":"elaboration","nuclearity":"NS"},{"parent":198,"left":193,"right":197,"relation":"elaboration","nuclearity":"NS"},{"parent":193,"left":183,"right":192,"relation":"elaboration","nuclearity":"NS"},{"parent":183,"left":174,"right":182,"relation":"elaboration","nuclearity":"NS"},{"parent":174,"left":168,"right":173,"relation":"elaboration","nuclearity":"NS"},{"parent":168,"left":161,"right":167,"relation":"explanation","nuclearity":"NS"},{"parent":161,"left":150,"right":160,"relation":"elaboration","nuclearity":"NS"},{"parent":150,"left":149,"right":4,"relation":"same-unit","nuclearity":"NN"},{"parent":149,"left":1,"right":148,"relation":"purpose","nuclearity":"NS"},{"parent":148,"left":2,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":160,"left":152,"right":159,"relation":"elaboration","nuclearity":"NS"},{"parent":152,"left":151,"right":7,"relation":"explanation","nuclearity":"NS"},{"parent":151,"left":5,"right":6,"relation":"attribution","nuclearity":"SN"},{"parent":159,"left":156,"right":158,"relation":"context","nuclearity":"NS"},{"parent":156,"left":155,"right":12,"relation":"attribution","nuclearity":"NS"},{"parent":155,"left":8,"right":154,"relation":"organization","nuclearity":"SN"},{"parent":154,"left":153,"right":11,"relation":"same-unit","nuclearity":"NN"},{"parent":153,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":158,"left":