{"article_id":"CEzGoHO4sTW24Fkn","edus":[{"id":0,"text":"That was the response Friday from the Romney team","depth":3},{"id":1,"text":"after Obama 's campaign manager tried once again to wrench more tax documents from the Republican president candidate ,","depth":4},{"id":2,"text":"this time","depth":5},{"id":3,"text":"by offering to refrain from criticizing Mitt Romney 's transparency","depth":6},{"id":4,"text":"if he agrees to release five more years of returns .","depth":6},{"id":5,"text":"Romney campaign manager Matt Rhoades wrote a brief email to Obama campaign manager Jim Messina","depth":5},{"id":6,"text":"dismissing the offer .","depth":5},{"id":7,"text":"`` Thanks for the note .","depth":5},{"id":8,"text":"It is clear that President Obama wants nothing more than to talk about Governor Romney 's tax returns instead of the issues","depth":9},{"id":9,"text":"that matter to voters ,","depth":9},{"id":10,"text":"like putting Americans back to work ,","depth":9},{"id":11,"text":"fixing the economy","depth":10},{"id":12,"text":"and reining in spending , ''","depth":10},{"id":13,"text":"he wrote .","depth":7},{"id":14,"text":"`` If Governor Romney 's tax returns are the core message of your campaign ,","depth":7},{"id":15,"text":"there will be ample time","depth":8},{"id":16,"text":"for President Obama","depth":9},{"id":17,"text":"to discuss them over the next 81 days . ''","depth":9},{"id":18,"text":"The Obama campaign offer came","depth":5},{"id":19,"text":"after Romney said a day earlier","depth":6},{"id":20,"text":"that he 's `` never paid less than 13 percent '' in taxes over the last 10 years .","depth":6},{"id":21,"text":"Messina ,","depth":8},{"id":22,"text":"pressing Romney once again for documentation ,","depth":8},{"id":23,"text":"wrote","depth":7},{"id":24,"text":"that he wanted to offer `` assurances ''","depth":8},{"id":25,"text":"to allay Romney 's concerns","depth":9},{"id":26,"text":"that releasing additional tax returns would just feed the Democrats ' appetite for more .","depth":9},{"id":27,"text":"`` So I am prepared to provide assurances on just that point :","depth":9},{"id":28,"text":"if the Governor will release five years of returns ,","depth":10},{"id":29,"text":"I commit in turn","depth":11},{"id":30,"text":"that we will not criticize him","depth":13},{"id":31,"text":"for not releasing more","depth":13},{"id":32,"text":"-- neither in ads nor in other public communications or commentary for the rest of the campaign , ''","depth":12},{"id":33,"text":"Messina wrote .","depth":8},{"id":34,"text":"Messina , notably , did not offer to refrain from criticizing the contents of whatever documents","depth":8},{"id":35,"text":"Romney might furnish .","depth":8},{"id":36,"text":"And that 's the kind of criticism","depth":8},{"id":37,"text":"Romney has expressed concern about .","depth":8},{"id":38,"text":"Speaking on NBC 's `` Rock Center , '' wife Ann Romney voiced the same reservations .","depth":7},{"id":39,"text":"She said ,","depth":10},{"id":40,"text":"before Messina 's letter was sent out ,","depth":10},{"id":41,"text":"that releasing more returns would give Democrats more ammunition ,","depth":9},{"id":42,"text":"and claimed","depth":9},{"id":43,"text":"the campaign would not be releasing more .","depth":9},{"id":44,"text":"Mitt Romney tried to clear the air on Thursday over the issue ,","depth":4},{"id":45,"text":"offering his most expansive answer yet on the topic","depth":5},{"id":46,"text":"while speaking to reporters outside a South Carolina airport .","depth":5},{"id":47,"text":"`` I did go back","depth":7},{"id":48,"text":"and look at my taxes , ''","depth":7},{"id":49,"text":"Romney said .","depth":6},{"id":50,"text":"`` And over the past 10 years , I never paid less than 13 percent .","depth":6},{"id":51,"text":"I think","depth":7},{"id":52,"text":"the most recent year is 13.6","depth":9},{"id":53,"text":"( percent )","depth":9},{"id":54,"text":"or something like that . ''","depth":8},{"id":55,"text":"Democrats","depth":8},{"id":56,"text":"-- most notably Senate Majority Leader Harry Reid --","depth":8},{"id":57,"text":"have hounded him for months over the issue .","depth":7},{"id":58,"text":"Reid went so far as to claim on the Senate floor ,","depth":10},{"id":59,"text":"without offering proof beyond an unnamed source ,","depth":10},{"id":60,"text":"that Romney had n't paid taxes for 10 years ,","depth":9},{"id":61,"text":"and then challenged Romney","depth":9},{"id":62,"text":"to prove him wrong .","depth":9},{"id":63,"text":"Romney says","depth":8},{"id":64,"text":"the claim is `` totally false . ''","depth":8},{"id":65,"text":"But Reid and the Obama campaign dug in on their position","depth":6},{"id":66,"text":"that it 's Romney 's obligation to prove","depth":8},{"id":67,"text":"he paid those taxes","depth":8},{"id":68,"text":"-- rather than their obligation","depth":8},{"id":69,"text":"to prove","depth":9},{"id":70,"text":"their charges are true .","depth":9},{"id":71,"text":"Messina wrote in his letter","depth":4},{"id":72,"text":"that Romney would `` only '' have to release three more sets of returns","depth":5},{"id":73,"text":"-- on top of the 2010 and 2011 returns .","depth":5},{"id":74,"text":"`` This request for the release of five years ,","depth":6},{"id":75,"text":"covering the complete returns for 2007-2012 ,","depth":6},{"id":76,"text":"is surely not unreasonable .","depth":5},{"id":77,"text":"Other Presidential candidates have released more ,","depth":7},{"id":78,"text":"including the Governor 's father","depth":8},{"id":79,"text":"who provided 12 years of returns , ''","depth":8},{"id":80,"text":"he wrote ,","depth":6},{"id":81,"text":"adding","depth":7},{"id":82,"text":"that the campaign is looking for answers on `` the range in the effective rates","depth":9},{"id":83,"text":"paid ,","depth":9},{"id":84,"text":"the foreign accounts","depth":10},{"id":85,"text":"maintained ,","depth":10},{"id":86,"text":"the foreign investments","depth":11},{"id":87,"text":"made ,","depth":11},{"id":88,"text":"and the types of tax shelters","depth":11},{"id":89,"text":"used . ''","depth":11},{"id":90,"text":"He closed :","depth":7},{"id":91,"text":"`` And ,","depth":9},{"id":92,"text":"I repeat ,","depth":10},{"id":93,"text":"the Governor and his campaign can expect in return","depth":10},{"id":94,"text":"that we will refrain from questioning","depth":9},{"id":95,"text":"whether he has released enough","depth":10},{"id":96,"text":"or pressing for more . ''","depth":10}],"relations":[{"parent":193,"left":140,"right":192,"relation":"elaboration","nuclearity":"NS"},{"parent":140,"left":101,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":0,"right":100,"relation":"context","nuclearity":"NS"},{"parent":100,"left":1,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":99,"left":2,"right":98,"relation":"mode","nuclearity":"NS"},{"parent":98,"left":3,"right":4,"relation":"condition","nuclearity":"NS"},{"parent":139,"left":113,"right":138,"relation":"elaboration","nuclearity":"NS"},{"parent":113,"left":102,"right":112,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":5,"right":6,"relation":"mode","nuclearity":"NS"},{"parent":112,"left":7,"right":111,"relation":"organization","nuclearity":"SN"},{"parent":111,"left":107,"right":110,"relation":"joint","nuclearity":"NN"},{"parent":107,"left":106,"right":13,"relation":"attribution","nuclearity":"NS"},{"parent":106,"left":103,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":103,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":105,"left":10,"right":104,"relation":"joint","nuclearity":"NN"},{"parent":104,"left":11,"right":12,"relation":"joint","nuclearity":"NN"},{"parent":110,"left":14,"right":109,"relation":"condition","nuclearity":"SN"},{"parent":109,"left":15,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":108,"left":16,"right":17,"relation":"purpose","nuclearity"