{"article_id":"UGoA0qoPY0UMWYl4","edus":[{"id":0,"text":"Story highlights","depth":2},{"id":1,"text":"Newtown family members praise emotional Sen. Manchin for his courage","depth":2},{"id":2,"text":"Two senators reach a deal","depth":7},{"id":3,"text":"to expand background checks to gun shows , Internet","depth":7},{"id":4,"text":"President Obama would prefer stronger proposal ,","depth":8},{"id":5,"text":"but says","depth":9},{"id":6,"text":"it is welcome progress","depth":9},{"id":7,"text":"Democrats believe","depth":8},{"id":8,"text":"they have enough votes","depth":9},{"id":9,"text":"to overcome a GOP filibuster","depth":9},{"id":10,"text":"In a breakthrough on gun legislation , two U.S. senators","depth":9},{"id":11,"text":"-- a Democrat and a Republican --","depth":9},{"id":12,"text":"announced Wednesday","depth":8},{"id":13,"text":"they had worked out a compromise","depth":8},{"id":14,"text":"on expanding background checks on firearms buyers","depth":9},{"id":15,"text":"to include gun shows and Internet sales .","depth":9},{"id":16,"text":"The deal","depth":9},{"id":17,"text":"reached by Sens . Joe Manchin , D-West Virginia , and Pat Toomey , R-Pennsylvania ,","depth":9},{"id":18,"text":"sets up the likelihood of a major Senate debate on gun legislation","depth":9},{"id":19,"text":"starting as soon as Thursday ,","depth":9},{"id":20,"text":"when the chamber is expected to overcome a GOP filibuster attempt","depth":8},{"id":21,"text":"to block the proposals .","depth":8},{"id":22,"text":"President Barack Obama and leading Democrats have pushed for tighter gun laws in the aftermath of the December school massacre in Newtown , Connecticut ,","depth":7},{"id":23,"text":"that killed 20 first-graders and six educators .","depth":7},{"id":24,"text":"In an emotional scene later on Wednesday , Manchin choked up","depth":9},{"id":25,"text":"while meeting with relatives of Newtown victims","depth":9},{"id":26,"text":"who praised him for his political courage","depth":9},{"id":27,"text":"in taking on the powerful gun lobby .","depth":9},{"id":28,"text":"`` You give me more legislative strength","depth":9},{"id":29,"text":"than you know , ''","depth":9},{"id":30,"text":"Manchin said at one point .","depth":8},{"id":31,"text":"JUST WATCHED Gun legislation teed up in Congress","depth":8},{"id":32,"text":"Replay More Videos ...","depth":8},{"id":33,"text":"MUST WATCH Gun legislation teed up in Congress","depth":8},{"id":34,"text":"01:55","depth":8},{"id":35,"text":"JUST WATCHED","depth":10},{"id":36,"text":"Manchin chokes up with Newtown families","depth":10},{"id":37,"text":"Replay More Videos ...","depth":10},{"id":38,"text":"MUST WATCH Manchin chokes up with Newtown families","depth":11},{"id":39,"text":"01:26","depth":11},{"id":40,"text":"JUST WATCHED Giffords lobbies","depth":12},{"id":41,"text":"despite struggles","depth":12},{"id":42,"text":"Replay More Videos ...","depth":11},{"id":43,"text":"MUST WATCH Giffords lobbies despite struggles","depth":11},{"id":44,"text":"07:20","depth":11},{"id":45,"text":"JUST WATCHED Sandy Hook victims ' families want change","depth":12},{"id":46,"text":"Replay More Videos ...","depth":12},{"id":47,"text":"MUST WATCH Sandy Hook victims ' families want change","depth":11},{"id":48,"text":"01:48","depth":10},{"id":49,"text":"He then was unable to speak","depth":8},{"id":50,"text":"when asked by a reporter","depth":9},{"id":51,"text":"how the Newtown families affected his role in the negotiations with Toomey and others .","depth":9},{"id":52,"text":"Despite the agreement","depth":6},{"id":53,"text":"reached by Manchin and Toomey ,","depth":7},{"id":54,"text":"both rated as strong supporters of gun rights by the influential National Rifle Association ,","depth":7},{"id":55,"text":"the prospects","depth":7},{"id":56,"text":"for significant gun legislation","depth":8},{"id":57,"text":"to win congressional approval","depth":8},{"id":58,"text":"remained uncertain .","depth":6},{"id":59,"text":"The NRA responded to the Manchin-Toomey agreement","depth":8},{"id":60,"text":"by saying","depth":9},{"id":61,"text":"it would fail to address the core issues of gun violence .","depth":9},{"id":62,"text":"`` Expanding background checks at gun shows will not prevent the next shooting ,","depth":9},{"id":63,"text":"will not solve violent crime","depth":10},{"id":64,"text":"and will not keep our kids safe in schools , ''","depth":10},{"id":65,"text":"it said in a statement .","depth":8},{"id":66,"text":"Following the Newtown shootings by a lone gunman ,","depth":10},{"id":67,"text":"Obama called for a series of proposals","depth":11},{"id":68,"text":"including `` universal '' background checks on all gun purchases .","depth":11},{"id":69,"text":"Currently , the federal law","depth":12},{"id":70,"text":"requiring background checks","depth":12},{"id":71,"text":"covers licensed firearms dealers ,","depth":12},{"id":72,"text":"with private sales excluded .","depth":12},{"id":73,"text":"Fierce opposition by the NRA and its allies in Congress","depth":14},{"id":74,"text":"-- mostly conservative Republicans but also some Democrats from gun-friendly states --","depth":14},{"id":75,"text":"made clear","depth":13},{"id":76,"text":"that the universal checks","depth":14},{"id":77,"text":"sought by Obama","depth":14},{"id":78,"text":"had no chance","depth":14},{"id":79,"text":"of passing ,","depth":14},{"id":80,"text":"leading to efforts by Manchin , Toomey and others to work out a compromise .","depth":11},{"id":81,"text":"`` The bottom line for me is this :","depth":14},{"id":82,"text":"If expanding background checks","depth":17},{"id":83,"text":"to include gun shows and Internet sales can reduce the likelihood of criminals and mentally ill people from getting guns","depth":17},{"id":84,"text":"and we can do it in a fashion","depth":17},{"id":85,"text":"that does not infringe on the Second Amendment rights of law-abiding citizens ,","depth":17},{"id":86,"text":"then we should do it ,","depth":15},{"id":87,"text":"and in this amendment","depth":14},{"id":88,"text":"I think","depth":15},{"id":89,"text":"we do , ''","depth":15},{"id":90,"text":"Toomey told reporters on Wednesday .","depth":12},{"id":91,"text":"Asked later about criticism by the NRA and others ,","depth":13},{"id":92,"text":"he told CNN","depth":13},{"id":93,"text":"that the proposed legislation was `` not a cure-all ,","depth":13},{"id":94,"text":"but I think","depth":14},{"id":95,"text":"it would be some progress . ''","depth":14},{"id":96,"text":"Manchin noted","depth":13},{"id":97,"text":"that the proposal meant","depth":14},{"id":98,"text":"that firearms buyers at gun shows would face the same background check","depth":15},{"id":99,"text":"currently required in sales by federally licensed gun dealers .","depth":15},{"id":100,"text":"In addition , it would close a loophole","depth":14},{"id":101,"text":"that exempts intrastate gun sales on the Internet from requiring a background check ,","depth":14},{"id":102,"text":"he said .","depth":13},{"id":103,"text":"Addressing concerns of the NRA","depth":13},{"id":104,"text":"that expanding background checks would burden law-abiding gun owners","depth":14},{"id":105,"text":"seeking to trade or gift weapons in a personal transfer ,","depth":14},{"id":106,"text":"Manchin declared","depth":13},{"id":107,"text":"that `` personal transfers are not touched whatsoever . ''","depth":13},{"id":108,"text":"Another provision would recognize the legitimacy of concealed weapons permits across state lines .","depth":10},{"id":109,"text":"The Manchin-Toomey compromise also would require states and the federal government to provide records on criminals and the `` violently mentally ill '' to the national background check system ,","depth":12},{"id":110,"text":"addressing a criticism by the NRA and other opponents of gun laws","depth":13},{"id":111,"text":"that the existing system lacks substantive information .","depth":13},{"id":112,"text":"In addition , the plan calls for a new National Commission on Mass Violence to report in six months on `` all aspects of the problem ,","depth":12},{"id":113,"text":"including guns , school safety , mental health , and violent media or video games . ''","depth":12},{"id":114,"text":"The NRA said","depth":9},{"id":115,"text":"rejection of the universal checks","depth":11},{"id":116,"text":"sought by Obama","depth":11},{"id":117,"text":"was `` a positive development , ''","depth":10},{"id":118,"text":"and it called for `` serious and meaningful solutions '' to gun violence","depth":9},{"id":119,"text":"instead of `` blaming law-abiding gun owners for the acts of psychopathic murderers . ''","depth":9},{"id":120,"text":"Obama said","depth":11},{"id":121,"text":"there are aspects of the proposal","depth":14},{"id":122,"text":"that he would like to see strengthened .","depth":14},{"id":123,"text":"`` But the agreement does represent welcome and significant bipartisan progress .","depth":13},{"id":124,"text":"It recognizes","depth":14},{"id":125,"text":"that there are good people on both sides of this issue ,","depth":14},{"id":126,"text":"and we do n't have to agree on everything","depth":14},{"id":127,"text":"to know","depth":15},{"id":128,"text":"that we 've got to do something","depth":16},{"id":129,"text":"to stem the tide of gun violence , ''","depth":16},{"id":130,"text":"he said .","depth":10},{"id":131,"text":"`` Congress needs to finish the job , ''","depth":11},{"id":132,"text":"Obama added ,","depth":11},{"id":133,"text":"saying","depth":11},{"id":134,"text":"he would continue `` asking the American people to stand up","depth":13},{"id":135,"text":"and raise their voices","depth":13},{"id":136,"text":"because these measures deserve a vote . ''","depth":12},{"id":137,"text":"The Brady Campaign ,","depth":11},{"id":138,"text":"named after the former White House press secretary","depth":12},{"id":139,"text":"wounded in an assassination attempt on President Ronald Reagan ,","depth":12},{"id":140,"text":"called the compromise a `` good step forward , ''","depth":10},{"id":141,"text":"while New York Gov . Andrew Cuomo described it as `` better than nothing '' but a sellout to the gun lobby .","depth":10},{"id":142,"text":"`` This is a Congress","depth":14},{"id":143,"text":"that is captive of the extremists","depth":14},{"id":144,"text":"and there is no clearer proof of that than this , ''","depth":13},{"id":145,"text":"Cuomo said on the `` Capitol Pressroom '' radio show ,","depth":12},{"id":146,"text":"adding","depth":12},{"id":147,"text":"that the compromise meant `` we are not talking about a significant package of gun control anymore . ''","depth":12},{"id":148,"text":"Manchin told reporters","depth":9},{"id":149,"text":"the compromise on background checks would be the first amendment offered","depth":9},{"id":150,"text":"when the Senate begins debating the package of gun legislation .","depth":8},{"id":151,"text":"Senate Majority Leader Harry Reid , D-Nevada , said Tuesday","depth":9},{"id":152,"text":"he would hold a vote on opening debate on the gun package Thursday ,","depth":9},{"id":153,"text":"putting pressure on Manchin and Toomey to finalize their agreement","depth":9},{"id":154,"text":"intended to overcome a Republican filibuster of the legislation .","depth":9},{"id":155,"text":"The filibuster","depth":10},{"id":156,"text":"pledged by 14 GOP senators","depth":10},{"id":157,"text":"means Reid ,","depth":12},{"id":158,"text":"whose Democratic caucus holds 55 seats ,","depth":12},{"id":159,"text":"needs 60 votes","depth":11},{"id":160,"text":"to open debate on the gun legislation .","depth":10},{"id":161,"text":"Democrats believe","depth":9},{"id":162,"text":"that as many as a dozen GOP senators will vote with them ,","depth":10},{"id":163,"text":"making up for the handful of pro-gun Democrats","depth":11},{"id":164,"text":"who might vote against launching debate on the bill .","depth":11},{"id":165,"text":"Obama has made gun measures a major focus of his second-term agenda ,","depth":7},{"id":166,"text":"holding events across the country","depth":9},{"id":167,"text":"to push for Congress to vote on the package .","depth":9},{"id":168,"text":"He spoke Monday in Connecticut ,","depth":10},{"id":169,"text":"where the Newtown shootings occurred ,","depth":10},{"id":170,"text":"and Vice President Joe Biden made a similar call for action at the White House on Tuesday .","depth":9},{"id":171,"text":"A successful GOP filibuster would prevent a vote on specific components of the legislative package .","depth":8},{"id":172,"text":"Even if an amended bill passes the Senate ,","depth":9},{"id":173,"text":"approval from the Republican-led House remains uncertain .","depth":9},{"id":174,"text":"House Speaker John Boehner , R-Ohio , was noncommittal on Wednesday on prospects for gun legislation ,","depth":9},{"id":175,"text":"telling reporters","depth":10},{"id":176,"text":"he would wait to see what the Senate passes .","depth":10},{"id":177,"text":"Meanwhile , Democratic Rep. Mike Thompson of California and Republican Rep. Peter King of New York said","depth":9},{"id":178,"text":"they planned to introduce legislation in the House similar to the Senate compromise by Manchin and Toomey .","depth":9},{"id":179,"text":"Obama 's rhetoric has reflected the political uncertainty ,","depth":7},{"id":180,"text":"with the president and his aides using increasingly personal language","depth":8},{"id":181,"text":"intended to shame Republicans into allowing public votes on measures","depth":9},{"id":182,"text":"that have public support","depth":10},{"id":183,"text":"but are fiercely opposed by the NRA .","depth":10},{"id":184,"text":"On the other side , the NRA and its supporters in Congress say","depth":8},{"id":185,"text":"the Democratic proposals threaten the constitutional right","depth":10},{"id":186,"text":"to bear arms ,","depth":10},{"id":187,"text":"and also offer ineffective responses","depth":10},{"id":188,"text":"intended as political show instead of real solutions to the problem of gun violence in America .","depth":10},{"id":189,"text":"`` On firearms questions , on Second Amendment questions , there 's a divide in this country , ''","depth":9},{"id":190,"text":"NRA President David Keene told CNN .","depth":9},{"id":191,"text":"`` To call it an ideological divide is too simple","depth":10},{"id":192,"text":"because it 's a cultural divide .","depth":10},{"id":193,"text":"When something happens ,","depth":11},{"id":194,"text":"the folks on the other side from us say ,","depth":11},{"id":195,"text":"'well the problem 's the gun ,","depth":11},{"id":196,"text":"we need to do something about guns . ' ``","depth":11},{"id":197,"text":"Failing to pass new gun laws would be a stinging defeat for Obama and Democrats .","depth":8},{"id":198,"text":"However , a public perception","depth":10},{"id":199,"text":"that Republicans blocked popular proposals ,","depth":11},{"id":200,"text":"such as expanding background checks ,","depth":11},{"id":201,"text":"could harm GOP prospects in 2014 and 2016 among moderates","depth":10},{"id":202,"text":"they need in their corner","depth":11},{"id":203,"text":"to have any chance","depth":12},{"id":204,"text":"of countering strong support for Democrats by minority demographics such as Hispanic Americans , African Americans and the gay-lesbian vote .","depth":12},{"id":205,"text":"A new national survey showed","depth":8},{"id":206,"text":"that 86 % of Americans support some expansion of background checks .","depth":8},{"id":207,"text":"At the same time , the CNN/ORC International poll","depth":9},{"id":208,"text":"released Wednesday","depth":9},{"id":209,"text":"also showed","depth":8},{"id":210,"text":"a majority of respondents fear","depth":8},{"id":211,"text":"that increased background checks would lead to a federal registry of gun owners","depth":9},{"id":212,"text":"that could allow the government to take away legally owned weapons .","depth":9},{"id":213,"text":"Keene and other opponents worry","depth":9},{"id":214,"text":"that an expanded background check system would create a paper trail","depth":10},{"id":215,"text":"that could eventually be used","depth":11},{"id":216,"text":"to build a national gun registry ,","depth":12},{"id":217,"text":"which they reject as unconstitutional .","depth":12},{"id":218,"text":"They also contend","depth":9},{"id":219,"text":"it would prove a burden to law-abiding gun owners","depth":10},{"id":220,"text":"while doing nothing","depth":11},{"id":221,"text":"to stop criminals from getting hold of firearms .","depth":11},{"id":222,"text":"`` The one thing","depth":12},{"id":223,"text":"you know today","depth":12},{"id":224,"text":"is that","depth":11},{"id":225,"text":"if the government creates a record ,","depth":11},{"id":226,"text":"it 's not secure , ''","depth":11},{"id":227,"text":"Keene said ,","depth":9},{"id":228,"text":"adding","depth":9},{"id":229,"text":"that requiring background checks on all gun sales","depth":11},{"id":230,"text":"-- the so-called universal system --","depth":11},{"id":231,"text":"raised the question","depth":11},{"id":232,"text":"of `` is it linked to a national registration scheme . ''","depth":11},{"id":233,"text":"According to a summary of the compromise proposal ,","depth":7},{"id":234,"text":"it includes language","depth":8},{"id":235,"text":"that prohibits creation of a national gun registry or misusing information from background checks .","depth":8},{"id":236,"text":"The high political stakes of the divisive gun law debate have bred hardball tactics and strategies .","depth":6},{"id":237,"text":"The NRA has long kept a comprehensive scorecard of the voting records of legislators on gun issues ,","depth":7},{"id":238,"text":"which it combines with campaign contributions","depth":8},{"id":239,"text":"to try to influence elections .","depth":8},{"id":240,"text":"In response , a group","depth":9},{"id":241,"text":"led by New York Mayor Michael Bloomberg","depth":9},{"id":242,"text":"called Mayors Against Illegal Guns","depth":8},{"id":243,"text":"announced this week","depth":7},{"id":244,"text":"it was launching its own scorecard","depth":7},{"id":245,"text":"to identify members of Congress","depth":8},{"id":246,"text":"who vote against tougher gun laws .","depth":8},{"id":247,"text":"The Senate Judiciary Committee passed a package of gun laws","depth":8},{"id":248,"text":"proposed by Obama","depth":8},{"id":249,"text":"after the Newtown attack by a lone gunman .","depth":7},{"id":250,"text":"Proposals in the committee 's package included expanding background checks on gun buyers , toughening laws against gun trafficking and straw purchases , banning semiautomatic rifles","depth":10},{"id":251,"text":"modeled after military assault weapons","depth":10},{"id":252,"text":"as well as large-capacity ammunition magazines ,","depth":9},{"id":253,"text":"and coming up with ideas","depth":9},{"id":254,"text":"for improving school safety .","depth":9},{"id":255,"text":"The weapons ban ,","depth":10},{"id":256,"text":"which would update a similar 1994 law","depth":11},{"id":257,"text":"that expired a decade later ,","depth":11},{"id":258,"text":"already has been dropped ,","depth":9},{"id":259,"text":"though Reid has promised a floor vote on it as an amendment to the package .","depth":8},{"id":260,"text":"Some states already have passed stricter gun laws similar to the federal proposals since the Newtown shootings .","depth":7},{"id":261,"text":"They include Connecticut ,","depth":9},{"id":262,"text":"where the killings occurred ,","depth":9},{"id":263,"text":"and Colorado , the site of two other notorious mass shootings","depth":9},{"id":264,"text":"that contributed to a renewed gun debate in America .","depth":9},{"id":265,"text":"The current background check system was created in 1989 .","depth":8},{"id":266,"text":"It requires federally approved gun dealers to check","depth":10},{"id":267,"text":"whether gun buyers have a criminal background or other problem","depth":11},{"id":268,"text":"to make them ineligible to purchase a firearm .","depth":11},{"id":269,"text":"Under the system , the gun dealer maintains a record of the transaction ,","depth":10},{"id":270,"text":"but the federal government keeps no such identifying paperwork .","depth":10},{"id":271,"text":"According to a Justice Department report ,","depth":9},{"id":272,"text":"less than 2 % of those","depth":12},{"id":273,"text":"seeking to purchase firearms","depth":12},{"id":274,"text":"were denied","depth":11},{"id":275,"text":"because of background checks from 1998 through 2009 .","depth":10},{"id":276,"text":"Opponents cite that figure as evidence","depth":10},{"id":277,"text":"that the system fails to stop illegal weapons sales","depth":11},{"id":278,"text":"that the legislation seeks to target ,","depth":11},{"id":279,"text":"while supporters say","depth":10},{"id":280,"text":"the result shows","depth":12},{"id":281,"text":"the system keeps some guns out of the hands of the wrong people","depth":12},{"id":282,"text":"and the system should be expanded","depth":12},{"id":283,"text":"and strengthened .","depth":12}],"relations":[{"parent":567,"left":285,"right":566,"relation":"organization","nuclearity":"SN"},{"parent":285,"left":0,"right":1,"relation":"organization","nuclearity":"SN"},{"parent":566,"left":447,"right":565,"relation":"elaboration","nuclearity":"NS"},{"parent":447,"left":334,"right":446,"relation":"joint","nuclearity":"NN"},{"parent":334,"left":304,"right":333,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":292,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":292,"left":286,"right":291,"relation":"elaboration","nuclearity":"NS"},{"parent":286,"left":2,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":291,"left":288,"right":290,"relation":"joint","nuclearity":"NN"},{"parent":288,"left":4,"right":287,"relation":"adversative","nuclearity":"SN"},{"parent":287,"left":5,"right":6,"relation":"attribution","nuclearity":"SN"},{"parent":290,"left":7,"right":289,"relation":"attribution","nuclearity":"SN"},{"parent":289,"left":8,"right":9,"relation":"purpose","nuclearity":"NS"},{"parent":303,"left":297,"right":302,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":294,"right":296,"relation":"attribution","nuclearity":"SN"},{"parent":294,"left":293,"right":12,"relation":"same-unit","nuclearity":"NN"},{"parent":293,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":296,"left":13,"right":295,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":14,"right":15,"relation":"purpose","nuclearity":"NS"},{"parent":302,"left":300,"right":301,"relation":"context","nuclearity":"NS"},{"parent":300,"left":298,"right":299,"relation":"same-unit","nuclearity":"NN"},{"parent":298,"left":16,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":18,"right":19,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":20,"right":21,"relation":"elaboration","nuclearity":"NS"},{"parent":333,"left":312,"right":332,"relation":"joint","nuclearity":"NN"},{"parent":312,"left":305,"right":311,"relation":"context","nuclearity":"SN"},{"parent":305,"left":22,"right":23,"relation":"elaboration","nuclearity":"NS"},{"parent":311,"left":308,"right":310,"relation":"elaboration","nuclearity":"NS"},{"parent":308,"left":306,"right":307,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":24,"right":25,"relation":"context","nuclearity":"NS"},{"parent":307,"left":26,"right":27,"relation":"elaboration","nuclearity":"NS"},{"parent":310,"left":309,"right":30,"relation":"attribution","nuclearity":"NS"},{"parent":309,"left":28,"right":29,"relation":"adversative","nuclearity":"NS"},{"parent":332,"left":315,"right":331,"relation":"joint","nuclearity":"NN"},{"parent":315,"left":313,"right":314,"relation":"context","nuclearity":"SN"},{"parent":313,"left":31,"right":32,