n":"attribution","nuclearity":"SN"},{"parent":260,"left":67,"right":68,"relation":"causal","nuclearity":"NS"},{"parent":264,"left":69,"right":263,"relation":"attribution","nuclearity":"SN"},{"parent":263,"left":70,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":295,"left":72,"right":294,"relation":"adversative","nuclearity":"SN"},{"parent":294,"left":266,"right":293,"relation":"elaboration","nuclearity":"NS"},{"parent":266,"left":73,"right":74,"relation":"attribution","nuclearity":"SN"},{"parent":293,"left":279,"right":292,"relation":"adversative","nuclearity":"SN"},{"parent":279,"left":273,"right":278,"relation":"elaboration","nuclearity":"NS"},{"parent":273,"left":270,"right":272,"relation":"restatement","nuclearity":"NN"},{"parent":270,"left":268,"right":269,"relation":"attribution","nuclearity":"NS"},{"parent":268,"left":267,"right":77,"relation":"attribution","nuclearity":"SN"},{"parent":267,"left":75,"right":76,"relation":"context","nuclearity":"NS"},{"parent":269,"left":78,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":272,"left":271,"right":82,"relation":"adversative","nuclearity":"NS"},{"parent":271,"left":80,"right":81,"relation":"attribution","nuclearity":"NS"},{"parent":278,"left":275,"right":277,"relation":"elaboration","nuclearity":"NS"},{"parent":275,"left":83,"right":274,"relation":"same-unit","nuclearity":"NN"},{"parent":274,"left":84,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":277,"left":276,"right":88,"relation":"same-unit","nuclearity":"NN"},{"parent":276,"left":86,"right":87,"relation":"attribution","nuclearity":"NS"},{"parent":292,"left":282,"right":291,"relation":"elaboration","nuclearity":"NS"},{"parent":282,"left":281,"right":92,"relation":"attribution","nuclearity":"SN"},{"parent":281,"left":280,"right":91,"relation":"same-unit","nuclearity":"NN"},{"parent":280,"left":89,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":93,"right":290,"relation":"attribution",