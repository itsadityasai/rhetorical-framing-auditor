{"article_id":"4SYLJmNefnKd8xJf","edus":[{"id":0,"text":"Twitter censored a tweet from President Donald Trump on Thursday night","depth":6},{"id":1,"text":"where the president expressed anger at rioters in Minneapolis","depth":7},{"id":2,"text":"who were \" dishonoring the memory of George Floyd \"","depth":8},{"id":3,"text":"and warning","depth":10},{"id":4,"text":"that","depth":10},{"id":5,"text":"\" when the looting starts ,","depth":10},{"id":6,"text":"the shooting starts. \"","depth":10},{"id":7,"text":"Trump ' s remarks ,","depth":7},{"id":8,"text":"said Twitter ,","depth":7},{"id":9,"text":"were \" glorifying violence . \"","depth":6},{"id":10,"text":"\" I can ' t stand back","depth":10},{"id":11,"text":"& watch this happen to a great American City , Minneapolis .","depth":10},{"id":12,"text":"A total lack of leadership .","depth":9},{"id":13,"text":"Either the very weak Radical Left Mayor , Jacob Frey , get his act together","depth":10},{"id":14,"text":"and bring the City under control ,","depth":10},{"id":15,"text":"or I will send in the National Guard","depth":10},{"id":16,"text":"& get the job done right , \"","depth":10},{"id":17,"text":"Trump tweeted .","depth":7},{"id":18,"text":"\" These THUGS are dishonoring the memory of George Floyd ,","depth":8},{"id":19,"text":"and I won ' t let that happen .","depth":8},{"id":20,"text":"Just spoke to Governor Tim Walz","depth":10},{"id":21,"text":"and told him","depth":11},{"id":22,"text":"that the Military is with him all the way .","depth":11},{"id":23,"text":"Any difficulty","depth":11},{"id":24,"text":"and we will assume control","depth":11},{"id":25,"text":"but , when the looting starts ,","depth":11},{"id":26,"text":"the shooting starts .","depth":11},{"id":27,"text":"Thank you ! \"","depth":8},{"id":28,"text":"When Trump ' s tweet is embedded in a post","depth":7},{"id":29,"text":"it does not show the censorship label","depth":8},{"id":30,"text":"that Twitter applied :","depth":8},{"id":31,"text":"....These THUGS are dishonoring the memory of George Floyd ,","depth":9},{"id":32,"text":"and I won ' t let that happen .","depth":9},{"id":33,"text":"Just spoke to Governor Tim Walz","depth":10},{"id":34,"text":"and told him","depth":11},{"id":35,"text":"that the Military is with him all the way .","depth":11},{"id":36,"text":"Any difficulty","depth":12},{"id":37,"text":"and we will assume control","depth":12},{"id":38,"text":"but , when the looting starts ,","depth":12},{"id":39,"text":"the shooting starts .","depth":12},{"id":40,"text":"Thank you !","depth":10},{"id":41,"text":"- Donald J. Trump","depth":9},{"id":42,"text":"( @ realDonaldTrump )","depth":9},{"id":43,"text":"May 29 , 2020","depth":8},{"id":44,"text":"However , a screenshot of the tweet on Twitter ' s platform shows the censorship label","depth":5},{"id":45,"text":"that Twitter applied :","depth":5},{"id":46,"text":"In a statement , Twitter Comms said :","depth":6},{"id":47,"text":"\" This Tweet violates our policies regarding the glorification of violence","depth":7},{"id":48,"text":"based on the historical context of the last line , its connection to violence , and the risk","depth":8},{"id":49,"text":"it could inspire similar actions today . \"","depth":8},{"id":50,"text":"\" We ' ve taken action in the interest","depth":9},{"id":51,"text":"of preventing others from being inspired to commit violent acts ,","depth":9},{"id":52,"text":"but have kept the Tweet on Twitter","depth":9},{"id":53,"text":"because it is important that the public still be able to see the Tweet","depth":10},{"id":54,"text":"given its relevance to ongoing matters of public importance , \"","depth":10},{"id":55,"text":"Twitter added .","depth":7},{"id":56,"text":"\" As is standard with this notice ,","depth":8},{"id":57,"text":"engagements with the Tweet will be limited .","depth":8},{"id":58,"text":"People will be able to Retweet with Comment ,","depth":8},{"id":59,"text":"but will not be able to Like , Reply or Retweet it . \"","depth":8},{"id":60,"text":"Twitter ' s actions against the president come","depth":5},{"id":61,"text":"after Trump signed an executive order on Thursday","depth":7},{"id":62,"text":"that took action against social media companies","depth":8},{"id":63,"text":"for repeatedly discriminating against and censoring conservatives .","depth":8},{"id":64,"text":"He issued the executive order","depth":7},{"id":65,"text":"after Twitter started applying controversial labels to his tweets","depth":8},{"id":66,"text":"while largely ignoring false statements from Democrats and the Chinese Communist Party","depth":9},{"id":67,"text":"( CCP ) .","depth":9},{"id":68,"text":"Twitter took no action against numerous tweets","depth":5},{"id":69,"text":"that appeared to encourage rioting , destruction of property , or fighting against law enforcement .","depth":5},{"id":70,"text":"The following controversial tweets ,","depth":7},{"id":71,"text":"which Twitter did not take any action against ,","depth":7},{"id":72,"text":"are from public figures","depth":6},{"id":73,"text":"or they are tweets","depth":6},{"id":74,"text":"that went viral on the platform","depth":7},{"id":75,"text":"and garnered tens of thousands of retweets :","depth":7},{"id":76,"text":"Twitter CEO Jack Dorsey has ties to Black Lives Matter","depth":7},{"id":77,"text":"and his company \" painted # blacklivesmatter on a wall at its San Francisco headquarters ,","depth":8},{"id":78,"text":"placing the company squarely into the national debate about excessive force","depth":9},{"id":79,"text":"used by police with blacks , \"","depth":9},{"id":80,"text":"USA Today reported in 2014 .","depth":6},{"id":81,"text":"The Daily Caller highlighted in 2018 an article","depth":10},{"id":82,"text":"that Dorsey promoted on his Twitter account","depth":11},{"id":83,"text":"and said","depth":12},{"id":84,"text":"was \" great. \"","depth":12},{"id":85,"text":"The article essentially called for turning the entire United States into California","depth":10},{"id":86,"text":"and completely eliminating the Republican Party .","depth":10},{"id":87,"text":"The Daily Caller reported :","depth":9},{"id":88,"text":"Author and media consultant Peter Leyden and political commentator Ruy Teixeira argued in the article","depth":11},{"id":89,"text":"titled \" The Great Lesson of California in America ' s New Civil War \"","depth":11},{"id":90,"text":"that America is already in the midst of a second major domestic conflict of sorts","depth":11},{"id":91,"text":"and the way out is for the rest of the country to imitate California . \"","depth":11},{"id":92,"text":"In this current period of American politics , at this juncture in our history , there ' s no way","depth":12},{"id":93,"text":"that a bipartisan path provides the way forward , \"","depth":12},{"id":94,"text":"they wrote .","depth":11},{"id":95,"text":"\" The way forward is on the path","depth":11},{"id":96,"text":"California blazed about 15 years ago. \"","depth":11},{"id":97,"text":"Essentially , the authors called for a complete marginalization of the Republican Party and its voters","depth":10},{"id":98,"text":"since they only care \" about rule by and for billionaires at the expense of working people \" and not \" average citizens. \"","depth":10},{"id":99,"text":"California , despite its mass wealth inequality , growing lack of social cohesion , poverty , and soaring housing costs \" provides a model for America as a whole , \"","depth":9},{"id":100,"text":"according to Leyden and Teixeira . ...","depth":9},{"id":101,"text":"Yet , they do not call for Democrats to try to understand their political adversaries .","depth":7},{"id":102,"text":"Instead , they proposed","depth":8},{"id":103,"text":"Americans \" take the Republican Party down for a generation or two \"","depth":9},{"id":104,"text":"in order to save the country .","depth":9},{"id":105,"text":",","depth":4},{"id":106,"text":"headed by bestselling author and popular podcast host Ben Shapiro ,","depth":4},{"id":107,"text":"is a leading provider of conservative news ,","depth":4},{"id":108,"text":"cutting through the mainstream media ' s rhetoric","depth":5},{"id":109,"text":"to provide readers the most important , relevant , and engaging stories of the day .","depth":5},{"id":110,"text":"Get inside access to","depth":3},{"id":111,"text":"by becoming a member .","depth":3}],"relations":[{"parent":223,"left":216,"right":222,"relation":"elaboration","nuclearity":"NS"},{"parent":216,"left":171,"right":215,"relation":"elaboration","nuclearity":"NS"},{"parent":171,"left":155,"right":170,"relation":"elaboration","nuclearity":"NS"},{"parent":155,"left":121,"right":154,"relation":"elaboration","nuclearity":"NS"},{"parent":121,"left":118,"right":120,"relation":"elaboration","nuclearity":"NS"},{"parent":118,"left":0,"right":117,"relation":"elaboration","nuclearity":"NS"},{"parent":117,"left":1,"right":116,"relation":"elaboration","nuclearity":"NS"},{"parent":116,"left":2,"right":115,"relation":"joint","nuclearity":"NN"},{"parent":115,"left":113,"right":114,"relation":"attribution","nuclearity":"SN"},{"parent":113,"left":3,"right":4,"relation":"attribution","nuclearity":"SN"},{"parent":114,"left":5,"right":6,"relation":"condition","nuclearity":"SN"},{"parent":120,"left":119,"right":9,"relation":"same-unit","nuclearity":"NN"},{"parent":119,"left":7,"right":8,"relation":"attribution","nuclearity":"NS"},{"parent":154,"left":138,"right":153,"relation":"joint","nuclearity":"NN"},{"parent":138,"left":128,"right":137,"relation":"joint","nuclearity":"NN"},{"parent":128,"left":127,"right":17,"relation":"attribution","nuclearity":"NS"},{"parent":127,"left":123,"right":126,"relation":"explanation","nuclearity":"SN"},{"parent":123,"left":122,"right":12,"relation":"evaluation","nuclearity":"NS"},{"parent":122,"left":10,"right":11,"relation":"joint","nuclearity":"NN"},{"parent":126,"left":124,"right":125,"relation":"joint","nuclearity":"NN"},{"parent":124,"left":13,"right":14,"relati