{"article_id":"7DxifrIf8lvUFsjS","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"Judge Brett Kavanaugh is enduring Day 3 of his Senate confirmation hearing","depth":4},{"id":2,"text":"after facing a marathon day of questioning Wednesday from members of the Senate Judiciary Committee .","depth":4},{"id":3,"text":"Senators grilled the 53-year-old appeals court judge on everything from his view of Democrat demands for more documents to what his kids thought of the hearing .","depth":5},{"id":4,"text":"`` They gave me a big hug","depth":8},{"id":5,"text":"and said ,","depth":9},{"id":6,"text":"'Good job , Daddy , ' ''","depth":9},{"id":7,"text":"Judge Kavanaugh told Sen. Lindsey Graham","depth":8},{"id":8,"text":"( R-SC ) .","depth":8},{"id":9,"text":"`` My personal beliefs are not relevant to how I decide cases , ''","depth":7},{"id":10,"text":"Kavanaugh assured .","depth":7},{"id":11,"text":"Senators like Dianne Feinstein","depth":8},{"id":12,"text":"( D-CA ) ,","depth":8},{"id":13,"text":"however , wanted to nail him down on hot topics such as abortion","depth":7},{"id":14,"text":"and learn exactly what he meant","depth":8},{"id":15,"text":"when he called Roe v. Wade `` settled law . ''","depth":8},{"id":16,"text":"`` It 's an important precedent of the Supreme Court","depth":9},{"id":17,"text":"that 's been reaffirmed many times , ''","depth":9},{"id":18,"text":"replied Kavanaugh .","depth":8},{"id":19,"text":"Kavanaugh was mum , however ,","depth":8},{"id":20,"text":"regarding his stance","depth":9},{"id":21,"text":"on whether presidents should be protected from criminal investigations .","depth":9},{"id":22,"text":"`` I ca n't give you an answer on that hypothetical question , ''","depth":9},{"id":23,"text":"Kavanaugh told the Senate panel ,","depth":9},{"id":24,"text":"though he did declare earlier","depth":9},{"id":25,"text":"that `` no one is above the law . ''","depth":9},{"id":26,"text":"The most contentious questioning came from Sens . Patrick Leahy","depth":12},{"id":27,"text":"( D-VT )","depth":12},{"id":28,"text":"and Dick Durbin","depth":12},{"id":29,"text":"( D-IL ) .","depth":12},{"id":30,"text":"They wanted to know","depth":11},{"id":31,"text":"if Judge Kavanaugh knew about emails","depth":13},{"id":32,"text":"stolen from them in the early 2000s","depth":13},{"id":33,"text":"that provided Republicans information during the confirmation process of some of President George W. Bush 's judicial nominees .","depth":12},{"id":34,"text":"Leahy tried to tie Kavanaugh to former Senate aide Manny Miranda ,","depth":11},{"id":35,"text":"who helped obtain the emails .","depth":11},{"id":36,"text":"Sen. Graham quickly gave Kavanaugh an opportunity","depth":12},{"id":37,"text":"to provide a straight answer .","depth":12},{"id":38,"text":"`` Did you ever knowingly participate in stealing anything from Senator Leahy or any other senator ? ''","depth":13},{"id":39,"text":"Graham asked .","depth":13},{"id":40,"text":"`` Did you ever know","depth":14},{"id":41,"text":"that you were dealing with anything","depth":15},{"id":42,"text":"that was stolen property ? ''","depth":15},{"id":43,"text":"he pressed .","depth":13},{"id":44,"text":"And Miranda himself provided cover during 's `` Faith Nation ''","depth":10},{"id":45,"text":"when he emailed an exclusive statement to Chief Political Analyst David Brody .","depth":10},{"id":46,"text":"`` I can confirm","depth":11},{"id":47,"text":"that Brett Kavanaugh knew nothing of the source of any information","depth":13},{"id":48,"text":"that we obtained ,","depth":13},{"id":49,"text":"nor did I ever meet with him privately or publicly","depth":13},{"id":50,"text":"to discuss it , ''","depth":13},{"id":51,"text":"Miranda said in the statement .","depth":10},{"id":52,"text":"Brody says","depth":8},{"id":53,"text":"Democrats are trying to twist this into an opportunity","depth":10},{"id":54,"text":"to paint Judge Kavanaugh in a negative light .","depth":10},{"id":55,"text":"`` Republicans will call it character assassination ,","depth":11},{"id":56,"text":"but this is what you do","depth":12},{"id":57,"text":"when you really do n't have the goods on a nominee , ''","depth":12},{"id":58,"text":"Brody explained .","depth":10},{"id":59,"text":"Senators will have 20 minutes each Wednesday","depth":4},{"id":60,"text":"to ask Judge Kavanaugh another round of questions ,","depth":4},{"id":61,"text":"and Senate Judiciary Chairman Chuck Grassley","depth":6},{"id":62,"text":"( R-IA )","depth":6},{"id":63,"text":"threatened to go into the weekend","depth":5},{"id":64,"text":"if needed","depth":5},{"id":65,"text":"to finish this hearing .","depth":5}],"relations":[{"parent":131,"left":0,"right":130,"relation":"organization","nuclearity":"SN"},{"parent":130,"left":123,"right":129,"relation":"joint","nuclearity":"NN"},{"parent":123,"left":67,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":1,"right":2,"relation":"context","nuclearity":"NS"},{"parent":122,"left":74,"right":121,"relation":"adversative","nuclearity":"NN"},{"parent":74,"left":3,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":71,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":69,"right":70,"relation":"attribution","nuclearity":"NS"},{"parent":69,"left":4,"right":68,"relation":"joint","nuclearity":"NN"},{"parent":68,"left":5,"right":6,"relation":"attribution","nuclearity":"SN"},{"parent":70,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":9,"right":10,"relation":"attribution","nuclearity":"NS"},{"parent":121,"left":81,"right":120,"relation":"joint","nuclearity":"NN"},{"parent":81,"left":76,"right":80,"relation":"joint","nuclearity":"NN"},{"parent":76,"left":75,"right":13,"relation":"same-unit","nuclearity":"NN"},{"parent":75,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":77,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"