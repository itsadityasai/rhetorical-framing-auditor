{"article_id":"ZB2jsvIxBFpgGtf3","edus":[{"id":0,"text":"( ) -","depth":1},{"id":1,"text":"The U.S. Congress has strong arguments","depth":7},{"id":2,"text":"for obtaining President Donald Trump ' s tax returns ,","depth":7},{"id":3,"text":"but first faces a long court battle","depth":7},{"id":4,"text":"that could extend into the 2020 presidential election ,","depth":7},{"id":5,"text":"some legal experts said .","depth":5},{"id":6,"text":"Democratic Party leaders ,","depth":8},{"id":7,"text":"who took control of the House in November ,","depth":8},{"id":8,"text":"have recently stepped up pressure on Trump to release tax records from 2013 to 2018 ,","depth":8},{"id":9,"text":"which","depth":10},{"id":10,"text":"legal experts said","depth":10},{"id":11,"text":"could shed light on the president ' s business dealings .","depth":9},{"id":12,"text":"Richard Neal , chairman of the House Ways and Means committee ,","depth":9},{"id":13,"text":"which oversees tax matters ,","depth":9},{"id":14,"text":"has given the Internal Revenue Service until April 23 to produce the documents .","depth":8},{"id":15,"text":"Trump ' s personal lawyer , William Consovoy , in a letter to the Treasury Department on Monday , accused Neal ' s committee of using its \" investigatory tools","depth":8},{"id":16,"text":"to unlawfully retaliate against a political opponent . \"","depth":8},{"id":17,"text":"Lawmakers can go to court","depth":10},{"id":18,"text":"and ask a judge to force disclosure of the tax returns ,","depth":10},{"id":19,"text":"but such a process could unfold slowly","depth":10},{"id":20,"text":"and become an issue in the 2020 election ,","depth":10},{"id":21,"text":"legal experts said .","depth":8},{"id":22,"text":"\" I expect","depth":9},{"id":23,"text":"Trump will stall at every opportunity , \"","depth":9},{"id":24,"text":"said Steven Rosenthal , a tax lawyer with the Urban-Brookings Tax Policy Center in Washington ,","depth":9},{"id":25,"text":"adding","depth":10},{"id":26,"text":"that \" delay is a victory for Trump . \"","depth":10},{"id":27,"text":"Consovoy did not immediately respond to a request for comment .","depth":6},{"id":28,"text":"A law from 1924 says","depth":7},{"id":29,"text":"that the IRS \" shall furnish \" any tax return","depth":8},{"id":30,"text":"requested by the chair of the Ways and Means committee .","depth":8},{"id":31,"text":"\" If you look at the plain language of the statute ,","depth":8},{"id":32,"text":"Neal is on strong footing here , \"","depth":8},{"id":33,"text":"said Jessica Levinson , a professor at Loyola Law School in Los Angeles .","depth":7},{"id":34,"text":"But this does not mean that Congress has unlimited power","depth":8},{"id":35,"text":"to request tax returns ,","depth":8},{"id":36,"text":"experts said .","depth":7},{"id":37,"text":"If Congress invokes this statute ,","depth":9},{"id":38,"text":"it must be acting with a legitimate legislative purpose ,","depth":9},{"id":39,"text":"legal experts said ,","depth":8},{"id":40,"text":"citing a 1957 ruling by the U.S. Supreme Court .","depth":8},{"id":41,"text":"In that decision , the Court said","depth":9},{"id":42,"text":"that Congress was not a \" law enforcement agency \"","depth":10},{"id":43,"text":"that can seek information","depth":11},{"id":44,"text":"to uncover crimes .","depth":11},{"id":45,"text":"Neal said in an April 4 statement","depth":7},{"id":46,"text":"that the documents will aid Congress","depth":8},{"id":47,"text":"in evaluating","depth":9},{"id":48,"text":"whether the IRS has been effective","depth":10},{"id":49,"text":"in enforcing tax laws against the president .","depth":10},{"id":50,"text":"\" The IRS has a policy","depth":9},{"id":51,"text":"of auditing the tax returns of all sitting presidents and vice presidents ,","depth":9},{"id":52,"text":"yet little is known about the effectiveness of the law , \"","depth":8},{"id":53,"text":"Neal said .","depth":7},{"id":54,"text":"Consovoy in Monday ' s letter said","depth":8},{"id":55,"text":"that \" no one actually believes \" Neal ' s \" invented \" reasons","depth":9},{"id":56,"text":"for wanting the tax returns .","depth":9},{"id":57,"text":"Ross Garber , a lawyer in Washington","depth":11},{"id":58,"text":"focusing on political investigations ,","depth":11},{"id":59,"text":"called Consovoy ' s argument \" plausible \"","depth":10},{"id":60,"text":"and said","depth":10},{"id":61,"text":"it was possible a court would side with the president .","depth":10},{"id":62,"text":"Garber said","depth":9},{"id":63,"text":"Congress ' authority","depth":13},{"id":64,"text":"to request the documents","depth":13},{"id":65,"text":"would be stronger","depth":12},{"id":66,"text":"if it were conducting impeachment proceedings .","depth":11},{"id":67,"text":"Courts have held","depth":12},{"id":68,"text":"that Congress ' investigative powers are broader in the impeachment context ,","depth":12},{"id":69,"text":"he said .","depth":11},{"id":70,"text":"But Edward Kleinbard , a tax law professor at the University of Southern California , said","depth":8},{"id":71,"text":"Neal ' s stated reason","depth":10},{"id":72,"text":"for demanding the tax returns","depth":11},{"id":73,"text":"- ensuring that tax laws are being enforced against Trump -","depth":11},{"id":74,"text":"was more than sufficient .","depth":9},{"id":75,"text":"\" The integrity of tax system depends on peoples ' willingness","depth":10},{"id":76,"text":"to assess tax against themselves .","depth":10},{"id":77,"text":"The president of the U.S. is the taxpayer-in-chief ,","depth":10},{"id":78,"text":"and he sets the standard , \"","depth":10},{"id":79,"text":"Kleinbard .","depth":8},{"id":80,"text":"Related Coverage","depth":4},{"id":81,"text":"House panels issue subpoenas to Deutsche Bank , others in Trump probe","depth":4},{"id":82,"text":"Kleinbard ,","depth":7},{"id":83,"text":"who formerly served as chief of staff to Congress ' Joint Committee on Taxation ,","depth":7},{"id":84,"text":"noted","depth":6},{"id":85,"text":"that Trump was the first U.S. president in nearly 40 years","depth":6},{"id":86,"text":"who has not voluntarily released his tax returns to the public .","depth":6},{"id":87,"text":"Trump has said","depth":6},{"id":88,"text":"he can not make the returns public","depth":7},{"id":89,"text":"because they are under audit .","depth":7},{"id":90,"text":"Kleinbard called that argument \" nonsense , \"","depth":6},{"id":91,"text":"saying","depth":7},{"id":92,"text":"nothing prohibits a person under audit from releasing his tax returns .","depth":7}],"relations":[{"parent":185,"left":0,"right":184,"relation":"organization","nuclearity":"SN"},{"parent":184,"left":171,"right":183,"relation":"elaboration","nuclearity":"NS"},{"parent":171,"left":119,"right":170,"relation":"elaboration","nuclearity":"NS"},{"parent":119,"left":97,"right":118,"relation":"elaboration","nuclearity":"NS"},{"parent":97,"left":96,"right":5,"relation":"attribution","nuclearity":"NS"},{"parent":96,"left":94,"right":95,"relation":"adversative","nuclearity":"SN"},{"parent":94,"left":1,"right":2,"relation":"purpose","nuclearity":"NS"},{"parent":95,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":118,"left":107,"right":117,"relation":"evaluation","nuclearity":"NS"},{"parent":107,"left":102,"right":106,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":98,"right":101,"relation":"same-unit","nuclearity":"NN"},{"parent":98,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":8,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":99,"right":11,"relation":"same-unit","nuclearity":"NN"},{"parent":99,"left":9,"right":10,"relation":"attribution","nuclearity":"NS"},{"parent":106,"left":104,"right":105,"relation":"adversative","nuclearity":"NS"},{"parent":104,"left":103,"right":14,"relation":"same-unit","nuclearity":"NN"},{"parent":103,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{