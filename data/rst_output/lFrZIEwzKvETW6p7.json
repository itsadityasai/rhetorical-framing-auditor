{"article_id":"lFrZIEwzKvETW6p7","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"The rules and general procedures","depth":6},{"id":2,"text":"outlining how the impeachment trial of President Donald Trump will move forward","depth":6},{"id":3,"text":"were set by the passage of a resolution along party lines after a marathon Senate session","depth":6},{"id":4,"text":"that stretched into early Wednesday .","depth":6},{"id":5,"text":"Democrats put forward 11 amendments","depth":6},{"id":6,"text":"that would have issued subpoenas to current and former Trump administration officials and to various government entities for documents and information .","depth":6},{"id":7,"text":"All were defeated in the Republican-controlled Senate .","depth":5},{"id":8,"text":"The resolution calls for opening statements to begin Wednesday at 1 p.m.","depth":4},{"id":9,"text":"Each side will have 24 hours over three to days","depth":5},{"id":10,"text":"to argue its case .","depth":5},{"id":11,"text":"Senate trial of President Donald Trump updates :","depth":3},{"id":12,"text":"House Democrats argue their case","depth":5},{"id":13,"text":"Senate Majority Leader Mitch McConnell , R-Ky. , originally proposed","depth":9},{"id":14,"text":"allowing the House managers","depth":12},{"id":15,"text":"prosecuting the case","depth":12},{"id":16,"text":"and Trump 's defense team 24 hours over two days","depth":11},{"id":17,"text":"to present their cases .","depth":10},{"id":18,"text":"McConnell 's first version of the resolution did not automatically enter evidence","depth":10},{"id":19,"text":"gathered by the House","depth":10},{"id":20,"text":"into the Senate ' s record .","depth":9},{"id":21,"text":"Sen. Susan Collins , R-Maine , joined Democrats","depth":10},{"id":22,"text":"in criticizing the resolution","depth":10},{"id":23,"text":"and led a push","depth":10},{"id":24,"text":"to change McConnell 's proposal","depth":11},{"id":25,"text":"to more closely mirror the format of the impeachment trial of President Bill Clinton in 1999 .","depth":11},{"id":26,"text":"She said","depth":9},{"id":27,"text":"the final version was a `` significant improvement . ''","depth":9},{"id":28,"text":"Chief Justice John Roberts admonished the House managers and the president ' s counsel after a fiery back-and-forth debate","depth":10},{"id":29,"text":"on whether former national security adviser John Bolton should be subpoenaed to testify before the Senate .","depth":10},{"id":30,"text":"`` Those","depth":13},{"id":31,"text":"addressing the Senate","depth":13},{"id":32,"text":"should remember","depth":13},{"id":33,"text":"where they are , ''","depth":13},{"id":34,"text":"Roberts told them .","depth":11},{"id":35,"text":"He reminded them to `` use language","depth":11},{"id":36,"text":"conducive to civil discourse . ''","depth":11},{"id":37,"text":"Chief Justice John Roberts :","depth":9},{"id":38,"text":"His role in impeachment ?","depth":10},{"id":39,"text":"Speak softly ,","depth":11},{"id":40,"text":"set a good example","depth":11},{"id":41,"text":"After the House managers and the president 's defense team present their cases ,","depth":9},{"id":42,"text":"the resolution gives senators 16 hours","depth":10},{"id":43,"text":"to ask questions .","depth":10},{"id":44,"text":"They can vote to issue subpoenas for new witnesses or documents","depth":10},{"id":45,"text":"they deem necessary .","depth":10},{"id":46,"text":"Amendments from Minority Leader Charles Schumer , D-N.Y. , called for subpoenas immediately .","depth":11},{"id":47,"text":"Republicans said","depth":14},{"id":48,"text":"that step should have been taken by the House during the impeachment inquiry .","depth":14},{"id":49,"text":"Collins said","depth":14},{"id":50,"text":"they should vote on the subpoenas later","depth":15},{"id":51,"text":"because that was how it was done in the Clinton trial .","depth":15},{"id":52,"text":"Democrats argued","depth":14},{"id":53,"text":"it made more sense to hear from witnesses and to see new evidence","depth":15},{"id":54,"text":"before the case is presented .","depth":15},{"id":55,"text":"They defended the House procedure ,","depth":14},{"id":56,"text":"citing the White House ' s refusal","depth":15},{"id":57,"text":"to comply with congressional subpoenas .","depth":15},{"id":58,"text":"McConnell said","depth":11},{"id":59,"text":"he would table any amendments","depth":13},{"id":60,"text":"`` brought forward","depth":14},{"id":61,"text":"to force premature decisions on mid-trial questions ''","depth":14},{"id":62,"text":"to `` protect our bipartisan precedent ''","depth":13},{"id":63,"text":"set in the Clinton trial .","depth":13},{"id":64,"text":"The 11 amendments","depth":9},{"id":65,"text":"proposed by Schumer and the Democrats","depth":9},{"id":66,"text":"were tabled :","depth":8},{"id":67,"text":"-First amendment :","depth":9},{"id":68,"text":"Subpoena all White House records","depth":10},{"id":69,"text":"related to the articles of impeachment","depth":12},{"id":70,"text":"alleging abuse of power and obstruction of Congress ,","depth":12},{"id":71,"text":"including National Security Council records , conversations about Ukraine and the delay in military assistance to Ukraine .","depth":11},{"id":72,"text":"-Second amendment :","depth":11},{"id":73,"text":"Subpoena all State Department documents from Jan. 1 , 2019 , until the present ,","depth":12},{"id":74,"text":"including Trump ' s communications with Ukrainian President Volodymyr Zelenksy , top State Department officials ' communications with Ukrainian officials about potential investigations and communications regarding U.S . Ambassador to Ukraine Marie Yovanovitch ' s removal from her post .","depth":12},{"id":75,"text":"-Third amendment :","depth":12},{"id":76,"text":"Subpoena for documents from the Office of Management and Budget","depth":13},{"id":77,"text":"related to the withholding of $ 391 million in military aid to Ukraine .","depth":13},{"id":78,"text":"-Fourth amendment :","depth":13},{"id":79,"text":"Subpoena for testimony from acting White House Chief of Staff Mick Mulvaney .","depth":13},{"id":80,"text":"-Sixth amendment :","depth":13},{"id":81,"text":"Subpoenas for testimony from Robert Blair , an assistant to the president and adviser to Mulvaney , and Michael Duffey , a senior official at the Office of Management and Budget .","depth":13},{"id":82,"text":"-Seventh amendment :","depth":11},{"id":83,"text":"A requirement","depth":12},{"id":84,"text":"that any new documents","depth":15},{"id":85,"text":"admitted in the Senate trial","depth":16},{"id":86,"text":"that had been subpoenaed by the House","depth":16},{"id":87,"text":"be made available to members of both parties ,","depth":14},{"id":88,"text":"which","depth":15},{"id":89,"text":"Democrats said","depth":15},{"id":90,"text":"would prevent the `` selective '' admission of evidence from the president .","depth":14},{"id":91,"text":"-Ninth amendment :","depth":13},{"id":92,"text":"A guarantee","depth":14},{"id":93,"text":"that any motion","depth":16},{"id":94,"text":"to subpoena additional witnesses or documents","depth":16},{"id":95,"text":"would get a vote .","depth":15},{"id":96,"text":"The rules","depth":15},{"id":97,"text":"as written ,","depth":16},{"id":98,"text":"Democrats argued ,","depth":16},{"id":99,"text":"do not allow for votes on documents and witnesses","depth":14},{"id":100,"text":"- only for a vote on a procedural motion","depth":14},{"id":101,"text":"to allow for later votes on documents and witnesses .","depth":14},{"id":102,"text":"-10th amendment :","depth":13},{"id":103,"text":"Allow 24 hours for both sides to respond to any motions","depth":15},{"id":104,"text":"that might be filed Wednesday .","depth":15},{"id":105,"text":"The resolution","depth":16},{"id":106,"text":"that passed","depth":16},{"id":107,"text":"provides two hours .","depth":15},{"id":108,"text":"-11th amendment :","depth":13},{"id":109,"text":"A requirement","depth":14},{"id":110,"text":"that Roberts rule on motions","depth":15},{"id":111,"text":"to subpoena witnesses and documents .","depth":15},{"id":112,"text":"Every amendment","depth":11},{"id":113,"text":"put forward by Schumer","depth":11},{"id":114,"text":"was rejected along the same 47-53 , party-line vote","depth":10},{"id":115,"text":"- except one .","depth":9},{"id":116,"text":"Collins voted with Democrats on the 10th amendment","depth":10},{"id":117,"text":"proposed by Schumer ,","depth":10},{"id":118,"text":"which would have allowed more time","depth":10},{"id":119,"text":"for both sides to respond to trial motions .","depth":10},{"id":120,"text":"The lack of defections was a victory for McConnell","depth":8},{"id":121,"text":"who could not lose more than three senators","depth":9},{"id":122,"text":"to block the Democratic amendments .","depth":9},{"id":123,"text":"Rep. Zoe Lofgren , D-Calif. , became the first female House manager","depth":10},{"id":124,"text":"to offer an argument on the Senate floor as part of a president ' s trial .","depth":10},{"id":125,"text":"Shortly after that , Rep. Val Demings , D-Fla. , became the first African American","depth":11},{"id":126,"text":"to serve as an impeachment trial manager","depth":11},{"id":127,"text":"when she spoke in favor of the amendment","depth":11},{"id":128,"text":"to subpoena all relevant State Department documents .","depth":11},{"id":129,"text":"James Risch , chairman of the Senate Foreign Relations Committee , was the first senator","depth":10},{"id":130,"text":"who appeared to doze off during the lengthy debate .","depth":10},{"id":131,"text":"The Idaho Republican slouched back in his chair on the Senate floor ,","depth":10},{"id":132,"text":"cradled his head in hand","depth":12},{"id":133,"text":"and shut his eyes","depth":12},{"id":134,"text":"as Demings delivered her argument .","depth":11},{"id":135,"text":"As the night wore on ,","depth":10},{"id":136,"text":"the hours of debate appeared to take a toll on more senators .","depth":10},{"id":137,"text":"Several appeared to doze off ,","depth":11},{"id":138,"text":"including McConnell","depth":12},{"id":139,"text":"who closed his eyes several times","depth":13},{"id":140,"text":"as House managers argued","depth":14},{"id":141,"text":"that officials and documents should be subpoenaed .","depth":14},{"id":142,"text":"As his body started to lean forward ,","depth":11},{"id":143,"text":"he caught himself","depth":12},{"id":144,"text":"and jolted back .","depth":12},{"id":145,"text":"Sen. Kirsten Gillibrand , D-N.Y. , nodded off multiple times","depth":10},{"id":146,"text":"as the night wore on .","depth":10},{"id":147,"text":"She dozed off ,","depth":10},{"id":148,"text":"started ,","depth":12},{"id":149,"text":"then immediately wrote something in her notes .","depth":12},{"id":150,"text":"Afterward , she shook her head lightly","depth":12},{"id":151,"text":"and stood up ,","depth":13},{"id":152,"text":"leaving the chamber for a few minutes .","depth":13},{"id":153,"text":"Want to talk more about politics ? :","depth":7},{"id":154,"text":"Join our Facebook group :","depth":8},{"id":155,"text":"' Across the Aisle , Across the Nation . '","depth":8}],"relations":[{"parent":311,"left":0,"right":310,"relation":"organization","nuclearity":"SN"},{"parent":310,"left":165,"right":309,"relation":"elaboration","nuclearity":"NS"},{"parent":165,"left":162,"right":164,"relation":"elaboration","nuclearity":"NS"},{"parent":162,"left":159,"right":161,"relation":"elaboration","nuclearity":"NS"},{"parent":159,"left":157,"right":158,"relation":"same-unit","nuclearity":"NN"},{"parent":157,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":158,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":161,"left":160,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":160,"left":5,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":164,"left":8,"right":163,"relation":"joint","nuclear