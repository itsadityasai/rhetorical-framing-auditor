rent":256,"left":119,"right":255,"relation":"elaboration","nuclearity":"NS"},{"parent":255,"left":253,"right":254,"relation":"adversative","nuclearity":"NN"},{"parent":253,"left":120,"right":121,"relation":"condition","nuclearity":"SN"},{"parent":254,"left":122,"right":123,"relation":"condition","nuclearity":"SN"},{"parent":264,"left":124,"right":263,"relation":"same-unit","nuclearity":"NN"},{"parent":263,"left":258,"right":262,"relation":"context","nuclearity":"SN"},{"parent":258,"left":125,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":262,"left":259,"right":261,"relation":"same-unit","nuclearity":"NN"},{"parent":259,"left":127,"right":128,"relation":"elaboration","nuclearity":"NS"},{"parent":261,"left":260,"right":131,"relation":"same-unit","nuclearity":"NN"},{"parent":260,"left":129,"right":130,"relation":"elaboration","nuclearity":"NS"},{"parent":274,"left":268,"right":273,"relation":"joint","nuclearity":"NN"},{"parent":268,"left":267,"right":134,"relation":"context","nuclearity":"SN"},{"parent":267,"left":132,"right":133,"relation":"elaboration","nuclearity":"NS"},{"parent":273,"left":269,"right":272,"relation":"context","nuclearity":"SN"},{"parent":269,"left":135,"right":136,"relation":"elaboration","nuclearity":"NS"},{"parent":272,"left":137,"right":271,"relation":"explanation","nuclearity":"NS"},{"parent":271,"left":270,"right":140,"relation":"same-unit","nuclearity":"NN"},{"parent":270,"left":138,"right":139,"relation":"elaboration","nuclearity":"NS"}]}