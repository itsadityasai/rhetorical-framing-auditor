{"article_id":"Tb4TaENzbzVnrTgb","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"The Senate impeachment trial of President Donald Trump will begin Jan. 21 ,","depth":8},{"id":2,"text":"after the House is scheduled to vote Wednesday to formally send the articles across the Capitol .","depth":8},{"id":3,"text":"Senate Majority Leader Mitch McConnell , R-Ky. , told reporters","depth":9},{"id":4,"text":"that the Senate will likely take up \" housekeeping \" measures on the trial this week ,","depth":10},{"id":5,"text":"possibly including swearing in senators and bringing over Supreme Court Chief Justice Roberts to preside .","depth":10},{"id":6,"text":"The trial would then likely begin Tuesday ,","depth":9},{"id":7,"text":"McConnell said .","depth":9},{"id":8,"text":"His announcement came","depth":7},{"id":9,"text":"after House Speaker Nancy Pelosi said","depth":8},{"id":10,"text":"the House would vote Wednesday to send the articles ,","depth":10},{"id":11,"text":"which accuse Trump of abuse of power and obstruction of Congress ,","depth":10},{"id":12,"text":"to the Senate .","depth":9},{"id":13,"text":"She asked Judiciary Committee Chairman Jerry Nadler , D-N.Y. , on Friday to prepare a resolution","depth":10},{"id":14,"text":"that would authorize and appoint the House lawmakers","depth":12},{"id":15,"text":"called managers ,","depth":12},{"id":16,"text":"who will prosecute the case during the Senate trial ,","depth":11},{"id":17,"text":"although she did n't name managers during the meeting .","depth":9},{"id":18,"text":"\" The president and the senators will be held accountable , \"","depth":9},{"id":19,"text":"said Pelosi , D-Calif .","depth":9},{"id":20,"text":"House Majority Leader Steny Hoyer , D-Md. , said","depth":9},{"id":21,"text":"the vote on the resolution would happen in the afternoon","depth":12},{"id":22,"text":"and take only 10 minutes .","depth":12},{"id":23,"text":"Each side will be given five minutes for debate .","depth":11},{"id":24,"text":"The precise timing has n't been set ,","depth":11},{"id":25,"text":"he said .","depth":11},{"id":26,"text":"The formal procession across the Capitol from the House to the Senate","depth":12},{"id":27,"text":"to deliver the articles","depth":12},{"id":28,"text":"could happen after the vote","depth":11},{"id":29,"text":"or wait until Thursday morning ,","depth":10},{"id":30,"text":"Hoyer said .","depth":9},{"id":31,"text":"Pelosi delayed sending the articles","depth":8},{"id":32,"text":"after the House voted to impeach Trump on Dec. 18 ,","depth":8},{"id":33,"text":"so she could learn more about how the trial would be conducted ,","depth":8},{"id":34,"text":"such as whether witnesses would be called .","depth":8},{"id":35,"text":"Members of the Judiciary and Intelligence committees declined to say","depth":6},{"id":36,"text":"whether Pelosi offered them manager positions","depth":7},{"id":37,"text":"or whether they 'd even spoken about it with her .","depth":7},{"id":38,"text":"As the names remained secret ,","depth":7},{"id":39,"text":"lawmakers","depth":10},{"id":40,"text":"leaving the meeting","depth":10},{"id":41,"text":"said","depth":9},{"id":42,"text":"they expect the managers to be deeply familiar with the details of the House case ,","depth":9},{"id":43,"text":"to be knowledgeable about the law","depth":10},{"id":44,"text":"and to offer diversity in skills , background and race .","depth":10},{"id":45,"text":"Rep. Mary Gay Scanlon , D-Pa. ,","depth":8},{"id":46,"text":"who as vice chairman of the Judiciary Committee is one of the lawmakers","depth":9},{"id":47,"text":"who could be tapped ,","depth":9},{"id":48,"text":"called it \" the biggest guessing game on Capitol Hill , \" one","depth":8},{"id":49,"text":"that she and others wish","depth":9},{"id":50,"text":"they could take bets on .","depth":9},{"id":51,"text":"Senators of both parties voiced frustration with the delay .","depth":5},{"id":52,"text":"Majority Leader Mitch McConnell , R-Ky. , said","depth":6},{"id":53,"text":"he would n't haggle with the House over trial procedures","depth":7},{"id":54,"text":"in what he called Pelosi 's `` one-woman blockade . ''","depth":7},{"id":55,"text":"Pelosi and McConnell :","depth":6},{"id":56,"text":"Pelosi warns McConnell , Senate Republicans","depth":7},{"id":57,"text":"they will 'pay a price '","depth":8},{"id":58,"text":"if they engage in 'cover-up '","depth":8},{"id":59,"text":"\" The president ' s opponents are afraid of having the Senate judge the case","depth":8},{"id":60,"text":"they actually are going to send us , \"","depth":8},{"id":61,"text":"McConnell said Monday from the Senate floor .","depth":7},{"id":62,"text":"\" They are afraid of having the Senate judge the case","depth":8},{"id":63,"text":"they themselves voted on .","depth":8},{"id":64,"text":"That alone speaks volumes . \"","depth":7},{"id":65,"text":"The articles accuse Trump of abuse of power and obstruction of Congress .","depth":4},{"id":66,"text":"The president said","depth":6},{"id":67,"text":"he expects to be exonerated in the Senate trial .","depth":6},{"id":68,"text":"A two-thirds majority would be required","depth":6},{"id":69,"text":"to convict Trump","depth":8},{"id":70,"text":"and remove him from office ,","depth":8},{"id":71,"text":"which is unlikely in a Senate","depth":8},{"id":72,"text":"where Republicans outnumber Democrats 53 to 47 .","depth":8},{"id":73,"text":"A major sticking point between Republicans and Democrats has been over whether witnesses will be allowed to testify during the Senate trial .","depth":6},{"id":74,"text":"Democrats argued","depth":8},{"id":75,"text":"the trial should include witnesses","depth":9},{"id":76,"text":"who did n't testify during the House inquiry .","depth":9},{"id":77,"text":"McConnell said","depth":8},{"id":78,"text":"he has the votes","depth":10},{"id":79,"text":"to begin the trial","depth":10},{"id":80,"text":"without deciding on whether to call witnesses","depth":10},{"id":81,"text":"until after both sides have presented opening statements .","depth":10},{"id":82,"text":"Former national security adviser John Bolton ,","depth":11},{"id":83,"text":"who declined an invitation","depth":12},{"id":84,"text":"to testify in the House inquiry ,","depth":12},{"id":85,"text":"said Jan. 6","depth":10},{"id":86,"text":"he is prepared to testify under subpoena in the Senate trial .","depth":9},{"id":87,"text":"Pelosi said","depth":9},{"id":88,"text":"Bolton 's offer justified the delay","depth":10},{"id":89,"text":"in sending the articles to the Senate .","depth":10},{"id":90,"text":"`` Leader McConnell 's tactics are a clear indication of the fear","depth":9},{"id":91,"text":"that he and President Trump have","depth":10},{"id":92,"text":"regarding the facts of the president 's violations","depth":11},{"id":93,"text":"for which he was impeached , ''","depth":11},{"id":94,"text":"Pelosi said .","depth":8},{"id":95,"text":"Senate Minority Leader Charles Schumer , D-N.Y. , urged testimony from four witnesses ,","depth":8},{"id":96,"text":"including Bolton and acting White House Chief of Staff Mick Mulvaney .","depth":8},{"id":97,"text":"Democrats need at least four Republicans to join them","depth":10},{"id":98,"text":"to reach a majority of 51 senators","depth":11},{"id":99,"text":"to approve subpoenas for witnesses and documents ,","depth":11},{"id":100,"text":"and a handful of Republicans said","depth":10},{"id":101,"text":"they are open to hearing from witnesses after the opening statements .","depth":10},{"id":102,"text":"Trump said","depth":9},{"id":103,"text":"he might block Bolton 's testimony under executive privilege","depth":10},{"id":104,"text":"to protect the confidentiality of advice","depth":11},{"id":105,"text":"presidents get from top aides .","depth":11},{"id":106,"text":"The House accused Trump of abusing the power of his office","depth":7},{"id":107,"text":"by asking Ukrainian President Volodymyr Zelensky to investigate a political rival , former Vice President Joe Biden ,","depth":8},{"id":108,"text":"while Trump withheld a White House meeting and $ 391 million in military aid .","depth":8},{"id":109,"text":"The House also accused Trump of obstructing Congress","depth":7},{"id":110,"text":"by directing aides and agencies to defy subpoenas for documents and testimony ,","depth":8},{"id":111,"text":"although some officials did testify .","depth":8},{"id":112,"text":"Trump and congressional Republicans argued","depth":6},{"id":113,"text":"he had the authority","depth":8},{"id":114,"text":"to set foreign policy","depth":8},{"id":115,"text":"and was justified in fighting corruption in Ukraine .","depth":7}],"relations":[{"parent":231,"left":0,"right":230,"relation":"organization","nuclearity":"SN"},{"parent":230,"left":179,"right":229,"relation":"elaboration","nuclearity":"NS"},{"parent":179,"left":165,"right":178,"relation":"elaboration","nuclearity":"NS"},{"parent":165,"left":149,"right":164,"relation":"elaboration","nuclearity":"NS"},{"parent":149,"left":127,"right":148,"relation":"elaboration","nuclearity":"NS"},{"parent":127,"left":122,"right":126,"relation":"context","nuclearity":"NS"},{"parent":122,"left":117,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":117,"left":1,"right":2,"relation":"context","nuclearity":"NS"},{"parent":121,"left":119,"right":120,"relation":"joint","nuclearity":"NN"},{"parent":119,"left":3,"right":118,"relation":"attribution","nuclearity":"SN"},{"parent":118,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":120,"left":6,"right":7,"relation":"attribution","nuclearity":"NS"},{"parent":126,"left":8,"right":125,"relation":"context","nuclearity":"NS"},{"parent":125,"left":9,"right":124,"relation":"attribution","nuclearity":"SN"},{"parent":124,"left":123,"right":12,"relation":"same-unit","nuclearity":"NN"},{"parent":123,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":148,"left":144,"right":147,"relation":"context"