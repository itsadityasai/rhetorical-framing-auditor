{"article_id":"Rv9p9FleIDGedm1Q","edus":[{"id":0,"text":"New claims for unemployment benefits fell to 1,542,000 last week ,","depth":9},{"id":1,"text":"data from the Department of Labor showed Thursday .","depth":9},{"id":2,"text":"This is the eleventh consecutive week of initial claims above 1 million .","depth":8},{"id":3,"text":"Prior to March , initial claims had never risen as high as 700,000 .","depth":7},{"id":4,"text":"Economists had forecast 1.565 million claims .","depth":7},{"id":5,"text":"Last week ' s claims were revised up slightly to 1.897 million from 1.877 million .","depth":7},{"id":6,"text":"Claims hit a record 6.87 million for the week of March 27 .","depth":6},{"id":7,"text":"Each subsequent week has seen claims decline .","depth":6},{"id":8,"text":"Continuing claims for unemployment benefits during the week","depth":8},{"id":9,"text":"ending May 30","depth":8},{"id":10,"text":"fell 339,000 to 20,929,000 .","depth":7},{"id":11,"text":"The previous week ' s level was revised down by 219,000 from 21,487,000 to 21,268,000 .","depth":7},{"id":12,"text":"These are reported with a one-week lag .","depth":7},{"id":13,"text":"The decline in continuing claims indicates","depth":7},{"id":14,"text":"that some of those","depth":9},{"id":15,"text":"who have lost their jobs","depth":9},{"id":16,"text":"have found new jobs","depth":9},{"id":17,"text":"or been rehired","depth":9},{"id":18,"text":"as states have lifted orders","depth":7},{"id":19,"text":"forcing businesses to close .","depth":7},{"id":20,"text":"The government reported last week","depth":5},{"id":21,"text":"that the unemployment rate declined","depth":7},{"id":22,"text":"and the economy actually added 2.5 million jobs in May ,","depth":7},{"id":23,"text":"beginning to claw back some of the 22 million jobs","depth":7},{"id":24,"text":"lost in March and April .","depth":7},{"id":25,"text":"Claims may have been elevated by the rioting , looting , and violence","depth":7},{"id":26,"text":"that accompanied the protests over the alleged killing of George Floyd .","depth":7},{"id":27,"text":"Some businesses were completely destroyed in the rioting ,","depth":7},{"id":28,"text":"many more were looted and vandalized ,","depth":8},{"id":29,"text":"and some were forced to close by the threat of violence .","depth":8},{"id":30,"text":"The highest rates of continuing claims ,","depth":9},{"id":31,"text":"which the government calls the insured unemployment rate ,","depth":9},{"id":32,"text":"in the week","depth":10},{"id":33,"text":"ending May 23","depth":10},{"id":34,"text":"were in Maine","depth":10},{"id":35,"text":"( 26.9 ) ,","depth":10},{"id":36,"text":"Nevada","depth":9},{"id":37,"text":"( 24.3 ) ,","depth":9},{"id":38,"text":"Michigan","depth":10},{"id":39,"text":"( 21.7 ) ,","depth":10},{"id":40,"text":"Hawaii","depth":11},{"id":41,"text":"( 20.1 ) ,","depth":11},{"id":42,"text":"Puerto Rico","depth":12},{"id":43,"text":"( 19.0 ) ,","depth":12},{"id":44,"text":"New York","depth":13},{"id":45,"text":"( 18.7 ) ,","depth":13},{"id":46,"text":"Pennsylvania","depth":14},{"id":47,"text":"( 17.5 ) ,","depth":14},{"id":48,"text":"Georgia","depth":15},{"id":49,"text":"( 17.2 ) ,","depth":15},{"id":50,"text":"Massachusetts","depth":16},{"id":51,"text":"( 16.8 ) ,","depth":16},{"id":52,"text":"and Rhode Island","depth":16},{"id":53,"text":"( 16.6 ) .","depth":16},{"id":54,"text":"The largest increases in initial claims for the week","depth":9},{"id":55,"text":"ending May 30","depth":9},{"id":56,"text":"were in Florida , California , Oklahoma , and Mississippi ,","depth":8},{"id":57,"text":"while the largest decreases were in New York , Michigan , Texas , Pennsylvania , and Washington .","depth":7},{"id":58,"text":"The federal government has been chipping in an extra $ 600 a week to state unemployment benefits ,","depth":5},{"id":59,"text":"making the program much more generous .","depth":5},{"id":60,"text":"Many workers can now earn more on unemployment","depth":6},{"id":61,"text":"than they did","depth":7},{"id":62,"text":"when they had a job .","depth":7},{"id":63,"text":"These super-sized benefits , however , are set to run out in July .","depth":5},{"id":64,"text":"In addition to claims for regular unemployment benefits , the government now offers two new forms of unemployment benefits to business owners , self-employed , gig-workers , and independent contractors","depth":4},{"id":65,"text":"who would not ordinarily qualify for unemployment benefits .","depth":4},{"id":66,"text":"During the week","depth":3},{"id":67,"text":"ending May 23 ,","depth":3},{"id":68,"text":"42 states reported 9,715,948 individuals","depth":4},{"id":69,"text":"claiming Pandemic Unemployment Assistance benefits","depth":4},{"id":70,"text":"and 32 states reported 518,942 individuals","depth":4},{"id":71,"text":"claiming Pandemic Emergency Unemployment Compensation benefits .","depth":4}],"relations":[{"parent":143,"left":137,"right":142,"relation":"joint","nuclearity":"NN"},{"parent":137,"left":129,"right":136,"relation":"elaboration","nuclearity":"NS"},{"parent":129,"left":91,"right":128,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":79,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":77,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":75,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":74,"right":3,"relation":"context","nuclearity":"NS"},{"parent":74,"left":73,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":0,"right":1,"relation":"attribution","nuclearity":"NS"},{"parent":76,"left":4,"right":5,"relation":"adversative","nuclearity":"NN"},{"parent":78,"left":6,"right":7,"relation":"joint","nuclearity":"NN"},{"parent":90,"left":83,"right":89,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":81,"right":82,"relation":"joint","nuclearity":"NN"},{"parent":81,"left":80,"right":10,"relation":"same-unit","nuclearity":"NN"},{"pare