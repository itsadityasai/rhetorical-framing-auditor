{"article_id":"7kCgPNwMyunBlir3","edus":[{"id":0,"text":"Lawyers for US President Donald Trump are seeking $ 20 million","depth":9},{"id":1,"text":"( £14m )","depth":9},{"id":2,"text":"in damages from a porn actress","depth":8},{"id":3,"text":"he says","depth":8},{"id":4,"text":"broke a non-disclosure deal","depth":9},{"id":5,"text":"signed before the 2016 elections .","depth":9},{"id":6,"text":"They argue","depth":7},{"id":7,"text":"Stormy Daniels breached the agreement at least 20 times .","depth":7},{"id":8,"text":"The actress claims","depth":6},{"id":9,"text":"she had an affair with Mr Trump","depth":7},{"id":10,"text":"that began in 2006","depth":8},{"id":11,"text":"and lasted several months .","depth":8},{"id":12,"text":"The president 's lawyer , Michael Cohen , has said","depth":6},{"id":13,"text":"he paid her $ 130,000 of his own money","depth":7},{"id":14,"text":"to remain silent .","depth":7},{"id":15,"text":"This is the first time","depth":7},{"id":16,"text":"President Trump has become directly involved in the case .","depth":7},{"id":17,"text":"He `` vehemently denies '' the alleged affair .","depth":6},{"id":18,"text":"The lawyer","depth":9},{"id":19,"text":"acting for Stormy Daniels ,","depth":9},{"id":20,"text":"whose real name is Stephanie Clifford ,","depth":8},{"id":21,"text":"this month filed a lawsuit","depth":8},{"id":22,"text":"aiming to scrap the non-disclosure agreement .","depth":8},{"id":23,"text":"Michael Avenatti said","depth":8},{"id":24,"text":"the filing by the law firm","depth":11},{"id":25,"text":"representing the president","depth":11},{"id":26,"text":"were `` unprecedented ''","depth":10},{"id":27,"text":"and `` yet another bullying tactic '' against her .","depth":9},{"id":28,"text":"The filing also sought a change of venue from state to federal court .","depth":7},{"id":29,"text":"Ms Clifford says","depth":6},{"id":30,"text":"the 2016 agreement is invalid","depth":7},{"id":31,"text":"as Mr Trump did not sign it .","depth":7},{"id":32,"text":"She first made claims of a sexual relationship with Mr Trump in a 2011 interview with InTouch magazine .","depth":6},{"id":33,"text":"The story came back into the public eye earlier this year","depth":8},{"id":34,"text":"when reports emerged","depth":9},{"id":35,"text":"she was paid not to discuss the alleged affair in the run-up to the 2016 election .","depth":9},{"id":36,"text":"Mr Cohen has acknowledged paying her $ 130,000","depth":10},{"id":37,"text":"( £95,000 )","depth":10},{"id":38,"text":"privately ,","depth":9},{"id":39,"text":"but said","depth":9},{"id":40,"text":"neither Mr Trump nor his company was a party to the transaction .","depth":9},{"id":41,"text":"A similar request","depth":9},{"id":42,"text":"made on Mr Trump 's behalf","depth":9},{"id":43,"text":"came from another lawyer , Charles Harder","depth":9},{"id":44,"text":"- best known for his handling of the Hulk Hogan sex tape case against Gawker and for defending Melania Trump in a suit against the Daily Mail .","depth":9},{"id":45,"text":"This motion says :","depth":8},{"id":46,"text":"`` Mr. Trump intends to pursue his rights to the fullest extent","depth":9},{"id":47,"text":"permitted by the law . ''","depth":9},{"id":48,"text":"It is thought that moving the case to a federal court would help keep the case behind closed doors in arbitration","depth":7},{"id":49,"text":"- a view","depth":8},{"id":50,"text":"expressed by Ms Clifford 's lawyer in a tweet .","depth":8},{"id":51,"text":"Mr Avenatti alleged on Friday","depth":4},{"id":52,"text":"that the porn actress had been physically threatened ,","depth":4},{"id":53,"text":"but did not give further details .","depth":3},{"id":54,"text":"Ms Clifford has recorded an interview with the CBS network 's 60 Minutes programme","depth":5},{"id":55,"text":"to air later this month","depth":5},{"id":56,"text":"about her fight","depth":5},{"id":57,"text":"to void the agreement .","depth":5},{"id":58,"text":"A CrowdJustice campaign","depth":5},{"id":59,"text":"to raise funds for her legal fees","depth":5},{"id":60,"text":"has already raised almost $ 200,000 .","depth":4},{"id":61,"text":"Mr Trump has also obtained a restraining order against the adult film actress","depth":3},{"id":62,"text":"to try to prevent her sharing `` confidential information '' about their alleged relationship .","depth":3}],"relations":[{"parent":125,"left":116,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":116,"left":113,"right":115,"relation":"elaboration","nuclearity":"NS"},{"parent":113,"left":80,"right":112,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":74,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":70,"right":73,"relation":"context","nuclearity":"NS"},{"parent":70,"left":68,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":65,"right":67,"relation":"same-unit","nuclearity":"NN"},{"parent":65,"left":64,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":64,"left":0,"right":1,"relation":"restatement","nuclearity":"NS"},{"parent":67,"left":3,"right":66,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":6,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":73,"left":8,"right":72,"relation":"attribution","nuclearity":"SN"},{"parent":72,"left":9,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":10,"right":11,"relation":"joint","nuclearity":"NN"},{"parent":79,"left":76,"right":78,"relation":"context","nuclearity":"NS"},{"parent":76,"left":12,"right":75,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":13,"right":14,"relation":"purpose","nuclearity":"NS"},{"parent":78,"left":77,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":15,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":112,"left":93,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":9