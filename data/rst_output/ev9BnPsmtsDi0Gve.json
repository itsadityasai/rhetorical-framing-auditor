{"article_id":"ev9BnPsmtsDi0Gve","edus":[{"id":0,"text":"President Obama defended his signature health care law Wednesday in a speech from Boston ,","depth":5},{"id":1,"text":"saying","depth":6},{"id":2,"text":"that people","depth":8},{"id":3,"text":"who are losing their insurance plans","depth":9},{"id":4,"text":"because of the law","depth":9},{"id":5,"text":"should start shopping around for better coverage .","depth":7},{"id":6,"text":"Speaking at historic Faneuil Hall ,","depth":7},{"id":7,"text":"Obama acknowledged the problem-plagued rollout of ObamaCare","depth":7},{"id":8,"text":"and attempted to deflect criticism over the wave of cancellation notices","depth":7},{"id":9,"text":"hitting small businesses and individuals","depth":8},{"id":10,"text":"who buy their own insurance .","depth":8},{"id":11,"text":"The cancellation notices apply to people","depth":7},{"id":12,"text":"whose plans changed","depth":9},{"id":13,"text":"after the law was implemented","depth":9},{"id":14,"text":"or do n't meet new coverage requirements .","depth":8},{"id":15,"text":"The president said","depth":8},{"id":16,"text":"those changes ensure","depth":9},{"id":17,"text":"that all Americans are able to get quality coverage .","depth":9},{"id":18,"text":"`` So","depth":10},{"id":19,"text":"if you 're getting one of these letters ,","depth":11},{"id":20,"text":"just shop around in the new marketplace .","depth":11},{"id":21,"text":"That 's what it 's for , ''","depth":10},{"id":22,"text":"Obama said .","depth":10},{"id":23,"text":"`` Because of the tax credits","depth":10},{"id":24,"text":"that we are offering ,","depth":10},{"id":25,"text":"and the competition between insurers , most people are going to be able to get better , comprehensive healthcare plans for the same price or even cheaper","depth":10},{"id":26,"text":"than projected . ''","depth":10},{"id":27,"text":"Republicans believe","depth":4},{"id":28,"text":"the president 's argument flies in the face of his repeated claims","depth":5},{"id":29,"text":"that consumers","depth":7},{"id":30,"text":"who liked their insurance","depth":7},{"id":31,"text":"would be able to keep it .","depth":6},{"id":32,"text":"Officials in Oregon say","depth":4},{"id":33,"text":"150,000 Oregonians","depth":7},{"id":34,"text":"enrolled in individual health care plans","depth":7},{"id":35,"text":"will see their plans cancelled by the end of the year","depth":6},{"id":36,"text":"because the plans don ' t provide the minimum level of coverage","depth":6},{"id":37,"text":"required under the new health care law .","depth":6},{"id":38,"text":"In Florida , about 300,000 Blue Cross and Blue Shield members will be affected .","depth":4},{"id":39,"text":"California ' s Blue Shield and Oakland-based Kaiser Permanente will withdraw policies for a combined 280,000 customers .","depth":5},{"id":40,"text":"CareFirst Blue Cross Blue Shield sent notices to more than 70,000 customers in D.C. , Virginia , Maryland and Washington","depth":7},{"id":41,"text":"whose current plans don ' t comply with the law ,","depth":7},{"id":42,"text":"according to Bloomberg News .","depth":6},{"id":43,"text":"Sens . Ron Johnson , R-Wis. , and Marco Rubio , R-Fla. , introduced legislation Wednesday","depth":6},{"id":44,"text":"aimed at giving American the ability","depth":7},{"id":45,"text":"to hold onto their plans","depth":8},{"id":46,"text":"if they liked them .","depth":8},{"id":47,"text":"The bill would add flexibility to the standards for insurance policies","depth":6},{"id":48,"text":"allowed under ObamaCare .","depth":6},{"id":49,"text":"`` That was a fundamental promise","depth":7},{"id":50,"text":"that was made","depth":8},{"id":51,"text":"in order to get this law passed","depth":8},{"id":52,"text":"and now that ' s being broken","depth":7},{"id":53,"text":"and we ' re seeing","depth":8},{"id":54,"text":"that it wasn ' t an unintended consequence ,","depth":9},{"id":55,"text":"it was an intended consequence , ''","depth":9},{"id":56,"text":"Rubio told ' Greta Van Susteren on \" On the Record . ''","depth":5},{"id":57,"text":"The president 's remarks marked a striking departure from his vow","depth":5},{"id":58,"text":"stretching back to 2009 :","depth":5},{"id":59,"text":"`` No matter how we reform health care ,","depth":7},{"id":60,"text":"we will keep this promise to the American people .","depth":7},{"id":61,"text":"If you like your doctor ,","depth":8},{"id":62,"text":"you will be able to keep your doctor , period .","depth":8},{"id":63,"text":"If you like your health care plan ,","depth":9},{"id":64,"text":"you 'll be able to keep your health care plan , period .","depth":9},{"id":65,"text":"No one will take it away , no matter what . ''","depth":8},{"id":66,"text":"And from the final months of the 2012 campaign :","depth":6},{"id":67,"text":"`` If you 're one of the more than 250 million Americans","depth":9},{"id":68,"text":"who already have health insurance ,","depth":9},{"id":69,"text":"you will keep your health insurance .","depth":8},{"id":70,"text":"This law will only make it more secure and more affordable . ''","depth":7},{"id":71,"text":"Obama chose the site","depth":7},{"id":72,"text":"where Massachusetts ' health care system became law","depth":7},{"id":73,"text":"to promote his health care law ,","depth":6},{"id":74,"text":"arguing","depth":7},{"id":75,"text":"that the state plan also faced initial setbacks and low enrollment","depth":8},{"id":76,"text":"but in time gained popularity","depth":9},{"id":77,"text":"and became a success .","depth":9},{"id":78,"text":"`` All the parade of horribles , the worst predictions about health care reform in Massachusetts never came true , ''","depth":8},{"id":79,"text":"he said .","depth":8},{"id":80,"text":"`` They 're the same arguments","depth":8},{"id":81,"text":"that you 're hearing now . ''","depth":8},{"id":82,"text":"The president pointed to benefits","depth":6},{"id":83,"text":"already available under the 3-year-old health care law ,","depth":6},{"id":84,"text":"including ending discrimination against children with pre-existing conditions and permission","depth":6},{"id":85,"text":"to keep young people on their parents ' insurance plans","depth":7},{"id":86,"text":"until they turn 26 .","depth":7},{"id":87,"text":"Romney took issue with Obama 's characterization of the Massachusetts health care law .","depth":5},{"id":88,"text":"In a statement , he said","depth":6},{"id":89,"text":"`` had President Obama actually learned the lessons of Massachusetts health care ,","depth":7},{"id":90,"text":"millions of Americans would not lose the insurance","depth":9},{"id":91,"text":"they were promised","depth":10},{"id":92,"text":"they could keep ,","depth":10},{"id":93,"text":"millions more would not see their premiums skyrocket","depth":9},{"id":94,"text":"and the installation of the program would not have been a frustrating embarrassment . ''","depth":9},{"id":95,"text":"Obama he conceded the troubled launch of the open enrollment period","depth":6},{"id":96,"text":"that began Oct. 1 .","depth":6},{"id":97,"text":"`` There ' s no denying it , right now ,","depth":8},{"id":98,"text":"the website is too slow ,","depth":11},{"id":99,"text":"too many people have gotten stuck .","depth":11},{"id":100,"text":"And I am not happy about it .","depth":10},{"id":101,"text":"And neither are a lot of Americans","depth":11},{"id":102,"text":"who need health care ,","depth":11},{"id":103,"text":"and they ' re trying to figure out how they can sign up as quickly as possible , ''","depth":10},{"id":104,"text":"he said .","depth":7},{"id":105,"text":"Underscoring the president 's challenge ,","depth":8},{"id":106,"text":"the HealthCare.gov website was down ,","depth":10},{"id":107,"text":"because of technical difficulties ,","depth":10},{"id":108,"text":"during his remarks .","depth":9},{"id":109,"text":"Republicans say","depth":9},{"id":110,"text":"the current computer dysfunction is more reason","depth":10},{"id":111,"text":"to repeal the law ,","depth":10},{"id":112,"text":"and they 're pressing Obama administration officials for an explanation .","depth":8}],"relations":[{"parent":225,"left":155,"right":224,"relation":"elaboration","nuclearity":"NS"},{"parent":155,"left":144,"right":154,"relation":"elaboration","nuclearity":"NS"},{"parent":144,"left":139,"right":143,"relation":"evaluation","nuclearity":"NS"},{"parent":139,"left":118,"right":138,"relation":"elaboration","nuclearity":"NS"},{"parent":118,"left":0,"right":117,"relation":"elaboration","nuclearity":"NS"},{"parent":117,"left":1,"right":116,"relation":"attribution","nuclearity":"SN"},{"parent":116,"left":115,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":115,"left":2,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":114,"left":3,"right":4,"relation":"causal","nuclearity":"NS"},{"parent":138,"left":122,"right":137,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":119,"right":121,"relation":"joint","nuclearity":"NN"},{"parent":119,"left":6,"right":7,"relation":"context","nuclearity":"SN"},{"parent":121,"left":8,"right":120,"relation":"elaboration","nuclearity":"NS"},{"parent":120,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":137,"left":125,"right":136,"relation":"context","nuclearity":"SN"},{"parent":125,"left":11,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":124,"left":123,"right":14,"relation":"joint","nuclearity":"NN"},{"parent":123,"left":12,"right":13,"relation":"context","nuclearity":"NS"},{"parent":136,"left":127,"right":135,"relation":"context","nuclearity":"SN"},{"parent":127,"left":15,"right":126,"relation":"attribution","nuclearity":"SN"},{"parent":126,"left":16,"right":17,"relation":"attribution","nuclearity":"SN"},{"parent":135,"left":131,"right":134,"relation":"elaboration","nuclearity":"NS"},{"parent":131,"left":129,"right":130,"relation":"restatement","nuclearity":"NN"},{"parent":129,"left":18,"right":128,"relatio