n":"purpose","nuclearity":"NS"},{"parent":307,"left":134,"right":306,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":135,"right":136,"relation":"joint","nuclearity":"NN"},{"parent":311,"left":137,"right":310,"relation":"explanation","nuclearity":"NS"},{"parent":310,"left":309,"right":140,"relation":"context","nuclearity":"SN"},{"parent":309,"left":138,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":319,"left":314,"right":318,"relation":"joint","nuclearity":"NN"},{"parent":314,"left":141,"right":142,"relation":"organization","nuclearity":"SN"},{"parent":318,"left":316,"right":317,"relation":"joint","nuclearity":"NN"},{"parent":316,"left":143,"right":315,"relation":"organization","nuclearity":"SN"},{"parent":315,"left":144,"right":145,"relation":"elaboration","nuclearity":"NS"},{"parent":317,"left":146,"right":147,"relation":"organization","nuclearity":"SN"},{"parent":346,"left":148,"right":345,"relation":"organization","nuclearity":"SN"},{"parent":345,"left":338,"right":344,"relation":"context","nuclearity":"NS"},{"parent":338,"left":328,"right":337,"relation":"elaboration","nuclearity":"NS"},{"parent":328,"left":322,"right":327,"relation":"elaboration","nuclearity":"NS"},{"parent":322,"left":149,"right":150,"relation":"context","nuclearity":"NS"},{"parent":327,"left":324,"right":326,"relation":"adversative","nuclearity":"SN"},{"parent":324,"left":151,"right":323,"relation":"elaboration","nuclearity":"NS"},{"parent":323,"left":152,"right":153,"relation":"elaboration","nuclearity":"NS"},{"parent":326,"left":154,"right":325,"relation":"elaboration","nuclearity":"NS"},{"parent":325,"left":155,"right":156,"relation":"purpose","nuclearity":"NS"},{"parent":337,"left":333,"right":336,"relation":"elaboration","nuclearity":"NS"},{"parent":333,"left":329,"right":332,"relation":"mode","nuclearity":"NS"},{"parent":329,"left":157,"right":158,"relation":"elaboration","nuclearity":"NS"},{"parent":332,"left":330,"right":331,"relation":"joint","nuclearity":"NN"},{"parent":330,"left":159,"right":160,"relation":"attribution","nuclearity":"SN"},{"parent":331,"left":161,"right":162,"relation":"attribution","nuclearity":"SN"},{"parent":336,"left":335,"right":166,"relation":"evaluation","nuclearity":"NS"},{"parent":335,"left":163,"right":334,"relation":"attribution","nuclearity":"NS"},{"parent":334,"left":164,"right":165,"relation":"elaboration","nuclearity":"NS"},{"parent":344,"left":167,"right":343,"relation":"causal","nuclearity":"NS"},{"parent":343,"left":340,"right":342,"relation":"elaboration","nuclearity":"NS"},{"parent":340,"left":168,"right":339,"relation":"elaboration","nuclearity":"NS"},{"parent":339,"left":169,"right":170,"relation":"purpose","nuclearity":"NS"},{"parent":342,"left":341,"right":173,"relation":"context","nuclearity":"NS"},{"parent":341,"left":171,"right":172,"relation":"elaboration","nuclearity":"NS"}]}