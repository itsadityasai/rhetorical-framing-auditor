{"article_id":"2oWRy3QkdPOI2uMs","edus":[{"id":0,"text":"WASHINGTON -","depth":1},{"id":1,"text":"Former Acting Attorney General Sally Yates testified Monday before a Senate subcommittee about her efforts","depth":4},{"id":2,"text":"to warn the Trump administration of misinformation","depth":5},{"id":3,"text":"put forth by former National Security Advisor Michael Flynn .","depth":5},{"id":4,"text":"Days after the inauguration , Yates says","depth":6},{"id":5,"text":"she spoke with White House counsel Donald McGahn three times , twice in person and once over the phone ,","depth":7},{"id":6,"text":"and told him","depth":8},{"id":7,"text":"that statements","depth":10},{"id":8,"text":"made by Vice President Mike Pence and others about Flynn ' s discussions with the Russia ' s ambassador to the U.S.","depth":10},{"id":9,"text":"were wrong .","depth":9},{"id":10,"text":"She said","depth":7},{"id":11,"text":"she worried","depth":8},{"id":12,"text":"Flynn was vulnerable to blackmail as a result .","depth":8},{"id":13,"text":"`` We believe","depth":8},{"id":14,"text":"that General Flynn was compromised with respect to the Russians , \"","depth":8},{"id":15,"text":"she told lawmakers .","depth":7},{"id":16,"text":"Much of her testimony revolved around her conversation with McGahn .","depth":5},{"id":17,"text":"\" We told them","depth":7},{"id":18,"text":"how we had this information ,","depth":8},{"id":19,"text":"how we had acquired it ,","depth":9},{"id":20,"text":"and how we knew","depth":10},{"id":21,"text":"it was untrue , \"","depth":10},{"id":22,"text":"she said .","depth":6},{"id":23,"text":"President Trump fired Flynn","depth":7},{"id":24,"text":"four days after the Washington Post published a story about Flynn and the reported misinformation","depth":8},{"id":25,"text":"he gave .","depth":8},{"id":26,"text":"This was more than two weeks after Yates ' warning to the White House .","depth":6},{"id":27,"text":"\" Ask Sally Yates , under oath ,","depth":9},{"id":28,"text":"if she knows","depth":9},{"id":29,"text":"how classified information got into the newspapers","depth":9},{"id":30,"text":"soon after she explained it to W.H . Council , \"","depth":9},{"id":31,"text":"he tweeted .","depth":7},{"id":32,"text":"In the hearing , Yates said","depth":8},{"id":33,"text":"she didn ' t know","depth":9},{"id":34,"text":"how the Washington Post got the story .","depth":9},{"id":35,"text":"She said","depth":8},{"id":36,"text":"she did know","depth":10},{"id":37,"text":"Flynn had shared untrue information","depth":10},{"id":38,"text":"because of phone calls","depth":10},{"id":39,"text":"intercepted by the Obama administration .","depth":10},{"id":40,"text":"Trump has been quick to defend Flynn","depth":5},{"id":41,"text":"and Judicial Watch , a conservative watchdog group","depth":8},{"id":42,"text":"that ' s filed a lawsuit about these intercepted phone calls ,","depth":8},{"id":43,"text":"is backing him up .","depth":7},{"id":44,"text":"\" President Trump is onto something , \"","depth":8},{"id":45,"text":"Judicial Watch President Tom Fitton told News .","depth":8},{"id":46,"text":"\" The Obama administration was monitoring at least people close to him","depth":8},{"id":47,"text":"and certainly the results of that classified intelligence gathering was leaked","depth":9},{"id":48,"text":"which is wildly illegal . \"","depth":9},{"id":49,"text":"Yates insists","depth":5},{"id":50,"text":"her decision","depth":8},{"id":51,"text":"to inform the White House","depth":8},{"id":52,"text":"was not politically motivated","depth":7},{"id":53,"text":"and she did not call for the Trump administration to fire Flynn .","depth":6},{"id":54,"text":"\" We gave them this information","depth":5},{"id":55,"text":"so that they could take action . \"","depth":5}],"relations":[{"parent":111,"left":0,"right":110,"relation":"organization","nuclearity":"SN"},{"parent":110,"left":77,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":58,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":58,"left":1,"right":57,"relation":"elaboration","nuclearity":"NS"},{"parent":57,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":69,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":63,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":4,"right":62,"relation":"attribution","nuclearity":"SN"},{"parent":62,"left":5,"right":61,"relation":"joint","nuclearity":"NN"},{"parent":61,"left":6,"right":60,"relation":"attribution","nuclearity":"SN"},{"parent":60,"left":59,"right":9,"relation":"same-unit","nuclearity":"NN"},{"parent":59,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":65,"right":67,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":10,"right":64,"relation":"attribution","nuclearity":"SN"},{"parent":64,"left":11,"right":12,"relation":"attribution","nuclearity":"SN"},{"parent":67,"left":66,"right":15,"relation":"attribution","nuclearity":"NS"},{"parent":66,"left":13,"right":14,"relation":"attribution","nuclearity":"SN"},{"parent":75,"left":16,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":73,"right":22,"relation":"attribution","nuclearity":"NS"},{"parent":73,"left":17,"right":72,"relation":"attribution","nuclearity":"SN"},{"parent":72,"left":18,"right":71,"relation":"joint","nuclearity":"NN"},{"parent":71,"left":19,"right":70,"relation":"joint","nuclearity":"NN"},{"parent":70,"left":20,"right":21,"relation":"attribution","nuclearity":"SN"},{"parent":109,"left":102,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":93,"right":101,"relation":"evaluation","nuclearity":"NS"},{"parent":93,"left":80,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":79,"right":26,"relation":"context","nuclearity":"NS"},{"parent":79,"left":23,"right":78,"relation":"context","nuclearity":"NS"},{"parent":78,"left":24,"right":25,"