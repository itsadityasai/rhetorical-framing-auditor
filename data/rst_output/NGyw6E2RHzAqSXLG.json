{"article_id":"NGyw6E2RHzAqSXLG","edus":[{"id":0,"text":"President Barack Obama ,","depth":5},{"id":1,"text":"shown here with then-Secretary of State Hillary Clinton in September 2012 ,","depth":5},{"id":2,"text":"said Sunday","depth":4},{"id":3,"text":"that Mrs. Clinton 's personal email set-up did n't endanger national security .","depth":3},{"id":4,"text":"Photo by the Associated Press","depth":2},{"id":5,"text":"President Barack Obama said","depth":5},{"id":6,"text":"former Secretary of State Hillary Clinton 's use of a personal email server was a mistake ,","depth":5},{"id":7,"text":"but that U.S. national security hadn ' t been endangered .","depth":4},{"id":8,"text":"In his first extensive remarks on the controversy","depth":8},{"id":9,"text":"that has roiled the Democratic presidential primary ,","depth":8},{"id":10,"text":"Mr. Obama said on CBS ' s \" 60 Minutes \" program on Sunday","depth":7},{"id":11,"text":"that questions about Mrs. Clinton 's email arrangement were legitimate .","depth":6},{"id":12,"text":"`` It is important for her to answer these questions to the satisfaction of the American public , ''","depth":7},{"id":13,"text":"Mr. Obama told CBS 's Steve Kroft .","depth":7},{"id":14,"text":"`` When we 're in these offices ,","depth":10},{"id":15,"text":"we have to be more sensitive","depth":11},{"id":16,"text":"and stay as far away from the line as possible","depth":11},{"id":17,"text":"when it comes to how we handle information ,","depth":10},{"id":18,"text":"how we handle our own personal data .","depth":10},{"id":19,"text":"And ,","depth":11},{"id":20,"text":"you know ,","depth":12},{"id":21,"text":"she made a mistake .","depth":12},{"id":22,"text":"She has acknowledged it , ''","depth":10},{"id":23,"text":"the president said .","depth":9},{"id":24,"text":"At the same , Mr. Obama said","depth":9},{"id":25,"text":"her email arrangement didn ' t put the U.S. at risk","depth":9},{"id":26,"text":"and said","depth":10},{"id":27,"text":"the issue had been politicized .","depth":10},{"id":28,"text":"`` The fact","depth":13},{"id":29,"text":"that for the last three months this is all","depth":14},{"id":30,"text":"that 's been spoken about","depth":14},{"id":31,"text":"is an indication","depth":13},{"id":32,"text":"that we 're in presidential political season , ''","depth":13},{"id":33,"text":"he said .","depth":11},{"id":34,"text":"`` I can tell you","depth":11},{"id":35,"text":"that this is not a situation","depth":12},{"id":36,"text":"in which America 's national security was endangered . \"","depth":12},{"id":37,"text":"While secretary of state ,","depth":7},{"id":38,"text":"Mrs. Clinton used a personal email account","depth":8},{"id":39,"text":"run off her own email server .","depth":8},{"id":40,"text":"Critics say","depth":7},{"id":41,"text":"her actions made public records requests difficult","depth":8},{"id":42,"text":"and may have left sensitive national security information vulnerable to hackers .","depth":8},{"id":43,"text":"Mrs. Clinton has said","depth":6},{"id":44,"text":"the State Department 's rules didn ' t forbid the use of a personal email account .","depth":6},{"id":45,"text":"Democrats have said","depth":5},{"id":46,"text":"that the congressional investigations into Mrs. Clinton have become increasingly partisan .","depth":5},{"id":47,"text":"The FBI is also investigating .","depth":4},{"id":48,"text":"On Sunday , a Republican former staffer on the House Select Committee on Benghazi ,","depth":7},{"id":49,"text":"which has been investigating Mrs. Clinton ' s email practices in a broader inquiry into the 2012 attacks on a U.S. diplomatic post in Libya ,","depth":7},{"id":50,"text":"said","depth":6},{"id":51,"text":"the investigation had become overly political","depth":6},{"id":52,"text":"and focused entirely on Mrs. Clinton 's emails .","depth":6},{"id":53,"text":"Maj. Bradley Podliska , an intelligence officer in the Air Force Reserve , said","depth":5},{"id":54,"text":"he lost his job as an investigator on the committee","depth":6},{"id":55,"text":"partly because he resisted pressure","depth":7},{"id":56,"text":"to focus his investigation only into Mrs. Clinton and the State Department ' s role in the attacks .","depth":7}],"relations":[{"parent":113,"left":61,"right":112,"relation":"context","nuclearity":"SN"},{"parent":61,"left":60,"right":4,"relation":"attribution","nuclearity":"NS"},{"parent":60,"left":59,"right":3,"relation":"attribution","nuclearity":"SN"},{"parent":59,"left":58,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":58,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":112,"left":100,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":63,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":62,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":62,"left":5,"right":6,"relation":"attribution","nuclearity":"SN"},{"parent":99,"left":91,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":66,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":65,"right":11,"relation":"attribution","nuclearity":"SN"},{"parent":65,"left":64,"right":10,"relation":"same-unit","nuclearity":"NN"},{"parent":64,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":90,"left":67,"right":89,"relation":"joint","nuclearity":"NN"},{"parent":67,"left":12,"right":13,"relation":"attribution","nuclearity":"NS"},{"parent":89,"left":76,"right":88,"relation":"joint","nuclearity":"NN"},{"parent":76,"left":71,"right":75,"relation":"context","nuclearity":"SN"},{"parent":71,"left":69,"right":70,"relation":"context","nuclearity":"NS"},{"parent":69,"left":14,"right":68,"relation":"context","nuclearity":"SN"},{"parent":68,"left":15,"right":16,"relation":"joint","nuclearity":"NN"},{"parent":70,"left":17,"right":18,"relation":"joint","nuclearity":"NN"},{"parent":75,"left":74,"right":23,"relation":"attribution","nuclearity":"NS"},{