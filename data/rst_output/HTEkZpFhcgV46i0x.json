ght":91,"relation":"adversative","nuclearity":"NN"},{"parent":233,"left":92,"right":232,"relation":"purpose","nuclearity":"NS"},{"parent":232,"left":93,"right":94,"relation":"purpose","nuclearity":"NS"},{"parent":277,"left":268,"right":276,"relation":"joint","nuclearity":"NN"},{"parent":268,"left":95,"right":267,"relation":"explanation","nuclearity":"NS"},{"parent":267,"left":249,"right":266,"relation":"joint","nuclearity":"NN"},{"parent":249,"left":239,"right":248,"relation":"elaboration","nuclearity":"NS"},{"parent":239,"left":237,"right":238,"relation":"elaboration","nuclearity":"NS"},{"parent":237,"left":236,"right":98,"relation":"elaboration","nuclearity":"NS"},{"parent":236,"left":96,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":238,"left":99,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":248,"left":240,"right":247,"relation":"context","nuclearity":"SN"},{"parent":240,"left":101,"right":102,"relation":"joint","nuclearity":"NN"},{"parent":247,"left":242,"right":246,"relation":"joint","nuclearity":"NN"},{"parent":242,"left":103,"right":241,"relation":"adversative","nuclearity":"NN"},{"parent":241,"left":104,"right":105,"relation":"mode","nuclearity":"NS"},{"parent":246,"left":244,"right":245,"relation":"adversative","nuclearity":"NN"},{"parent":244,"left":106,"right":243,"relation":"attribution","nuclearity":"SN"},{"parent":243,"left":107,"right":108,"relation":"purpose","nuclearity":"NS"},{"parent":245,"left":109,"right":110,"relation":"causal","nuclearity":"SN"},{"parent":266,"left":251,"right":265,"relation":"adversative","nuclearity":"SN"},{"parent":251,"left":250,"right":113,"relation":"purpose","nuclearity":"NS"},{"parent":250,"left":111,"right":112,"relation":"purpose","nuclearity":"NS"},{"parent":265,"left":256,"right":264,"relation":"explanation","nuclearity":"NS"},{"parent":256,"left":253,"right":255,"relation":"explanation","nuclearity":"NS"},{"parent":253,"left":252,"right":116,"relation":"same-unit","nuclearity"