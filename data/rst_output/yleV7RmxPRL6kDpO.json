{"article_id":"yleV7RmxPRL6kDpO","edus":[{"id":0,"text":"CBS News reportedly fired a staffer","depth":4},{"id":1,"text":"who previously worked for ABC News","depth":5},{"id":2,"text":"and accessed footage of the anchor Amy Robach","depth":6},{"id":3,"text":"complaining","depth":7},{"id":4,"text":"that the network killed her exposé on Jeffrey Epstein .","depth":7},{"id":5,"text":"The journalist Yashar Ali reported in his newsletter on Wednesday","depth":4},{"id":6,"text":"that ABC News executives learned the identity of the former staffer ,","depth":5},{"id":7,"text":"then informed their counterparts at CBS News .","depth":5},{"id":8,"text":"The right-wing organization Project Veritas on Tuesday published a leaked video","depth":5},{"id":9,"text":"showing Robach angrily discussing how ABC News refused to air her story for years .","depth":5},{"id":10,"text":"It 's unclear whether the staffer","depth":6},{"id":11,"text":"who was fired","depth":6},{"id":12,"text":"leaked the footage to Project Veritas","depth":6},{"id":13,"text":"or passed it to someone else","depth":7},{"id":14,"text":"who did .","depth":7},{"id":15,"text":"CBS News did not immediately respond to Insider 's request for comment .","depth":3},{"id":16,"text":"CBS News fired a staffer","depth":6},{"id":17,"text":"who previously worked for ABC News","depth":6},{"id":18,"text":"and accessed explosive footage of one of its anchors","depth":6},{"id":19,"text":"complaining","depth":7},{"id":20,"text":"that the network killed her exposé about Jeffrey Epstein ,","depth":7},{"id":21,"text":"according to reports","depth":5},{"id":22,"text":"published Thursday .","depth":5},{"id":23,"text":"The journalist Yashar Ali tweeted on Thursday morning","depth":5},{"id":24,"text":"that two sources familiar with the matter confirmed","depth":6},{"id":25,"text":"that the staffer had been fired .","depth":6},{"id":26,"text":"Page Six also cited a source","depth":5},{"id":27,"text":"who said","depth":7},{"id":28,"text":"CBS News fired the staffer on Wednesday","depth":7},{"id":29,"text":"after ABC News executives contacted the network .","depth":6},{"id":30,"text":"On Tuesday , the right-wing organization Project Veritas published a leaked video ,","depth":6},{"id":31,"text":"which it said","depth":7},{"id":32,"text":"was shot in August ,","depth":7},{"id":33,"text":"featuring the anchor Amy Robach angrily discussing a story","depth":7},{"id":34,"text":"she tried to report in 2015 on the allegations against Epstein ,","depth":7},{"id":35,"text":"as well as connections to the Clintons and Prince Andrew .","depth":6},{"id":36,"text":"The video was shot between takes","depth":5},{"id":37,"text":"and did n't air .","depth":5},{"id":38,"text":"Robach said","depth":6},{"id":39,"text":"ABC News refused to air her story for three years","depth":7},{"id":40,"text":"partly because of concerns","depth":8},{"id":41,"text":"that the network would lose access to prominent figures .","depth":8},{"id":42,"text":"She also said","depth":6},{"id":43,"text":"she believed","depth":8},{"id":44,"text":"Epstein was murdered in prison in August ,","depth":8},{"id":45,"text":"despite a medical examiner 's official ruling","depth":8},{"id":46,"text":"that Epstein died by suicide .","depth":8},{"id":47,"text":"ABC News said in a statement on Tuesday","depth":6},{"id":48,"text":"that the network never stopped investigating Epstein","depth":7},{"id":49,"text":"and that Robach 's reporting in 2015 did n't meet high enough standards","depth":8},{"id":50,"text":"to air .","depth":8},{"id":51,"text":"Ali reported in his newsletter on Wednesday","depth":8},{"id":52,"text":"that ABC News executives learned the identity of the former staffer","depth":9},{"id":53,"text":"who accessed the footage of Robach","depth":10},{"id":54,"text":"and then informed their counterparts at CBS News .","depth":10},{"id":55,"text":"It 's unclear whether that person ,","depth":10},{"id":56,"text":"who has not been publicly identified ,","depth":10},{"id":57,"text":"leaked the footage to Project Veritas","depth":9},{"id":58,"text":"or obtained it","depth":9},{"id":59,"text":"and perhaps showed it to another person","depth":10},{"id":60,"text":"who leaked it .","depth":10},{"id":61,"text":"CBS News did not immediately respond to Insider 's request for comment .","depth":6}],"relations":[{"parent":123,"left":77,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":69,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":66,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":0,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":1,"right":64,"relation":"joint","nuclearity":"NN"},{"parent":64,"left":2,"right":63,"relation":"elaboration","nuclearity":"NS"},{"parent":63,"left":3,"right":4,"relation":"attribution","nuclearity":"SN"},{"parent":68,"left":5,"right":67,"relation":"attribution","nuclearity":"SN"},{"parent":67,"left":6,"right":7,"relation":"joint","nuclearity":"NN"},{"parent":76,"left":75,"right":15,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":70,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":71,"right":73,"relation":"same-unit","nuclearity":"NN"},{"parent":71,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":12,"right":72,"relation":"joint","nuclearity":"NN"},{"parent":72,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":90,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":90,"left":83,"right":89,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":81,"right":82,"relation":"attribution","nuclearity":"NS"},{"parent":81,"left":78,"right":80,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":16,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":18,"right":79,"relation":