{"article_id":"Gy4ulTWvHca1A6w6","edus":[{"id":0,"text":"GOP front-runner Donald Trump widens his lead in the nomination race ,","depth":4},{"id":1,"text":"while Marco Rubio and Ted Cruz threaten to overtake Ben Carson for the number two spot .","depth":4},{"id":2,"text":"Those four once again constitute the top tier in the latest national poll on the 2016 election .","depth":4},{"id":3,"text":"In addition , Rubio joins Carson as the only candidates","depth":7},{"id":4,"text":"at least half of voters say","depth":8},{"id":5,"text":"are honest and trustworthy","depth":8},{"id":6,"text":"-- though Carson ' s honesty rating has taken a hit .","depth":6},{"id":7,"text":"More on that later .","depth":5},{"id":8,"text":"First , here ' s how the GOP race stands :","depth":3},{"id":9,"text":"Trump remains in the top spot with a record 28 percent support from Republican primary voters .","depth":6},{"id":10,"text":"He was at 26 percent in the last Fox poll ,","depth":7},{"id":11,"text":"which was completed before the last debate and the Paris attacks","depth":8},{"id":12,"text":"( November 1-3 , 2015 ) .","depth":8},{"id":13,"text":"Carson drops from 23 percent to 18 percent in the new poll .","depth":6},{"id":14,"text":"Cruz and Rubio are both up three points","depth":8},{"id":15,"text":"and garner 14 percent each .","depth":8},{"id":16,"text":"All others are in the low single digits :","depth":8},{"id":17,"text":"Jeb Bush gets 5 percent ,","depth":9},{"id":18,"text":"while Chris Christie , Carly Fiorina , and Mike Huckabee each get 3 percent .","depth":10},{"id":19,"text":"John Kasich and Rand Paul receive 2 percent a piece .","depth":10},{"id":20,"text":"Three key GOP constituencies put the four favorites in the upper-tier :","depth":7},{"id":21,"text":"the Tea Party , white evangelical Christians , and talk radio listeners .","depth":7},{"id":22,"text":"Among GOP primary voters","depth":9},{"id":23,"text":"who are part of the Tea Party movement ,","depth":9},{"id":24,"text":"Trump is the first choice","depth":9},{"id":25,"text":"( 38 percent ) ,","depth":9},{"id":26,"text":"followed by Cruz","depth":9},{"id":27,"text":"( 30 percent ) .","depth":9},{"id":28,"text":"Carson","depth":13},{"id":29,"text":"( 14 percent )","depth":13},{"id":30,"text":"comes in third","depth":12},{"id":31,"text":"-- receiving less than half of Trump ' s support .","depth":11},{"id":32,"text":"Rubio rounds out the quartet with 9 percent .","depth":10},{"id":33,"text":"About a quarter of white evangelical Christians back Trump","depth":13},{"id":34,"text":"( 25 percent )","depth":13},{"id":35,"text":"and Carson","depth":13},{"id":36,"text":"( 24 percent ) ,","depth":13},{"id":37,"text":"while Cruz gets 18 percent","depth":12},{"id":38,"text":"and Rubio receives 11 percent .","depth":12},{"id":39,"text":"Cruz","depth":13},{"id":40,"text":"( 31 percent )","depth":13},{"id":41,"text":"is the preferred pick among those","depth":13},{"id":42,"text":"who listen to conservative talk radio daily .","depth":13},{"id":43,"text":"Trump","depth":13},{"id":44,"text":"( 24 percent ) ,","depth":13},{"id":45,"text":"Rubio","depth":14},{"id":46,"text":"( 16 percent )","depth":14},{"id":47,"text":"and Carson","depth":15},{"id":48,"text":"( 11 percent )","depth":15},{"id":49,"text":"also get double-digit backing .","depth":14},{"id":50,"text":"Earlier this month , Carson was the only 2016 candidate","depth":11},{"id":51,"text":"deemed honest and trustworthy by a majority of voters :","depth":11},{"id":52,"text":"60 percent said","depth":12},{"id":53,"text":"he was","depth":12},{"id":54,"text":"( November 1-3 , 2015 ) .","depth":11},{"id":55,"text":"Since then , some reporters","depth":12},{"id":56,"text":"-- and Trump --","depth":12},{"id":57,"text":"have questioned","depth":11},{"id":58,"text":"whether everything in Carson ' s new book is true .","depth":10},{"id":59,"text":"The attacks seem to have pushed Carson ' s honesty ratings down :","depth":9},{"id":60,"text":"today 53 percent of all voters say","depth":11},{"id":61,"text":"he is honest ,","depth":11},{"id":62,"text":"while 34 percent say","depth":11},{"id":63,"text":"he isn ' t .","depth":11},{"id":64,"text":"Still , that ' s a net positive of 19 points ,","depth":10},{"id":65,"text":"which gives him the second highest honesty score","depth":12},{"id":66,"text":"( the total percentage points of those","depth":14},{"id":67,"text":"saying","depth":15},{"id":68,"text":"you ' re honest","depth":15},{"id":69,"text":"minus those","depth":14},{"id":70,"text":"saying","depth":15},{"id":71,"text":"you ' re not )","depth":15},{"id":72,"text":"of the candidates","depth":12},{"id":73,"text":"included in the poll .","depth":12},{"id":74,"text":"Rubio does a touch better on that measure .","depth":11},{"id":75,"text":"By a 51-31 percent margin , voters say","depth":13},{"id":76,"text":"he is honest and trustworthy","depth":14},{"id":77,"text":"( +20 points ) ,","depth":14},{"id":78,"text":"up from 41-36 percent earlier this month .","depth":12},{"id":79,"text":"Cruz","depth":12},{"id":80,"text":"( +11 points ) ,","depth":12},{"id":81,"text":"Fiorina","depth":14},{"id":82,"text":"( +5 points )","depth":14},{"id":83,"text":"and Bush","depth":14},{"id":84,"text":"( +4 points )","depth":14},{"id":85,"text":"also get positive honesty scores .","depth":12},{"id":86,"text":"Trump gets a negative 14 honesty score","depth":11},{"id":87,"text":"( 41 percent honest vs. 55 percent not ) .","depth":11},{"id":88,"text":"That still puts him ahead of Hillary Clinton .","depth":11},{"id":89,"text":"She receives a net negative 20 score","depth":12},{"id":90,"text":"( 38 percent honest vs. 58 percent not ) .","depth":12},{"id":91,"text":"Clinton ' s ratings hit a record low in early November","depth":10},{"id":92,"text":"when just 35 percent of voters said","depth":11},{"id":93,"text":"she was honest .","depth":11},{"id":94,"text":"Among self-identified Republicans , all of the GOP candidates","depth":10},{"id":95,"text":"tested","depth":10},{"id":96,"text":"have a positive net honest and trustworthy score :","depth":9},{"id":97,"text":"Carson","depth":10},{"id":98,"text":"( +56 points ) ,","depth":10},{"id":99,"text":"Cruz","depth":11},{"id":100,"text":"( +51 points ) ,","depth":11},{"id":101,"text":"Rubio","depth":12},{"id":102,"text":"( +46 points ) ,","depth":12},{"id":103,"text":"Fiorina","depth":13},{"id":104,"text":"( +35 points ) ,","depth":13},{"id":105,"text":"Bush","depth":14},{"id":106,"text":"( +32 points )","depth":14},{"id":107,"text":"and Trump","depth":14},{"id":108,"text":"( +24 points ) .","depth":14},{"id":109,"text":"Seventy-three percent of Republicans say","depth":8},{"id":110,"text":"Carson is honest , down from 82 percent in early November .","depth":8},{"id":111,"text":"The poll is based on landline and cellphone interviews with 1,016 randomly chosen registered voters nationwide","depth":3},{"id":112,"text":"and was conducted under the joint direction of Anderson Robbins Research","depth":5},{"id":113,"text":"( D )","depth":5},{"id":114,"text":"and Shaw & Company Research","depth":6},{"id":115,"text":"( R )","depth":6},{"id":116,"text":"from November 16-19 , 2015 .","depth":5},{"id":117,"text":"The poll has a margin of sampling error of plus or minus three percentage points for all registered voters , and 5 points for Democratic primary voters and 4.5 points for Republican primary voters .","depth":2}],"relations":[{"parent":235,"left":228,"right":234,"relation":"context","nuclearity":"NS"},{"parent":228,"left":125,"right":227,"relation":"elaboration","nuclearity":"NS"},{"parent":125,"left":119,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":119,"left":0,"right":1,"relation":"joint","nuclearity":"NN"},{"parent":124,"left":2,"right":123,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":122,"right":7,"relation":"adversative","nuclearity":"NS"},{"parent":122,"left":121,"right":6,"relation":"adversative","nuclearity"