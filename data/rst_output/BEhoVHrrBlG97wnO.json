n","nuclearity":"NS"},{"parent":290,"left":288,"right":289,"relation":"elaboration","nuclearity":"NS"},{"parent":288,"left":142,"right":143,"relation":"attribution","nuclearity":"SN"},{"parent":289,"left":144,"right":145,"relation":"attribution","nuclearity":"SN"}]}