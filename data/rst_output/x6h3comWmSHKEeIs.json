{"article_id":"x6h3comWmSHKEeIs","edus":[{"id":0,"text":"Donald Trump Jr. was allegedly informed in an email of a Russian government effort","depth":5},{"id":1,"text":"to help his father","depth":5},{"id":2,"text":"prior to meeting with a Kremlin-connected lawyer ,","depth":4},{"id":3,"text":"according to a Monday night New York Times report .","depth":3},{"id":4,"text":"It was recently revealed that Trump Jr. had met with Natalia Veselnitskaya , a Russian lawyer , on June 9 , 2016","depth":4},{"id":5,"text":"because she had promised him","depth":5},{"id":6,"text":"that she had damaging information","depth":6},{"id":7,"text":"that might hurt Hillary Clinton ' s presidential campaign .","depth":6},{"id":8,"text":"Trump Jr. admitted","depth":7},{"id":9,"text":"that he sought the information ,","depth":7},{"id":10,"text":"but claimed","depth":7},{"id":11,"text":"he did not know","depth":8},{"id":12,"text":"that the person","depth":10},{"id":13,"text":"he was meeting","depth":10},{"id":14,"text":"had connections to the Russian government prior to the meeting .","depth":9},{"id":15,"text":"\" I was asked to have a meeting by an acquaintance","depth":9},{"id":16,"text":"I knew from the 2013 Miss Universe pageant","depth":9},{"id":17,"text":"with an individual","depth":9},{"id":18,"text":"who I was told","depth":10},{"id":19,"text":"might have information helpful to the campaign , \"","depth":10},{"id":20,"text":"Trump Jr. said .","depth":7},{"id":21,"text":"\" I was not told her name prior to the meeting .","depth":7},{"id":22,"text":"I asked Jared and Paul to attend ,","depth":8},{"id":23,"text":"but told them nothing of the substance . \"","depth":8},{"id":24,"text":"However , it is now being reported that Trump Jr. was told in an email","depth":9},{"id":25,"text":"before arranging the meeting","depth":9},{"id":26,"text":"that the Russian government was behind the damaging information ,","depth":8},{"id":27,"text":"according to three NYT sources with knowledge of the email .","depth":7},{"id":28,"text":"The email was allegedly sent by Rob Goldstone , a British reporter","depth":8},{"id":29,"text":"who helped Trump Jr. arrange the meeting back in June .","depth":8},{"id":30,"text":"According to the three sources ,","depth":9},{"id":31,"text":"the email indicates","depth":10},{"id":32,"text":"that the damaging Clinton information came from the Russian government","depth":10},{"id":33,"text":"but does not indicate","depth":9},{"id":34,"text":"if they procured the information from the Democratic National Committee hack .","depth":9},{"id":35,"text":"\" Obviously I ' m the first person on a campaign","depth":9},{"id":36,"text":"to ever take a meeting","depth":10},{"id":37,"text":"to hear info about an opponent...","depth":10},{"id":38,"text":"went nowhere","depth":9},{"id":39,"text":"but had to listen , \"","depth":9},{"id":40,"text":"Trump Jr. previously wrote in one tweet about the meeting .","depth":7},{"id":41,"text":"\" No inconsistency in statements ,","depth":10},{"id":42,"text":"meeting ended up being primarily about adoptions , \"","depth":10},{"id":43,"text":"he said in another tweet ,","depth":9},{"id":44,"text":"backing up claims","depth":10},{"id":45,"text":"he had made","depth":10},{"id":46,"text":"that his meeting with Veselnitskaya centered on Russian adoptions .","depth":9},{"id":47,"text":"\" In response to further Q ' s","depth":8},{"id":48,"text":"I simply provided more details . \"","depth":8},{"id":49,"text":"Goldstone ,","depth":5},{"id":50,"text":"who allegedly wrote the email to Trump Jr. ,","depth":5},{"id":51,"text":"also denied knowing","depth":5},{"id":52,"text":"if the Russian government had anything to do with the information .","depth":5},{"id":53,"text":"Interestingly , one of NYT ' s sources said","depth":4},{"id":54,"text":"it appeared that Goldstone was simply passing along information","depth":5},{"id":55,"text":"he had been given by others .","depth":5},{"id":56,"text":"Further attempts by the NYT","depth":5},{"id":57,"text":"to reach Goldstone","depth":5},{"id":58,"text":"were unsuccessful ,","depth":4},{"id":59,"text":"leaving questions","depth":4},{"id":60,"text":"as to how Goldstone would have authored an email","depth":5},{"id":61,"text":"without fully reading or understanding its contents .","depth":5}],"relations":[{"parent":123,"left":110,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":110,"left":65,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":64,"right":3,"relation":"attribution","nuclearity":"NS"},{"parent":64,"left":63,"right":2,"relation":"context","nuclearity":"NS"},{"parent":63,"left":0,"right":1,"relation":"purpose","nuclearity":"NS"},{"parent":109,"left":68,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":4,"right":67,"relation":"causal","nuclearity":"NS"},{"parent":67,"left":5,"right":66,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":108,"left":83,"right":107,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":74,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":69,"right":73,"relation":"adversative","nuclearity":"NN"},{"parent":69,"left":8,"right":9,"relation":"attribution","nuclearity":"SN"},{"parent":73,"left":10,"right":72,"relation":"attribution","nuclearity":"SN"},{"parent":72,"left":11,"right":71,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":70,"right":14,"relation":"same-unit","nuclearity":"NN"},{"parent":70,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":79,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":78,"right":20,"relation":"attribution","nuclearity":"NS"},{"parent":78,"left":75,"right":77,"relation":"same-unit","nuclearity":"NN"},{"parent":75,"left":15,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":17,"right":76,"relation":"ela