{"article_id":"KSCIgxmVd0IhbyBQ","edus":[{"id":0,"text":"Story highlights","depth":5},{"id":1,"text":"Rep. Peter King tells AC360","depth":7},{"id":2,"text":"that journalists also should be prosecuted","depth":7},{"id":3,"text":"FBI building case against the self-avowed NSA leaker ;","depth":7},{"id":4,"text":"source says","depth":8},{"id":5,"text":"charges not imminent","depth":8},{"id":6,"text":"The ex-NSA contractor says","depth":6},{"id":7,"text":"he gave journalists documents on secret surveillance programs","depth":6},{"id":8,"text":"The man","depth":10},{"id":9,"text":"who acknowledged leaking details of classified U.S. surveillance programs","depth":10},{"id":10,"text":"seemed to melt into the streets of Hong Kong","depth":9},{"id":11,"text":"as FBI investigators worked Tuesday","depth":10},{"id":12,"text":"to build a case against him","depth":10},{"id":13,"text":"and criticism of the programs continued to mount .","depth":9},{"id":14,"text":"Edward Snowden , 29 , apparently checked out of his Hong Kong hotel room Monday","depth":10},{"id":15,"text":"and has not been seen since .","depth":10},{"id":16,"text":"A reporter","depth":12},{"id":17,"text":"who helped develop stories from the information","depth":13},{"id":18,"text":"Snowden leaked","depth":13},{"id":19,"text":"said","depth":11},{"id":20,"text":"he believes","depth":11},{"id":21,"text":"the former contractor for the National Security Agency remains there .","depth":11},{"id":22,"text":"U.S. authorities are preparing charges against Snowden ,","depth":10},{"id":23,"text":"a law enforcement source told CNN on Tuesday .","depth":10},{"id":24,"text":"But they are not imminent ,","depth":10},{"id":25,"text":"the source said .","depth":10},{"id":26,"text":"As authorities investigated ,","depth":7},{"id":27,"text":"one U.S. congressman told CNN","depth":8},{"id":28,"text":"that journalists","depth":10},{"id":29,"text":"who published the leaked information","depth":10},{"id":30,"text":"should be punished .","depth":9},{"id":31,"text":"JUST WATCHED Manhunt underway for NSA leaker","depth":9},{"id":32,"text":"Replay More Videos ...","depth":9},{"id":33,"text":"MUST WATCH Manhunt underway for NSA leaker","depth":8},{"id":34,"text":"03:00","depth":7},{"id":35,"text":"JUST WATCHED","depth":11},{"id":36,"text":"Whistleblower :","depth":12},{"id":37,"text":"US violating 4th amend .","depth":12},{"id":38,"text":"Replay More Videos ...","depth":10},{"id":39,"text":"MUST WATCH Whistleblower :","depth":10},{"id":40,"text":"US violating 4th amend .","depth":10},{"id":41,"text":"04:05","depth":8},{"id":42,"text":"JUST WATCHED Paul on Snowden :","depth":11},{"id":43,"text":"It 's a heroic effort","depth":11},{"id":44,"text":"Replay More Videos ...","depth":11},{"id":45,"text":"MUST WATCH Paul on Snowden :","depth":12},{"id":46,"text":"It 's a heroic effort","depth":12},{"id":47,"text":"01:54","depth":9},{"id":48,"text":"JUST WATCHED Snowden 's life prior to leak","depth":10},{"id":49,"text":"Replay More Videos ...","depth":10},{"id":50,"text":"MUST WATCH Snowden 's life prior to leak 03:06","depth":9},{"id":51,"text":"And the first civil lawsuits were filed against federal officials ,","depth":8},{"id":52,"text":"arguing","depth":9},{"id":53,"text":"that the surveillance programs are unconstitutional .","depth":9},{"id":54,"text":"Snowden , a former computer security contractor , acknowledged in a Guardian newspaper interview","depth":8},{"id":55,"text":"that he gave journalists classified documents about U.S. surveillance of telephone and Internet traffic .","depth":8},{"id":56,"text":"The FBI has been investigating the leaks ,","depth":7},{"id":57,"text":"but it was unclear Tuesday how far along the agency was .","depth":7},{"id":58,"text":"Snowden told the Guardian","depth":6},{"id":59,"text":"that he expects to be charged under the Espionage Act","depth":6},{"id":60,"text":"and said","depth":6},{"id":61,"text":"he traveled to Hong Kong in hopes","depth":7},{"id":62,"text":"that state 's commitment to free speech would prevent his extradition to the United States .","depth":7},{"id":63,"text":"On Tuesday , one lawmaker told CNN 's AC360","depth":5},{"id":64,"text":"that journalists","depth":7},{"id":65,"text":"tied to the leaks","depth":7},{"id":66,"text":"should also be prosecuted .","depth":6},{"id":67,"text":"`` If they willingly knew","depth":8},{"id":68,"text":"that this was classified information ,","depth":8},{"id":69,"text":"I think","depth":8},{"id":70,"text":"actions should be taken , especially on something of this magnitude , ''","depth":8},{"id":71,"text":"said Rep. Peter King , a New York Republican","depth":7},{"id":72,"text":"who leads the House Homeland Security subcommittee on Counterintelligence and Terrorism .","depth":7},{"id":73,"text":"`` There is an obligation","depth":8},{"id":74,"text":"both moral , but also legal ,","depth":9},{"id":75,"text":"I believe ,","depth":9},{"id":76,"text":"against a reporter","depth":9},{"id":77,"text":"disclosing something","depth":10},{"id":78,"text":"which would so severely compromise national security , ''","depth":10},{"id":79,"text":"he said .","depth":8},{"id":80,"text":"`` As a practical matter , I guess","depth":7},{"id":81,"text":"there have been in the past several years a number of reporters","depth":8},{"id":82,"text":"who have been prosecuted under ( the Espionage Act ) . ''","depth":8},{"id":83,"text":"As for Snowden , King said","depth":7},{"id":84,"text":"there 's no doubt","depth":7},{"id":85,"text":"he should face charges .","depth":6},{"id":86,"text":"`` I think","depth":8},{"id":87,"text":"what he 's done has been incredible damage to our country .","depth":8},{"id":88,"text":"It 's going to put American lives at risk , ''","depth":7},{"id":89,"text":"he said .","depth":6},{"id":90,"text":"The congressman did not provide specific examples","depth":6},{"id":91,"text":"of how the leaked information damages national security ,","depth":6},{"id":92,"text":"but argued","depth":7},{"id":93,"text":"that it helps enemies of the United States .","depth":7},{"id":94,"text":"`` Al Qaeda and its allies now know with great exactitude exactly what we 're doing , ''","depth":7},{"id":95,"text":"he said ,","depth":8},{"id":96,"text":"`` and how we 're doing it . ''","depth":8},{"id":97,"text":"Snowden 's disclosures have fueled new debate about the U.S. government 's collection of records of domestic telephone calls and overseas Internet activity in the global hunt for terrorists and criminals .","depth":5},{"id":98,"text":"Civil liberties advocates say","depth":7},{"id":99,"text":"the measures are unacceptable intrusions .","depth":7},{"id":100,"text":"But supporters say","depth":7},{"id":101,"text":"they are legal","depth":8},{"id":102,"text":"and have yielded evidence","depth":9},{"id":103,"text":"that has helped stop terror plots .","depth":9},{"id":104,"text":"JUST WATCHED","depth":8},{"id":105,"text":"President Obama open to NSA changes","depth":8},{"id":106,"text":"Replay More Videos ...","depth":7},{"id":107,"text":"MUST WATCH","depth":8},{"id":108,"text":"President Obama open to NSA changes","depth":8},{"id":109,"text":"02:31","depth":8},{"id":110,"text":"JUST WATCHED","depth":12},{"id":111,"text":"NSA leaker back in shadows","depth":12},{"id":112,"text":"Replay More Videos ...","depth":12},{"id":113,"text":"MUST WATCH NSA leaker back in shadows","depth":12},{"id":114,"text":"01:45","depth":10},{"id":115,"text":"JUST WATCHED","depth":11},{"id":116,"text":"Why did U.S. leaker hide in Hong Kong ?","depth":12},{"id":117,"text":"Replay More Videos ...","depth":12},{"id":118,"text":"MUST WATCH","depth":13},{"id":119,"text":"Why did U.S. leaker hide in Hong Kong ?","depth":13},{"id":120,"text":"03:25","depth":12},{"id":121,"text":"JUST WATCHED","depth":12},{"id":122,"text":"Where could NSA leaker go ?","depth":13},{"id":123,"text":"Replay More Videos ...","depth":14},{"id":124,"text":"MUST WATCH Where could NSA leaker go ?","depth":15},{"id":125,"text":"05:01","depth":15},{"id":126,"text":"White House spokesman Jay Carney said Tuesday","depth":11},{"id":127,"text":"that the measures `` strike a balance between our security interest and our desire for privacy . ''","depth":11},{"id":128,"text":"`` There has to be some modest concession to the need for information","depth":11},{"id":129,"text":"as we pursue terrorists","depth":13},{"id":130,"text":"who mean to do harm to the country","depth":14},{"id":131,"text":"and take the lives of Americans , ''","depth":14},{"id":132,"text":"Carney said .","depth":12},{"id":133,"text":"`` But ... we need to make sure","depth":10},{"id":134,"text":"that the programs","depth":14},{"id":135,"text":"we have in place","depth":14},{"id":136,"text":"are properly overseen ,","depth":13},{"id":137,"text":"that they are legal ,","depth":13},{"id":138,"text":"that they are authorized by Congress","depth":14},{"id":139,"text":"and they are authorized by the courts ,","depth":14},{"id":140,"text":"and that is the case here . ''","depth":11},{"id":141,"text":"But at least two civil lawsuits have been filed so far against federal officials ,","depth":11},{"id":142,"text":"arguing","depth":13},{"id":143,"text":"that the collection of phone records is unconstitutional","depth":13},{"id":144,"text":"and calling for a judge to block the measure .","depth":12},{"id":145,"text":"`` The practice is akin to snatching every American 's address book","depth":13},{"id":146,"text":"-- with annotations","depth":14},{"id":147,"text":"detailing whom we spoke to , when we talked , for how long , and from where , ''","depth":14},{"id":148,"text":"the American Civil Liberties Union and several other groups said in a federal lawsuit","depth":13},{"id":149,"text":"filed Tuesday .","depth":13},{"id":150,"text":"`` It gives the government a comprehensive record of our associations and public movements ,","depth":12},{"id":151,"text":"revealing a wealth of detail about our familial , political , professional , religious and intimate associations . ''","depth":12},{"id":152,"text":"A Philadelphia couple","depth":12},{"id":153,"text":"who allege","depth":13},{"id":154,"text":"they were singled out for electronic surveillance","depth":14},{"id":155,"text":"because of their criticism of the U.S. military","depth":14},{"id":156,"text":"filed a $ 3 billion class-action lawsuit ,","depth":11},{"id":157,"text":"claiming","depth":11},{"id":158,"text":"their privacy and free speech rights were compromised .","depth":11},{"id":159,"text":"House Democratic Whip Steny Hoyer , D-Maryland , told reporters","depth":9},{"id":160,"text":"the closed briefing was `` thoughtful ''","depth":10},{"id":161,"text":"and not steeped in politics .","depth":10},{"id":162,"text":"Representatives from both parties raised `` legitimate '' concerns about the programs ,","depth":9},{"id":163,"text":"said Rep. Mark Sanford , R-South Carolina .","depth":9},{"id":164,"text":"Throughout the day , the administration facing a steady stream of criticism and support from allies and enemies alike .","depth":11},{"id":165,"text":"Some of the sharpest criticism came from Democratic Sen. Ron Wyden of Oregon ,","depth":13},{"id":166,"text":"who blasted Obama 's top intelligence official Tuesday ,","depth":14},{"id":167,"text":"saying","depth":15},{"id":168,"text":"that James Clapper failed to shoot straight during a March congressional hearing .","depth":15},{"id":169,"text":"`` One of the most important responsibilities","depth":16},{"id":170,"text":"a senator has","depth":16},{"id":171,"text":"is oversight of the intelligence community , ''","depth":15},{"id":172,"text":"Wyden said .","depth":14},{"id":173,"text":"`` This job can not be done responsibly","depth":14},{"id":174,"text":"if senators are n't getting straight answers to direct questions . ''","depth":14},{"id":175,"text":"In March , Wyden asked Clapper","depth":11},{"id":176,"text":"whether the NSA collects `` any type of data at all on millions or hundreds of millions of Americans ? ''","depth":11},{"id":177,"text":"On Saturday , Clapper told NBC News","depth":11},{"id":178,"text":"that he `` responded in what I thought","depth":12},{"id":179,"text":"was the most truthful , or least most untruthful , manner . ''","depth":12},{"id":180,"text":"He told NBC","depth":11},{"id":181,"text":"that he had interpreted `` collection '' to mean actually examining the materials","depth":12},{"id":182,"text":"gathered by the NSA .","depth":12},{"id":183,"text":"He had previously told the National Journal","depth":9},{"id":184,"text":"that he had meant","depth":11},{"id":185,"text":"that `` the NSA does not voyeuristically pore through U.S. citizens ' e-mails , ''","depth":11},{"id":186,"text":"but he did not mention e-mails at the hearing .","depth":10},{"id":187,"text":"Criticism also began to emerge over how Snowden , a low-level computer technician","depth":10},{"id":188,"text":"working for a private contractor in Hawaii ,","depth":10},{"id":189,"text":"was able to have access to such highly classified information .","depth":9},{"id":190,"text":"Sen. Barbara Mikulski , D-Maryland , said Tuesday","depth":10},{"id":191,"text":"that `` people are asking","depth":11},{"id":192,"text":"why does a kid","depth":14},{"id":193,"text":"who could n't make it through community college","depth":14},{"id":194,"text":"can make $ 200 grand a year","depth":13},{"id":195,"text":"and be exposed to some of our most significant secrets . ''","depth":12},{"id":196,"text":"Snowden last worked for the computer consulting firm Booz Allen Hamilton .","depth":11},{"id":197,"text":"The company fired him Monday after less than three months on the job for violations of company policy and its code of ethics .","depth":11},{"id":198,"text":"Despite what he had said was a $ 200,000 salary ,","depth":11},{"id":199,"text":"the company said","depth":12},{"id":200,"text":"he earned $ 122,000 .","depth":12},{"id":201,"text":"U.S. intelligence officials say","depth":7},{"id":202,"text":"the NSA , CIA and other intelligence officials are reviewing security measures in light of the leaks ,","depth":8},{"id":203,"text":"examining how Snowden had access to so much information","depth":9},{"id":204,"text":"and weighing whether changes should be made .","depth":9},{"id":205,"text":"They are also looking at the contractor piece of the picture ,","depth":7},{"id":206,"text":"although the officials say","depth":8},{"id":207,"text":"security clearances are no different for contractors","depth":9},{"id":208,"text":"than they are for staff employees .","depth":9},{"id":209,"text":"Michael Hayden ,","depth":10},{"id":210,"text":"who once led both the CIA and NSA ,","depth":10},{"id":211,"text":"told CNN","depth":9},{"id":212,"text":"the leaks showed a failure of security , not a contractor issue .","depth":8},{"id":213,"text":"`` If you 're going to give anyone access to your database ,","depth":10},{"id":214,"text":"it 's still your database , ''","depth":10},{"id":215,"text":"he said ,","depth":9},{"id":216,"text":"`` and you have to assume responsibility for the vetting process of the contractors","depth":9},{"id":217,"text":"involved . ''","depth":9},{"id":218,"text":"Hayden said","depth":8},{"id":219,"text":"he was surprised","depth":9},{"id":220,"text":"this kind of data would have been available to Snowden .","depth":9},{"id":221,"text":"`` I 'm more surprised","depth":9},{"id":222,"text":"that a low-ranking fellow ,","depth":11},{"id":223,"text":"working apparently on a NSA contract in Hawaii ,","depth":11},{"id":224,"text":"gets access to such a sensitive program , ''","depth":10},{"id":225,"text":"he said .","depth":8},{"id":226,"text":"A federal law enforcement source told CNN on Monday","depth":6},{"id":227,"text":"that the government 's investigation will include searches of Snowden 's home and efforts","depth":7},{"id":228,"text":"to interview his girlfriend , relatives , co-workers and friends .","depth":7},{"id":229,"text":"The official did not know","depth":6},{"id":230,"text":"if the FBI would attempt to contact Snowden overseas","depth":8},{"id":231,"text":"and ask","depth":9},{"id":232,"text":"if he would agree to a voluntary interview ,","depth":9},{"id":233,"text":"or if the agency would wait","depth":8},{"id":234,"text":"until other evidence had been gathered .","depth":8},{"id":235,"text":"While Snowden said","depth":5},{"id":236,"text":"he fled to Hong Kong in hopes","depth":6},{"id":237,"text":"of avoiding extradition ,","depth":6},{"id":238,"text":"what 's next for him remains unclear .","depth":4},{"id":239,"text":"Although Hong Kong is part of communist-ruled China ,","depth":8},{"id":240,"text":"the former British colony has a separate system of government","depth":9},{"id":241,"text":"that allows a free press","depth":10},{"id":242,"text":"and tolerates political dissent .","depth":10},{"id":243,"text":"But legal experts say","depth":8},{"id":244,"text":"Hong Kong 's extradition treaty with the United States could make it hard for Snowden to successfully fight any proceedings against him","depth":9},{"id":245,"text":"unless he is able to prove , for example ,","depth":10},{"id":246,"text":"that any charges against him are politically motivated .","depth":10},{"id":247,"text":"Patricia Ho , a lawyer with Daly & Associates in Hong Kong ,","depth":10},{"id":248,"text":"whose firm has handled asylum and refugee claims ,","depth":10},{"id":249,"text":"said","depth":9},{"id":250,"text":"that","depth":9},{"id":251,"text":"given Hong Kong 's lackluster track record","depth":11},{"id":252,"text":"on granting asylum ,","depth":11},{"id":253,"text":"she was surprised","depth":11},{"id":254,"text":"that Snowden had lauded the territory for its commitment to civil liberties .","depth":11},{"id":255,"text":"`` Within China itself , Hong Kong has better civil liberties ,","depth":9},{"id":256,"text":"but I could n't see the Hong Kong government granting him asylum","depth":10},{"id":257,"text":"given their present practices , ''","depth":10},{"id":258,"text":"she said .","depth":8},{"id":259,"text":"On Monday , the office of Russian President Vladimir Putin 's spokesman tweeted","depth":7},{"id":260,"text":"that U.S. officials had broken the law with the surveillance programs ,","depth":8},{"id":261,"text":"making Snowden a `` human rights activist . ''","depth":8},{"id":262,"text":"Spokesman Dmitry Peskov told CNN","depth":7},{"id":263,"text":"that Russia would consider an asylum request from Snowden","depth":8},{"id":264,"text":"but has not received one .","depth":8},{"id":265,"text":"Google on Tuesday asked for permission","depth":8},{"id":266,"text":"to publish details of requests for information under the Foreign Intelligence Security Act .","depth":8},{"id":267,"text":"It wants to regain the trust of users after initial assertions","depth":8},{"id":268,"text":"that it and other companies were providing the NSA with direct , unrestricted access to data","depth":9},{"id":269,"text":"stored on their computers .","depth":9},{"id":270,"text":"`` Assertions in the press","depth":11},{"id":271,"text":"that our compliance with these requests gives the U.S. government unfettered access to our users ' data","depth":11},{"id":272,"text":"are simply untrue , ''","depth":10},{"id":273,"text":"the company said in a letter to Attorney General Eric Holder and FBI Director Robert Mueller .","depth":9},{"id":274,"text":"But government laws","depth":11},{"id":275,"text":"demanding secrecy about the requests","depth":11},{"id":276,"text":"`` fuel that speculation , ''","depth":10},{"id":277,"text":"the company said .","depth":9},{"id":278,"text":"`` Google 's numbers would clearly show","depth":10},{"id":279,"text":"that our compliance with these requests falls far short of the claims","depth":11},{"id":280,"text":"being made , ''","depth":11},{"id":281,"text":"the company said .","depth":9},{"id":282,"text":"`` Google has nothing to hide . ''","depth":8},{"id":283,"text":"A Justice Department spokeswoman said","depth":6},{"id":284,"text":"officials have received Google 's request","depth":7},{"id":285,"text":"and are reviewing it .","depth":7}],"relations":[{"parent":571,"left":382,"right":570,"relation":"joint","nuclearity":"NN"},{"parent":382,"left":348,"right":381,"relation":"joint","nuclearity":"NN"},{"parent":348,"left":316,"right":347,"relation":"joint","nuclearity":"NN"},{"parent":316,"left":291,"right":315,"relation":"joint","nuclearity":"NN"},{"parent":291,"left":0,"right":290,"relation":"organization","nuclearity":"SN"},{"parent":290,"left":287,"right":289,"relation":"context","nuclearity":"NS"},{"parent":287,"left":1,"right":2,"relation":"attribution","nuclearity":"SN"},{"parent":289,"left":3,"right":288,"relation":"adversative","nuclearity":"NN"},{"parent":288,"left":4,"right":5,"relation":"attribution","nuclearity":"SN"},{"parent":315,"left":292,"right":314,"relation":"organization","nuclearity":"SN"},{"parent":292,"left":6,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":314,"left":309,"right":313,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":297,"right":308,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":294,"right":296,"relation":"context","nuclearity":"NS"},{"parent":294,"left":293,"right":10,"relation":"same-unit","nuclearity":"NN"},{"parent":293,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":296,"left":295,"right":13,"relation":"joint","nuclearity":"NN"},{"parent":295,"left":11,"right":12,"relation":"purpose","nuclearity":"NS"},{"parent":308,"left":304,"right":307,"relation":"joint","nuclearity":"NN"},{"parent":304,"left":298,"right":303,"relation":"joint","nuclearity":"NN"},{"parent":298,"left":14,"right":15,"relation":"joint","nuclearity":"NN"},{"parent":303,"left":301,"right":302,"relation":"attribution","nuclearity":"SN"},{"parent":301,"left":300,"right":19,"relation":"same-unit","nuclearity":"NN"},{"parent"