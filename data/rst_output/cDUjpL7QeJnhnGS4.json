{"article_id":"cDUjpL7QeJnhnGS4","edus":[{"id":0,"text":"Sen. Rand Paul","depth":6},{"id":1,"text":"( R-KY )","depth":6},{"id":2,"text":"predicted Monday","depth":5},{"id":3,"text":"that ten Republican senators will vote for a Democrat resolution","depth":5},{"id":4,"text":"to end President Donald Trump ' s national emergency declaration","depth":6},{"id":5,"text":"to build the wall .","depth":6},{"id":6,"text":"Sen. Paul told reporters","depth":5},{"id":7,"text":"that he believes","depth":6},{"id":8,"text":"that ten Republicans senators will vote","depth":7},{"id":9,"text":"to end Trump ' s national emergency declaration .","depth":7},{"id":10,"text":"Paul announced Saturday","depth":6},{"id":11,"text":"that he will vote for the Democrat resolution .","depth":6},{"id":12,"text":"\" I can ' t vote to give the president the power","depth":7},{"id":13,"text":"to spend money","depth":8},{"id":14,"text":"that hasn ' t been appropriated by Congress .","depth":8},{"id":15,"text":"We may want more money for border security ,","depth":9},{"id":16,"text":"but Congress didn ' t authorize it , \"","depth":9},{"id":17,"text":"Paul said .","depth":8},{"id":18,"text":"\" If we take away those checks and balances ,","depth":8},{"id":19,"text":"it ' s a dangerous thing . \"","depth":8},{"id":20,"text":"The Kentucky Republican ' s prediction arises","depth":5},{"id":21,"text":"as Senate Majority Leader Mitch McConnell","depth":8},{"id":22,"text":"( R-KY )","depth":8},{"id":23,"text":"reportedly broke a promise to President Trump :","depth":7},{"id":24,"text":"McConnell promised to back the national emergency in exchange for Trump ' s endorsement of a long-term spending bill .","depth":6},{"id":25,"text":"McConnell said","depth":6},{"id":26,"text":"that the Democrat resolution","depth":8},{"id":27,"text":"to end the national emergency","depth":8},{"id":28,"text":"will pass through the Senate .","depth":7},{"id":29,"text":"However ,","depth":8},{"id":30,"text":"if Paul correctly predicts the Senate vote ,","depth":9},{"id":31,"text":"then the resolution will pass through the Senate ,","depth":9},{"id":32,"text":"but Senate Republicans and Democrats would not be able to defeat a presidential veto","depth":8},{"id":33,"text":"unless more Republicans defect .","depth":8},{"id":34,"text":"\" What is clear in the Senate is that there will be enough votes","depth":8},{"id":35,"text":"to pass the resolution of disapproval ,","depth":10},{"id":36,"text":"which will then be vetoed by the president","depth":10},{"id":37,"text":"and then in all likelihood the veto will be upheld in the House , \"","depth":9},{"id":38,"text":"McConnell said .","depth":7},{"id":39,"text":"Currently , four senators have come out in favor ofthe Democrat resolution .","depth":5},{"id":40,"text":"Sens . Paul , Susan Collins","depth":7},{"id":41,"text":"( R-ME ) ,","depth":7},{"id":42,"text":"Lisa Murkowski","depth":9},{"id":43,"text":"( R-AK ) ,","depth":9},{"id":44,"text":"and Tom Tillis","depth":9},{"id":45,"text":"( R-NC )","depth":9},{"id":46,"text":"have come out publicly against Trump ' s executive action","depth":8},{"id":47,"text":"to secure the border .","depth":8},{"id":48,"text":"Sen. Mitt Romney","depth":8},{"id":49,"text":"( R-UT )","depth":8},{"id":50,"text":"has not announced his decision regarding the national emergency ,","depth":7},{"id":51,"text":"but said Monday","depth":8},{"id":52,"text":"he will reveal his decision at the \" right time . \"","depth":8},{"id":53,"text":"Sen Romney says","depth":8},{"id":54,"text":"he will put out a statement on disapproval resolution \" at a time","depth":10},{"id":55,"text":"that","depth":12},{"id":56,"text":"I think","depth":12},{"id":57,"text":"is the right time \"","depth":11},{"id":58,"text":"but is still trying to decide when that will be","depth":9},{"id":59,"text":"- Erica Werner","depth":7},{"id":60,"text":"( @ ericawerner )","depth":7},{"id":61,"text":"March 4 , 2019","depth":6},{"id":62,"text":"McConnell later also said","depth":3},{"id":63,"text":"that he tried to convince Trump to not declare a national emergency ,","depth":4},{"id":64,"text":"contending","depth":5},{"id":65,"text":"that future Democrat presidential administrations might abuse Trump ' s precedent .","depth":5},{"id":66,"text":"\" That ' s one reason","depth":5},{"id":67,"text":"I argued without success","depth":6},{"id":68,"text":"that he not take this route , \"","depth":6},{"id":69,"text":"McConnell said .","depth":4},{"id":70,"text":"\" I was one of those","depth":6},{"id":71,"text":"hoping","depth":7},{"id":72,"text":"the president would not take the national emergency route , \"","depth":7},{"id":73,"text":"McConnell added .","depth":5},{"id":74,"text":"\" Once he decided to do that","depth":6},{"id":75,"text":"I said","depth":7},{"id":76,"text":"I would support it ,","depth":7},{"id":77,"text":"but I was hoping","depth":6},{"id":78,"text":"he wouldn ' t take that particular path . \"","depth":6}],"relations":[{"parent":157,"left":140,"right":156,"relation":"elaboration","nuclearity":"NS"},{"parent":140,"left":98,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":98,"left":84,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":81,"right":83,"relation":"attribution","nuclearity":"SN"},{"parent":81,"left":80,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":80,"left":0,"right":1,"relation":"restatement","nuclearity":"NS"},{"parent":83,"left":3,"right":82,"relation":"purpose","nuclearity":"NS"},{"parent":82,"left":4,"right":5,"relation":"purpose","nuclearity":"NS"},{"parent":97,"left":87,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":87,"left":6,"right":86,"relation":"attribution","nuclearity":"SN"},{"parent":86,"left":7,"right":85,"relation":"attribution","nuclearity":"SN"},{"parent":85,"left":8,"right":9,"relation":"purpose","nuclearity":"NS"},{"parent":96,"left":88,"right":95,"relation":"explanation","nuclearity":"NS"},{"parent":88,"