{"article_id":"yuCi4ym4FK4flsSi","edus":[{"id":0,"text":"Roger Stone ,","depth":5},{"id":1,"text":"left , with his wife Nydia Stone ,","depth":5},{"id":2,"text":"leaves federal court in Washington , Friday , Nov. 15 , 2019 .","depth":4},{"id":3,"text":"Stone , a longtime friend of President Donald Trump , has been found guilty at his trial in federal court in Washington .","depth":4},{"id":4,"text":"( AP Photo/Julio Cortez )","depth":4},{"id":5,"text":"Roger Stone ,","depth":5},{"id":6,"text":"left , with his wife Nydia Stone ,","depth":5},{"id":7,"text":"leaves federal court in Washington , Friday , Nov. 15 , 2019 .","depth":4},{"id":8,"text":"Stone , a longtime friend of President Donald Trump , has been found guilty at his trial in federal court in Washington .","depth":4},{"id":9,"text":"( AP Photo/Julio Cortez )","depth":4},{"id":10,"text":"WASHINGTON","depth":4},{"id":11,"text":"( AP ) -","depth":4},{"id":12,"text":"Roger Stone , a longtime friend and ally of President Donald Trump , was found guilty Friday of witness tampering and lying to Congress about his pursuit of Russian-hacked emails","depth":9},{"id":13,"text":"damaging to Hillary Clinton ' s 2016 election bid .","depth":9},{"id":14,"text":"Stone was convicted of all seven counts in a federal indictment","depth":10},{"id":15,"text":"that accused him of lying to Congress , tampering with a witness","depth":11},{"id":16,"text":"and obstructing the House investigation","depth":12},{"id":17,"text":"into whether the Trump campaign coordinated with Russia","depth":13},{"id":18,"text":"to tip the 2016 election .","depth":13},{"id":19,"text":"He is the sixth Trump aide or adviser","depth":10},{"id":20,"text":"to be convicted of charges","depth":11},{"id":21,"text":"brought as part of special counsel Robert Mueller ' s Russia investigation .","depth":11},{"id":22,"text":"Stone has denied wrongdoing","depth":9},{"id":23,"text":"and consistently criticized the case against him as politically motivated .","depth":9},{"id":24,"text":"He did not take the stand during the trial","depth":9},{"id":25,"text":"and his lawyers did not call any witnesses in his defense .","depth":9},{"id":26,"text":"Stone , 67 , showed no visible reaction","depth":8},{"id":27,"text":"as the verdict was read aloud , count by count .","depth":8},{"id":28,"text":"He ' s scheduled to be sentenced on Feb. 6 .","depth":8},{"id":29,"text":"He could face up to 20 years .","depth":8},{"id":30,"text":"Another former Trump campaign aide , Michael Caputo , was removed by the courtroom by security officers","depth":7},{"id":31,"text":"after he turned his back on the jury","depth":8},{"id":32,"text":"after the verdict was read .","depth":8},{"id":33,"text":"Stone smirked at reporters","depth":8},{"id":34,"text":"as he left the courtroom ,","depth":9},{"id":35,"text":"holding hands with his wife .","depth":9},{"id":36,"text":"As he walked out of the courthouse ,","depth":9},{"id":37,"text":"Stone was asked","depth":10},{"id":38,"text":"if he had any comment on the verdict","depth":10},{"id":39,"text":"and replied :","depth":10},{"id":40,"text":"\" none whatsoever \"","depth":10},{"id":41,"text":"before he hopped into a waiting SUV with his wife .","depth":9},{"id":42,"text":"Trump tweeted minutes after the verdict ,","depth":9},{"id":43,"text":"calling the conviction \" a double standard","depth":11},{"id":44,"text":"like never seen before in the history of our Country , \"","depth":11},{"id":45,"text":"because his frequent nemeses ,","depth":12},{"id":46,"text":"including Hillary Clinton , former FBI Director James Comey and \" including even Mueller himself , \"","depth":12},{"id":47,"text":"have not been convicted .","depth":11},{"id":48,"text":"\" Didn ' t they lie ? \"","depth":8},{"id":49,"text":"In a trial","depth":11},{"id":50,"text":"that lasted about a week ,","depth":11},{"id":51,"text":"witnesses highlighted","depth":10},{"id":52,"text":"how Trump campaign associates were eager to gather information about emails","depth":11},{"id":53,"text":"the U.S. says","depth":12},{"id":54,"text":"were hacked by Russia","depth":12},{"id":55,"text":"and then provided to the anti-secrecy website WikiLeaks .","depth":10},{"id":56,"text":"Steve Bannon ,","depth":12},{"id":57,"text":"who served as the campaign ' s chief executive ,","depth":12},{"id":58,"text":"testified during the trial the trial","depth":11},{"id":59,"text":"that Stone had boasted about his ties to WikiLeaks and its founder Julian Assange ,","depth":11},{"id":60,"text":"alerting them to pending new batches of damaging emails .","depth":11},{"id":61,"text":"Campaign officials saw Stone as the \" access point \" to WikiLeaks ,","depth":10},{"id":62,"text":"he said .","depth":10},{"id":63,"text":"After the verdict was read ,","depth":9},{"id":64,"text":"prosecutors asked for Stone to be jailed","depth":11},{"id":65,"text":"as he awaits sentencing ,","depth":11},{"id":66,"text":"arguing","depth":11},{"id":67,"text":"that he may have violated a judge ' s order","depth":12},{"id":68,"text":"that prohibits him from communicating with the media about his case .","depth":12},{"id":69,"text":"But Judge Amy Berman Jackson rejected that request","depth":9},{"id":70,"text":"and said","depth":10},{"id":71,"text":"Stone will be subject to same conditions","depth":12},{"id":72,"text":"he faced","depth":13},{"id":73,"text":"following his arrest ,","depth":13},{"id":74,"text":"including the gag order .","depth":11},{"id":75,"text":"Throughout the trial , prosecutors used Stone ' s own text messages and emails","depth":11},{"id":76,"text":"- some of which appeared to contradict his congressional testimony -","depth":11},{"id":77,"text":"to lay out their case","depth":11},{"id":78,"text":"that he lied to Congress","depth":12},{"id":79,"text":"and threatened a witness .","depth":12},{"id":80,"text":"Stone did not testify ,","depth":10},{"id":81,"text":"and his lawyers called no witnesses in his defense .","depth":10},{"id":82,"text":"On Tuesday , a top Trump campaign official , Rick Gates ,","depth":11},{"id":83,"text":"who was a key cooperator in the Mueller probe ,","depth":11},{"id":84,"text":"testified","depth":10},{"id":85,"text":"that that Stone tried to contact Jared Kushner , Trump ' s son-in-law ,","depth":10},{"id":86,"text":"to \" debrief \" him about developments on the hacked emails .","depth":10},{"id":87,"text":"Prosecutors alleged","depth":7},{"id":88,"text":"Stone lied to Congress about his conversations about WikiLeaks with New York radio host and comedian Randy Credico","depth":9},{"id":89,"text":"- who scored an interview with WikiLeaks founder Julian Assange in 2016 ,","depth":10},{"id":90,"text":"when he was avoiding prosecution","depth":11},{"id":91,"text":"by sheltering in the Ecuadoran embassy in London -","depth":11},{"id":92,"text":"and conservative writer and conspiracy theorist Jerome Corsi .","depth":8},{"id":93,"text":"During the 2016 campaign , Stone had mentioned in interviews and public appearances","depth":11},{"id":94,"text":"that he was in contact with Assange through a trusted intermediary","depth":11},{"id":95,"text":"and hinted at inside knowledge of WikiLeaks ' plans .","depth":10},{"id":96,"text":"But he started pressing Credico to broker a contact ,","depth":10},{"id":97,"text":"and Credico testified","depth":11},{"id":98,"text":"that he told Stone to work through his own intermediary .","depth":11},{"id":99,"text":"Earlier testimony revealed","depth":9},{"id":100,"text":"that Stone ,","depth":11},{"id":101,"text":"while appearing before the House Intelligence Committee ,","depth":12},{"id":102,"text":"named Credico as his intermediary to Assange","depth":12},{"id":103,"text":"and pressured Credico not to contradict him .","depth":10},{"id":104,"text":"After Credico was contacted by Congress ,","depth":10},{"id":105,"text":"he reached out to Stone ,","depth":11},{"id":106,"text":"who told him","depth":12},{"id":107,"text":"he should \" stonewall it \"","depth":13},{"id":108,"text":"and \" plead the fifth , \"","depth":13},{"id":109,"text":"he testified .","depth":9},{"id":110,"text":"Credico also testified during Stone ' s trial","depth":10},{"id":111,"text":"that Stone repeatedly told him to \" do a ' Frank Pentangeli , ' \" a reference to a character in \" The Godfather : Part II \"","depth":11},{"id":112,"text":"who lies before Congress .","depth":11},{"id":113,"text":"Prosecutors said","depth":10},{"id":114,"text":"Stone also had threatened Credico ' s therapy dog , Bianca ,","depth":11},{"id":115,"text":"saying","depth":12},{"id":116,"text":"he was \" going to take that dog away from you . \"","depth":12},{"id":117,"text":"Follow Michael Balsamo on Twitter at www.twitter.com/MikeBalsamo1","depth":3},{"id":118,"text":"and Ashraf Khalil at www.twitter.com/ashrafkhalil .","depth":3}],"relations":[{"parent":237,"left":128,"right":236,"relation":"context","nuclearity":"SN"},{"parent":128,"left":123,"right":127,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":121,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":121,"left":120,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":120,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":3,"right":4,"relation":"attribution","nuclearity":"NS"},{"parent":127,"left":125,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":125,"left":124,"right":7,"relation":"same-unit","nuclearity":"NN"},{"parent":124,"left":5,"right":6,"relation":"elaboration","nuclearity":"NS"},{"parent":126,"left":8,"right":9,"relation":"attribution","nuclearity":"NS"},{"parent":236,"left":234,"right":235,"relation":"joint","nuclearity":"NN"},{"parent":234,"left":129,"right":233,"relation":"organization","nuclearity":"SN"},{"parent":129,"left":10,"right":11,"relation":"explanation","nuclearity":"NS"},{"parent":233,"left":158,"right":232,"relation":"joint","nuclearity":"NN"},{"parent":158,"left":146,"right":157,"rela