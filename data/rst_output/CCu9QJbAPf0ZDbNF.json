notes","depth":7},{"id":176,"text":"that the tactics","depth":10},{"id":177,"text":"employed in 2016 ,","depth":10},{"id":178,"text":"namely the proliferation of fake accounts and misinformation ,","depth":9},{"id":179,"text":"were unprecedented and unexpected .","depth":8},{"id":180,"text":"Today ,","depth":8},{"id":181,"text":"he says ,","depth":8},{"id":182,"text":"the company is vigilant","depth":7},{"id":183,"text":"in searching for , identifying , and removing these accounts .","depth":6},{"id":184,"text":"Facebook is also raising the standards of authentication for those","depth":5},{"id":185,"text":"attempting to purchase political ads on the social media platform .","depth":5},{"id":186,"text":"\" I started Facebook","depth":8},{"id":187,"text":"when I was in college .","depth":8},{"id":188,"text":"We ' ve come a long way since then , \"","depth":7},{"id":189,"text":"Zuckerberg writes in his prepared testimony .","depth":6},{"id":190,"text":"\" We now serve more than 2 billion people around the world ,","depth":6},{"id":191,"text":"and every day , people use our services","depth":7},{"id":192,"text":"to stay connected with the people","depth":8},{"id":193,"text":"that matter to them most .","depth":8},{"id":194,"text":"I believe deeply in what we ' re doing .","depth":5},{"id":195,"text":"And","depth":7},{"id":196,"text":"when we address these challenges ,","depth":8},{"id":197,"text":"I know","depth":8},{"id":198,"text":"we ' ll look back","depth":7},{"id":199,"text":"and view","depth":8},{"id":200,"text":"helping people connect","depth":9},{"id":201,"text":"and giving more people a voice as a positive force in the world . \"","depth":9}],"relations":[{"parent":403,"left":265,"right":402,"relation":"elaboration","nuclearity":"NS"},{"parent":265,"left":219,"right":264,"relation":"elaboration","nuclearity":"NS"},{"parent":219,"left":204,"right":218,"relation":"elaboration","nuclearity":"NS"},{"parent":204,"left":203,"right":2,"relation":"elaboration","nuclea