lation":"adversative","nuclearity":"NN"},{"parent":228,"left":227,"right":107,"relation":"adversative","nuclearity":"NN"},{"parent":227,"left":104,"right":226,"relation":"context","nuclearity":"SN"},{"parent":226,"left":105,"right":106,"relation":"attribution","nuclearity":"SN"},{"parent":229,"left":108,"right":109,"relation":"attribution","nuclearity":"SN"},{"parent":252,"left":249,"right":251,"relation":"joint","nuclearity":"NN"},{"parent":249,"left":240,"right":248,"relation":"elaboration","nuclearity":"NS"},{"parent":240,"left":236,"right":239,"relation":"context","nuclearity":"SN"},{"parent":236,"left":110,"right":111,"relation":"purpose","nuclearity":"NS"},{"parent":239,"left":112,"right":238,"relation":"elaboration","nuclearity":"NS"},{"parent":238,"left":237,"right":115,"relation":"same-unit","nuclearity":"NN"},{"parent":237,"left":113,"right":114,"relation":"attribution","nuclearity":"NS"},{"parent":248,"left":245,"right":247,"relation":"joint","nuclearity":"NN"},{"parent":245,"left":242,"right":244,"relation":"elaboration","nuclearity":"NS"},{"parent":242,"left":241,"right":118,"relation":"context","nuclearity":"SN"},{"parent":241,"left":116,"right":117,"relation":"restatement","nuclearity":"NN"},{"parent":244,"left":243,"right":121,"relation":"attribution","nuclearity":"NS"},{"parent":243,"left":119,"right":120,"relation":"joint","nuclearity":"NN"},{"parent":247,"left":122,"right":246,"relation":"elaboration","nuclearity":"NS"},{"parent":246,"left":123,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":251,"left":250,"right":127,"relation":"elaboration","nuclearity":"NS"},{"parent":250,"left":125,"right":126,"relation":"purpose","nuclearity":"NS"}]}