{"article_id":"wwJ4BT4nhZmda3e7","edus":[{"id":0,"text":"Planned Parenthood and the American Civil Liberties Union","depth":9},{"id":1,"text":"( ACLU )","depth":9},{"id":2,"text":"filed a federal lawsuit Friday","depth":8},{"id":3,"text":"challenging a new law in Alabama","depth":8},{"id":4,"text":"that bans most abortions in the state ,","depth":9},{"id":5,"text":"save those","depth":10},{"id":6,"text":"to prevent a serious health risk to the mother .","depth":10},{"id":7,"text":"JUST IN :","depth":7},{"id":8,"text":"Planned Parenthood and ACLU sue in federal court over Alabama 's near-total abortion ban .","depth":7},{"id":9,"text":"https : //t.co/1FqFoVwzn","depth":5},{"id":10,"text":"2 - NBC News","depth":6},{"id":11,"text":"( @ NBCNews )","depth":6},{"id":12,"text":"May 24 , 2019","depth":5},{"id":13,"text":"The law reclassifies abortion as a Class A felony ,","depth":6},{"id":14,"text":"punishable by up to 99 years in prison for abortionists .","depth":6},{"id":15,"text":"Women","depth":6},{"id":16,"text":"who undergo an abortion , however , would not be criminally liable .","depth":6},{"id":17,"text":"The complaint was filed in the United States District Court of the Middle District of Alabama .","depth":4},{"id":18,"text":"In a joint press statement , Alexa Kolbi-Molinas , senior staff attorney at the ACLU Reproductive Freedom Project , said","depth":5},{"id":19,"text":"Alabama ' s Human Life Protection Act is \" blatantly unconstitutional . \"","depth":5},{"id":20,"text":"\" The Alabama legislature has been pushing abortion care further and further out of reach for years with medically unnecessary and politically-motivated restrictions ,","depth":7},{"id":21,"text":"and this extreme abortion ban shows us just how far they ' ll go","depth":8},{"id":22,"text":"to push their anti-abortion agenda , \"","depth":8},{"id":23,"text":"she said ,","depth":6},{"id":24,"text":"adding","depth":6},{"id":25,"text":"\" the ACLU will not stand by","depth":7},{"id":26,"text":"while politicians","depth":9},{"id":27,"text":"emboldened by President Trump ' s anti-abortion agenda","depth":9},{"id":28,"text":"exploit our health and our lives for political gain . \"","depth":8},{"id":29,"text":"Dr. Leana Wen , president of Planned Parenthood Federation of America , called the Alabama law \" dangerous \" and \" immoral . \"","depth":5},{"id":30,"text":"To patients","depth":7},{"id":31,"text":"seeking safe , legal abortion care in Alabama :","depth":7},{"id":32,"text":"this extreme ban hasn ' t gone into effect yet -","depth":7},{"id":33,"text":"and Planned Parenthood will make sure of it .","depth":7},{"id":34,"text":"# StopTheBans","depth":5},{"id":35,"text":"https : //t.co/KQaoVVh7J","depth":7},{"id":36,"text":"0 - Leana Wen , M.D .","depth":8},{"id":37,"text":"( @ DrLeanaWen )","depth":8},{"id":38,"text":"May 24 , 2019","depth":6},{"id":39,"text":"\" The facts are on our side ,","depth":6},{"id":40,"text":"the public is on our side ,","depth":6},{"id":41,"text":"and we will do whatever it takes","depth":7},{"id":42,"text":"to ensure","depth":7},{"id":43,"text":"women across Alabama can receive the health care","depth":7},{"id":44,"text":"they need today , tomorrow , and beyond , \"","depth":7},{"id":45,"text":"Wen said .","depth":4},{"id":46,"text":"\" Abortion has been safe and legal in this country for more than 45 years","depth":6},{"id":47,"text":"and we aim to keep it that way , \"","depth":6},{"id":48,"text":"said Staci Fox , president and CEO at Planned Parenthood Southeast .","depth":5},{"id":49,"text":"\" We are protecting the rights of our patients .","depth":5},{"id":50,"text":"We are defending the work of the brave folks","depth":7},{"id":51,"text":"who came before us .","depth":7},{"id":52,"text":"And we are fighting to take this country forward , not backwards . \"","depth":6},{"id":53,"text":"Gov . Kay Ivey","depth":6},{"id":54,"text":"( R )","depth":6},{"id":55,"text":"signed the Alabama Human Life Protection Act into law on May 15 .","depth":5},{"id":56,"text":"\" To the bill ' s many supporters , this legislation stands as a powerful testament to Alabamians ' deeply held belief","depth":5},{"id":57,"text":"that every life is precious","depth":6},{"id":58,"text":"and that every life is a sacred gift from God . \"","depth":6},{"id":59,"text":"\" The heart of this bill is to confront a decision","depth":6},{"id":60,"text":"that was made by the courts in 1973","depth":7},{"id":61,"text":"that said","depth":8},{"id":62,"text":"the baby in the womb is not a person , \"","depth":8},{"id":63,"text":"said state Rep. Terri Collins","depth":7},{"id":64,"text":"( R ) ,","depth":7},{"id":65,"text":"one of the bill ' s sponsors .","depth":6},{"id":66,"text":"\" This bill addresses that one issue .","depth":5},{"id":67,"text":"Is that baby in the womb a person ?","depth":6},{"id":68,"text":"I believe","depth":8},{"id":69,"text":"our law says","depth":9},{"id":70,"text":"it is .","depth":9},{"id":71,"text":"I believe","depth":9},{"id":72,"text":"our people say","depth":10},{"id":73,"text":"it is .","depth":10},{"id":74,"text":"And I believe","depth":9},{"id":75,"text":"technology shows","depth":10},{"id":76,"text":"it is . \"","depth":10}],"relations":[{"parent":153,"left":115,"right":152,"relation":"joint","nuclearity":"NN"},{"parent":115,"left":94,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":94,"left":89,"right":93,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":86,"right":88,"relation":"attribution","nuclearity":"NS"},{"parent":86,"left":85,"right":9,"relation":"explanation","nuclearity":"NS"},{"parent":85,"left":83,"right":84,"relation":"context","nuclearity":"NS"},{"parent":83,"left":79,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":78,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":78,"left":0,"right":1,"relation":"restatement","nuclearity":"NS"},{"parent":82,"left":3,"right":81,"relation":"elaboration","nuclearity