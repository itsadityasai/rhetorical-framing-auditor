{"article_id":"XyK4SeiSsDFC1ujQ","edus":[{"id":0,"text":"Story highlights","depth":1},{"id":1,"text":"Secretary of Defense Chuck Hagel will step down ,","depth":7},{"id":2,"text":"President Barack Obama announced Monday","depth":7},{"id":3,"text":"Hagel ,","depth":9},{"id":4,"text":"a former Republican senator from Nebraska , has been in this post since February 2013","depth":9},{"id":5,"text":"Hagel had a rocky tenure from the beginning","depth":8},{"id":6,"text":"and during his confirmation hearings President Barack Obama announced Monday","depth":8},{"id":7,"text":"that Defense Secretary Chuck Hagel will step down from his position","depth":9},{"id":8,"text":"as soon as the Senate confirms a successor .","depth":9},{"id":9,"text":"Hagel ,","depth":8},{"id":10,"text":"who has served as Defense secretary since February 2013 ,","depth":8},{"id":11,"text":"was forced out by President Barack Obama ,","depth":7},{"id":12,"text":"CNN confirmed from several sources .","depth":6},{"id":13,"text":"During his remarks from the White House , however , Obama praised Hagel as an `` exemplary '' Defense secretary ,","depth":7},{"id":14,"text":"calling him critical to a number of national security accomplishments during his tenure ,","depth":8},{"id":15,"text":"and characterized Hagel 's resignation as his own choice .","depth":8},{"id":16,"text":"`` If there 's one thing","depth":10},{"id":17,"text":"I know about Chuck","depth":10},{"id":18,"text":"it is that he does not make this or any decision lightly , ''","depth":9},{"id":19,"text":"Obama said from the State Dining Room .","depth":8},{"id":20,"text":"`` This decision does not come easily to him . ''","depth":7},{"id":21,"text":"However , Arizona Sen. John McCain , the expected incoming chairman of the Armed Services Committee , said on local Arizona radio station KFYI 550 's `` The Mike Broomhead Show ''","depth":8},{"id":22,"text":"that he spoke with Hagel last week","depth":9},{"id":23,"text":"and the Defense secretary was `` frustrated . ''","depth":9},{"id":24,"text":"`` They 're gon na say","depth":10},{"id":25,"text":"well it was time for a change and all that ...","depth":10},{"id":26,"text":"but I can tell you","depth":11},{"id":27,"text":"he was in my office last week ,","depth":11},{"id":28,"text":"he was very frustrated , ''","depth":10},{"id":29,"text":"McCain said ,","depth":9},{"id":30,"text":"with a lack of strategy","depth":10},{"id":31,"text":"to combat ISIS ,","depth":12},{"id":32,"text":"help the Ukranians","depth":12},{"id":33,"text":"and what McCain called `` a lack of U.S. influence ... unknown in history . ''","depth":11},{"id":34,"text":"McCain said ,","depth":7},{"id":35,"text":"despite the fact","depth":11},{"id":36,"text":"`` White House people are leaking ,","depth":12},{"id":37,"text":"'Well , he was n't up to the job ,","depth":12},{"id":38,"text":"' believe me ,","depth":11},{"id":39,"text":"he was up to the job '' -","depth":11},{"id":40,"text":"and that the real issue was the White House itself .","depth":9},{"id":41,"text":"`` It was the job","depth":11},{"id":42,"text":"that he was given","depth":11},{"id":43,"text":"where he really was never really brought into that real tight circle inside the White House","depth":11},{"id":44,"text":"that makes all the decisions , ''","depth":11},{"id":45,"text":"he said .","depth":9},{"id":46,"text":"Throughout the day Monday , administration officials continued to insist","depth":6},{"id":47,"text":"the decision","depth":9},{"id":48,"text":"for Hagel","depth":10},{"id":49,"text":"to step down","depth":10},{"id":50,"text":"was mutual","depth":8},{"id":51,"text":"and had nothing to do with his feelings on the administration 's defense strategy .","depth":7},{"id":52,"text":"Pentagon Press Secretary John Kirby told CNN 's Christiane Amanpour","depth":8},{"id":53,"text":"that `` the secretary 's decision","depth":10},{"id":54,"text":"to resign","depth":10},{"id":55,"text":"has nothing to do with Iraq policy or strategy . ''","depth":9},{"id":56,"text":"`` He 's very much a strong advocate for the policy and the strategy","depth":10},{"id":57,"text":"that we 're executing there , ''","depth":10},{"id":58,"text":"he said .","depth":9},{"id":59,"text":"He added","depth":9},{"id":60,"text":"that Hagel 's resignation does n't hint at any `` major changes '' to the nation 's strategy in Iraq ,","depth":10},{"id":61,"text":"including the president 's decision","depth":11},{"id":62,"text":"not to put boots on the ground there in a combat role .","depth":11},{"id":63,"text":"Behind the scenes , administration officials told CNN","depth":9},{"id":64,"text":"there were a series of discussions over the past several weeks with the President ,","depth":10},{"id":65,"text":"initiated by Hagel .","depth":10},{"id":66,"text":"The talks covered a `` broader discussion of national security for the next two years , ''","depth":10},{"id":67,"text":"a defense official said .","depth":10},{"id":68,"text":"The two came to realize","depth":11},{"id":69,"text":"that `` a different focus was needed","depth":12},{"id":70,"text":"and a change is in order , ''","depth":12},{"id":71,"text":"the official added .","depth":10},{"id":72,"text":"`` It is wrong to conclude","depth":8},{"id":73,"text":"that this was a protest by Hagel","depth":9},{"id":74,"text":"or it was over policy differences . ''","depth":9},{"id":75,"text":"JUST WATCHED","depth":10},{"id":76,"text":"Defense Secretary Hagel to step down","depth":11},{"id":77,"text":"Replay More Videos ...","depth":11},{"id":78,"text":"MUST WATCH","depth":11},{"id":79,"text":"Defense Secretary Hagel to step down","depth":11},{"id":80,"text":"01:12","depth":10},{"id":81,"text":"JUST WATCHED","depth":11},{"id":82,"text":"White House :","depth":12},{"id":83,"text":"Secy . Hagel to resign","depth":12},{"id":84,"text":"Replay More Videos ...","depth":10},{"id":85,"text":"MUST WATCH","depth":12},{"id":86,"text":"White House :","depth":14},{"id":87,"text":"Secy .","depth":14},{"id":88,"text":"Hagel to resign","depth":13},{"id":89,"text":"01:35","depth":11},{"id":90,"text":"JUST WATCHED","depth":12},{"id":91,"text":"Sources :","depth":15},{"id":92,"text":"Secy .","depth":15},{"id":93,"text":"Hagel pushed out","depth":14},{"id":94,"text":"Replay More Videos ...","depth":13},{"id":95,"text":"MUST WATCH","depth":12},{"id":96,"text":"Sources :","depth":15},{"id":97,"text":"Secy .","depth":15},{"id":98,"text":"Hagel pushed out","depth":14},{"id":99,"text":"02:57","depth":13},{"id":100,"text":"The New York Times first reported Monday morning","depth":10},{"id":101,"text":"that Obama asked Hagel to step down last Friday ,","depth":11},{"id":102,"text":"seeking to reassure critics of the President 's foreign policy with the move .","depth":11},{"id":103,"text":"The move ,","depth":13},{"id":104,"text":"White House officials told the Times ,","depth":13},{"id":105,"text":"was meant to acknowledge","depth":12},{"id":106,"text":"that the new national security threats","depth":14},{"id":107,"text":"facing the nation","depth":14},{"id":108,"text":"- most notably the rise of the Islamic State in Iraq and Syria -","depth":13},{"id":109,"text":"call for a different kind of leadership in the Defense Department .","depth":12},{"id":110,"text":"`` The next couple of years will demand a different kind of focus , ''","depth":11},{"id":111,"text":"an administration official told the paper .","depth":11},{"id":112,"text":"Obama did not announce a successor Monday .","depth":9},{"id":113,"text":"According to a White House aide ,","depth":11},{"id":114,"text":"the list","depth":13},{"id":115,"text":"to replace Hagel","depth":13},{"id":116,"text":"includes former Under Secretary of Defense for Policy Michèle Flournoy and former Deputy Secretary of Defense Ash Carter .","depth":12},{"id":117,"text":"Rhode Island Sen. Jack Reed , a former paratrooper , was initially in the mix ,","depth":12},{"id":118,"text":"but his spokesman said in a statement","depth":13},{"id":119,"text":"that he 's not interested in the job .","depth":13},{"id":120,"text":"`` Senator Reed loves his job","depth":14},{"id":121,"text":"and wants to continue serving the people of Rhode Island in the United States Senate .","depth":14},{"id":122,"text":"He has made it very clear","depth":14},{"id":123,"text":"that he does not wish to be considered for Secretary of Defense or any other cabinet position , ''","depth":14},{"id":124,"text":"spokesman Chip Unruh said .","depth":12},{"id":125,"text":"But it 's highly unlikely that the confirmation process for Hagel 's replacement will occur before next year","depth":9},{"id":126,"text":"when the Republican-led Senate convenes ,","depth":9},{"id":127,"text":"Senate leadership aides from both parties tell CNN .","depth":8},{"id":128,"text":"A GOP aide said","depth":10},{"id":129,"text":"it would be `` logistically impossible '' to complete it in the two weeks","depth":11},{"id":130,"text":"senators expect to be in session in December","depth":12},{"id":131,"text":"before leaving for the holidays .","depth":12},{"id":132,"text":"A Democratic aide said","depth":11},{"id":133,"text":"that","depth":12},{"id":134,"text":"while Democrats are `` open '' to considering the nomination","depth":14},{"id":135,"text":"when they return to session next week ,","depth":14},{"id":136,"text":"doing so would require consent from Republicans .","depth":13},{"id":137,"text":"`` It 's not impossible for this year","depth":12},{"id":138,"text":"but would require a nominee","depth":13},{"id":139,"text":"before we come back Monday","depth":14},{"id":140,"text":"and complete cooperation from Republican leadership , committee members and rank and file , ''","depth":14},{"id":141,"text":"the Democratic aide said .","depth":11},{"id":142,"text":"The move ,","depth":12},{"id":143,"text":"White House officials told the Times ,","depth":12},{"id":144,"text":"was meant to acknowledge","depth":11},{"id":145,"text":"that the new national security threats","depth":12},{"id":146,"text":"facing the nation","depth":13},{"id":147,"text":"- most notably the rise of the Islamic State in Iraq and Syria -","depth":13},{"id":148,"text":"call for a different kind of leadership in the Defense Department .","depth":11},{"id":149,"text":"`` The next couple of years will demand a different kind of focus , ''","depth":10},{"id":150,"text":"an administration official told the paper .","depth":10},{"id":151,"text":"At the White House press conference , Hagel thanked the President and his colleagues ,","depth":9},{"id":152,"text":"pledged to work `` just as hard","depth":11},{"id":153,"text":"as I have over the last couple years ''","depth":11},{"id":154,"text":"until his successor is confirmed .","depth":10},{"id":155,"text":"And he evaluated his tenure at the Pentagon as a success .","depth":9},{"id":156,"text":"`` I believe","depth":11},{"id":157,"text":"we have set not only this department , the department of Defense , but the nation on a stronger course towards security , stability and prosperity .","depth":11},{"id":158,"text":"If I did n't believe","depth":12},{"id":159,"text":"that I would not have done this job , ''","depth":12},{"id":160,"text":"he said .","depth":11},{"id":161,"text":"A critic of the Iraq war , Hagel was brought on to oversee withdrawal from Afghanistan and a smaller Pentagon budget than ever before .","depth":8},{"id":162,"text":"Hagel , a former senator of Nebraska , was the last Republican","depth":10},{"id":163,"text":"still serving in Obama 's Cabinet","depth":10},{"id":164,"text":"and was a Vietnam combat veteran .","depth":9},{"id":165,"text":"During his confirmation hearings , Hagel drew sharp criticism from pro-Israel Republicans","depth":10},{"id":166,"text":"concerned with his opposition to aggressive sanctions against Iran","depth":10},{"id":167,"text":"and for his criticism of the Defense Department as `` bloated . ''","depth":9},{"id":168,"text":"His confirmation was filibustered","depth":9},{"id":169,"text":"before he ultimately won approval .","depth":9},{"id":170,"text":"And his two years at the Pentagon have been marred by gaffes","depth":11},{"id":171,"text":"that occasionally undercut the President","depth":11},{"id":172,"text":"and an inability","depth":11},{"id":173,"text":"to sell the administration 's national security policy .","depth":11},{"id":174,"text":"He at one point called ISIS an `` imminent threat to every interest","depth":11},{"id":175,"text":"we have , ''","depth":11},{"id":176,"text":"contradicting the President 's comments","depth":12},{"id":177,"text":"just months before","depth":12},{"id":178,"text":"that the group was simply `` junior varsity . ''","depth":11},{"id":179,"text":"The administration has taken persistent criticism over the past few months","depth":10},{"id":180,"text":"as a series of national security crises roiled the nation ,","depth":10},{"id":181,"text":"and the President 's response was seen by many as flat-footed and inconsistent .","depth":9},{"id":182,"text":"Hagel 's departure has been rumored to be coming for weeks ,","depth":4},{"id":183,"text":"and as recently as last week he dodged questions about his continued tenure at the Pentagon .","depth":4},{"id":184,"text":"`` First of all , I serve at the pleasure of the President , ''","depth":7},{"id":185,"text":"Hagel told PBS ,","depth":7},{"id":186,"text":"asked whether he 'd continue in the position .","depth":6},{"id":187,"text":"`` I 'm immensely grateful for the opportunity","depth":9},{"id":188,"text":"I 've had the last two years","depth":9},{"id":189,"text":"to work every day for the country and for the men and women","depth":9},{"id":190,"text":"who serve this country .","depth":9},{"id":191,"text":"I do n't get up in the morning","depth":8},{"id":192,"text":"and worry about my job .","depth":8},{"id":193,"text":"It 's not unusual by the way , to change teams at different times . ''","depth":6},{"id":194,"text":"Pressed on whether he felt","depth":6},{"id":195,"text":"he still had Obama 's confidence ,","depth":6},{"id":196,"text":"Hagel said ,","depth":6},{"id":197,"text":"`` Well , I do n't think","depth":9},{"id":198,"text":"I would be here","depth":10},{"id":199,"text":"if I did n't .","depth":10},{"id":200,"text":"But you 'd have to ask him that .","depth":8},{"id":201,"text":"I mean","depth":8},{"id":202,"text":"I see him all the time . ''","depth":8}],"relations":[{"parent":405,"left":0,"right":404,"relation":"organization","nuclearity":"SN"},{"parent":404,"left":383,"right":403,"relation":"joint","nuclearity":"NN"},{"parent":383,"left":247,"right":382,"relation":"elaboration","nuclearity":"NS"},{"parent":247,"left":214,"right":246,"relation":"elaboration","nuclearity":"NS"},{"parent":214,"left":210,"right":213,"relation":"elaboration","nuclearity":"NS"},{"parent":210,"left":204,"right":209,"relation":"context","nuclearity":"NS"},{"parent":204,"left":1,"right":2,"relation":"attribution","nuclearity":"NS"},{"parent":209,"left":206,"right":208,"relation":"context","nuclearity":"SN"},{"parent":206,"left":205,"right":5,"relation":"joint","nuclearity":"NN"},{"parent":205,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":208,"left":6,"right":207,"relation":"attribution","nuclearity":"SN"},{"parent":207,"left":7,"right":8,"relation":"condition","nuclearity":"NS"},{"parent":213,"left":212,"right":12,"relation":"attribution","nuclearity":"NS"},{"parent":212,"left":211,"right":11,"relation":"same-unit","nuclearity":"NN"},{"parent":211,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":246,"left":221,"right":245,"relation":"elaboration","nuclearity":"NS"},{"parent":221,"left":216,"right":220,"relation":"elaboration","nuclearity":"NS"},{"parent":216,"left":13,"right":215,"relation":"elaboration","nuclearity":"NS"},{"parent":215,"left":14,"right":15,"relation":"joint","nuclearity":"NN"},{"parent":220,"left":219,"right":20,"relation":"elaboration","nucle