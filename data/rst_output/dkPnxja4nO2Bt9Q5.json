{"article_id":"dkPnxja4nO2Bt9Q5","edus":[{"id":0,"text":"On Friday , many Americans had pinned their hopes on Susan Collins .","depth":3},{"id":1,"text":"Seen as a crucial swing vote on Brett Kavanaugh ' s nomination","depth":6},{"id":2,"text":"ever since President Trump nominated him to the Supreme Court ,","depth":6},{"id":3,"text":"she only became more pivotal","depth":6},{"id":4,"text":"after Christine Blasey Ford stated publicly","depth":7},{"id":5,"text":"that Kavanaugh had assaulted her","depth":8},{"id":6,"text":"when both were in high school .","depth":8},{"id":7,"text":"She became \" the most sought-after senator in Washington , \"","depth":7},{"id":8,"text":"as ' s Dylan Scott put it ,","depth":7},{"id":9,"text":"meeting with multiple sexual assault survivors","depth":7},{"id":10,"text":"as she weighed her final decision on Kavanaugh .","depth":7},{"id":11,"text":"It was never particularly fair ,","depth":9},{"id":12,"text":"as Scott also noted ,","depth":9},{"id":13,"text":"to put the burden","depth":10},{"id":14,"text":"of accepting or rejecting Kavanaugh","depth":10},{"id":15,"text":"on Collins ,","depth":9},{"id":16,"text":"when dozens of her Republican male colleagues had already made their intentions clear .","depth":7},{"id":17,"text":"As it turned out , though , Collins wasn ' t different anyway -","depth":8},{"id":18,"text":"in her speech Friday","depth":10},{"id":19,"text":"announcing her intention","depth":11},{"id":20,"text":"to vote yes on Kavanaugh ,","depth":11},{"id":21,"text":"she espoused the same arguments","depth":10},{"id":22,"text":"that right-wing men ,","depth":13},{"id":23,"text":"including President Trump ,","depth":13},{"id":24,"text":"have been using for days","depth":12},{"id":25,"text":"to explain away Ford ' s testimony","depth":12},{"id":26,"text":"and defend Kavanaugh .","depth":12},{"id":27,"text":"Collins ended up echoing the arguments","depth":8},{"id":28,"text":"Trump and others used","depth":9},{"id":29,"text":"to defend Kavanaugh","depth":10},{"id":30,"text":"and slam his accusers","depth":10},{"id":31,"text":"Ever since Christine Blasey Ford came forward to publicly state","depth":6},{"id":32,"text":"that Brett Kavanaugh sexually assaulted her","depth":7},{"id":33,"text":"when they were in high school ,","depth":7},{"id":34,"text":"Kavanaugh ' s defenders have argued","depth":5},{"id":35,"text":"that he is entitled to due process","depth":5},{"id":36,"text":"- to be presumed innocent","depth":7},{"id":37,"text":"until proven guilty -","depth":7},{"id":38,"text":"never mind that he ' s not on trial","depth":7},{"id":39,"text":"and that all","depth":9},{"id":40,"text":"he stands to lose","depth":10},{"id":41,"text":"as a result of the Senate ' s decision","depth":10},{"id":42,"text":"is a chance at a job","depth":9},{"id":43,"text":"that the vast majority of Americans would never dream of holding .","depth":9},{"id":44,"text":"Collins said","depth":5},{"id":45,"text":"she appreciated","depth":6},{"id":46,"text":"that the Senate was not a criminal court ,","depth":6},{"id":47,"text":"but argued","depth":5},{"id":48,"text":"that","depth":6},{"id":49,"text":"\" in evaluating any given claim of misconduct ,","depth":8},{"id":50,"text":"we will be ill-served in the long run","depth":8},{"id":51,"text":"if we abandon the presumption of innocence and fairness ,","depth":8},{"id":52,"text":"tempting though it may be . \"","depth":8},{"id":53,"text":"When it came to Kavanaugh ' s accusers , though ,","depth":4},{"id":54,"text":"many of those","depth":6},{"id":55,"text":"defending him","depth":6},{"id":56,"text":"abandoned the idea of the presumption of innocence .","depth":5},{"id":57,"text":"Those","depth":8},{"id":58,"text":"who doubted Ford and others","depth":9},{"id":59,"text":"accusing Kavanaugh of sexual misconduct","depth":9},{"id":60,"text":"didn ' t just argue","depth":8},{"id":61,"text":"that their cases couldn ' t be proved beyond a reasonable doubt","depth":8},{"id":62,"text":"- they insinuated , or stated outright ,","depth":7},{"id":63,"text":"that these accusers were contemptible liars .","depth":7},{"id":64,"text":"According to President Trump ,","depth":6},{"id":65,"text":"they and those","depth":8},{"id":66,"text":"supporting them","depth":8},{"id":67,"text":"were \" evil people. \"","depth":7},{"id":68,"text":"According to Senate Majority Leader Mitch McConnell ,","depth":6},{"id":69,"text":"protesters","depth":8},{"id":70,"text":"supporting Ford","depth":8},{"id":71,"text":"were bullies","depth":8},{"id":72,"text":"trying to intimidate senators .","depth":8},{"id":73,"text":"According to New York Times columnist Bret Stephens ,","depth":6},{"id":74,"text":"\" falsely accusing a person of sexual assault is nearly as despicable as sexual assault itself . \"","depth":6},{"id":75,"text":"Unlike Trump , Collins avoided smearing Ford .","depth":5},{"id":76,"text":"\" I believe","depth":7},{"id":77,"text":"that she is a survivor of a sexual assault","depth":8},{"id":78,"text":"and that this trauma has upended her life , \"","depth":8},{"id":79,"text":"she said .","depth":6},{"id":80,"text":"But","depth":7},{"id":81,"text":"when it came to Julie Swetnick ,","depth":8},{"id":82,"text":"who has said","depth":9},{"id":83,"text":"that she attended parties","depth":10},{"id":84,"text":"where Kavanaugh and his friend Mark Judge plotted to drug and rape girls ,","depth":10},{"id":85,"text":"Collins abandoned her restraint .","depth":6},{"id":86,"text":"\" Some of the allegations","depth":11},{"id":87,"text":"levied against Judge Kavanaugh","depth":11},{"id":88,"text":"illustrate why the presumption of innocence is so important , \"","depth":10},{"id":89,"text":"she said .","depth":9},{"id":90,"text":"\" I am thinking in particular not of the allegations","depth":11},{"id":91,"text":"raised by Professor Ford ,","depth":11},{"id":92,"text":"but of the allegations","depth":11},{"id":93,"text":"that","depth":12},{"id":94,"text":"when he was a teenager","depth":14},{"id":95,"text":"Judge Kavanaugh drugged multiple girls","depth":14},{"id":96,"text":"and used their weakened state","depth":14},{"id":97,"text":"to facilitate gang rape . \"","depth":14},{"id":98,"text":"\" This outlandish allegation was put forth","depth":13},{"id":99,"text":"without any credible supporting evidence","depth":13},{"id":100,"text":"and simply parroted public statements of others , \"","depth":12},{"id":101,"text":"Collins concluded .","depth":11},{"id":102,"text":"\" That such an allegation can find its way into the Supreme Court confirmation process is a stark reminder","depth":11},{"id":103,"text":"about why the presumption of innocence is so ingrained in our American consciousness . \"","depth":11},{"id":104,"text":"Many have cast doubt on Swetnick ' s allegations","depth":9},{"id":105,"text":"because they came through attorney Michael Avenatti ,","depth":10},{"id":106,"text":"who has discussed a run for president in 2020","depth":11},{"id":107,"text":"and has a reputation","depth":12},{"id":108,"text":"for seeking the limelight .","depth":12},{"id":109,"text":"But there ' s a difference","depth":9},{"id":110,"text":"between subjecting Swetnick ' s claims to scrutiny","depth":10},{"id":111,"text":"and arguing","depth":11},{"id":112,"text":"that they are \" outlandish \"","depth":12},{"id":113,"text":"and have no place in the confirmation process .","depth":12},{"id":114,"text":"Sadly , there ' s nothing outlandish about boys or men","depth":8},{"id":115,"text":"drugging and raping women ,","depth":8},{"id":116,"text":"and Swetnick ' s claims were in fact right in line with the picture","depth":10},{"id":117,"text":"Ford and Deborah Ramirez had painted","depth":10},{"id":118,"text":"of Kavanaugh","depth":10},{"id":119,"text":"harming women for the amusement of other men .","depth":10},{"id":120,"text":"Lili Loofbourow at Slate called it \" toxic homosociality . \"","depth":9},{"id":121,"text":"\" Indelible in the hippocampus is the laughter , \"","depth":11},{"id":122,"text":"Ford said during her testimony .","depth":11},{"id":123,"text":"\" The uproarious laughter between the two ,","depth":11},{"id":124,"text":"and their having fun at my expense . \"","depth":11},{"id":125,"text":"Collins could have demanded an investigation of Swetnick ' s claims","depth":7},{"id":126,"text":"with this in mind .","depth":7},{"id":127,"text":"She could have refused to vote to confirm Kavanaugh","depth":7},{"id":128,"text":"until such an investigation was completed .","depth":7},{"id":129,"text":"Instead , she appears to have presumed Swetnick guilty of lying","depth":7},{"id":130,"text":"and then used that presumption","depth":8},{"id":131,"text":"to cast doubt on all opposition to Kavanaugh .","depth":8},{"id":132,"text":"She seems to have followed a train of thinking similar to that of Stephens ,","depth":8},{"id":133,"text":"who wrote ,","depth":9},{"id":134,"text":"\" uncorroborated plus uncorroborated plus largely uncorroborated is not the accumulation of questions , much less of evidence .","depth":10},{"id":135,"text":"It is the duplication of hearsay . \"","depth":10},{"id":136,"text":"This is handy logic ,","depth":9},{"id":137,"text":"which allows allegations","depth":11},{"id":138,"text":"made by women","depth":11},{"id":139,"text":"to cancel each other out","depth":11},{"id":140,"text":"rather than support each other .","depth":11},{"id":141,"text":"If one is hearsay ,","depth":9},{"id":142,"text":"they all are .","depth":9},{"id":143,"text":"It wasn ' t fair to hold Collins responsible","depth":7},{"id":144,"text":"for stopping Kavanaugh ' s confirmation","depth":7},{"id":145,"text":"just because she ' s a woman .","depth":6},{"id":146,"text":"It was fair to expect her to live up to her reputation as an independent thinker","depth":7},{"id":147,"text":"who makes her own decisions .","depth":7},{"id":148,"text":"Instead , she seems to have subscribed to the same fallacies as all those","depth":7},{"id":149,"text":"who have been defending Kavanaugh in recent days","depth":8},{"id":150,"text":"by attacking the women","depth":9},{"id":151,"text":"who accused him .","depth":9}],"relations":[{"parent":303,"left":204,"right":302,"relation":"elaboration","nuclearity":"NS"},{"parent":204,"left":182,"right":203,"relation":"elaboration","nuclearity":"NS"},{"parent":182,"left":0,"right":181,"relation":"elaboration","nuclearity":"NS"},{"parent":181,"left":157,"right":180,"relation":"elaboration","nuclearity":"NS"},{"parent":157,"left":153,"right":156,"relation":"context","nuclearity":"SN"},{"parent":153,"left":1,"right":2,"relation":"context","nuclearity":"NS"},{"parent":156,"left":3,"right":155,"relation":"context","nuclearity":"NS"},{"parent":155,"left":4,"right":154,"relation":"attribution","nuclearity":"SN"},{"parent":154,"left":5,"right":6,"relation":"context","nuclearity":"NS"},{"parent":180,"left":160,"right":179,"relation":"elaboration","nuclearity":"NS"},{"parent":160,"left":158,"right":159,"relation":"elaboration","nuclearity":"NS"},{"parent":158,"left":7,"right":8,"relation":"attribution","nuclearity":"NS"},{"parent":159,"left":9,"right":10,"relation":"context","nuclearity":"NS"},{"parent":179,"left":165,"right":178,"relation":"adversative","nuclearity":"SN"},{"parent":165,"left":164,"right":16,"relation":"context","nuclearity":"NS"},{"parent":164,"left":161,"right":163,"relation":"same-unit","nuclearity":"NN"},{"parent":161,"left":11,"right":12,"relation":"attribution","nuclearity":"NS"},{"parent":163,"left":162,"right":15,"relation":"same-unit","nuclearity":"NN"},{"parent":162,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":178,"left":174,"right":177,"relation":"evaluation","nuclearity":"NS"},{"parent":174,"left":17,"right":173,"relation":"organization","nuclearity":"SN"},{"parent":173,"left":167,"right":172,"relation":"same-unit","nuclearity":"NN"},{"parent":167,"left":18,"right":166,"relation":"elaboration","nuclearity":"NS