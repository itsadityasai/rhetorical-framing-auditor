rent":345,"left":164,"right":165,"relation":"elaboration","nuclearity":"NS"},{"parent":349,"left":346,"right":348,"relation":"joint","nuclearity":"NN"},{"parent":346,"left":166,"right":167,"relation":"attribution","nuclearity":"SN"},{"parent":348,"left":168,"right":347,"relation":"attribution","nuclearity":"SN"},{"parent":347,"left":169,"right":170,"relation":"purpose","nuclearity":"NS"},{"parent":351,"left":171,"right":172,"relation":"elaboration","nuclearity":"NS"},{"parent":362,"left":358,"right":361,"relation":"evaluation","nuclearity":"NS"},{"parent":358,"left":357,"right":179,"relation":"joint","nuclearity":"NN"},{"parent":357,"left":353,"right":356,"relation":"same-unit","nuclearity":"NN"},{"parent":353,"left":173,"right":174,"relation":"elaboration","nuclearity":"NS"},{"parent":356,"left":355,"right":178,"relation":"elaboration","nuclearity":"NS"},{"parent":355,"left":354,"right":177,"relation":"same-unit","nuclearity":"NN"},{"parent":354,"left":175,"right":176,"relation":"elaboration","nuclearity":"NS"},{"parent":361,"left":359,"right":360,"relation":"same-unit","nuclearity":"NN"},{"parent":359,"left":180,"right":181,"relation":"attribution","nuclearity":"NS"},{"parent":360,"left":182,"right":183,"relation":"elaboration","nuclearity":"NS"}]}