{"article_id":"DcjFzmmTrm9PgKUo","edus":[{"id":0,"text":"1 of 2","depth":3},{"id":1,"text":"In this 2008 , photo","depth":7},{"id":2,"text":"David Dorn poses .","depth":7},{"id":3,"text":"Dorn , a 77-year-old retired St. Louis police officer","depth":9},{"id":4,"text":"who served 38 years on the force","depth":9},{"id":5,"text":"was shot and killed by looters at a pawn shop early Tuesday , June 2 , 2020 ,","depth":8},{"id":6,"text":"police said .","depth":7},{"id":7,"text":"David Dorn was found dead on the sidewalk in front of Lee 's Pawn & Jewelry ,","depth":6},{"id":8,"text":"which had been ransacked","depth":7},{"id":9,"text":"after peaceful protests over the death of George Floyd turned violent overnight .","depth":7},{"id":10,"text":"( Scott Bandle , Suburban Journals/St . Louis Post-Dispatch via AP )","depth":4},{"id":11,"text":"1 of 2","depth":3},{"id":12,"text":"In this 2008 , photo","depth":6},{"id":13,"text":"David Dorn poses .","depth":6},{"id":14,"text":"Dorn , a 77-year-old retired St. Louis police officer","depth":8},{"id":15,"text":"who served 38 years on the force","depth":8},{"id":16,"text":"was shot and killed by looters at a pawn shop early Tuesday , June 2 , 2020 ,","depth":7},{"id":17,"text":"police said .","depth":6},{"id":18,"text":"David Dorn was found dead on the sidewalk in front of Lee 's Pawn & Jewelry ,","depth":7},{"id":19,"text":"which had been ransacked","depth":7},{"id":20,"text":"after peaceful protests over the death of George Floyd turned violent overnight .","depth":6},{"id":21,"text":"( Scott Bandle , Suburban Journals/St . Louis Post-Dispatch via AP )","depth":5},{"id":22,"text":"ST. LOUIS","depth":6},{"id":23,"text":"( AP ) -","depth":6},{"id":24,"text":"A retired police captain","depth":10},{"id":25,"text":"who died during a night of violent protests","depth":10},{"id":26,"text":"was trying to protect his friend ' s pawn shop ,","depth":9},{"id":27,"text":"his widow said .","depth":8},{"id":28,"text":"David Dorn ' s last moments were caught on video","depth":8},{"id":29,"text":"and apparently posted on Facebook Live ,","depth":9},{"id":30,"text":"though the video has since been taken down .","depth":9},{"id":31,"text":"He was killed by people","depth":9},{"id":32,"text":"who had broken into Lee ' s Pawn & Jewelry ,","depth":9},{"id":33,"text":"and his body found on the sidewalk at about 2:30 a.m. Tuesday .","depth":8},{"id":34,"text":"No arrests have been made .","depth":7},{"id":35,"text":"His death came on a violent night in St. Louis ,","depth":6},{"id":36,"text":"where four officers were shot ,","depth":8},{"id":37,"text":"officers were pelted with rocks and fireworks ,","depth":9},{"id":38,"text":"and 55 businesses were burglarized or damaged ,","depth":10},{"id":39,"text":"including a convenience store","depth":11},{"id":40,"text":"that burned .","depth":11},{"id":41,"text":"Police also shot and gravely injured a burglary suspect","depth":8},{"id":42,"text":"who","depth":10},{"id":43,"text":"they say","depth":10},{"id":44,"text":"shot at officers .","depth":9},{"id":45,"text":"Cities across the U.S. have seen protests and violence","depth":6},{"id":46,"text":"since George Floyd died May 25","depth":7},{"id":47,"text":"after a white Minneapolis officer pressed his knee into Floyd ' s neck for several minutes","depth":8},{"id":48,"text":"even after the handcuffed black man stopped moving","depth":9},{"id":49,"text":"and pleading for air .","depth":9},{"id":50,"text":"Dorn was a friend of the pawn shop ' s owner","depth":5},{"id":51,"text":"and frequently checked on the business","depth":6},{"id":52,"text":"when alarms went off ,","depth":6},{"id":53,"text":"his wife , St. Louis police Sgt . Ann Marie Dorn , told the St. Louis Post-Dispatch .","depth":4},{"id":54,"text":"David Dorn served 38 years on the St. Louis police force","depth":5},{"id":55,"text":"before retiring in October 2007 .","depth":5},{"id":56,"text":"He then became chief of Moline Acres , a small town in St. Louis County .","depth":4},{"id":57,"text":"Former St. Louis County police Chief Tim Fitch knew Dorn for 30 years","depth":5},{"id":58,"text":"and said","depth":6},{"id":59,"text":"they became close friends","depth":7},{"id":60,"text":"when Dorn and his wife were leading the St. Louis police department ' s Explorers program for young people","depth":9},{"id":61,"text":"interested in law enforcement careers ,","depth":9},{"id":62,"text":"while Fitch was leading the county ' s program .","depth":8},{"id":63,"text":"\" He was very dedicated to youth , especially disadvantaged youth , \"","depth":9},{"id":64,"text":"said Fitch ,","depth":10},{"id":65,"text":"who led the St. Louis County Police Department from 2009 to 2014 .","depth":10},{"id":66,"text":"\" He wanted to see them succeed .","depth":9},{"id":67,"text":"He wanted to be a role model for those young men and women","depth":10},{"id":68,"text":"to go into law enforcement . \"","depth":10},{"id":69,"text":"Dorn ' s personality was \" bigger than life , \"","depth":9},{"id":70,"text":"Fitch said .","depth":9},{"id":71,"text":"\" He was a fun guy , a happy guy .","depth":9},{"id":72,"text":"You never had to wonder what he was thinking","depth":11},{"id":73,"text":"when somebody did something incredibly stupid like a crime","depth":11},{"id":74,"text":"because he would just say it","depth":11},{"id":75,"text":"as he saw it . \"","depth":11},{"id":76,"text":"When he took over as chief in Moline Acres ,","depth":9},{"id":77,"text":"Dorn made it clear","depth":10},{"id":78,"text":"that his officers would be held to the strictest of standards ,","depth":10},{"id":79,"text":"Fitch said .","depth":8},{"id":80,"text":"\" He wanted them to do the right thing all the time , \"","depth":8},{"id":81,"text":"Fitch said .","depth":8},{"id":82,"text":"The Ethical Society of Police ,","depth":9},{"id":83,"text":"which represents black officers in St. Louis ,","depth":9},{"id":84,"text":"said in a news release","depth":8},{"id":85,"text":"that Dorn was \" the type of brother","depth":8},{"id":86,"text":"that would ' ve given his life","depth":9},{"id":87,"text":"to save them","depth":10},{"id":88,"text":"if he had to . \"","depth":10},{"id":89,"text":"St. Louis police Chief John Hayden called Dorn a \" fine captain . \"","depth":8},{"id":90,"text":"\" Many of us , the other officers , looked up to him , \"","depth":11},{"id":91,"text":"Hayden said .","depth":11},{"id":92,"text":"\" Was very well-liked , very pleasant .","depth":10},{"id":93,"text":"And his wife still works here .","depth":9},{"id":94,"text":"So a very sad time for our agency .","depth":8},{"id":95,"text":"We will honor him . \"","depth":8}],"relations":[{"parent":191,"left":117,"right":190,"relation":"elaboration","nuclearity":"NS"},{"parent":117,"left":106,"right":116,"relation":"elaboration","nuclearity":"NS"},{"parent":106,"left":0,"right":105,"relation":"organization","nuclearity":"SN"},{"parent":105,"left":104,"right":10,"relation":"attribution","nuclearity":"NS"},{"parent":104,"left":101,"right":103,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":97,"right":100,"relation":"context","nuclearity":"SN"},{"parent":97,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":100,"left":99,"right":6,"relation":"attribution","nuclearity":"NS"},{"parent":99,"left":98,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":98,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":103,"left":7,"right":102,"relation":"elaboration","nuclearity":"NS"},{"parent":102,"left":8,"right":9,"relation":"context","nuclearity":"NS"},{"parent":116,"left":11,"right":115,"relation":"organization","nuclearity":"SN"},{"parent":115,"left":111,"right":114,"relation":"elaboration","nuclearity":"NS"},{"parent":111,"left":107,"right":110,"relation":"context","nuclearity":"SN"},{"parent":107,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":110,"left":109,"right":17,"relation":"at