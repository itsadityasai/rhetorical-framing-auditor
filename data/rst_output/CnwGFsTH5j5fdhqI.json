{"article_id":"CnwGFsTH5j5fdhqI","edus":[{"id":0,"text":"Ethics experts astonished","depth":4},{"id":1,"text":"after Trump acknowledges","depth":5},{"id":2,"text":"he repaid Cohen via retainer","depth":6},{"id":3,"text":"that had ' nothing to do with the campaign '","depth":6},{"id":4,"text":"Donald Trump has admitted","depth":8},{"id":5,"text":"that $ 130,000 of hush money was paid to the pornographic film actor Stormy Daniels","depth":9},{"id":6,"text":"to stop her going public about an alleged affair with him ,","depth":9},{"id":7,"text":"despite the president previously denying knowledge of a deal .","depth":7},{"id":8,"text":"The revelation threatened to engulf Trump in one of the most tawdry and legally damaging scandals of his presidency ,","depth":7},{"id":9,"text":"and on Thursday provoked astonished reactions from ethics experts .","depth":7},{"id":10,"text":"Donald Trump repaid his lawyer for Stormy Daniels hush money ,","depth":11},{"id":11,"text":"says Rudy Giuliani","depth":11},{"id":12,"text":"Read more","depth":10},{"id":13,"text":"Daniels ' lawyer called the revelation \" stunning \"","depth":10},{"id":14,"text":"and said :","depth":11},{"id":15,"text":"\" This is not about sex ...","depth":12},{"id":16,"text":"this is about a cover-up . \"","depth":12},{"id":17,"text":"Rudy Giuliani , the former mayor of New York and now one of Trump ' s lawyers , revealed on Wednesday night","depth":10},{"id":18,"text":"that Trump reimbursed his personal lawyer , Michael Cohen , for the $ 130,000","depth":11},{"id":19,"text":"he paid to Daniels .","depth":11},{"id":20,"text":"A report emerged on Thursday from NBC","depth":12},{"id":21,"text":"that Cohen ' s phones had been subject to a federal wiretap","depth":13},{"id":22,"text":"and that at least one call between Cohen and the White House had been intercepted .","depth":13},{"id":23,"text":"The White House press secretary , Sarah Sanders , in an afternoon briefing shortly afterwards declined to comment on the report .","depth":13},{"id":24,"text":"She referred reporters to both Trump ' s outside lawyers and the Department of Justice .","depth":13},{"id":25,"text":"However NBC later corrected the report","depth":13},{"id":26,"text":"saying","depth":14},{"id":27,"text":"that Cohen ' s calls had been monitored via a pen register ,","depth":15},{"id":28,"text":"which simply tracks calls","depth":16},{"id":29,"text":"and does not involve conversations","depth":17},{"id":30,"text":"being recorded .","depth":17},{"id":31,"text":"Daniels ,","depth":13},{"id":32,"text":"whose real name is Stephanie Clifford ,","depth":13},{"id":33,"text":"claims","depth":12},{"id":34,"text":"that she had a sexual encounter with Trump in 2006","depth":13},{"id":35,"text":"- months after his wife , Melania , gave birth -","depth":13},{"id":36,"text":"and was paid to stay silent as part of a non-disclosure agreement","depth":13},{"id":37,"text":"she is now seeking to invalidate .","depth":13},{"id":38,"text":"Trump had told reporters on Air Force One last month","depth":10},{"id":39,"text":"that he did not know about the $ 130,000 payment to Daniels","depth":12},{"id":40,"text":"- made by Cohen days before the 2016 presidential election -","depth":12},{"id":41,"text":"or the source of the money .","depth":11},{"id":42,"text":"But","depth":11},{"id":43,"text":"after Giuliani said on live television on Wednesday","depth":12},{"id":44,"text":"that Trump had indeed reimbursed Cohen for the payment ,","depth":12},{"id":45,"text":"the president reversed his position in an extraordinary sequence of tweets","depth":11},{"id":46,"text":"- just hours before leading a national day of prayer at the White House .","depth":11},{"id":47,"text":"At 6.46am on Thursday , Trump wrote on Twitter , in uncharacteristically legal-minded language ,","depth":11},{"id":48,"text":"that Cohen received a monthly retainer .","depth":11},{"id":49,"text":"\" Not from the campaign and having nothing","depth":13},{"id":50,"text":"to do with the campaign ,","depth":13},{"id":51,"text":"from which he entered into , through reimbursement , \" a non-disclosure agreement with Daniels .","depth":12},{"id":52,"text":"He claimed :","depth":12},{"id":53,"text":"\" These agreements are ... very common among celebrities and people of wealth . \"","depth":12},{"id":54,"text":"Trump described the allegations of an affair as \" false and extortionist \" ,","depth":10},{"id":55,"text":"adding :","depth":11},{"id":56,"text":"\" Money from the campaign , or campaign contributions , played no roll","depth":13},{"id":57,"text":"[ sic ]","depth":13},{"id":58,"text":"in this transaction . \"","depth":12},{"id":59,"text":"Donald J. Trump","depth":10},{"id":60,"text":"( @ realDonaldTrump )","depth":10},{"id":61,"text":"Mr. Cohen , an attorney , received a monthly retainer , not from the campaign and having nothing","depth":12},{"id":62,"text":"to do with the campaign ,","depth":12},{"id":63,"text":"from which he entered into , through reimbursement , a private contract between two parties ,","depth":12},{"id":64,"text":"known as a non-disclosure agreement , or NDA .","depth":12},{"id":65,"text":"These agreements are .....","depth":10},{"id":66,"text":"Sanders said of Trump ' s comments on Air Force One :","depth":10},{"id":67,"text":"\" He didn ' t know at the time","depth":12},{"id":68,"text":"but eventually learned \" about the payments","depth":12},{"id":69,"text":"that he made .","depth":11},{"id":70,"text":"She added","depth":11},{"id":71,"text":"the \" president denies","depth":13},{"id":72,"text":"and continues to deny \"","depth":13},{"id":73,"text":"the allegations of an affair","depth":12},{"id":74,"text":"but conceded","depth":11},{"id":75,"text":"that she only learned of the payments from Giuliani ' s appearance on Fox News on Wednesday evening .","depth":11},{"id":76,"text":"But watchdog groups and experts argued","depth":8},{"id":77,"text":"that","depth":10},{"id":78,"text":"despite his contention","depth":13},{"id":79,"text":"that no money from his campaign was used","depth":14},{"id":80,"text":"to pay off Daniels ,","depth":14},{"id":81,"text":"Trump still broke campaign finance laws","depth":12},{"id":82,"text":"by failing to declare the secret payment to the Federal Election Commission","depth":12},{"id":83,"text":"( FEC ) .","depth":12},{"id":84,"text":"No debt to Cohen is listed on Trump ' s personal financial disclosure form ,","depth":10},{"id":85,"text":"which was certified on 16 June 2017 .","depth":10},{"id":86,"text":"Our case just got exponentially better .","depth":6},{"id":87,"text":"This is not about sex ...","depth":7},{"id":88,"text":"this is about a cover-up","depth":7},{"id":89,"text":"Michael Avenatti","depth":6},{"id":90,"text":"Walter Shaub , the former director of the Office of Government Ethics and vocal Trump critic , tweeted :","depth":9},{"id":91,"text":"\" AMAZING !","depth":10},{"id":92,"text":"In trying to talk his way out of a campaign finance violation ,","depth":12},{"id":93,"text":"Trump has inadvertently admitted to filing a false financial disclosure in 2017 .","depth":12},{"id":94,"text":"He personally certified","depth":12},{"id":95,"text":"that his disclosure was ' complete and correct ' . \"","depth":12},{"id":96,"text":"Shaub added :","depth":9},{"id":97,"text":"\" This seems like as strong a circumstantial case for a violation","depth":11},{"id":98,"text":"as one is going to see .","depth":11},{"id":99,"text":"It is absolutely stunning that we ' ve reached the point","depth":11},{"id":100,"text":"where the president of the United States appears to have lied to the US Office of Government Ethics about a payoff to a porn star . \"","depth":11},{"id":101,"text":"Norm Eisen , the chair of left-leaning Citizens for Responsibility and Ethics in Washington","depth":12},{"id":102,"text":"( Crew ) ,","depth":12},{"id":103,"text":"which has already filed a criminal complaint ,","depth":11},{"id":104,"text":"added on Twitter :","depth":10},{"id":105,"text":"\" This dope & evidently his lawyers do not","depth":12},{"id":106,"text":"- despite everything -","depth":12},{"id":107,"text":"understand how campaign finance law works .","depth":11},{"id":108,"text":"Whole point is that money came from outside the campaign","depth":12},{"id":109,"text":"& benefitted it .","depth":12},{"id":110,"text":"That is the illegal ' roll ' under review .","depth":12},{"id":111,"text":"No one saying","depth":13},{"id":112,"text":"it was campaign money . \"","depth":13},{"id":113,"text":"Crew ,","depth":13},{"id":114,"text":"which requested a Department of Justice","depth":15},{"id":115,"text":"( DoJ )","depth":15},{"id":116,"text":"investigation into the payment in March ,","depth":14},{"id":117,"text":"filed a supplemental criminal and ethics complaint on Thursday .","depth":12},{"id":118,"text":"\" There is now more than enough evidence","depth":13},{"id":119,"text":"for the DoJ to investigate","depth":14},{"id":120,"text":"whether President Trump intentionally omitted the Stormy Daniels liability from his personal financial disclosures , \"","depth":14},{"id":121,"text":"Eisen said .","depth":12},{"id":122,"text":"\" This is a very serious matter ,","depth":11},{"id":123,"text":"including because there can be criminal penalties for false statements . \"","depth":11},{"id":124,"text":"There can be criminal or civil penalties","depth":11},{"id":125,"text":"for violating campaign finance laws ,","depth":11},{"id":126,"text":"although it is as yet unclear what fresh angle of investigation ,","depth":12},{"id":127,"text":"if any ,","depth":12},{"id":128,"text":"could be prompted by the latest developments .","depth":11},{"id":129,"text":"Facebook Twitter Pinterest","depth":5},{"id":130,"text":"' Mr Cohen has acted","depth":7},{"id":131,"text":"like he is above the law ' :","depth":7},{"id":132,"text":"Stormy Daniels on Trump ' s lawyer - video","depth":6},{"id":133,"text":"On Wednesday night , Giuliani told Fox News host Sean Hannity :","depth":6},{"id":134,"text":"\" They funneled through a law firm ,","depth":8},{"id":135,"text":"and the president repaid it .","depth":8},{"id":136,"text":"That was money","depth":9},{"id":137,"text":"that was paid by his lawyer .","depth":9},{"id":138,"text":"The president reimbursed that over the period of several months . \"","depth":8},{"id":139,"text":"Daniels ' lawyer , Michael Avenatti , described Trump ' s tweets as \" a stunning revelation \" .","depth":6},{"id":140,"text":"He wrote on Twitter :","depth":8},{"id":141,"text":"\" Mr Trump stood on AF1","depth":10},{"id":142,"text":"and blatantly lied .","depth":10},{"id":143,"text":"This followed the lies","depth":10},{"id":144,"text":"told by others close to him ,","depth":11},{"id":145,"text":"including Mr Cohen . \"","depth":11},{"id":146,"text":"Avenatti told MSNBC :","depth":8},{"id":147,"text":"\" This is not about sex ...","depth":9},{"id":148,"text":"this is about a cover-up . \"","depth":9},{"id":149,"text":"FBI agents raided Cohen ' s home and office several weeks ago","depth":4},{"id":150,"text":"seeking records about the non-disclosure agreement .","depth":4},{"id":151,"text":"Sign up","depth":2},{"id":152,"text":"to receive the top US stories every morning","depth":2}],"relations":[{"parent":305,"left":303,"right":304,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":281,"right":302,"relation":"elaboration","nuclearity":"NS"},{"parent":281,"left":156,"right":280,"relation":"organization","nuclearity":"SN"},{"parent":156,"left":0,"right":155,"relation":"context","nuclearity":"NS"},{"parent":155,"left":1,"right":154,"relation":"attribution","nuclearity":"SN"},{"parent":154,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":280,"left":237,"right":279,"relation":"elaboration","nuclearity":"NS"},{"parent":237,"left":161,"right":236,"relation":"elaboration","nuclearity":"NS"},{"parent":161,"left":159,"right":160,"relation":"causal","nuclearity"