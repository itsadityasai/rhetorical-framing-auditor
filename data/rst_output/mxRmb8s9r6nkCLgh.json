{"article_id":"mxRmb8s9r6nkCLgh","edus":[{"id":0,"text":"WASHINGTON ( ) -","depth":1},{"id":1,"text":"The U.S. Supreme Court on Friday agreed to decide","depth":10},{"id":2,"text":"whether President Donald Trump acted lawfully","depth":11},{"id":3,"text":"when he moved to end a program","depth":12},{"id":4,"text":"that protects from deportation hundreds of thousands of immigrants","depth":13},{"id":5,"text":"who were brought into the country illegally as children , a key element of his hardline immigration policies .","depth":13},{"id":6,"text":"The nine justices took up the Trump administration ' s appeals of lower court rulings in California , New York and the District of Columbia","depth":10},{"id":7,"text":"that blocked as unlawful his 2017 plan","depth":11},{"id":8,"text":"to rescind the Deferred Action for Childhood Arrivals","depth":14},{"id":9,"text":"( DACA )","depth":14},{"id":10,"text":"program","depth":13},{"id":11,"text":"implemented in 2012 by his Democratic predecessor Barack Obama .","depth":12},{"id":12,"text":"The program currently shields about 700,000 immigrants","depth":11},{"id":13,"text":"often called \" Dreamers , \" mostly Hispanic young adults ,","depth":11},{"id":14,"text":"from deportation","depth":10},{"id":15,"text":"and provides them work permits , though not a path to citizenship .","depth":9},{"id":16,"text":"The conservative-majority Supreme Court will hear arguments","depth":9},{"id":17,"text":"and issue a ruling during its next term ,","depth":10},{"id":18,"text":"which starts in October","depth":11},{"id":19,"text":"and runs through June 2020 ,","depth":11},{"id":20,"text":"meaning a decision could come in the thick of next year ' s presidential race","depth":9},{"id":21,"text":"in which Trump is seeking re-election .","depth":9},{"id":22,"text":"Democratic presidential candidates","depth":11},{"id":23,"text":"including front-runner Joe Biden","depth":11},{"id":24,"text":"have pledged actions","depth":11},{"id":25,"text":"to protect the Dreamers","depth":12},{"id":26,"text":"and offer them citizenship .","depth":12},{"id":27,"text":"Three federal district court judges issued orders","depth":10},{"id":28,"text":"halting Trump ' s move","depth":12},{"id":29,"text":"to end DACA","depth":12},{"id":30,"text":"after lawsuits were filed by a group of states","depth":13},{"id":31,"text":"including California and New York , people","depth":14},{"id":32,"text":"protected by the program ,","depth":14},{"id":33,"text":"civil rights groups and others","depth":13},{"id":34,"text":"challenging the legality of the Republican president ' s move .","depth":13},{"id":35,"text":"Trump , Republicans in Congress and Democratic lawmakers have been unable to hammer out a legislative deal","depth":9},{"id":36,"text":"to protect \" Dreamers. \"","depth":9},{"id":37,"text":"The Trump administration has argued","depth":9},{"id":38,"text":"that Obama exceeded his constitutional powers","depth":10},{"id":39,"text":"when he bypassed Congress","depth":11},{"id":40,"text":"and created DACA .","depth":11},{"id":41,"text":"In the meantime , the program ,","depth":11},{"id":42,"text":"in which those eligible can get renewable two-year work permits ,","depth":11},{"id":43,"text":"remains in effect for people","depth":11},{"id":44,"text":"already enrolled .","depth":11},{"id":45,"text":"New applications are not being accepted by Trump ' s administration .","depth":10},{"id":46,"text":"Since January 2018 , the administration has issued more than 373,000 renewals ,","depth":11},{"id":47,"text":"according to U.S . Citizenship and Immigration Services data .","depth":11},{"id":48,"text":"\" DACA reflects our nation ' s commitment","depth":11},{"id":49,"text":"to helping hard-working people","depth":11},{"id":50,"text":"and creates hope and opportunity for a new generation","depth":11},{"id":51,"text":"- many of whom were brought to our country as toddlers , \"","depth":11},{"id":52,"text":"said California Attorney General Xavier Becerra , a Democrat ,","depth":10},{"id":53,"text":"who leads one of the legal challenges .","depth":10},{"id":54,"text":"\" So far , both lower courts in our legal fight","depth":12},{"id":55,"text":"to protect DACA","depth":12},{"id":56,"text":"have agreed with us","depth":11},{"id":57,"text":"that the Trump administration ' s attempt","depth":12},{"id":58,"text":"to end it","depth":12},{"id":59,"text":"was unlawful , \"","depth":11},{"id":60,"text":"Becerra added .","depth":9},{"id":61,"text":"Justice Department spokesman Alexei Woltornist welcomed the Supreme Court ' s action .","depth":8},{"id":62,"text":"\" We are pleased","depth":10},{"id":63,"text":"the Supreme Court agreed","depth":11},{"id":64,"text":"that this issue needs resolution , \"","depth":11},{"id":65,"text":"Woltornist said .","depth":9},{"id":66,"text":"The Democratic-led House of Representatives on June 4 passed a bill","depth":8},{"id":67,"text":"that would protect \" Dreamers \"","depth":8},{"id":68,"text":"but the Republican-controlled Senate has shown no sign","depth":9},{"id":69,"text":"of approving it .","depth":9},{"id":70,"text":"Dick Durbin , the No . 2 Senate Democrat , on Friday urged the Senate to pass the legislation .","depth":8},{"id":71,"text":"The legal question before the Supreme Court is whether the administration properly followed a federal law","depth":9},{"id":72,"text":"called the Administrative Procedure Act","depth":9},{"id":73,"text":"in Trump ' s plan","depth":9},{"id":74,"text":"to end DACA .","depth":9},{"id":75,"text":"The administration appealed in November","depth":8},{"id":76,"text":"and the Supreme Court could have acted on it as early as January ,","depth":9},{"id":77,"text":"but delayed action for half a year","depth":10},{"id":78,"text":"before taking up the matter .","depth":10},{"id":79,"text":"The court ' s announcement came","depth":7},{"id":80,"text":"a day","depth":8},{"id":81,"text":"after it issued a 5-4 ruling on last official day of its 2018-2019 term ,","depth":9},{"id":82,"text":"dealing a major setback to Trump ' s plan","depth":10},{"id":83,"text":"to add a contentious citizenship question to the 2020 census .","depth":10},{"id":84,"text":"In another important immigration-related case , the Supreme Court last year upheld Trump ' s travel ban","depth":8},{"id":85,"text":"targeting people from several Muslim-majority countries .","depth":8},{"id":86,"text":"Trump ' s effort","depth":11},{"id":87,"text":"to rescind DACA ,","depth":11},{"id":88,"text":"even as he has said","depth":11},{"id":89,"text":"\" I love these kids , \"","depth":11},{"id":90,"text":"is part of his tough stance on immigration ,","depth":10},{"id":91,"text":"which has become a prominent feature of his presidency and his re-election campaign .","depth":10},{"id":92,"text":"Trump has backed limits on legal and illegal immigration","depth":9},{"id":93,"text":"and has sought construction of a wall along the U.S.-Mexican border","depth":10},{"id":94,"text":"since taking office in January 2017 .","depth":10},{"id":95,"text":"Under Trump ' s September 2017 decision","depth":9},{"id":96,"text":"to rescind DACA ,","depth":9},{"id":97,"text":"protections for Dreamers were to have begun phasing out in March 2018 .","depth":8},{"id":98,"text":"But lower courts directed the administration to continue processing renewals of existing DACA applications","depth":8},{"id":99,"text":"while the litigation was resolved .","depth":8},{"id":100,"text":"Obama created DACA by executive action in 2012 as what he called \" a temporary stop-gap measure \" after the failure in Congress of bipartisan legislation","depth":6},{"id":101,"text":"called the Dream Act","depth":6},{"id":102,"text":"that would have provided a path to citizenship to young immigrants","depth":6},{"id":103,"text":"brought by their parents illegally into the country as children .","depth":6},{"id":104,"text":"When he created DACA ,","depth":5},{"id":105,"text":"Obama said","depth":6},{"id":106,"text":"the people","depth":8},{"id":107,"text":"it protected","depth":8},{"id":108,"text":"were raised and educated in the United States ,","depth":8},{"id":109,"text":"grew up as Americans in their hearts and minds ,","depth":9},{"id":110,"text":"and may know little about their countries of origin .","depth":9},{"id":111,"text":"The Trump administration said","depth":4},{"id":112,"text":"Trump possesses the authority","depth":5},{"id":113,"text":"to end a program","depth":6},{"id":114,"text":"implemented by a previous president ,","depth":8},{"id":115,"text":"acted lawfully","depth":9},{"id":116,"text":"in seeking to rescind it","depth":9},{"id":117,"text":"and that courts should have no say in the matter .","depth":7},{"id":118,"text":"The administration sought to bypass the normal court process ,","depth":7},{"id":119,"text":"filing papers on Nov. 5","depth":9},{"id":120,"text":"asking the high court to intervene","depth":9},{"id":121,"text":"even before some federal appeals courts","depth":10},{"id":122,"text":"considering the matter","depth":10},{"id":123,"text":"had issued rulings .","depth":9},{"id":124,"text":"Since then , on Nov. 8 , the San Francisco-based 9th U.S . Circuit Court of Appeals upheld District Judge William Alsup ' s January 2018 ruling against Trump ,","depth":9},{"id":125,"text":"saying","depth":10},{"id":126,"text":"the challengers provided evidence of \" discriminatory motivation ,","depth":11},{"id":127,"text":"including the rescission order ' s disparate impact on Latinos and persons of Mexican heritage . \"","depth":11},{"id":128,"text":"The Richmond , Virginia-based 4th U.S . Circuit Court of Appeals subsequently ruled against Trump last month .","depth":8},{"id":129,"text":"Two federal appeals court have yet to issue rulings .","depth":7},{"id":130,"text":"Also among those","depth":7},{"id":131,"text":"suing the administration","depth":8},{"id":132,"text":"to preserve DACA","depth":8},{"id":133,"text":"were the University of California , labor unions and Microsoft Corp ,","depth":7},{"id":134,"text":"which expressed concern","depth":8},{"id":135,"text":"its own employees would be affected .","depth":8},{"id":136,"text":"For a graphic on major Supreme Court rulings , click tmsnrt.rs/2V2T0Uf","depth":4}],"relations":[{"parent":273,"left":0,"right":272,"relation":"organization","nuclearity":"SN"},{"parent":272,"left":246,"right":271,"relation":"elaboration","nuclearity":"NS"},{"parent":246,"left":235,"right":245,"relation":"elaboration","nuclearity":"NS"},{"parent":235,"left":206,"right":234,"relation":"elaboration","nuclearity":"NS"},{"parent":206,"left":183,"right":205,"relation":"elaboration","nuclearity":"NS"},{"parent":183,"left":157,"right":182,"relation":"elaboration","nuclearity":"NS"},{"parent":157,"left":151,"right":156,"relation":"elaboration","nuclearity":"NS"},{"parent":151,"left":147,"right":150,"relation":"elaboration","nuclearity":"NS"},{"parent":147,"left":141,"right":146,"relation":"elaboration","nuclearity":"NS"},{"parent":141,"left":1,"right":140,"relation":"attribution","nuclearity":"SN"},{"parent":140,"left":2,"right":139,"relation":"context","nuclearity":"NS"},{"parent":139,"left":3,"right":138,"relation":"elaboration","nuclearity":"NS"},{"parent":138,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":146,"left":6,"right":145,"relation":"elaboration","nuclearity":"NS"},{"parent":145,"left":7,"right":144,"relation":"elaboration","nuclearity":"NS"},{"parent":144,"left":143,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":143,"left":142,"right":10,"relation":"same-unit","nuclearity":"NN"},{"parent":142,"left":8,"right":9,"relation":"restatement","nuclearity":"NS"},{"parent":150,"left":149,"right":15,"relation":"joint","nuclearity":"NN"},{"parent":149,"left":148,"right":14,"relation":"same-unit","nuclearity":"NN"},{"parent":148,"left":12,"right":13,"relation":"elaboration","nuclearity":"NS"},{"parent":156,"left":154,"right":155,"relation":"cau