{"article_id":"34K9DwjVO8Y5eBLy","edus":[{"id":0,"text":"Rayshard Brooks sustained organ damage and blood loss","depth":5},{"id":1,"text":"when he was shot twice in the back during his fatal shooting by police in Atlanta ,","depth":5},{"id":2,"text":"Fulton County Medical Examiner 's Office said Sunday evening ,","depth":5},{"id":3,"text":"per the Atlanta Journal Constitution .","depth":5},{"id":4,"text":"Details :","depth":4},{"id":5,"text":"The autopsy found","depth":8},{"id":6,"text":"Brooks ' manner of death was homicide ,","depth":8},{"id":7,"text":"CBS News reports .","depth":7},{"id":8,"text":"This means it was determined that the death was caused by the actions of another person","depth":7},{"id":9,"text":"and it 's up to law enforcement to decide what charges","depth":9},{"id":10,"text":"to bring ,","depth":9},{"id":11,"text":"according to the Medical Examiner 's Office ,","depth":9},{"id":12,"text":"which notes","depth":10},{"id":13,"text":"not all homicides are murders .","depth":10},{"id":14,"text":"Fulton County District Attorney Paul Howard told CNN on Sunday","depth":6},{"id":15,"text":"authorities are weighing possible charges of murder , felony murder or aggravated assault over Brooks ' death , with a decision","depth":7},{"id":16,"text":"expected by Wednesday .","depth":7},{"id":17,"text":"The big picture :","depth":5},{"id":18,"text":"Garrett Rolfe , the officer","depth":9},{"id":19,"text":"who fatally shot Brooks in a Wendy 's parking lot on Friday ,","depth":9},{"id":20,"text":"was fired","depth":8},{"id":21,"text":"and Devin Bronsan , an officer","depth":9},{"id":22,"text":"who was present during the incident ,","depth":9},{"id":23,"text":"was placed on administrative duty ,","depth":8},{"id":24,"text":"authorities said early Sunday .","depth":6},{"id":25,"text":"Georgia Bureau of Investigation announcement Friday","depth":5},{"id":26,"text":"that it had launched a review into the shooting .","depth":5},{"id":27,"text":"What they 're saying :","depth":4},{"id":28,"text":"Howard told CNN","depth":6},{"id":29,"text":"Brooks `` did not seem to present any kind of threat to anyone ,","depth":8},{"id":30,"text":"and so the fact","depth":10},{"id":31,"text":"that it would escalate to his death just seems unreasonable . '' `` It just seems like this is not the kind of conversation and incident","depth":10},{"id":32,"text":"that should have led to someone 's death , ''","depth":9},{"id":33,"text":"he added .","depth":7},{"id":34,"text":"Howard said","depth":6},{"id":35,"text":"they were looking at","depth":8},{"id":36,"text":"whether the officer","depth":10},{"id":37,"text":"involved in the shooting at the time","depth":10},{"id":38,"text":"felt Brooks `` presented imminent harm of death or some serious physical injury . ''","depth":9},{"id":39,"text":"`` If that shot was fired for some reason","depth":9},{"id":40,"text":"other than to save that officer 's life or to prevent injury to him or others ,","depth":9},{"id":41,"text":"then that shooting is not justified under the law . ''","depth":8},{"id":42,"text":"Go deeper :","depth":2},{"id":43,"text":"Atlanta officer fired ,","depth":3},{"id":44,"text":"chief resigns ,","depth":4},{"id":45,"text":"Wendy 's torched after fatal shooting","depth":4}],"relations":[{"parent":91,"left":87,"right":90,"relation":"elaboration","nuclearity":"NS"},{"parent":87,"left":62,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":62,"left":49,"right":61,"relation":"elaboration","nuclearity":"NS"},{"parent":49,"left":47,"right":48,"relation":"attribution","nuclearity":"NS"},{"parent":47,"left":0,"right":1,"relation":"context","nuclearity":"NS"},{"parent":48,"left":2,"right":3,"relation":"attribution","nuclearity":"NS"},{"parent":61,"left":4,"right":60,"relation":"organization","nuclearity":"SN"},{"parent":60,"left":57,"right":59,"relation":"elaboration","nuclearity":"NS"},{"parent":57,"left":51,"right":56,"relation":"elaboration","nuclearity":"NS"},{"parent":51,"left":50