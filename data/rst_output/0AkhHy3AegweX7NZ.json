n":"attribution","nuclearity":"SN"},{"parent":285,"left":284,"right":132,"relation":"elaboration","nuclearity":"NS"},{"parent":284,"left":130,"right":131,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":304,"right":308,"relation":"joint","nuclearity":"NN"},{"parent":304,"left":295,"right":303,"relation":"joint","nuclearity":"NN"},{"parent":295,"left":288,"right":294,"relation":"elaboration","nuclearity":"NS"},{"parent":288,"left":133,"right":287,"relation":"adversative","nuclearity":"SN"},{"parent":287,"left":134,"right":135,"relation":"attribution","nuclearity":"SN"},{"parent":294,"left":293,"right":142,"relation":"context","nuclearity":"NS"},{"parent":293,"left":136,"right":292,"relation":"attribution","nuclearity":"SN"},{"parent":292,"left":290,"right":291,"relation":"elaboration","nuclearity":"NS"},{"parent":290,"left":137,"right":289,"relation":"adversative","nuclearity":"SN"},{"parent":289,"left":138,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":140,"right":141,"relation":"context","nuclearity":"SN"},{"parent":303,"left":298,"right":302,"relation":"joint","nuclearity":"NN"},{"parent":298,"left":143,"right":297,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":144,"right":296,"relation":"attribution","nuclearity":"SN"},{"parent":296,"left":145,"right":146,"relation":"purpose","nuclearity":"NS"},{"parent":302,"left":301,"right":151,"relation":"context","nuclearity":"SN"},{"parent":301,"left":147,"right":300,"relation":"mode","nuclearity":"NS"},{"parent":300,"left":148,"right":299,"relation":"joint","nuclearity":"NN"},{"parent":299,"left":149,"right":150,"relation":"attribution","nuclearity":"SN"},{"parent":308,"left":307,"right":156,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":305,"right":306,"relation":"same-unit","nuclearity":"NN"},{"parent":305,"left":152,"right":153,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":154,"right":155,"relation":"elaboration","nuclearity":