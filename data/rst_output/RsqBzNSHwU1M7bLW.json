{"article_id":"RsqBzNSHwU1M7bLW","edus":[{"id":0,"text":"Rowan County , Kentucky clerk Kim Davis sits behind bars","depth":5},{"id":1,"text":"for refusing to issue marriage licenses to anyone in her tiny district .","depth":6},{"id":2,"text":"In doing so ,","depth":7},{"id":3,"text":"the Rowan County clerk has become a national symbol for many","depth":8},{"id":4,"text":"who oppose gay marriage","depth":9},{"id":5,"text":"because of their faith .","depth":9},{"id":6,"text":"The gay couples","depth":9},{"id":7,"text":"suing Davis","depth":9},{"id":8,"text":"had asked","depth":8},{"id":9,"text":"that she be fined .","depth":7},{"id":10,"text":"But in a surprise move , the federal judge decided to put her in jail instead ,","depth":7},{"id":11,"text":"saying","depth":8},{"id":12,"text":"a mere fine would n't be enough","depth":9},{"id":13,"text":"to bring about the desired result of compliance .","depth":9},{"id":14,"text":"At the last minute , Davis rejected a deal","depth":7},{"id":15,"text":"to allow her deputies to process same-sex marriage licenses .","depth":7},{"id":16,"text":"That could have prompted her release .","depth":6},{"id":17,"text":"`` She 's been ordered to stay there","depth":5},{"id":18,"text":"until she is willing to change her mind ,","depth":6},{"id":19,"text":"until she is ready to change her conscience about what that belief is , ''","depth":6},{"id":20,"text":"Davis ' attorney , Roger Gannam , said .","depth":4},{"id":21,"text":"Within hours of the judge 's order , several Republican presidential candidates declared their support for Davis .","depth":3},{"id":22,"text":"Former Arkansas Gov . Mike Huckabee said","depth":6},{"id":23,"text":"her imprisonment `` removes all doubt of the criminalization of Christianity in our country . ''","depth":7},{"id":24,"text":"`` Who will be next ?","depth":10},{"id":25,"text":"Pastors ?","depth":10},{"id":26,"text":"Photographers ?","depth":10},{"id":27,"text":"Caterers ?","depth":11},{"id":28,"text":"Florists ? ''","depth":11},{"id":29,"text":"he asked .","depth":8},{"id":30,"text":"`` This is a reckless , appalling , out-of-control decision","depth":7},{"id":31,"text":"that undermines the Constitution","depth":8},{"id":32,"text":" and our fundamental right to religious liberty . ''","depth":8},{"id":33,"text":"`` Today , for the first time ever , the government arrested a Christian woman","depth":9},{"id":34,"text":"for living according to her faith .","depth":9},{"id":35,"text":"This is wrong .","depth":9},{"id":36,"text":"This is not America , ''","depth":9},{"id":37,"text":"he said .","depth":7},{"id":38,"text":"Hillary Clinton disagreed ,","depth":7},{"id":39,"text":"saying","depth":8},{"id":40,"text":"government officials should uphold the law .","depth":8},{"id":41,"text":"`` The success of our democracy depends on the rule of law","depth":8},{"id":42,"text":"and there is no public official","depth":9},{"id":43,"text":"that is above the rule of law , ''","depth":9},{"id":44,"text":"White House press secretary Josh Earnest said .","depth":7},{"id":45,"text":"But a Wall Street Journal editorial suggested","depth":7},{"id":46,"text":"the Obama administration 's position was hypocritical .","depth":7},{"id":47,"text":"`` We do n't recall President Obama insisting on the 'rule of law '","depth":7},{"id":48,"text":"when his then Attorney General Eric Holder announced in 2011","depth":9},{"id":49,"text":"that he would n't defend challenges to what was then the law","depth":10},{"id":50,"text":" the Defense of Marriage Act , ''","depth":10},{"id":51,"text":"the editorial read .","depth":8},{"id":52,"text":"Meanwhile , protesters on both sides of the issue are up in arms in Kentucky .","depth":3},{"id":53,"text":"`` If you ca n't do your job","depth":6},{"id":54,"text":"then resign , ''","depth":6},{"id":55,"text":"a Kim Davis opponent said .","depth":5},{"id":56,"text":"But a supporter said ,","depth":5},{"id":57,"text":"`` Today we came to stand for God","depth":6},{"id":58,"text":"and support our county clerk Kim Davis . ''","depth":6},{"id":59,"text":"Davis had hoped","depth":5},{"id":60,"text":"Kentucky lawmakers would find a way for her","depth":6},{"id":61,"text":"to keep her job","depth":7},{"id":62,"text":" and her conscience .","depth":7},{"id":63,"text":"But the governor has refused to call a special session .","depth":4},{"id":64,"text":"In the meantime , her deputies plan to follow a U.S. district judge 's orders","depth":4},{"id":65,"text":"and issue marriage licenses to same-sex couples ,","depth":5},{"id":66,"text":"starting Friday .","depth":5}],"relations":[{"parent":133,"left":118,"right":132,"relation":"elaboration","nuclearity":"NS"},{"parent":118,"left":87,"right":117,"relation":"elaboration","nuclearity":"NS"},{"parent":87,"left":83,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":72,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":0,"right":71,"relation":"causal","nuclearity":"NS"},{"parent":71,"left":1,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":2,"right":69,"relation":"context","nuclearity":"SN"},{"parent":69,"left":3,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":4,"right":5,"relation":"causal","nuclearity":"NS"},{"parent":82,"left":79,"right":81,"relation":"joint","nuclearity":"NN"},{"parent":79,"left":75,"right":78,"relation":"adversative","nuclearity":"NN"},{"parent":75,"left":74,"right":9,"relation":"attribution","nuclearity":"SN"},{"parent":74,"left":73,"right":8,"relation":"same-unit","nuclearity":"NN"},{"parent":73,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":10,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":11,"right":76,"relation":"attribution","nuclearity":"SN"},{"parent":76,"left":12,"right":13,"relation":"purpose","nuclearity":"NS"},{"parent":81,"left":80,"right":16,"relation":"causal","nuclearity":"NS"},{"parent"