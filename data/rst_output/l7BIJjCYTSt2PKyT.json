{"article_id":"l7BIJjCYTSt2PKyT","edus":[{"id":0,"text":"Iran has admitted","depth":6},{"id":1,"text":"`` unintentionally '' shooting down a Ukrainian passenger jet ,","depth":7},{"id":2,"text":"killing all 176 people on board .","depth":7},{"id":3,"text":"An investigation found","depth":8},{"id":4,"text":"that `` missiles fired due to human error '' ,","depth":8},{"id":5,"text":"President Hassan Rouhani said .","depth":7},{"id":6,"text":"He described the crash as an `` unforgivable mistake '' .","depth":6},{"id":7,"text":"The military said","depth":6},{"id":8,"text":"the jet turned towards a sensitive site","depth":8},{"id":9,"text":"belonging to Iran 's Revolutionary Guards","depth":8},{"id":10,"text":"and was then mistaken for a cruise missile .","depth":7},{"id":11,"text":"Iran had previously rejected suggestions","depth":6},{"id":12,"text":"that it was to blame .","depth":6},{"id":13,"text":"The downing of Ukraine International Airlines flight PS752 on Wednesday came just hours after Iran carried out missile strikes on two airbases","depth":9},{"id":14,"text":"housing US forces in Iraq .","depth":9},{"id":15,"text":"The strikes were a response to the killing of senior Iranian commander Qasem Soleimani in a US drone strike in Baghdad on 3 January .","depth":8},{"id":16,"text":"Iran initially denied reports","depth":10},{"id":17,"text":"that one of its missiles had brought down the Ukrainian plane near the capital , Tehran .","depth":10},{"id":18,"text":"But pressure quickly mounted","depth":10},{"id":19,"text":"after Western intelligence officials said","depth":11},{"id":20,"text":"evidence pointed to Iranian involvement .","depth":11},{"id":21,"text":"The Ukrainian flight ,","depth":11},{"id":22,"text":"which was en route to Kyiv ,","depth":11},{"id":23,"text":"came down near Imam Khomeini Airport shortly after take-off .","depth":10},{"id":24,"text":"Victims included dozens of Iranians and Canadians , as well as nationals from Ukraine , the UK , Afghanistan and Germany .","depth":9},{"id":25,"text":"On Saturday morning , an Iranian military statement","depth":11},{"id":26,"text":"read on state TV","depth":11},{"id":27,"text":"announced","depth":10},{"id":28,"text":"that it had struck flight PS752 with a missile by mistake .","depth":9},{"id":29,"text":"It said","depth":11},{"id":30,"text":"the plane had turned towards a `` sensitive military centre '' of the Revolutionary Guards , a force","depth":12},{"id":31,"text":"set up","depth":13},{"id":32,"text":"to defend the country 's Islamic system .","depth":13},{"id":33,"text":"The statement said","depth":11},{"id":34,"text":"it had the `` flying posture and altitude of an enemy target '' .","depth":11},{"id":35,"text":"Because of heightened tensions with the US ,","depth":12},{"id":36,"text":"Iran 's military `` was at its highest level of readiness '' ,","depth":12},{"id":37,"text":"the statement added .","depth":11},{"id":38,"text":"`` In such a condition ,","depth":11},{"id":39,"text":"because of human error and in an unintentional way ,","depth":12},{"id":40,"text":"the flight was hit . ''","depth":12},{"id":41,"text":"The military apologised","depth":10},{"id":42,"text":"for downing the plane ,","depth":10},{"id":43,"text":"saying","depth":10},{"id":44,"text":"it would upgrade its systems","depth":11},{"id":45,"text":"to prevent such `` mistakes '' in the future .","depth":11},{"id":46,"text":"It added","depth":9},{"id":47,"text":"that those responsible would be held accountable and prosecuted .","depth":9},{"id":48,"text":"Ukraine International Airlines denies","depth":7},{"id":49,"text":"that the plane veered from its expected course before the crash .","depth":7},{"id":50,"text":"It says","depth":7},{"id":51,"text":"officials should have closed the airport .","depth":7},{"id":52,"text":"Brig-Gen Amir Ali Hajizadeh , the Revolutionary Guards aerospace commander , said","depth":8},{"id":53,"text":"the force took `` full responsibility '' for the crash .","depth":8},{"id":54,"text":"He said","depth":8},{"id":55,"text":"a request had been made for a no-fly zone in the area before the incident","depth":9},{"id":56,"text":"but - for reasons","depth":11},{"id":57,"text":"that are unclear -","depth":11},{"id":58,"text":"this was rejected .","depth":10},{"id":59,"text":"Gen Hajizadeh also said","depth":8},{"id":60,"text":"the aircraft was shot down by a short-range missile","depth":9},{"id":61,"text":"that exploded next to it .","depth":9},{"id":62,"text":"He said","depth":8},{"id":63,"text":"he informed the authorities about what had happened on Wednesday ,","depth":9},{"id":64,"text":"days before Iran publicly admitted its involvement .","depth":9},{"id":65,"text":"Iran 's Supreme Leader Ali Khamenei ordered the military to investigate `` the possible shortcomings or mistakes ''","depth":8},{"id":66,"text":"that led to the crash .","depth":8},{"id":67,"text":"In a statement , he said","depth":9},{"id":68,"text":"there was `` proof of human error ''","depth":9},{"id":69,"text":"and confirmed","depth":9},{"id":70,"text":"that he had `` requested the relevant authorities to take necessary measures","depth":10},{"id":71,"text":"to prevent '' it happening again .","depth":10},{"id":72,"text":"Foreign Minister Javad Zarif apologised to the families of the victims","depth":12},{"id":73,"text":"but laid part of the blame on the US .","depth":12},{"id":74,"text":"`` Human error at a time of crisis","depth":14},{"id":75,"text":"caused by US adventurism","depth":14},{"id":76,"text":"led to [ this ] disaster , ''","depth":13},{"id":77,"text":"he said .","depth":12},{"id":78,"text":"And Iran 's ambassador to the UK , Hamid Baeidinejad , apologised","depth":12},{"id":79,"text":"for sharing `` wrong findings '' about the crash .","depth":12},{"id":80,"text":"He had said","depth":13},{"id":81,"text":"Iran was `` confident ''","depth":14},{"id":82,"text":"that a missile had not been launched .","depth":14},{"id":83,"text":"`` I conveyed the official findings ...","depth":15},{"id":84,"text":"that [ a ] missile could not be fired and hit the Ukrainian plane at that period of time , ''","depth":15},{"id":85,"text":"he said .","depth":14},{"id":86,"text":"`` I apologise . ''","depth":13},{"id":87,"text":"This is a major admission at a crucial moment for Iran .","depth":11},{"id":88,"text":"Taking responsibility for such a tragic error is highly unusual ,","depth":12},{"id":89,"text":"but so is the crisis","depth":13},{"id":90,"text":"that now confronts the Islamic Republic .","depth":13},{"id":91,"text":"Iran has decided","depth":11},{"id":92,"text":"it has to own this disaster","depth":12},{"id":93,"text":"to avoid it triggering another war of words with the West","depth":13},{"id":94,"text":"or exacerbating further anger and anguish among its own people ,","depth":14},{"id":95,"text":"who are reeling from one calamity after another .","depth":14},{"id":96,"text":"Make no mistake ,","depth":10},{"id":97,"text":"this admission was an act of de-escalation .","depth":10},{"id":98,"text":"The repercussions at home may soon be clear .","depth":9},{"id":99,"text":"Iran 's foreign minister has already sought to shift blame","depth":9},{"id":100,"text":"by saying","depth":10},{"id":101,"text":"it was `` a crisis","depth":11},{"id":102,"text":"caused by US adventurism '' .","depth":11},{"id":103,"text":"But the big question now is :","depth":9},{"id":104,"text":"who took the decision","depth":11},{"id":105,"text":"to allow a civilian airliner to take off","depth":11},{"id":106,"text":"when Iran 's airspace was shot through with such tension ?","depth":10},{"id":107,"text":"There were 57 Canadian nationals on board the downed flight","depth":4},{"id":108,"text":"and the country 's Prime Minister Justin Trudeau described the crash as `` a national tragedy '' .","depth":5},{"id":109,"text":"In a statement , he demanded `` transparency and justice for the families and loved ones of the victims '' .","depth":6},{"id":110,"text":"`` We will continue working with our partners around the world","depth":8},{"id":111,"text":"to ensure a complete and thorough investigation , ''","depth":8},{"id":112,"text":"he said .","depth":7},{"id":113,"text":"Ukrainian President Volodymyr Zelensky called on Iran to punish those responsible .","depth":6},{"id":114,"text":"`` We expect Iran ... to bring the guilty to the courts , ''","depth":7},{"id":115,"text":"he said .","depth":7},{"id":116,"text":"Elsewhere , the president of Ukraine International Airlines said :","depth":7},{"id":117,"text":"`` We did n't doubt for a second","depth":8},{"id":118,"text":"that our crew and our plane could n't be the cause for this horrible crash '' .","depth":8},{"id":119,"text":"`` These were our best guys and girls .","depth":8},{"id":120,"text":"The best , ''","depth":8},{"id":121,"text":"Yevhenii Dykhne said of the nine crew members","depth":8},{"id":122,"text":"who were on board .","depth":8},{"id":123,"text":"Separately , Ukraine 's top security official said","depth":9},{"id":124,"text":"his country 's investigators had gathered conclusive evidence of a missile strike","depth":9},{"id":125,"text":"before Iran admitted responsibility on Saturday .","depth":8},{"id":126,"text":"Oleksiy Danilov showed the BBC 's Jonah Fisher photographs of the aircraft","depth":9},{"id":127,"text":"which","depth":12},{"id":128,"text":"he said","depth":12},{"id":129,"text":"proved","depth":11},{"id":130,"text":"it had been downed by a missile .","depth":10},{"id":131,"text":"The president 's office also released images","depth":9},{"id":132,"text":"which","depth":11},{"id":133,"text":"it said","depth":11},{"id":134,"text":"supported this .","depth":10},{"id":135,"text":"The statement marks a stark departure from the denials of recent days .","depth":7},{"id":136,"text":"As recently as Friday , Iran was insistent","depth":9},{"id":137,"text":"that the plane had not been shot down .","depth":9},{"id":138,"text":"`` The thing","depth":11},{"id":139,"text":"that is clear to us","depth":12},{"id":140,"text":"and that we can say with certainty","depth":12},{"id":141,"text":"is that this plane was not hit by a missile , ''","depth":10},{"id":142,"text":"Iran 's Civil Aviation Organisation","depth":11},{"id":143,"text":"( CAOI )","depth":11},{"id":144,"text":"chief Ali Abedzadeh said .","depth":10},{"id":145,"text":"On Thursday , government spokesman Ali Rabiei accused the US and its allies of `` lying","depth":8},{"id":146,"text":"and engaging in psychological warfare ''","depth":8},{"id":147,"text":"by speculating about the cause of the crash .","depth":7},{"id":148,"text":"But","depth":9},{"id":149,"text":"as evidence","depth":11},{"id":150,"text":"pointing to a missile strike built ,","depth":11},{"id":151,"text":"calls for a transparent investigation grew louder .","depth":10},{"id":152,"text":"Video","depth":11},{"id":153,"text":"obtained by the New York Times","depth":11},{"id":154,"text":"appeared to show a missile streaking across the night sky","depth":11},{"id":155,"text":"and then exploding on contact with a plane .","depth":11},{"id":156,"text":"On Thursday , TV images showed a mechanical digger","depth":11},{"id":157,"text":"helping to clear debris from the crash site ,","depth":11},{"id":158,"text":"raising concerns","depth":11},{"id":159,"text":"that important evidence could have been removed .","depth":11},{"id":160,"text":"In response , Iran promised a full investigation ,","depth":8},{"id":161,"text":"inviting air accident agencies from Ukraine , Canada and the US to take part .","depth":8},{"id":162,"text":"A missile strike on a passenger plane is not unprecedented .","depth":2},{"id":163,"text":"In 1988 , an Iranian aircraft was shot down in error by a US navy warship","depth":4},{"id":164,"text":"and 290 people were killed .","depth":4},{"id":165,"text":"And in 2014 , a Russian-made missile hit a Malaysian civilian airliner over Ukraine ,","depth":4},{"id":166,"text":"killing 298 people .","depth":4}],"relations":[{"parent":333,"left":328,"right":332,"relation":"context","nuclearity":"NS"},{"parent":328,"left":273,"right":327,"relation":"joint","nuclearity":"NN"},{"parent":273,"left":179,"right":272,"relation":"elaboration","nuclearity":"NS"},{"parent":179,"left":173,"right":178,"relation":"elaboration","nuclearity":"NS"},{"parent":173,"left":169,"right":172,"relation":"elaboration","nuclearity":"NS"},{"parent":169,"left":0,"right":168,"relation":"attribution","nuclearity":"SN"},{"parent":168,"left":1,"right":2,"relation":"causal","nuclearity":"NS"},{"parent":172,"left":171,"right":6,"relation":"evaluation","nuclearity":"NS"},{"parent":171,"left":170,"right":5,"relation":"attribution","nuclearity":"NS"},{"parent":170,"left":3,"right":4,"relation":"attribution","nuclearity":"SN"},{"parent":178,"left":176,"right":177,"relation":"adversative","nuclearity":"NN"},{"parent":176,"left":7,"right":175,"relation":"attribution","nuclearity":"SN"},{"parent":175,"left":174,"right":10,"relation":"joint","nuclearity":"NN"},{"parent":174,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":177,"left":11,"right":12,"relation":"attribution","nuclearity":"SN"},{"parent":272,"left":217,"right":271,"relation":"elaboration","nuclearity":"NS"},{"parent":217,"left":213,"right":216,"relation":"elaboration","nuclearity":"NS"},{"parent":213,"left":190,"right":212,"relation":"elaboration","nuclearity":"NS"},{"parent":190,"left":181,"right":189,"relation":"elaboration","nuclearity":"NS"},{"parent":181,"left":180,"right":15,"relation":"elaboration","nuclearity":"NS"},{"parent":180,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":189,"left":185,"right":188,"relation":"elaboration","nuclearity":"NS"},{"parent":185,"left":182,"right":184,"relation":"adversative","nuclearity":"NN"},{"parent":182,"left":16,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":184,"left":18,"right":183,"relation":"explanation","nuclearity