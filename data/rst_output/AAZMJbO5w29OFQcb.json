{"article_id":"AAZMJbO5w29OFQcb","edus":[{"id":0,"text":"As the partial government shutdown reached a record 22nd day on Saturday ,","depth":4},{"id":1,"text":"President Trump blamed Democrats","depth":6},{"id":2,"text":"and called on them to end it","depth":6},{"id":3,"text":"by agreeing to his demand","depth":6},{"id":4,"text":"to fund a border wall .","depth":6},{"id":5,"text":"\" Democrats should come back to Washington","depth":7},{"id":6,"text":"and work","depth":7},{"id":7,"text":"to end the Shutdown ,","depth":7},{"id":8,"text":"while at the same time ending the horrible humanitarian crisis at our Southern Border , \"","depth":7},{"id":9,"text":"Mr. Trump tweeted .","depth":5},{"id":10,"text":"\" I am in the White House","depth":8},{"id":11,"text":"waiting for you ! \"","depth":8},{"id":12,"text":"He warned ,","depth":7},{"id":13,"text":"\" We will be out for a long time","depth":7},{"id":14,"text":"unless the Democrats come back from their ' vacations '","depth":8},{"id":15,"text":"and get back to work .","depth":8},{"id":16,"text":"I am in the White House","depth":6},{"id":17,"text":"ready to sign ! \"","depth":6},{"id":18,"text":"The president also insisted","depth":5},{"id":19,"text":"he has a plan","depth":6},{"id":20,"text":"to end the shutdown ,","depth":6},{"id":21,"text":"pushing back on a news report","depth":5},{"id":22,"text":"that he has no strategy","depth":6},{"id":23,"text":"for resolving the historic impasse .","depth":6},{"id":24,"text":"\" I just watched a Fake reporter from the Amazon Washington Post say","depth":8},{"id":25,"text":"the White House is ' chaotic ,","depth":8},{"id":26,"text":"there does not seem to be a strategy for this Shutdown .","depth":7},{"id":27,"text":"There is no plan. '","depth":6},{"id":28,"text":"The Fakes always like talking Chaos ,","depth":7},{"id":29,"text":"there is NONE , \"","depth":7},{"id":30,"text":"Mr. Trump said .","depth":6},{"id":31,"text":"\" In fact , there ' s almost nobody in the W.H . but me ,","depth":5},{"id":32,"text":"and I do have a plan on the Shutdown .","depth":6},{"id":33,"text":"But to understand that plan","depth":9},{"id":34,"text":"you would have to understand the fact","depth":9},{"id":35,"text":"that I won the election ,","depth":9},{"id":36,"text":"and I promised safety and security for the American people .","depth":10},{"id":37,"text":"Part of that promise was a Wall at the Southern Border .","depth":10},{"id":38,"text":"Elections have consequences ! \"","depth":7},{"id":39,"text":"The shutdown has now surpassed the longest previous closure of 1995-96 .","depth":2},{"id":40,"text":"No new talks are scheduled ,","depth":4},{"id":41,"text":"and about 800,000 federal employees went without paychecks Friday .","depth":5},{"id":42,"text":"Congress approved a measure Friday","depth":6},{"id":43,"text":"to give federal workers back pay","depth":7},{"id":44,"text":"when the shutdown ends .","depth":7},{"id":45,"text":"The president said Friday","depth":5},{"id":46,"text":"he is holding off on declaring a national emergency on the border","depth":6},{"id":47,"text":"because he wants Congress to do its job","depth":7},{"id":48,"text":"and beef up border security .","depth":7},{"id":49,"text":"Mr. Trump said","depth":7},{"id":50,"text":"Democrats \" could solve the Shutdown in 15 minutes ! \"","depth":7},{"id":51,"text":"\" Call your Dem Senator or Congresswoman/man .","depth":7},{"id":52,"text":"Tell them","depth":10},{"id":53,"text":"to get it done !","depth":10},{"id":54,"text":"Humanitarian Crisis , \"","depth":9},{"id":55,"text":"he said .","depth":8},{"id":56,"text":"He asserted","depth":8},{"id":57,"text":"that a border wall is needed","depth":8},{"id":58,"text":"because \" 23 % of Federal inmates are illegal immigrants .","depth":9},{"id":59,"text":"Border arrests are up 240 % . \"","depth":9},{"id":60,"text":"\" In the Great State of Texas , between 2011 & 2018 , there were a total of 292,000 crimes by illegal aliens , 539 murders , 32,000 assaults , 3,426 sexual assaults and 3000 weapons charges .","depth":8},{"id":61,"text":"Democrats come back ! \"","depth":7},{"id":62,"text":"the president said .","depth":7}],"relations":[{"parent":125,"left":101,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":101,"left":80,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":67,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":0,"right":66,"relation":"context","nuclearity":"SN"},{"parent":66,"left":64,"right":65,"relation":"mode","nuclearity":"NS"},{"parent":64,"left":1,"right":2,"relation":"joint","nuclearity":"NN"},{"parent":65,"left":3,"right":4,"relation":"purpose","nuclearity":"NS"},{"parent":79,"left":71,"right":78,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":70,"right":9,"relation":"attribution","nuclearity":"NS"},{"parent":70,"left":68,"right":69,"relation":"purpose","nuclearity":"NS"},{"parent":68,"left":5,"right":6,"relation":"joint","nuclearity":"NN"},{"parent":69,"left":7,"right":8,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":76,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":76,"left":73,"right":75,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":72,"right":12,"relation":"attribution","nuclearity":"NS"},{"parent":72,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":13,"right":74,"relation":"condition","nuclearity":"NS"},{"parent":74,"left":14,"right":15,"relation":"joint","nuclearity":"NN"},{"parent":77,"left":16,"right":17,"relation":"purpose","nuclearity":"NS"},{"parent":100,"left":85,"right":99,"relation":"elaboration","nuclearity":"NS"},{"parent":85,"left":82,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":82,"left":18,"right":81,"relation":"attribution","nuclearity":"SN"},{"parent":81,"left":19,"right":20,"relation":"purpose","nuclearity":"NS"},{"parent":84,"left":21,"right":83,"relation":"attribution","nuclearity