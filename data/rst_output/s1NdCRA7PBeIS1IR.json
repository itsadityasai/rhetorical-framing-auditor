{"article_id":"s1NdCRA7PBeIS1IR","edus":[{"id":0,"text":"The budget crisis","depth":4},{"id":1,"text":"manufactured by Congressional Republicans","depth":4},{"id":2,"text":"will never succeed at halting health care reform ,","depth":3},{"id":3,"text":"but it has already caused long-lasting harm .","depth":3},{"id":4,"text":"It will preserve the deeply damaging spending cuts ,","depth":5},{"id":5,"text":"known as the sequester ,","depth":5},{"id":6,"text":"that are costing jobs","depth":5},{"id":7,"text":"and hurting the lives of millions .","depth":5},{"id":8,"text":"Most of the attention","depth":7},{"id":9,"text":"given to the House ' s temporary spending resolution","depth":7},{"id":10,"text":"has focused on the provision in it","depth":7},{"id":11,"text":"to defund President Obama ' s health law .","depth":7},{"id":12,"text":"The Senate plans to drop that wording ,","depth":6},{"id":13,"text":"and ,","depth":7},{"id":14,"text":"if the House doesn ' t agree ,","depth":8},{"id":15,"text":"the government will shut down on Tuesday .","depth":8},{"id":16,"text":"But","depth":7},{"id":17,"text":"even without the provision ,","depth":8},{"id":18,"text":"the resolution itself is pernicious","depth":8},{"id":19,"text":"because it preserves through mid-December all the blunt and arbitrary sequester cuts","depth":8},{"id":20,"text":"that began in March ,","depth":8},{"id":21,"text":"making it much less likely those cuts will be replaced with more sensible cuts and revenue increases for the rest of the 2014 fiscal year .","depth":7},{"id":22,"text":"The only other change to the resolution","depth":8},{"id":23,"text":"that Senate Democrats will try to make","depth":8},{"id":24,"text":"is to limit the duration of the stopgap resolution to mid-November ,","depth":7},{"id":25,"text":"hoping to use the next six weeks","depth":7},{"id":26,"text":"to negotiate a more responsible budget .","depth":7},{"id":27,"text":"Although many Democrats in both chambers would prefer a resolution","depth":5},{"id":28,"text":"that repudiates the sequester cuts now ,","depth":5},{"id":29,"text":"they are resigned to what is known as a \" clean C.R. , \" a continuing resolution","depth":6},{"id":30,"text":"that simply continues the abysmally low spending levels of 2013 into the first weeks or months of fiscal 2014 ,","depth":7},{"id":31,"text":"which begins on Tuesday .","depth":7},{"id":32,"text":"To insist on a fight would mean Democrats would have to bear partial responsibility for a government shutdown","depth":7},{"id":33,"text":"if a continuing resolution is not approved in time","depth":7},{"id":34,"text":"- a burden","depth":7},{"id":35,"text":"now borne entirely by Republicans","depth":8},{"id":36,"text":"obsessed with stopping health reform .","depth":8},{"id":37,"text":"But any hope","depth":5},{"id":38,"text":"that Congress will use the stopgap period","depth":6},{"id":39,"text":"to negotiate a better budget","depth":6},{"id":40,"text":"is slim .","depth":4},{"id":41,"text":"It has already been six months","depth":4},{"id":42,"text":"since the Senate passed a realistic budget","depth":6},{"id":43,"text":"to replace the sequester with cuts of $ 975 billion , mostly from agriculture supports and efficiencies in medical spending .","depth":6},{"id":44,"text":"It also raises $ 1 trillion in revenue","depth":6},{"id":45,"text":"by removing tax breaks","depth":7},{"id":46,"text":"enjoyed by corporations and wealthy individuals .","depth":7}],"relations":[{"parent":93,"left":54,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":54,"left":49,"right":53,"relation":"adversative","nuclearity":"NN"},{"parent":49,"left":48,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":48,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":53,"left":3,"right":52,"relation":"explanation","nuclearity":"NS"},{"parent":52,"left":50,"right":51,"relation":"elaboration","nuclearity":"NS"},{"parent":50,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":51,"left":6,"right":7,"relation":"joint","nuclearity":"NN"},{"parent":92,"left":82,"right":91,"relation":"adversative","nuclearity":"SN"},{"parent":82,"left":72,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":61,"right":71,"relation":"adversative","nuclearity":"SN"},{"parent":61,"left":57,"right":60,"relation":"context","nuclearity":"SN"},{"parent":57,"left":55,"right":56,"relation":"same-unit","nuclearity":"NN"},{"parent":55,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":56,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":12,"right":59,"relation":"joint","nuclearity":"NN"},{"parent":59,"left":13,"right":58,"relation":"same-unit","nuclearity":"NN"},{"parent":58,"left":14,"right":15,"relation":"condition","nuclearity":"SN"},{"parent":71,"left":66,"right":70,"relation":"joint","nuclearity":"NN"},{"parent":66,"left":63,"right":65,"relation":"explanation","nuclearity":"NS"},{"parent":63,"left":16,"right":62,"relation":"same-unit","nuclearity":"NN"},{"parent":62,"left":17,"right":18,"relation":"adversative","nuclearity":"SN"},{"parent":65,"left":64,"right":21,"relation":"causal","nuclearity":"NS"},{"parent":64,"left":19,"right":20,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":68,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":67,"right":24,"relation":"same-unit","nuclearity":"NN"},{"parent":67,"left":22,"right":23,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":25,"right":26,"relation":"purpose","nuclearity":"NS"},{"parent":81,"left":73,"right":80,"relation":"adversative","nuclearity":"SN"},{"parent":73,"left":27,"right":28,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":75,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":29,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":30,"right":31,"relation":"elaboration","nucle