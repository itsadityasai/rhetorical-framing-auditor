lation":"context","nuclearity":"SN"},{"parent":278,"left":117,"right":118,"relation":"explanation","nuclearity":"SN"},{"parent":286,"left":283,"right":285,"relation":"attribution","nuclearity":"NS"},{"parent":283,"left":281,"right":282,"relation":"joint","nuclearity":"NN"},{"parent":281,"left":120,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":282,"left":122,"right":123,"relation":"explanation","nuclearity":"SN"},{"parent":285,"left":284,"right":126,"relation":"same-unit","nuclearity":"NN"},{"parent":284,"left":124,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":297,"right":312,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":294,"right":296,"relation":"joint","nuclearity":"NN"},{"parent":294,"left":127,"right":293,"relation":"attribution","nuclearity":"SN"},{"parent":293,"left":128,"right":129,"relation":"purpose","nuclearity":"NS"},{"parent":296,"left":130,"right":295,"relation":"attribution","nuclearity":"SN"},{"parent":295,"left":131,"right":132,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":301,"right":311,"relation":"elaboration","nuclearity":"NS"},{"parent":301,"left":300,"right":137,"relation":"attribution","nuclearity":"NS"},{"parent":300,"left":133,"right":299,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":298,"right":136,"relation":"joint","nuclearity":"NN"},{"parent":298,"left":134,"right":135,"relation":"attribution","nuclearity":"SN"},{"parent":311,"left":307,"right":310,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":302,"right":306,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":138,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":305,"right":144,"relation":"attribution","nuclearity":"NS"},{"parent":305,"left":303,"right":304,"relation":"joint","nuclearity":"NN"},{"parent":303,"left":140,"right":141,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":142,"right":143,"relation":"elaboration","nuclearity":"NS"},{"parent":310,"left":145,"right":309,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":146,"right":308,"relation":"joint","nuclearity":"NN"},{"parent":308,"left":147,"right":148,"relation":"elaboration","nuclearity":"NS"},{"parent":333,"left":320,"right":332,"relation":"elaboration","nuclearity":"NS"},{"parent":320,"left":149,"right":319,"relation":"elaboration","nuclearity":"NS"},{"parent":319,"left":316,"right":318,"relation":"elaboration","nuclearity":"NS"},{"parent":316,"left":150,"right":151,"relation":"elaboration","nuclearity":"NS"},{"parent":318,"left":152,"right":317,"relation":"adversative","nuclearity":"SN"},{"parent":317,"left":153,"right":154,"relation":"elaboration","nuclearity":"NS"},{"parent":332,"left":330,"right":331,"relation":"elaboration","nuclearity":"NS"},{"parent":330,"left":323,"right":329,"relation":"elaboration","nuclearity":"NS"},{"parent":323,"left":155,"right":322,"relation":"attribution","nuclearity":"SN"},{"parent":322,"left":321,"right":158,"relation":"adversative","nuclearity":"SN"},{"parent":321,"left":156,"right":157,"relation":"attribution","nuclearity":"SN"},{"parent":329,"left":324,"right":328,"relation":"same-unit","nuclearity":"NN"},{"parent":324,"left":159,"right":160,"relation":"mode","nuclearity":"NS"},{"parent":328,"left":161,"right":327,"relation":"elaboration","nuclearity":"NS"},{"parent":327,"left":162,"right":326,"relation":"joint","nuclearity":"NN"},{"parent":326,"left":163,"right":325,"relation":"same-unit","nuclearity":"NN"},{"parent":325,"left":164,"right":165,"relation":"attribution","nuclearity":"SN"},{"parent":331,"left":166,"right":167,"relation":"attribution","nuclearity":"NS"}]}