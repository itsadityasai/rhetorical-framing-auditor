{"article_id":"frGmgETYrCMm74Sb","edus":[{"id":0,"text":"U.S. District Judge orders homophobic Kentucky clerk to explain","depth":5},{"id":1,"text":"why she should n't be fined or jailed for contempt","depth":5},{"id":2,"text":"Her `` old redneck hillbilly '' husband tells reporter","depth":6},{"id":3,"text":"he 's a fan of 2nd Amendment :","depth":6},{"id":4,"text":"`` Do n't come knocking on my door ''","depth":5},{"id":5,"text":"Kim Davis","depth":7},{"id":6,"text":"-- the Rowan County , Kentucky Clerk","depth":8},{"id":7,"text":"who earlier today brazenly defied the Supreme Court 's order","depth":9},{"id":8,"text":"to issue marriage licenses","depth":10},{"id":9,"text":"citing `` God 's authority '' --","depth":10},{"id":10,"text":"has been ordered to stand before U.S. District Judge David Bunning on Thursday","depth":7},{"id":11,"text":"and explain why she should n't be jailed and fined for her actions .","depth":7},{"id":12,"text":"In a statement","depth":9},{"id":13,"text":"released","depth":10},{"id":14,"text":"after she refused , for the fourth time , to issue David Moore and David Ermold a marriage license ,","depth":10},{"id":15,"text":"Davis said","depth":8},{"id":16,"text":"that","depth":9},{"id":17,"text":"`` [ t ] o issue a marriage license","depth":11},{"id":18,"text":"which conflicts with God 's definition of marriage ,","depth":12},{"id":19,"text":"with my name affixed to the certificate ,","depth":12},{"id":20,"text":"would violate my conscience .","depth":10},{"id":21,"text":"It is not a light issue for me .","depth":9},{"id":22,"text":"It is a Heaven or Hell decision . ''","depth":9},{"id":23,"text":"`` I was elected by the people","depth":9},{"id":24,"text":"to serve as the County Clerk , ''","depth":9},{"id":25,"text":"she continued ,","depth":8},{"id":26,"text":"and `` I intend to continue to serve the people of Rowan County ,","depth":8},{"id":27,"text":"but I can not violate my conscience . ''","depth":8},{"id":28,"text":"That she is an elected official has become a point of contention ,","depth":7},{"id":29,"text":"because as such she ca n't be fired","depth":8},{"id":30,"text":"for refusing to abide by the Supreme Court 's ruling .","depth":8},{"id":31,"text":"Removing her from office would entail impeachment proceedings ,","depth":7},{"id":32,"text":"which will either have to wait until the next legislative session","depth":8},{"id":33,"text":"or require the calling of a special session ,","depth":9},{"id":34,"text":"which could be prohibitively expensive .","depth":9},{"id":35,"text":"In the meantime , no one in Rowan County will be issued a marriage licenses .","depth":5},{"id":36,"text":"Lawyers","depth":6},{"id":37,"text":"representing the four couples","depth":7},{"id":38,"text":"who were denied licenses","depth":7},{"id":39,"text":"told the Associated Press","depth":5},{"id":40,"text":"that `` [ s ] ince","depth":4},{"id":41,"text":"Defendant Davis continues to collect compensation from the Commonwealth for duties","depth":5},{"id":42,"text":"she fails to perform ,","depth":5},{"id":43,"text":"'' they want Judge Bunning to `` impose financial penalties sufficiently serious and increasingly onerous ''","depth":5},{"id":44,"text":"-- but that they are not seeking for her to be jailed for contempt .","depth":5},{"id":45,"text":"The scene at Davis ' office this morning was raucous ,","depth":3},{"id":46,"text":"with supporters of both side lining the walkway into it","depth":4},{"id":47,"text":"and occupying the tiny building .","depth":4},{"id":48,"text":"`` Praise the Lord ! ''","depth":6},{"id":49,"text":"yelled one ,","depth":6},{"id":50,"text":"`` Stand your ground ! ''","depth":5},{"id":51,"text":"Another demanded Davis","depth":5},{"id":52,"text":"`` Do your job ! ''","depth":5},{"id":53,"text":"One of her supporters was her husband ,","depth":5},{"id":54,"text":"who noted","depth":6},{"id":55,"text":"that his family has received death threats","depth":7},{"id":56,"text":"and warned people","depth":8},{"id":57,"text":"that he 's a firm believer in the Second Amendment .","depth":8},{"id":58,"text":"`` I 'm an old redneck hillbilly , ''","depth":6},{"id":59,"text":"he warned .","depth":6},{"id":60,"text":"`` That 's all","depth":7},{"id":61,"text":"I 've got to say .","depth":7},{"id":62,"text":"Do n't come knocking on my door . ''","depth":6}],"relations":[{"parent":125,"left":107,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":107,"left":98,"right":106,"relation":"elaboration","nuclearity":"NS"},{"parent":98,"left":67,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":64,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":0,"right":1,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":65,"right":4,"relation":"organization","nuclearity":"SN"},{"parent":65,"left":2,"right":3,"relation":"attribution","nuclearity":"SN"},{"parent":97,"left":89,"right":96,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":73,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":71,"right":72,"relation":"same-unit","nuclearity":"NN"},{"parent":71,"left":5,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":6,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":7,"right":68,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":10,"right":11,"relation":"joint","nuclearity":"NN"},{"parent":88,"left":83,"right":87,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":76,"right":82,"relation":"attribution","nuclearity":"SN"},{"parent":76,"left":75,"right":15,"relation":"same-unit","nuclearity":"NN"},{"parent":75,"left":12,"right":74,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":13,"right":14,"relation":"context","nuclearity":"NS"},{"parent":82,"left":80,"right":81,"relation":"evaluation","nuclearity":"NS"},{"par