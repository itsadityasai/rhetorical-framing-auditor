arity":"NS"},{"parent":237,"left":236,"right":44,"relation":"same-unit","nuclearity":"NN"},{"parent":236,"left":42,"right":43,"relation":"elaboration","nuclearity":"NS"},{"parent":240,"left":47,"right":48,"relation":"purpose","nuclearity":"NS"},{"parent":253,"left":247,"right":252,"relation":"elaboration","nuclearity":"NS"},{"parent":247,"left":243,"right":246,"relation":"elaboration","nuclearity":"NS"},{"parent":243,"left":49,"right":242,"relation":"elaboration","nuclearity":"NS"},{"parent":242,"left":50,"right":51,"relation":"attribution","nuclearity":"SN"},{"parent":246,"left":244,"right":245,"relation":"joint","nuclearity":"NN"},{"parent":244,"left":52,"right":53,"relation":"attribution","nuclearity":"SN"},{"parent":245,"left":54,"right":55,"relation":"attribution","nuclearity":"SN"},{"parent":252,"left":56,"right":251,"relation":"context","nuclearity":"NS"},{"parent":251,"left":57,"right":250,"relation":"elaboration","nuclearity":"NS"},{"parent":250,"left":249,"right":61,"relation":"purpose","nuclearity":"NS"},{"parent":249,"left":248,"right":60,"relation":"same-unit","nuclearity":"NN"},{"parent":248,"left":58,"right":59,"relation":"attribution","nuclearity":"NS"},{"parent":258,"left":256,"right":257,"relation":"adversative","nuclearity":"NN"},{"parent":256,"left":62,"right":63,"relation":"attribution","nuclearity":"SN"},{"parent":257,"left":64,"right":65,"relation":"attribution","nuclearity":"SN"},{"parent":284,"left":273,"right":283,"relation":"joint","nuclearity":"NN"},{"parent":273,"left":263,"right":272,"relation":"adversative","nuclearity":"NN"},{"parent":263,"left":66,"right":262,"relation":"attribution","nuclearity":"SN"},{"parent":262,"left":67,"right":261,"relation":"joint","nuclearity":"NN"},{"parent":261,"left":68,"right":260,"relation":"attribution","nuclearity":"SN"},{"parent":260,"left":69,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":272,"left":266,"right":271,"relation":"elaboration","nuclearity":"NS"},{"parent":266,"left":71,"right":265,"relation":"elaboration","nuclearity":"NS"},{"parent":265,"left":72,"right":264,"relation":"elaboration","nuclearity":"NS"},{"parent":264,"left":73,"right":74,"relation":"mode","nuclearity":"NS"},{"parent":271,"left":75,"right":270,"relation":"attribution","nuclearity":"SN"},{"parent":270,"left":269,"right":80,"relation":"evaluation","nuclearity":"NS"},{"parent":269,"left":267,"right":268,"relation":"organization","nuclearity":"SN"},{"parent":267,"left":76,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":268,"left":78,"right":79,"relation":"joint","nuclearity":"NN"},{"parent":283,"left":279,"right":282,"relation":"elaboration","nuclearity":"NS"},{"parent":279,"left":276,"right":278,"relation":"elaboration","nuclearity":"NS"},{"parent":276,"left":81,"right":275,"relation":"elaboration","nuclearity":"NS"},{"parent":275,"left":82,"right":274,"relation":"joint","nuclearity":"NN"},{"parent":274,"left":83,"right":84,"relation":"elaboration","nuclearity":"NS"},{"parent":278,"left":277,"right":87,"relation":"attribution","nuclearity":"NS"},{"parent":277,"left":85,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":282,"left":281,"right":91,"relation":"evaluation","nuclearity":"NS"},{"parent":281,"left":88,"right":280,"relation":"elaboration","nuclearity":"NS"},{"parent":280,"left":89,"right":90,"relation":"attribution","nuclearity":"SN"},{"parent":389,"left":327,"right":388,"relation":"elaboration","nuclearity":"NS"},{"parent":327,"left":287,"right":326,"relation":"joint","nuclearity":"NN"},{"parent":287,"left":92,"right":286,"relation":"attribution","nuclearity":"SN"},{"parent":286,"left":93,"right":94,"relation":"joint","nuclearity":"NN"},{"parent":326,"left":306,"right":325,"relation":"elaboration","nuclearity":"NS"},{"parent":306,"left":292,"right":305,"relation":"adversative","nuclearity":"SN"},{"parent":292,"left":289,"right":291,"relation":"elaboration","nuclearity":"NS"},{"parent":289,"left":95,"right":288,"relation":"attribution","nuclearity":"SN"},{"parent":288,"left":96,"right":97,"relation":"elaboration","nuclearity":"NS"},{"parent":291,"left":98,"right":290,"relation":"attribution","nuclearity":"SN"},{"parent":290,"left":99,"right":100,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":101,"right":304,"relation":"elaboration","nuclearity":"NS"},{"parent":304,"left":297,"right":303,"relation":"elaboration","nuclearity":"NS"},{"parent":297,"left":293,"right":296,"relation":"elaboration","nuclearity":"NS"},{"parent":293,"left":102,"right":103,"relation":"elaboration","nuclearity":"NS"},{"parent":296,"left":104,"right":295,"relation":"joint","nuclearity":"NN"},{"parent":295,"left":105,"right":294,"relation":"context","nuclearity":"NS"},{"parent":294,"left":106,"right":107,"relation":"elaboration","nuclearity":"NS"},{"parent":303,"left":301,"right":302,"relation":"joint","nuclearity":"NN"},{"parent":301,"left":300,"right":112,"relation":"attribution","nuclearity":"NS"},{"parent":300,"left":298,"right":299,"relation":"elaboration","nuclearity":"NS"},{"parent":298,"left":108,"right":109,"relation":"elaboration","nuclearity":"NS"},{"parent":299,"left":110,"right":111,"relation":"elaboration","nuclearity":"NS"},{"parent":302,"left":113,"right":114,"relation":"attribution","nuclearity":"SN"},{"parent":325,"left":313,"right":324,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":115,"right":312,"relation":"joint","nuclearity":"NN"},{"parent":312,"left":307,"right":311,"relation":"joint","nuclearity":"NN"},{"parent":307,"left":116,"right":117,"relation":"attribution","nuclearity":"SN"},{"parent":311,"left":118,"right":310,"relation":"attribution","nuclearity":"SN"},{"parent":310,"left":119,"right":309,"relation":"elaboration","nuclearity":"NS"},{"parent":309,"left":120,"right":308,"relation":"joint","nuclearity":"NN"},{"parent":308,"left":121,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":324,"left":317,"right":323,"relation":"elaboration","nucle