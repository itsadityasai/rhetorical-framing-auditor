{"article_id":"GWIpUKMRvSxkz0Px","edus":[{"id":0,"text":"Ferguson , Missouri","depth":1},{"id":1,"text":"( CNN ) --","depth":6},{"id":2,"text":"Hours after federal civil rights investigators and the FBI opened an inquiry into the death of a teenager","depth":8},{"id":3,"text":"shot by a police officer in Ferguson , Missouri ,","depth":8},{"id":4,"text":"violence flared again in the St. Louis suburb .","depth":7},{"id":5,"text":"Police Chief Thomas Jackson told CNN","depth":8},{"id":6,"text":"shots were fired Monday night in Ferguson ,","depth":9},{"id":7,"text":"and police fired tear gas","depth":10},{"id":8,"text":"to disperse a crowd","depth":11},{"id":9,"text":"that had gathered in an area","depth":12},{"id":10,"text":"where looting occurred Sunday .","depth":12},{"id":11,"text":"`` Officers were brought in","depth":10},{"id":12,"text":"to quell the hostilities , ''","depth":10},{"id":13,"text":"he said .","depth":9},{"id":14,"text":"`` Tear gas was deployed . ''","depth":8},{"id":15,"text":"The Saturday-night shooting ,","depth":9},{"id":16,"text":"which left 18-year-old Michael Brown dead ,","depth":9},{"id":17,"text":"has fueled rising tensions in the town of 21,000","depth":8},{"id":18,"text":"and sparked national debate .","depth":7},{"id":19,"text":"One side says","depth":7},{"id":20,"text":"the African-American teenager was surrendering ,","depth":9},{"id":21,"text":"his hands in the air","depth":10},{"id":22,"text":"to show","depth":11},{"id":23,"text":"he was unarmed ,","depth":11},{"id":24,"text":"when the officer opened fire .","depth":8},{"id":25,"text":"Authorities counter","depth":7},{"id":26,"text":"that Brown had attacked the officer in his car","depth":8},{"id":27,"text":"and tried to take his gun .","depth":8},{"id":28,"text":"After a vigil for the teen devolved into chaos Sunday","depth":8},{"id":29,"text":"when violence and looting broke out among some protesters ,","depth":8},{"id":30,"text":"NAACP President Cornell William Brooks called Monday for people","depth":10},{"id":31,"text":"protesting Brown 's death","depth":10},{"id":32,"text":"to do so nonviolently .","depth":9},{"id":33,"text":"`` We have seen young people giving in to violence and frustration and rage .","depth":11},{"id":34,"text":"It may be inexcusable .","depth":12},{"id":35,"text":"It is not unexpected , ''","depth":12},{"id":36,"text":"Brooks told reporters .","depth":10},{"id":37,"text":"`` But I say to my young brothers and sisters ,","depth":11},{"id":38,"text":"note the young man","depth":13},{"id":39,"text":"whose rage is your heart ,","depth":13},{"id":40,"text":"note","depth":13},{"id":41,"text":"that he was nonviolent .","depth":14},{"id":42,"text":"He never got into a fight .","depth":14},{"id":43,"text":"If you want to honor his memory ,","depth":11},{"id":44,"text":"honor his memory","depth":12},{"id":45,"text":"by seeking justice nonviolently . ''","depth":12},{"id":46,"text":"Witnesses to Brown 's shooting say","depth":10},{"id":47,"text":"he was unarmed","depth":11},{"id":48,"text":"and had his hands in the air","depth":12},{"id":49,"text":"when the police officer shot him .","depth":12},{"id":50,"text":"Authorities tell a different story .","depth":9},{"id":51,"text":"St. Louis County Police Chief Jon Belmar says","depth":12},{"id":52,"text":"the officer tried to get out of his vehicle just before the shooting ,","depth":13},{"id":53,"text":"but Brown pushed him back into his car .","depth":13},{"id":54,"text":"Brown `` physically assaulted '' the officer ,","depth":14},{"id":55,"text":"Belmar said ,","depth":14},{"id":56,"text":"and the teen tried to get the officer 's weapon .","depth":13},{"id":57,"text":"Brown was shot about 35 feet from the vehicle ,","depth":14},{"id":58,"text":"the chief said ,","depth":14},{"id":59,"text":"declining to provide more details .","depth":13},{"id":60,"text":"The officer 's name has not been released by authorities .","depth":10},{"id":61,"text":"`` The genesis of this was a physical confrontation , ''","depth":11},{"id":62,"text":"Belmar said ,","depth":11},{"id":63,"text":"adding","depth":11},{"id":64,"text":"that his department has been called in","depth":12},{"id":65,"text":"to conduct an independent investigation .","depth":12},{"id":66,"text":"The Ferguson Police Department said","depth":9},{"id":67,"text":"its cars are not equipped with dashboard cameras .","depth":9},{"id":68,"text":"Shell casings","depth":11},{"id":69,"text":"collected at the scene","depth":11},{"id":70,"text":"were from the officer 's weapon ,","depth":10},{"id":71,"text":"Belmar said .","depth":9},{"id":72,"text":"Monday , U.S. Attorney General Eric Holder said","depth":7},{"id":73,"text":"the shooting `` deserves a fulsome review '' by federal investigators .","depth":7},{"id":74,"text":"`` At every step , we will work with the local investigators ,","depth":8},{"id":75,"text":"who should be prepared to complete a thorough , fair investigation in their own right .","depth":8},{"id":76,"text":"I will continue to receive regular updates on this matter in the coming days , ''","depth":8},{"id":77,"text":"Holder said in a statement .","depth":8},{"id":78,"text":"`` Aggressively pursuing investigations such as this is critical","depth":6},{"id":79,"text":"for preserving trust between law enforcement and the communities","depth":7},{"id":80,"text":"they serve . ''","depth":7},{"id":81,"text":"The lawyer","depth":11},{"id":82,"text":"representing Brown 's parents","depth":11},{"id":83,"text":"called Monday for a swift investigation .","depth":10},{"id":84,"text":"`` We want this investigation to be done fairly ,","depth":11},{"id":85,"text":"and we make a demand to the Justice Department to come in","depth":12},{"id":86,"text":"and help restore trust and confidence in the process of equal justice . ...","depth":12},{"id":87,"text":"This family is very distrustful .","depth":12},{"id":88,"text":"This community is very distrustful , ''","depth":12},{"id":89,"text":"attorney Benjamin Crump told reporters ,","depth":12},{"id":90,"text":"calling for witnesses to come forward .","depth":12},{"id":91,"text":"`` No violence , just justice , ''","depth":10},{"id":92,"text":"the teen 's mother , Lesley McSpadden , told reporters .","depth":10},{"id":93,"text":"McSpadden said","depth":11},{"id":94,"text":"her son recently graduated from high school","depth":12},{"id":95,"text":"and was supposed to start college Monday .","depth":12},{"id":96,"text":"`` We ca n't even celebrate , ''","depth":12},{"id":97,"text":"she said .","depth":12},{"id":98,"text":"`` We 've got to plan a funeral . ''","depth":11},{"id":99,"text":"Standing beside the teen 's family ,","depth":11},{"id":100,"text":"Brooks said","depth":11},{"id":101,"text":"the NAACP is committed to determining what happened .","depth":10},{"id":102,"text":"`` We are committed to this family ,","depth":11},{"id":103,"text":"committed to seeking justice ,","depth":12},{"id":104,"text":"committed to being a presence , day-in and day-out , ''","depth":12},{"id":105,"text":"he told reporters .","depth":10},{"id":106,"text":"`` Obviously , the events of last night are not indicative of who we are , ''","depth":10},{"id":107,"text":"Ferguson Mayor James Knowles said on CNN on Monday morning ,","depth":10},{"id":108,"text":"adding","depth":10},{"id":109,"text":"that Sunday night 's chaos was `` not constructive ''","depth":11},{"id":110,"text":"and was only `` bringing down the community . ''","depth":11},{"id":111,"text":"St. Louis County Police said","depth":10},{"id":112,"text":"32 people were arrested","depth":11},{"id":113,"text":"and shots were fired at police .","depth":11},{"id":114,"text":"Monday , St. Louis County Prosecuting Attorney Robert McCulloch said","depth":10},{"id":115,"text":"charges had been filed against about 10 people in connection with burglaries of several businesses .","depth":10},{"id":116,"text":"`` What occurred last night , the mob action ,","depth":11},{"id":117,"text":"we know","depth":11},{"id":118,"text":"certainly is not representative of what 's going on","depth":11},{"id":119,"text":"and what the people in the neighborhood necessarily think , ''","depth":11},{"id":120,"text":"he said .","depth":9},{"id":121,"text":"Flanked by several from the community Sunday ,","depth":12},{"id":122,"text":"McSpadden was","depth":12},{"id":123,"text":"McSpadden was emotional","depth":13},{"id":124,"text":"as she shouted into a television reporter 's microphone .","depth":13},{"id":125,"text":"`` You took my son away from me !","depth":14},{"id":126,"text":"You know how hard it was for me to get him to stay in school","depth":18},{"id":127,"text":"and graduate ?","depth":18},{"id":128,"text":"You know how many black men graduate ?","depth":18},{"id":129,"text":"Not many ! ''","depth":18},{"id":130,"text":"she said .","depth":16},{"id":131,"text":"`` Because you bring them down to this type of level","depth":17},{"id":132,"text":"where they feel","depth":18},{"id":133,"text":"they do n't got nothing","depth":19},{"id":134,"text":"to live for anyway !","depth":19},{"id":135,"text":"( They feel )","depth":17},{"id":136,"text":"they gon na try to take me out anyway ! '' `","depth":17},{"id":137,"text":"` We will stay out here","depth":15},{"id":138,"text":"as long as you are ! ''","depth":15},{"id":139,"text":"they screamed at officers .","depth":14},{"id":140,"text":"Many of the officers appeared stoic ,","depth":13},{"id":141,"text":"watching young men kneel before them","depth":14},{"id":142,"text":"and raise their hands up","depth":15},{"id":143,"text":"to symbolize surrender ,","depth":15},{"id":144,"text":"but one officer can be heard on video","depth":13},{"id":145,"text":"yelling back ,","depth":14},{"id":146,"text":"calling protesters `` animals . ''","depth":14},{"id":147,"text":"Some in Ferguson are demanding","depth":13},{"id":148,"text":"that the name of the officer","depth":15},{"id":149,"text":"who shot the teenager","depth":15},{"id":150,"text":"be released .","depth":14},{"id":151,"text":"Monday afternoon , Jackson","depth":16},{"id":152,"text":"-- the police chief --","depth":16},{"id":153,"text":"said","depth":15},{"id":154,"text":"he plans to release the name in the next 24 hours .","depth":14},{"id":155,"text":"Authorities want to make sure","depth":15},{"id":156,"text":"the officer is in a safe location ,","depth":15},{"id":157,"text":"he said .","depth":14},{"id":158,"text":"He was asked about the officer","depth":11},{"id":159,"text":"who called protesters `` animals . ''","depth":11},{"id":160,"text":"`` The officers did their best .","depth":13},{"id":161,"text":"They 're only human , ''","depth":13},{"id":162,"text":"Knowles responded ,","depth":12},{"id":163,"text":"adding","depth":12},{"id":164,"text":"that not every police officer present was from the Ferguson department .","depth":12},{"id":165,"text":"Sunday 's gathering became more intense","depth":10},{"id":166,"text":"as some people broke windows at a store","depth":12},{"id":167,"text":"and began taking things from it .","depth":12},{"id":168,"text":"They threw rocks and bottles .","depth":12},{"id":169,"text":"Gunshots rang out .","depth":12},{"id":170,"text":"Antonio French , an alderman in St. Louis , said","depth":12},{"id":171,"text":"a QuikTrip gas station was looted","depth":13},{"id":172,"text":"and an ATM dragged out .","depth":13},{"id":173,"text":"`` This QuikTrip is where things started","depth":16},{"id":174,"text":"( Saturday )","depth":16},{"id":175,"text":"with this case ,","depth":15},{"id":176,"text":"based on various accounts , ''","depth":14},{"id":177,"text":"French said .","depth":13},{"id":178,"text":"The slain teenager and a friend were `` accused of stealing gum from the store or some sort of cigarettes , ''","depth":13},{"id":179,"text":"the alderman said .","depth":13},{"id":180,"text":"`` People have a lot of anger","depth":14},{"id":181,"text":"and are frustrated , ''","depth":14},{"id":182,"text":"French said .","depth":13},{"id":183,"text":"`` They do n't have recourse in the system ,","depth":14},{"id":184,"text":"and it happens often in this country ,","depth":14},{"id":185,"text":"and it has boiled over .","depth":13},{"id":186,"text":"I think","depth":12},{"id":187,"text":"people are angry","depth":13},{"id":188,"text":"and looking for a reason","depth":14},{"id":189,"text":"to let it out tonight . ''","depth":14},{"id":190,"text":"Knowles said","depth":8},{"id":191,"text":"he wants to let the independent investigation into Brown 's death take its course .","depth":8},{"id":192,"text":"He plans to meet with Brown 's parents soon","depth":9},{"id":193,"text":"and will meet with clergy in Ferguson and African-American leadership in the town .","depth":9},{"id":194,"text":"Whatever the investigation 's findings ,","depth":10},{"id":195,"text":"`` we will deal with that , ''","depth":10},{"id":196,"text":"he said .","depth":9},{"id":197,"text":"An autopsy will determine","depth":10},{"id":198,"text":"how many times Brown was shot .","depth":10},{"id":199,"text":"The medical examiner for St. Louis County , Mary Case , said Monday afternoon","depth":11},{"id":200,"text":"the autopsy is complete ,","depth":11},{"id":201,"text":"but she would not give details","depth":11},{"id":202,"text":"and said","depth":12},{"id":203,"text":"St. Louis County police will release the information .","depth":12},{"id":204,"text":"On the number of times Brown might have been shot , Belmar has said ,","depth":10},{"id":205,"text":"`` It was more than just a couple . ''","depth":10},{"id":206,"text":"`` We do n't know","depth":12},{"id":207,"text":"what happened ,","depth":13},{"id":208,"text":"and there are lots of conflicting stories , ''","depth":13},{"id":209,"text":"Knowles said .","depth":11},{"id":210,"text":"`` Unfortunately , there will have to be some time","depth":12},{"id":211,"text":"taken","depth":13},{"id":212,"text":"to understand what happened .","depth":13},{"id":213,"text":"Hopefully , we will get to an understanding ,","depth":12},{"id":214,"text":"and justice will be served . ''","depth":12},{"id":215,"text":"The officer","depth":11},{"id":216,"text":"who shot Brown","depth":11},{"id":217,"text":"is on paid administrative leave during the investigation","depth":10},{"id":218,"text":"and will be available","depth":10},{"id":219,"text":"to talk to county homicide detectives .","depth":10},{"id":220,"text":"He has been with the force for six years","depth":10},{"id":221,"text":"and will be required to undergo two psychological evaluations","depth":11},{"id":222,"text":"before returning to duty ,","depth":11},{"id":223,"text":"Belmar said .","depth":9},{"id":224,"text":"Crump ,","depth":8},{"id":225,"text":"who also handled the case of Trayvon Martin in Florida ,","depth":8},{"id":226,"text":"said Monday","depth":7},{"id":227,"text":"that Brown 's family is `` devastated ''","depth":7},{"id":228,"text":"and does n't believe","depth":8},{"id":229,"text":"that the teenager got into a physical confrontation with police .","depth":8},{"id":230,"text":"Martin , 17 , was killed in 2012 by a Florida neighborhood watch organizer","depth":6},{"id":231,"text":"who was acquitted last year of murder charges .","depth":6},{"id":232,"text":"The high-profile case sparked a heated nationwide discussion of race as well as debate over Florida 's `` stand your ground '' law .","depth":4},{"id":233,"text":"Monday , Crump said","depth":5},{"id":234,"text":"Brown 's shooting once again highlights `` the senseless death of a young boy of color at the hands of people","depth":6},{"id":235,"text":"who are supposed to protect and serve them . ''","depth":6},{"id":236,"text":"`` Their son was doing all the right things , ''","depth":6},{"id":237,"text":"Crump said .","depth":6},{"id":238,"text":"`` Graduating from high school ,","depth":7},{"id":239,"text":"never been in trouble .","depth":7},{"id":240,"text":"And for this to happen ,","depth":8},{"id":241,"text":"for him to be killed in broad daylight ...","depth":8},{"id":242,"text":"they want answers just like everybody else in the community . ''","depth":7}],"relations":[{"parent":485,"left":0,"right":484,"relation":"organization","nuclearity":"SN"},{"parent":484,"left":465,"right":483,"relation":"elaboration","nuclearity":"NS"},{"parent":465,"left":313,"right":464,"relation":"elaboration","nuclearity":"NS"},{"parent":313,"left":260,"right":312,"relation":"elaboration","nuclearity":"NS"},{"parent":260,"left":246,"right":259,"relation":"elaboration","nuclearity":"NS"},{"parent":246,"left":1,"right":245,"relation":"attribution","nuclearity":"SN"},{"parent":245,"left":244,"right":4,"relation":"context","nuclearity":"SN"},{"parent":244,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":259,"left":255,"right":258,"relation":"causal","nuclearity":"NS"},{"parent":255,"left":251,"right":254,"relation":"elaboration","nuclearity":"NS"},{"parent":251,"left":5,"right":250,"relation":"attribution","nuclearity":"SN"},{"parent":250,"left":6,"right":249,"relation":"joint","nuclearity":"NN"},{"parent":249,"left":7,"right":248,"relation":"purpose","nuclearity":"NS"},{"parent":248,"left":8,"right":247,"relation":"elaboration","nuclearity":"NS"},{"parent":247,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":254,"left":253,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":253,"left":252,"right":13,"relation":"attribution","nuclearity":"NS"},{"parent":252,"left":11,"right":12,"relation":"purpose","nuclearity":"NS"},{"parent":258,"left":257,"right":18,"relation":"joint","nuclearity":"NN"},{"parent":257,"left":256,"right":17,"relation":"same-unit","nuclearity":"NN"},{"parent":256,"left":15,"right":16,"relation":"elaboration","nuclearity":"NS"},{"parent":312,"left":268,"right":311,"relation":"joint","nuclearity":"NN"},{"parent":268,"left":265,"right":267,"relation":"adversative","nuclearity":"NN"},{"parent":265,