{"article_id":"bhmeayIEmmRPLXPq","edus":[{"id":0,"text":"A U.S. cybersecurity official said Wednesday","depth":5},{"id":1,"text":"that Russia `` successfully penetrated '' the voter rolls in a small number of states in 2016 .","depth":5},{"id":2,"text":"Jeanette Manfra , the head of cybersecurity at the Department of Homeland Security","depth":7},{"id":3,"text":"( DHS ) ,","depth":7},{"id":4,"text":"told NBC News","depth":6},{"id":5,"text":"that Russia targeted 21 states","depth":6},{"id":6,"text":"and \" an exceptionally small number of them were actually successfully penetrated . \"","depth":6},{"id":7,"text":"DHS previously notified the 21 states","depth":7},{"id":8,"text":"that Russia had attempted to hack their elections systems before the 2016 election .","depth":7},{"id":9,"text":"It was Manfra who first revealed to the Senate Intelligence Committee last June","depth":7},{"id":10,"text":"that the states had their systems","depth":8},{"id":11,"text":"targeted by Russian hackers ahead of the election .","depth":8},{"id":12,"text":"It was previously known that voter registration databases in Arizona and Illinois were breached by hackers .","depth":7},{"id":13,"text":"Alabama , California , Colorado , Wisconsin and Florida are among the other states","depth":8},{"id":14,"text":"that have confirmed","depth":9},{"id":15,"text":"they were targeted .","depth":9},{"id":16,"text":"Officials told NBC","depth":7},{"id":17,"text":"there is no evidence","depth":8},{"id":18,"text":"any of the voter rolls were altered in any way .","depth":8},{"id":19,"text":"Homeland Security formally notified election officials in the states","depth":7},{"id":20,"text":"that were targeted .","depth":7},{"id":21,"text":"Officials said then","depth":7},{"id":22,"text":"that most of the targeting amounted to mere preparations for hacking ,","depth":8},{"id":23,"text":"such as probing for vulnerabilities .","depth":8},{"id":24,"text":"The targeting was part of a broader effort by Moscow","depth":8},{"id":25,"text":"to meddle in the presidential election ,","depth":8},{"id":26,"text":"according to the U.S. intelligence community .","depth":7},{"id":27,"text":"The systems","depth":8},{"id":28,"text":"targeted","depth":8},{"id":29,"text":"were not involved in vote tallying .","depth":7},{"id":30,"text":"The revelations have sparked widespread fears","depth":3},{"id":31,"text":"that Russia or another foreign actor could seek to interfere in future elections","depth":4},{"id":32,"text":"using cyberattacks and other tactics .","depth":4},{"id":33,"text":"Secretary of State Rex Tillerson","depth":3},{"id":34,"text":"Rex Wayne TillersonSteve Schmidt :","depth":6},{"id":35,"text":"'Overwhelming chance","depth":7},{"id":36,"text":"that Trump will dump Pence ' for Haley","depth":7},{"id":37,"text":"Nikki Haley :","depth":7},{"id":38,"text":"Trump 'truthful ' in 'every instance","depth":8},{"id":39,"text":"that I dealt with him '","depth":8},{"id":40,"text":"Tillerson denies Haley 's claims","depth":7},{"id":41,"text":"of taking actions","depth":8},{"id":42,"text":"to undermine Trump","depth":8},{"id":43,"text":"MORE warned Tuesday","depth":6},{"id":44,"text":"that Russia is already attempting to meddle in the U.S. midterm elections this year .","depth":6},{"id":45,"text":"But Manfra told in a recent interview","depth":7},{"id":46,"text":"that ,","depth":8},{"id":47,"text":"while she is unaware of any credible targeting efforts","depth":10},{"id":48,"text":"related to the 2018 midterm elections ,","depth":10},{"id":49,"text":"she remains worried about the threat .","depth":9},{"id":50,"text":"\" I will always be worried about it","depth":8},{"id":51,"text":"and it is always something","depth":10},{"id":52,"text":"that entities are going to look to influence our democratic processes , \"","depth":10},{"id":53,"text":"she said .","depth":9},{"id":54,"text":"\" As a country , we should be in a position","depth":8},{"id":55,"text":"to counter that . \"","depth":8},{"id":56,"text":"The department is providing vulnerability tests and other services to states","depth":5},{"id":57,"text":"looking to shore up the cybersecurity of their election systems ahead of future votes ,","depth":5},{"id":58,"text":"as part of its new designation of voting systems as critical infrastructure .","depth":4},{"id":59,"text":"Homeland Security is also working with state election officials","depth":4},{"id":60,"text":"to share information on cyber threats .","depth":4}],"relations":[{"parent":121,"left":93,"right":120,"relation":"elaboration","nuclearity":"NS"},{"parent":93,"left":90,"right":92,"relation":"elaboration","nuclearity":"NS"},{"parent":90,"left":67,"right":89,"relation":"elaboration","nuclearity":"NS"},{"parent":67,"left":62,"right":66,"relation":"elaboration","nuclearity":"NS"},{"parent":62,"left":0,"right":1,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":64,"right":65,"relation":"attribution","nuclearity":"SN"},{"parent":64,"left":63,"right":4,"relation":"same-unit","nuclearity":"NN"},{"parent":63,"left":2,"right":3,"relation":"restatement","nuclearity":"NS"},{"parent":65,"left":5,"right":6,"relation":"joint","nuclearity":"NN"},{"parent":89,"left":78,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":78,"left":71,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":68,"right":70,"relation":"joint","nuclearity":"NN"},{"parent":68,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":9,"right":69,"relation":"attribution","nuclearity":"SN"},{"parent":69,"left":10,"right":11,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":74,"right":76,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":12,"right":73,"relation":"joint","nuclearity":"NN"},{"parent":73,"left":13,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":14,"right":15,"relation":"attribution","nuclearity":"SN"},{"parent":76,"left":16,"right":75,"relation":