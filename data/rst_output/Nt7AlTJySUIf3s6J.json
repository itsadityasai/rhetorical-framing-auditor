{"article_id":"Nt7AlTJySUIf3s6J","edus":[{"id":0,"text":"Story highlights","depth":5},{"id":1,"text":"IRS official invoked Fifth Amendment right","depth":6},{"id":2,"text":"not to answer questions before Congress","depth":6},{"id":3,"text":"She joined a long line of public figures","depth":6},{"id":4,"text":"exercising right against self-incrimination","depth":6},{"id":5,"text":"Lois Lerner could still be called back to testify before House committee","depth":5},{"id":6,"text":"Lois Lerner , the head of the IRS unit","depth":7},{"id":7,"text":"handling tax-exempt status ,","depth":7},{"id":8,"text":"invoked her Fifth Amendment right against self-incrimination before the House Oversight Committee on Wednesday .","depth":6},{"id":9,"text":"She is in the spotlight","depth":6},{"id":10,"text":"following a Treasury inspector general 's report","depth":7},{"id":11,"text":"that found","depth":8},{"id":12,"text":"her unit used political criteria","depth":9},{"id":13,"text":"to screen applications for tax-exempt status from tea party and other conservative organizations .","depth":9},{"id":14,"text":"Lerner joins a long line of officials","depth":6},{"id":15,"text":"who `` took the Fifth ''","depth":7},{"id":16,"text":"when called to testify before Congress .","depth":7},{"id":17,"text":"Former Enron CEO Kenneth Lay , former lobbyist Jack Abramoff , retired Lt. Col. Oliver North and several Justice Department officials all invoked that privilege before Congress due to concerns","depth":6},{"id":18,"text":"that anything","depth":8},{"id":19,"text":"they may have said","depth":8},{"id":20,"text":"could have been used against them in court .","depth":7},{"id":21,"text":"Here is what the Fifth Amendment to the U.S. Constitution says :","depth":3},{"id":22,"text":"JUST WATCHED","depth":8},{"id":23,"text":"Lerner :","depth":9},{"id":24,"text":"' I have not done anything wrong '","depth":9},{"id":25,"text":"Replay More Videos ...","depth":8},{"id":26,"text":"MUST WATCH Lerner :","depth":9},{"id":27,"text":"' I have not done anything wrong '","depth":9},{"id":28,"text":"00:58","depth":6},{"id":29,"text":"JUST WATCHED IRS grilling on Capitol Hill continues","depth":7},{"id":30,"text":"Replay More Videos ...","depth":7},{"id":31,"text":"MUST WATCH IRS grilling on Capitol Hill continues","depth":7},{"id":32,"text":"02:03","depth":7},{"id":33,"text":"JUST WATCHED IRS acting commissioner forced out","depth":7},{"id":34,"text":"Replay More Videos ...","depth":7},{"id":35,"text":"MUST WATCH IRS acting commissioner forced out","depth":7},{"id":36,"text":"02:51","depth":7},{"id":37,"text":"No person shall be held to answer for a capital , or otherwise infamous crime ,","depth":10},{"id":38,"text":"unless on a presentment or indictment of a Grand Jury ,","depth":10},{"id":39,"text":"except in cases","depth":10},{"id":40,"text":"arising in the land or naval forces , or in the Militia ,","depth":11},{"id":41,"text":"when in actual service in time of War or public danger ;","depth":11},{"id":42,"text":"nor shall any person be subject for the same offense to be twice put in jeopardy of life or limb ;","depth":9},{"id":43,"text":"nor shall be compelled in any criminal case to be a witness against himself ,","depth":10},{"id":44,"text":"nor be deprived of life , liberty , or property ,","depth":12},{"id":45,"text":"without due process of law ;","depth":12},{"id":46,"text":"nor shall private property be taken for public use ,","depth":12},{"id":47,"text":"without just compensation .","depth":12},{"id":48,"text":"What that last part","depth":11},{"id":49,"text":"-- also known as the `` self-incrimination clause '' --","depth":11},{"id":50,"text":"generally means","depth":10},{"id":51,"text":"is that a witness can not be forced to make statements","depth":10},{"id":52,"text":"that","depth":12},{"id":53,"text":"he or she feels","depth":12},{"id":54,"text":"might be negative or used against them .","depth":11},{"id":55,"text":"The right must be affirmatively waived .","depth":8},{"id":56,"text":"Invoking the Fifth Amendment is usually done","depth":7},{"id":57,"text":"to avoid answering specific questions .","depth":7},{"id":58,"text":"In Lerner 's case , the Justice Department is investigating the IRS saga","depth":4},{"id":59,"text":"and agency officials have faced pointed questions from lawmakers at three hearings .","depth":4},{"id":60,"text":"It remains unclear whether she ultimately will be compelled to testify by the Oversight panel .","depth":3},{"id":61,"text":"Republicans have questioned","depth":4},{"id":62,"text":"whether Lerner voided her right","depth":6},{"id":63,"text":"not to testify","depth":6},{"id":64,"text":"when she read her opening statement .","depth":5},{"id":65,"text":"`` I have not done anything wrong .","depth":5},{"id":66,"text":"I have not broken any laws .","depth":6},{"id":67,"text":"I have not violated any IRS rules and regulations , ''","depth":6},{"id":68,"text":"she said .","depth":4}],"relations":[{"parent":137,"left":126,"right":136,"relation":"elaboration","nuclearity":"NS"},{"parent":126,"left":89,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":74,"right":88,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":71,"right":73,"relation":"organization","nuclearity":"SN"},{"parent":71,"left":0,"right":70,"relation":"attribution","nuclearity":"SN"},{"parent":70,"left":1,"right":2,"relation":"purpose","nuclearity":"NS"},{"parent":73,"left":72,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":88,"left":81,"right":87,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":76,"right":80,"relation":"context","nuclearity":"NS"},{"parent":76,"left":75,"right":8,"relation":"same-unit","nuclearity":"NN"},{"parent":75,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":9,"right":79,"relation":"causal","nuclearity":"NS"},{"parent":79,"l