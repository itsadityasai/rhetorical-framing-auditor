{"article_id":"QCV1WQ253p2G1OKn","edus":[{"id":0,"text":"House Minority Leader Nancy Pelosi blasted Brett Kavanaugh on Saturday as \" hysterical \" and unfit to serve on the Supreme Court ,","depth":5},{"id":1,"text":"putting his judicial career in jeopardy","depth":5},{"id":2,"text":"as Democrats ponder pursuing impeachment","depth":5},{"id":3,"text":"pending the outcome of the Nov. 6 midterm races .","depth":5},{"id":4,"text":"Mrs. Pelosi , California Democrat , made the remarks","depth":5},{"id":5,"text":"while speaking at the 2018 Texas Tribune Festival during an interview","depth":6},{"id":6,"text":"conducted in light of his emotional testimony on Capitol Hill this week","depth":7},{"id":7,"text":"denying sexual assault allegations","depth":8},{"id":8,"text":"dating back several decades .","depth":8},{"id":9,"text":"\" I couldn ' t help but think","depth":7},{"id":10,"text":"that","depth":9},{"id":11,"text":"if a woman had ever performed that way ,","depth":10},{"id":12,"text":"they would say","depth":11},{"id":13,"text":"' hysterical , ' \"","depth":11},{"id":14,"text":"Mrs. Pelosi said ,","depth":8},{"id":15,"text":"according to CBS News .","depth":6},{"id":16,"text":"\" It ' s not time","depth":6},{"id":17,"text":"for a hysterical , biased person to go to the court","depth":7},{"id":18,"text":"and expect us to say ,","depth":8},{"id":19,"text":"' isn ' t that wonderful . ' \"","depth":8},{"id":20,"text":"Judge Kavanaugh , President Trump ' s pick","depth":6},{"id":21,"text":"to replace retired Justice Anthony Kennedy","depth":6},{"id":22,"text":"and current member of the D.C . Circuit Court of Appeals , testified before the Senate Judiciary Committee Thursday ,","depth":5},{"id":23,"text":"hours after one of his accusers , Dr. Christine Blasey Ford , publicly discussed the allegations during a televised hearing with lawmakers .","depth":4},{"id":24,"text":"In addition to adamantly denying the allegations ,","depth":5},{"id":25,"text":"the Supreme Court hopeful accused Democrats , and the Clinton family in particular , of conspiring to derail his confirmation .","depth":5},{"id":26,"text":"\" I think","depth":6},{"id":27,"text":"that he disqualifies himself with those statements and the manner","depth":7},{"id":28,"text":"in which he went after the Clintons and the Democrats , \"","depth":7},{"id":29,"text":"Mrs. Pelosi said .","depth":5},{"id":30,"text":"Mr. Trump , meanwhile , instructed the FBI on Friday to conduct a limited investigation into credible allegations","depth":5},{"id":31,"text":"involving his nominee ,","depth":5},{"id":32,"text":"postponing confirmation proceedings for at least a week .","depth":4},{"id":33,"text":"Even if the FBI probe clears the president ' s pick , however ,","depth":6},{"id":34,"text":"Democrats could pursue his impeachment","depth":6},{"id":35,"text":"if the Republicans lose control of the House","depth":6},{"id":36,"text":"as a result of the upcoming midterms ,","depth":6},{"id":37,"text":"Mrs. Pelosi acknowledged .","depth":4},{"id":38,"text":"\" Well , let ' s take it one step at a time , \"","depth":5},{"id":39,"text":"the former House speaker said Saturday .","depth":5},{"id":40,"text":"\" I was asked that yesterday morning ,","depth":5},{"id":41,"text":"and I said","depth":6},{"id":42,"text":"...","depth":7},{"id":43,"text":"divine intervention ,","depth":9},{"id":44,"text":"whatever it takes ,","depth":9},{"id":45,"text":"let ' s see","depth":9},{"id":46,"text":"if we can ' t get to a better place than that .","depth":9},{"id":47,"text":"\" But let me say this , \"","depth":5},{"id":48,"text":"she added .","depth":5},{"id":49,"text":"\" If Judge Kavanaugh ...","depth":6},{"id":50,"text":"if he is not telling the truth , to Congress or to the FBI ,","depth":6},{"id":51,"text":"then he ' s not fit","depth":6},{"id":52,"text":"not only to be on the Supreme Court ,","depth":7},{"id":53,"text":"but to be on the court","depth":8},{"id":54,"text":"that he ' s on right now . \"","depth":8}],"relations":[{"parent":109,"left":84,"right":108,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":74,"right":83,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":58,"right":73,"relation":"elaboration","nuclearity":"NS"},{"parent":58,"left":56,"right":57,"relation":"causal","nuclearity":"NS"},{"parent":56,"left":0,"right":1,"relation":"causal","nuclearity":"NS"},{"parent":57,"left":2,"right":3,"relation":"context","nuclearity":"NS"},{"parent":73,"left":62,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":62,"left":4,"right":61,"relation":"context","nuclearity":"NS"},{"parent":61,"left":5,"right":60,"relation":"elaboration","nuclearity":"NS"},{"parent":60,"left":6,"right":59,"relation":"elaboration","nuclearity":"NS"},{"parent":59,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":68,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":68,"left":67,"right":15,"relation":"attribution","nuclearity":"NS"},{"parent":67,"left":9,"right":66,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":65,"right":14,"relation":"attribution","nuclearity":"NS"},{"parent":65,"left":10,"right":64,"relation":"same-unit","nuclearity":"NN"},{"parent":64,"left":11,"right":63,"relation":"condition","nuclearity":"SN"},{"parent":63,"left":12,"right":13,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":16,"right":70,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":17,"right":69,"relation":"joint","nuclearity":"NN"},{"parent":69,"left":18,"right":19,"relation":"attribution","nuclearity":"SN"},{"parent":83,"left":77,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":76,"right":23,"relation":"context","nuclearity":"NS"},{"parent":76,"left":75,"right":22,"relation":"same-unit","nuclearity":"NN"},{"parent":75,"left":20,"right":21,"relation":"purpose","nuclearity":"NS"},{"parent":82,"left":78,"right":81,"relation":"evaluation","nuclearity":"N