{"article_id":"McN7qxRTrCNSKUsL","edus":[{"id":0,"text":"Attorney General Jeff Sessions is suggesting","depth":6},{"id":1,"text":"he has no regrets","depth":7},{"id":2,"text":"about recusing himself on anything","depth":8},{"id":3,"text":"related to Russia ,","depth":8},{"id":4,"text":"telling","depth":6},{"id":5,"text":"that","depth":7},{"id":6,"text":"he believes","depth":8},{"id":7,"text":"he \" did the right thing . \"","depth":8},{"id":8,"text":"Sessions ' decision in March 2016","depth":9},{"id":9,"text":"to step aside from the Justice Department investigation","depth":10},{"id":10,"text":"into whether the Trump campaign colluded with Russia during the 2016 White House race","depth":10},{"id":11,"text":"reportedly infuriated his boss , President Trump ,","depth":8},{"id":12,"text":"because special counsel Robert Mueller would now lead the investigation .","depth":7},{"id":13,"text":"In a wide-ranging interview with Maria Bartiromo for `` Sunday Morning Futures , \" Sessions said ,","depth":8},{"id":14,"text":"\" I believe","depth":10},{"id":15,"text":"I did the right thing ,","depth":10},{"id":16,"text":"the only thing","depth":10},{"id":17,"text":"I could do .","depth":10},{"id":18,"text":"I participated in this campaign","depth":8},{"id":19,"text":"and as such , under explicit regulations of the Department of Justice , no one can participate in the investigation , in the campaign ,","depth":9},{"id":20,"text":"of which they were an active participant . \"","depth":9},{"id":21,"text":"Sessions , a former Alabama Republican senator and an early Trump for president supporter , also said Sunday","depth":8},{"id":22,"text":"that he didn ' t know","depth":9},{"id":23,"text":"whether Congress would find a permanent legislative solution to the Obama-era Deferred Action for Childhood Arrivals , or DACA , program","depth":10},{"id":24,"text":"-- which temporarily protects some illegal immigrants","depth":11},{"id":25,"text":"but will expire on March 5 .","depth":11},{"id":26,"text":"\" I don ' t know , \"","depth":8},{"id":27,"text":"Sessions said .","depth":8},{"id":28,"text":"\" The people","depth":8},{"id":29,"text":"who say","depth":9},{"id":30,"text":"they want to fix that ,","depth":9},{"id":31,"text":"President Trump has offered ( them ) that .","depth":8},{"id":32,"text":"He ' s been very generous in his legislation .","depth":10},{"id":33,"text":"I think","depth":11},{"id":34,"text":"that is a very generous policy .","depth":11},{"id":35,"text":"It goes beyond , actually , what President Obama had in his DACA policy ,","depth":11},{"id":36,"text":"goes beyond what , even some people","depth":13},{"id":37,"text":"who favored the DACA","depth":13},{"id":38,"text":"expected .","depth":12},{"id":39,"text":"So that ' s been very generous . ... He ' s already made compromises . \"","depth":10},{"id":40,"text":"DACA protects an estimated 700,000 immigrants","depth":4},{"id":41,"text":"brought illegally to the United States by their parents .","depth":4},{"id":42,"text":"Trump ' s immigration reform plan offers a potential path to citizenship for as many as 1.8 million illegal immigrants .","depth":3},{"id":43,"text":"However , the Senate last week stalled on immigration-reform efforts ,","depth":5},{"id":44,"text":"despite Senate Majority Leader Mitch McConnell , R-Ky. , conducting full , open debates on bipartisan and other reform proposals ,","depth":5},{"id":45,"text":"as the March deadline approaches .","depth":4},{"id":46,"text":"Sessions on Sunday also said","depth":4},{"id":47,"text":"law enforcement officials think","depth":5},{"id":48,"text":"that everybody needs to improve on identifying signs of potential mass shooters ,","depth":5},{"id":49,"text":"after the FBI acknowledged","depth":4},{"id":50,"text":"being alerted","depth":5},{"id":51,"text":"but failing to follow up on a tip about the alleged shooter last week at a Florida high school ,","depth":6},{"id":52,"text":"where 17 people were killed .","depth":6},{"id":53,"text":"\" I met with a group of sheriffs , yesterday , \"","depth":5},{"id":54,"text":"Sessions said .","depth":5},{"id":55,"text":"\" They all believe","depth":5},{"id":56,"text":"that we need to do a better job ,","depth":6},{"id":57,"text":"of receiving these signs","depth":7},{"id":58,"text":"and acting on them","depth":8},{"id":59,"text":"and following up on them better .","depth":8},{"id":60,"text":"That is probably the most valuable thing","depth":5},{"id":61,"text":"we can do","depth":5},{"id":62,"text":"to stop these kind of cases . \"","depth":4}],"relations":[{"parent":125,"left":108,"right":124,"relation":"joint","nuclearity":"NN"},{"parent":108,"left":104,"right":107,"relation":"context","nuclearity":"NS"},{"parent":104,"left":102,"right":103,"relation":"context","nuclearity":"NS"},{"parent":102,"left":70,"right":101,"relation":"elaboration","nuclearity":"NS"},{"parent":70,"left":66,"right":69,"relation":"elaboration","nuclearity":"NS"},{"parent":66,"left":0,"right":65,"relation":"attribution","nuclearity":"SN"},{"parent":65,"left":1,"right":64,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":2,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":4,"right":68,"relation":"attribution","nuclearity":"SN"},{"parent":68,"left":5,"right":67,"relation":"same-unit","nuclearity":"NN"},{"parent":67,"left":6,"right":7,"relation":"attribution","nuclearity":"SN"},{"parent":101,"left":82,"right":100,"relation":"joint","nuclearity":"NN"},{"parent":82,"left":74,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":74,"left":73,"right":12,"relation":"causal","nuclearity":"NS"},{"parent":73,"left":72,"right":11,"relation":"same-unit","nuclearity":"NN"},{"parent":72,"left":8,"right":71,"relation":"elaboration","nuclearity":"NS"},{"parent":71,"left":9,"right":10,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":78,"right":80,"relation":"explanation","nuclearity":"NS"},{"parent":78,"left":13,"right":77,"rela