{"article_id":"eBeaJ21YwHxqMHAA","edus":[{"id":0,"text":"A federal judge ruled Monday","depth":7},{"id":1,"text":"that Georgia election officials must review provisional ballots","depth":8},{"id":2,"text":"that have n't been counted in the state 's hotly contested governor 's race .","depth":8},{"id":3,"text":"The order from U.S. District Judge Amy Totenberg prevented the secretary of state from certifying the race between Republican Brian Kemp and Democrat Stacey Abrams until Friday .","depth":6},{"id":4,"text":"Kemp has already declared victory in the race","depth":6},{"id":5,"text":"and resigned his secretary of state position","depth":7},{"id":6,"text":"to prepare for the transition .","depth":7},{"id":7,"text":"In a 56-page ruling , Totenberg also called for the office to provide a hotline or website for provisional ballot voters","depth":7},{"id":8,"text":"to find out why or if they were rejected .","depth":7},{"id":9,"text":"The judge ordered all 159 of the state 's counties to publicize the availability of the hotlines on their websites .","depth":6},{"id":10,"text":"The court decision comes","depth":8},{"id":11,"text":"as votes are still being counted in the race for governor between Democrat Stacey Abrams and Republican Brian Kemp .","depth":8},{"id":12,"text":"Abrams trails Kemp","depth":8},{"id":13,"text":"and would need to gain more than 20,000 additional votes","depth":9},{"id":14,"text":"to force a runoff election .","depth":9},{"id":15,"text":"Totenberg said","depth":7},{"id":16,"text":"she ' s providing `` limited , modest '' relief","depth":8},{"id":17,"text":"to help protect voters .","depth":8},{"id":18,"text":"The order preserves Tuesday ' s deadline","depth":7},{"id":19,"text":"for county election offices","depth":8},{"id":20,"text":"to certify results","depth":8},{"id":21,"text":"and the Nov. 20 deadline","depth":7},{"id":22,"text":"for Secretary of State Robyn Crittenden","depth":8},{"id":23,"text":"to certify the election .","depth":8},{"id":24,"text":"The ruling enjoins Crittenden from certifying the election before Friday at 5 p.m .","depth":6},{"id":25,"text":"Her ruling applies to provisional ballots ,","depth":7},{"id":26,"text":"which were issued to as many as 27,000 Georgia voters","depth":8},{"id":27,"text":"because their registration or identification couldn ' t be verified .","depth":8},{"id":28,"text":"Provisional ballots are usually only counted","depth":5},{"id":29,"text":"if voters prove their eligibility within three days of the election , a deadline","depth":6},{"id":30,"text":"that passed Friday .","depth":6},{"id":31,"text":"Common Cause Georgia filed the lawsuit","depth":5},{"id":32,"text":"and celebrated the ruling ,","depth":6},{"id":33,"text":"calling it a victory for voting rights .","depth":6},{"id":34,"text":"The order did not change the Tuesday deadline","depth":7},{"id":35,"text":"for counties to certify results ,","depth":7},{"id":36,"text":"NBC News reported .","depth":6},{"id":37,"text":"The Abrams campaign has filed a separate lawsuit","depth":7},{"id":38,"text":"calling for the certification deadline to be pushed back to Wednesday ,","depth":7},{"id":39,"text":"as well as calling for the counting of rejected provisional ballots","depth":7},{"id":40,"text":"that were turned down for minor mistakes , such as an incorrect date or mismatched signature .","depth":7},{"id":41,"text":"A federal judge just issued a 56 page order","depth":7},{"id":42,"text":"that could affect thousands of provisional ballots in Georgia 's race for governor .","depth":7},{"id":43,"text":"# gapol - Greg Bluestein","depth":9},{"id":44,"text":"( @ bluestein )","depth":9},{"id":45,"text":"November 13 , 2018","depth":8},{"id":46,"text":"The order by Judge Amy Totenberg blocks the Secretary of State from certifying the election until Friday","depth":9},{"id":47,"text":"and directs state and local officials to conduct a review of many of the provisional ballots .","depth":9},{"id":48,"text":"# gapol - Greg Bluestein","depth":11},{"id":49,"text":"( @ bluestein )","depth":11},{"id":50,"text":"November 13 , 2018","depth":10},{"id":51,"text":"The state also has to provide new , rolling updates","depth":11},{"id":52,"text":"of why provisional ballots were rejected","depth":11},{"id":53,"text":"and to set up a hotline for voters","depth":11},{"id":54,"text":"so they can determine","depth":12},{"id":55,"text":"whether their provisional ballots were counted .","depth":12},{"id":56,"text":"# gapol - Greg Bluestein","depth":7},{"id":57,"text":"( @ bluestein )","depth":7},{"id":58,"text":"November 13 , 2018","depth":6},{"id":59,"text":"Kemp has repeatedly called on Abrams to concede ,","depth":7},{"id":60,"text":"but she has refused .","depth":7},{"id":61,"text":"Kemp 's campaign has also called Abrams desperate ,","depth":7},{"id":62,"text":"saying","depth":8},{"id":63,"text":"the math is not there for her","depth":9},{"id":64,"text":"to make up the ground necessary","depth":10},{"id":65,"text":"to force a runoff .","depth":10},{"id":66,"text":"There is a dispute between the camps on the number of provisional ballots .","depth":9},{"id":67,"text":"Over the weekend , the Georgia secretary of state office said","depth":11},{"id":68,"text":"there were 21,190 ,","depth":11},{"id":69,"text":"while Abrams ' campaign aides estimated","depth":11},{"id":70,"text":"there were more than 26,000 votes","depth":12},{"id":71,"text":"yet to be counted .","depth":12},{"id":72,"text":"As more Georgia counties certify their voting results ,","depth":10},{"id":73,"text":"Abrams still trails by nearly 60,000 votes","depth":10},{"id":74,"text":"and needs to net more than 20,000 votes of whatever remains uncounted","depth":10},{"id":75,"text":"to get Kemp below the 50-percent threshold .","depth":10},{"id":76,"text":"A few hundred more votes just came in","depth":10},{"id":77,"text":"and the margin in the race for governor remains the same .","depth":10},{"id":78,"text":"@ staceyabrams still needs to net 20k+ votes","depth":10},{"id":79,"text":"to force a runoff .","depth":10},{"id":80,"text":"We should get provisional ballots from DeKalb & Gwinnett later today -","depth":10},{"id":81,"text":"two heavily D counties .","depth":10},{"id":82,"text":"# gapol pic.twitter.com/6A5u5OD1VR","depth":9},{"id":83,"text":"- Greg Bluestein","depth":8},{"id":84,"text":"( @ bluestein )","depth":8},{"id":85,"text":"November 13 , 2018","depth":7},{"id":86,"text":"While Abrams looks unlikely to get to a runoff ,","depth":3},{"id":87,"text":"over in Georgia 's 7th Congressional Cistrict , Rep . Rob Woodall","depth":6},{"id":88,"text":"( R. , Ga. )","depth":6},{"id":89,"text":"is trying to fend off Democratic challenger Carolyn Bourdeaux .","depth":5},{"id":90,"text":"He leads her by less than 1,000 votes in the race","depth":7},{"id":91,"text":"to represent the northern Atlanta suburban district ,","depth":8},{"id":92,"text":"which includes portions of Gwinnett and Forsyth Counties .","depth":8},{"id":93,"text":"She has filed a lawsuit","depth":7},{"id":94,"text":"trying to stop Gwinnett from certifying its results","depth":8},{"id":95,"text":"before counting about 3,200 absentee and provisional ballots","depth":9},{"id":96,"text":"that","depth":11},{"id":97,"text":"she says","depth":11},{"id":98,"text":"were rejected for trivial reasons .","depth":10},{"id":99,"text":"The AJC reports","depth":6},{"id":100,"text":"the U.S. District Court","depth":10},{"id":101,"text":"where Bourdeaux filed her motion","depth":10},{"id":102,"text":"was closed Monday for the Veterans Day holiday","depth":9},{"id":103,"text":"and will have to respond soon to her request ,","depth":8},{"id":104,"text":"since the Gwinnett elections board plans to meet Tuesday","depth":8},{"id":105,"text":"to certify the results .","depth":8},{"id":106,"text":"Democrats have already flipped the neighboring-and longtime Republican-6th Congressional District ,","depth":3},{"id":107,"text":"ousting Rep. Karen Handel","depth":5},{"id":108,"text":"( R. , Ga. )","depth":5},{"id":109,"text":"after a narrow win by Democrat Lucy McBath .","depth":4}],"relations":[{"parent":219,"left":195,"right":218,"relation":"elaboration","nuclearity":"NS"},{"parent":195,"left":140,"right":194,"relation":"elaboration","nuclearity":"NS"},{"parent":140,"left":127,"right":139,"relation":"elaboration","nuclearity":"NS"},{"parent":127,"left":116,"right":126,"relation":"elaboration","nuclearity":"NS"},{"parent":116,"left":113,"right":115,"relation":"context","nuclearity":"NS"},{"parent":113,"left":112,"right":3,"relation":"elaboration","nuclearity":"NS"},{"parent":112,"left":0,"right":111,"relation":"attribution","nuclearity":"SN"},{"parent":111,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":115,"left":4,"right":114,"relation":"joint","nuclearity":"NN"},{"parent":114,"left":5,"right":6,"relation":"purpose","nuclearity":"NS"},{"parent":126,"left":118,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":118,"left":117,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":117,"left":7,"right":8,"relation":"purpose","nuclearity":"NS"},{"parent":125,"left":122,"right":124,"relation":"elaboration","nuclearity":"NS"},{"parent":122,"left":119,"right":121,"relation":"elaboration","nuclearity":"NS"},{"parent":119,"left":10,"right":11,"relation":"context","nuclearity":"NS"},{"parent":121,"left":12,"right":120,"relation":"joint","nuclearity":"NN"},{"parent":120,"left":13,"right":14,"relation":"purpose","nuclearity":"NS"},{"parent":124,"left":15,"right":123,"relation":"attribution","nuclearity":"SN"},{"parent":123,"left":16,"right":17,"relation":"purpose","nuclearity":"NS"},{"parent":139,"left":136,"right":138,"relation":"elaboration","nuclearity":"NS"},{"parent":136,"left":132,"right":135,"relation":"elaboration","nuclearity":"NS"},{"parent":132,"left":129,"right":131,"relation":"same-unit","nuclearity":"NN"},{"parent":129,"left":18,"right":128,"relation":"purpose","nucl