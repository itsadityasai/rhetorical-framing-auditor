{"article_id":"p9bMR4Wqa9hJ1zQX","edus":[{"id":0,"text":"With Congress still not on board his border wall plans ,","depth":3},{"id":1,"text":"President Trump said Saturday","depth":5},{"id":2,"text":"that it ' s a \" good time","depth":6},{"id":3,"text":"to do a shutdown , \"","depth":6},{"id":4,"text":"suggesting","depth":5},{"id":5,"text":"he will refuse to accept any appropriations bills","depth":6},{"id":6,"text":"that don ' t include the $ 5 billion","depth":7},{"id":7,"text":"he ' s asking for .","depth":7},{"id":8,"text":"He did say","depth":4},{"id":9,"text":"he doesn ' t think","depth":6},{"id":10,"text":"one will happen","depth":6},{"id":11,"text":"because \" Democrats will come to their senses \" on the issue .","depth":5},{"id":12,"text":"And he said","depth":6},{"id":13,"text":"he ' s ready to keep the troops","depth":8},{"id":14,"text":"he deployed to the border","depth":8},{"id":15,"text":"as long as necessary .","depth":7},{"id":16,"text":"\" We ' re talking about border wall ,","depth":8},{"id":17,"text":"we ' re talking about quite a big sum of money , about $ 5 billion , \"","depth":8},{"id":18,"text":"he told reporters at the White House","depth":7},{"id":19,"text":"before jetting off to California","depth":7},{"id":20,"text":"to survey the effort","depth":8},{"id":21,"text":"to contain wildfires .","depth":8},{"id":22,"text":"\" This would be a very good time","depth":6},{"id":23,"text":"to do a shutdown .","depth":6},{"id":24,"text":"I don ' t think","depth":7},{"id":25,"text":"it ' s going to be necessary ,","depth":7},{"id":26,"text":"because I think","depth":7},{"id":27,"text":"the Democrats will come to their senses ,","depth":8},{"id":28,"text":"and","depth":9},{"id":29,"text":"if they don ' t come to their senses ,","depth":10},{"id":30,"text":"we will continue to win elections . \"","depth":10},{"id":31,"text":"For most people in Washington a government shutdown is a sign of failure ,","depth":4},{"id":32,"text":"but Mr. Trump views it as a weapon","depth":7},{"id":33,"text":"to be deployed ,","depth":7},{"id":34,"text":"and at times has even seemed eager over the possibility .","depth":6},{"id":35,"text":"He said","depth":7},{"id":36,"text":"before the election he was cooling shutdown talk","depth":8},{"id":37,"text":"because Republicans on Capitol Hill convinced him","depth":9},{"id":38,"text":"it was hurting them .","depth":9},{"id":39,"text":"But with the election over , he appears emboldened again .","depth":6},{"id":40,"text":"A shutdown now would be less painful than the GOP-orchestrated 16-day shutdown in 2013","depth":5},{"id":41,"text":"because Congress has already approved","depth":8},{"id":42,"text":"- and Mr. Trump signed -","depth":8},{"id":43,"text":"five of the 12 annual spending bills into law .","depth":7},{"id":44,"text":"covering about 70 percent of discretionary government funding .","depth":6},{"id":45,"text":"There is a Dec. 7 deadline , though ,","depth":5},{"id":46,"text":"for funding operations at the State , Interior , Homeland Security , Justice and other departments .","depth":5},{"id":47,"text":"The border wall money fight is part of the debate over that Homeland Security spending bill .","depth":4},{"id":48,"text":"Mr. Trump initially asked for $ 1.6 billion , or the same amount as last year ,","depth":6},{"id":49,"text":"but later upped the request to $ 5 billion .","depth":6},{"id":50,"text":"Senators are working on a bill at the $ 1.6 billion level ,","depth":6},{"id":51,"text":"while the House passed a bill at the $ 5 billion level .","depth":6},{"id":52,"text":"Senate Minority Leader Charles E. Schumer has shown little willingness to compromise ,","depth":6},{"id":53,"text":"saying","depth":7},{"id":54,"text":"Congress should stick with his chamber ' s $ 1.6 billion figure .","depth":7},{"id":55,"text":"And he urged Mr. Trump to butt out of any negotiations .","depth":5},{"id":56,"text":"\" We believe","depth":8},{"id":57,"text":"Democrats and Republicans should stick with their agreement","depth":8},{"id":58,"text":"and not let President Trump interfere .","depth":7},{"id":59,"text":"Every time he interferes ,","depth":7},{"id":60,"text":"it gets bollixed up , \"","depth":7},{"id":61,"text":"Mr. Schumer told reporters this week .","depth":5}],"relations":[{"parent":123,"left":92,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":92,"left":69,"right":91,"relation":"elaboration","nuclearity":"NS"},{"parent":69,"left":0,"right":68,"relation":"condition","nuclearity":"SN"},{"parent":68,"left":64,"right":67,"relation":"elaboration","nuclearity":"NS"},{"parent":64,"left":1,"right":63,"relation":"attribution","nuclearity":"SN"},{"parent":63,"left":2,"right":3,"relation":"purpose","nuclearity":"NS"},{"parent":67,"left":4,"right":66,"relation":"attribution","nuclearity":"SN"},{"parent":66,"left":5,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":65,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":91,"left":72,"right":90,"relation":"joint","nuclearity":"NN"},{"parent":72,"left":8,"right":71,"relation":"attribution","nuclearity":"SN"},{"parent":71,"left":70,"right":11,"relation":"explanation","nuclearity":"NS"},{"parent":70,"left":9,"right":10,"relation":"attribution","nuclearity":"SN"},{"parent":90,"left":81,"right":89,"relation":"joint","nuclearity":"NN"},{"parent":81,"left":75,"right":80,"relation":"context","nuclearity":"NS"},{"parent":75,"left":12,"right":74,"relation":"attribution","nuclearity":"SN"},{"parent":74,"left":73,"right":15,"relation":"condition","nuclearity":"NS"},{"parent":73,"left":13,"right":14,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":77,"right":79,"relation":"joint","nuclearity":"NN"},{"parent":77,"left":76,"right":18,"relation":"attribution","nuclearity":"NS"},{"parent":76,"left":16,"right":17,"relation":"context","nuclearity":"SN"},{"parent":79,"left":19,"right":78,"relation":"purpose","nuclearity":"NS"},{"parent":78,"left":20,"right"