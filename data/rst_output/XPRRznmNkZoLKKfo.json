{"article_id":"XPRRznmNkZoLKKfo","edus":[{"id":0,"text":"President Donald Trump signed an executive order on Wednesday","depth":5},{"id":1,"text":"aimed at helping the more than 30 million Americans","depth":6},{"id":2,"text":"who suffer from chronic kidney disease .","depth":6},{"id":3,"text":"The changes","depth":7},{"id":4,"text":"outlined in the order","depth":7},{"id":5,"text":"are intended to help ease the financial hardships for living donors ,","depth":6},{"id":6,"text":"make it easier for patients to get in-home dialysis ,","depth":6},{"id":7,"text":"improve the system","depth":8},{"id":8,"text":"for collecting usable kidneys from deceased donors ,","depth":8},{"id":9,"text":"and to give financial incentives for doctors and clinics","depth":8},{"id":10,"text":"to help patients stave off end-stage kidney disease by about six months .","depth":8},{"id":11,"text":"Officials cited a study","depth":4},{"id":12,"text":"that suggests","depth":5},{"id":13,"text":"long term it may be possible to find 17,000 more kidneys and 11,000 other organs from deceased donors for transplant every year .","depth":5},{"id":14,"text":"\" It ' s truly an exciting day","depth":6},{"id":15,"text":"for advancing kidney health in our country , \"","depth":6},{"id":16,"text":"Trump said .","depth":5},{"id":17,"text":"`` Today ' s announcement on Advancing the American Kidney Health Initiative is smart policy","depth":7},{"id":18,"text":"that benefits patients and taxpayers alike , ''","depth":7},{"id":19,"text":"the American Association of Kidney Patients said in a statement .","depth":6},{"id":20,"text":"`` We are gratified","depth":7},{"id":21,"text":"that the Administration is releasing a policy platform","depth":8},{"id":22,"text":"that will make a real difference in the lives of Americans","depth":9},{"id":23,"text":"affected by this disease , ''","depth":9},{"id":24,"text":"the American Kidney Fund President LaVarne Burton said .","depth":6},{"id":25,"text":"While the moves","depth":9},{"id":26,"text":"to help living donors","depth":9},{"id":27,"text":"and to improve the procurement of organs from deceased donors","depth":8},{"id":28,"text":"will require new innovation ,","depth":7},{"id":29,"text":"the initiative","depth":8},{"id":30,"text":"to increase the number of patients","depth":9},{"id":31,"text":"getting at-home dialysis","depth":9},{"id":32,"text":"is expected to take effect sooner .","depth":7},{"id":33,"text":"With changes to Medicare","depth":9},{"id":34,"text":"that will give dialysis providers equal incentive","depth":10},{"id":35,"text":"to treat patients at home ,","depth":10},{"id":36,"text":"the administration hopes to decrease the number of patients","depth":9},{"id":37,"text":"having to spend hours","depth":10},{"id":38,"text":"getting dialysis at a facility three or four times a week .","depth":10},{"id":39,"text":"Currently , about 14 % of patients in kidney failure get at-home dialysis or an early transplant .","depth":8},{"id":40,"text":"By 2025 , the goal is to have 80 % of patients","depth":10},{"id":41,"text":"getting one of those options ,","depth":10},{"id":42,"text":"officials said .","depth":9},{"id":43,"text":"The change in Medicare is being implemented through a part of the Affordable Care Act","depth":7},{"id":44,"text":"that was created","depth":8},{"id":45,"text":"to find ways","depth":9},{"id":46,"text":"to save funds","depth":10},{"id":47,"text":"and improve the quality of care .","depth":10},{"id":48,"text":"The administration is currently arguing in federal court","depth":5},{"id":49,"text":"that ACA ,","depth":8},{"id":50,"text":"often referred to as Obamacare ,","depth":8},{"id":51,"text":"should be ruled unconstitutional","depth":7},{"id":52,"text":"and thrown out entirely ,","depth":7},{"id":53,"text":"which would include the innovation center .","depth":7},{"id":54,"text":"Much of the response on social media to Trump 's speech","depth":5},{"id":55,"text":"celebrating the executive order","depth":5},{"id":56,"text":"focused more on his choice of words than the specifics of the policy .","depth":4},{"id":57,"text":"`` The kidney has a very special place in the heart , ''","depth":5},{"id":58,"text":"Trump said ,","depth":6},{"id":59,"text":"pointing to his chest","depth":7},{"id":60,"text":"as he wrapped up his remarks .","depth":7},{"id":61,"text":"`` It 's an incredible thing . ''","depth":4},{"id":62,"text":"Many mocked the comment ,","depth":5},{"id":63,"text":"which clearly appeared to be intended metaphorically ,","depth":5},{"id":64,"text":"as evidence","depth":5},{"id":65,"text":"that the president lacks basic knowledge of human anatomy .","depth":5},{"id":66,"text":"`` Narrator :","depth":5},{"id":67,"text":"Donald Trump , of course , has no idea","depth":6},{"id":68,"text":"what a kidney is","depth":7},{"id":69,"text":"or what it does , ''","depth":7},{"id":70,"text":"one Twitter user quipped .","depth":4}],"relations":[{"parent":141,"left":124,"right":140,"relation":"elaboration","nuclearity":"NS"},{"parent":124,"left":84,"right":123,"relation":"elaboration","nuclearity":"NS"},{"parent":84,"left":81,"right":83,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":73,"right":80,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":0,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":72,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":80,"left":75,"right":79,"relation":"joint","nuclearity":"NN"},{"parent":75,"left":74,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":74,"left":3,"right":4,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":6,"right":78,"relation":"joint","nuclearity":"NN"},{"parent":78,"left":76,"right":77,"relation":"joint","nuclearity":"NN"},{"parent":76,"left":7,"right":8,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":9,"right":10,"relation":"purpose","nuclearity":"NS"},{"parent":83,"left":11,"right":82,"relation":"elaboration","nuc