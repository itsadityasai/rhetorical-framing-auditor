{"article_id":"UvrcbdMyzA2lzH7v","edus":[{"id":0,"text":"As the government shutdown entered its 12th day ,","depth":2},{"id":1,"text":"the best","depth":5},{"id":2,"text":"lawmakers on Capitol Hill could say on Saturday","depth":5},{"id":3,"text":"is that","depth":4},{"id":4,"text":"they ' ve started talking","depth":4},{"id":5,"text":"- again .","depth":4},{"id":6,"text":"Negotiations between President Obama and House Republicans have collapsed ,","depth":8},{"id":7,"text":"but now Senate Republican leaders reached out","depth":9},{"id":8,"text":"and asked to talk to Senate Democrats .","depth":9},{"id":9,"text":"Those involved said","depth":8},{"id":10,"text":"that , at least , should be encouraging to nervous financial markets","depth":9},{"id":11,"text":"eying a Thursday deadline","depth":10},{"id":12,"text":"for raising the debt ceiling .","depth":10},{"id":13,"text":"\" I hope","depth":9},{"id":14,"text":"that our talking gives some solace to the American people , \"","depth":9},{"id":15,"text":"Senate Majority Leader Harry Reid , Nevada Democrat , said ,","depth":8},{"id":16,"text":"pointing to his morning meeting with his Republican counterpart Sen. Mitch McConnell .","depth":8},{"id":17,"text":"\" This should be seen as something very positive . \"","depth":8},{"id":18,"text":"But he had no progress","depth":7},{"id":19,"text":"to report in the talks ,","depth":7},{"id":20,"text":"and the hurdles remain huge .","depth":6},{"id":21,"text":"Mr. Reid has rejected every request","depth":8},{"id":22,"text":"Republicans have made ,","depth":8},{"id":23,"text":"including most recently a proposal","depth":9},{"id":24,"text":"circulated by Sen. Susan Collins , Maine Republican ,","depth":9},{"id":25,"text":"that would have repealed a despised Obamacare tax","depth":10},{"id":26,"text":"and given the White House more flexibility","depth":11},{"id":27,"text":"to manage the sequesters ,","depth":11},{"id":28,"text":"in return for opening up the government","depth":10},{"id":29,"text":"and passing a debt increase .","depth":10},{"id":30,"text":"Mr. Reid said","depth":7},{"id":31,"text":"the government must be opened","depth":8},{"id":32,"text":"and the debt increased","depth":9},{"id":33,"text":"without any conditions .","depth":9},{"id":34,"text":"But Republicans said","depth":9},{"id":35,"text":"they can not accept a debt increase with no strings ,","depth":9},{"id":36,"text":"and they led a filibuster of Mr. Reid ' s plan ,","depth":9},{"id":37,"text":"which would have let Mr. Obama add more debt for 15 months","depth":10},{"id":38,"text":"without any controls .","depth":10},{"id":39,"text":"The GOP said","depth":8},{"id":40,"text":"that would have amounted to $ 1.1 trillion .","depth":8},{"id":41,"text":"\" After watching President Obama add over six trillion dollars to our debt","depth":9},{"id":42,"text":"since taking office ,","depth":9},{"id":43,"text":"I can not support a clean debt limit increase , \"","depth":8},{"id":44,"text":"said Sen. John Cornyn , Texas Republican .","depth":7},{"id":45,"text":"The government only has enough wiggle room","depth":7},{"id":46,"text":"to last through Thursday","depth":7},{"id":47,"text":"before it will be unable to avoid its $ 16.7 trillion debt limit ,","depth":7},{"id":48,"text":"and will have to stop borrowing .","depth":7},{"id":49,"text":"At that point , it can only pay out as much","depth":7},{"id":50,"text":"as it is taking in each day in taxes ,","depth":7},{"id":51,"text":"which means an average of about 20 percent in spending cuts .","depth":6},{"id":52,"text":"That is on top of the partial government shutdown ,","depth":5},{"id":53,"text":"which began Oct. 1","depth":6},{"id":54,"text":"when Congress and Mr. Obama weren ' t able to agree on how to fund the government in fiscal year 2014 .","depth":6},{"id":55,"text":"House Republicans and the White House had both said","depth":5},{"id":56,"text":"they were making progress over the previous two days ,","depth":5},{"id":57,"text":"saying","depth":5},{"id":58,"text":"that they had cleared the air","depth":6},{"id":59,"text":"and that the GOP was working","depth":7},{"id":60,"text":"to see","depth":8},{"id":61,"text":"if it could find an offer","depth":9},{"id":62,"text":"Mr. Obama could accept .","depth":9},{"id":63,"text":"But by Saturday morning Republicans were accusing the White House of negotiating in bad faith ,","depth":4},{"id":64,"text":"and Mr. Reid declared the White House talks dead .","depth":5},{"id":65,"text":"\" That ' s over with .","depth":8},{"id":66,"text":"It ' s done .","depth":8},{"id":67,"text":"They ' re not talking anymore , \"","depth":7},{"id":68,"text":"Senate Majority Leader Harry Reid said","depth":7},{"id":69,"text":"as he opened his chamber .","depth":7}],"relations":[{"parent":139,"left":75,"right":138,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":0,"right":74,"relation":"context","nuclearity":"SN"},{"parent":74,"left":72,"right":73,"relation":"attribution","nuclearity":"SN"},{"parent":72,"left":71,"right":3,"relation":"same-unit","nuclearity":"NN"},{"parent":71,"left":1,"right":2,"relation":"elaboration","nuclearity":"NS"},{"parent":73,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":138,"left":123,"right":137,"relation":"elaboration","nuclearity":"NS"},{"parent":123,"left":113,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":113,"left":89,"right":112,"relation":"elaboration","nuclearity":"NS"},{"parent":89,"left":86,"right":88,"relation":"adversative","nuclearity":"NS"},{"parent":86,"left":81,"right":85,"relation":"elaboration","nuclearity":"NS"},{"parent":81,"left":77,"right":80,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":6,"right":76,"relation":"adversative","nuclearity":"SN"},{"parent":76,"left":7,"right":8,"relation":"joint","nuclearity":"NN"},{"parent":80,"left":9,"right":79,"relation":"attribution","nuclearity":"SN"},{"parent":79,"left":10,"right":78,"relation":"elabor