rity":"NN"},{"parent":279,"left":257,"right":278,"relation":"joint","nuclearity":"NN"},{"parent":257,"left":239,"right":256,"relation":"explanation","nuclearity":"NS"},{"parent":239,"left":49,"right":50,"relation":"evaluation","nuclearity":"SN"},{"parent":256,"left":242,"right":255,"relation":"explanation","nuclearity":"NS"},{"parent":242,"left":51,"right":241,"relation":"adversative","nuclearity":"SN"},{"parent":241,"left":52,"right":240,"relation":"elaboration","nuclearity":"NS"},{"parent":240,"left":53,"right":54,"relation":"adversative","nuclearity":"NS"},{"parent":255,"left":246,"right":254,"relation":"elaboration","nuclearity":"NS"},{"parent":246,"left":55,"right":245,"relation":"elaboration","nuclearity":"NS"},{"parent":245,"left":243,"right":244,"relation":"elaboration","nuclearity":"NS"},{"parent":243,"left":56,"right":57,"relation":"joint","nuclearity":"NN"},{"parent":244,"left":58,"right":59,"relation":"elaboration","nuclearity":"NS"},{"parent":254,"left":247,"right":253,"relation":"explanation","nuclearity":"NS"},{"parent":247,"left":60,"right":61,"relation":"mode","nuclearity":"NS"},{"parent":253,"left":251,"right":252,"relation":"evaluation","nuclearity":"NS"},{"parent":251,"left":250,"right":66,"relation":"context","nuclearity":"SN"},{"parent":250,"left":248,"right":249,"relation":"same-unit","nuclearity":"NN"},{"parent":248,"left":62,"right":63,"relation":"attribution","nuclearity":"SN"},{"parent":249,"left":64,"right":65,"relation":"elaboration","nuclearity":"NS"},{"parent":252,"left":67,"right":68,"relation":"topic","nuclearity":"SN"},{"parent":278,"left":263,"right":277,"relation":"elaboration","nuclearity":"NS"},{"parent":263,"left":260,"right":262,"relation":"adversative","nuclearity":"SN"},{"parent":260,"left":69,"right":259,"relation":"elaboration","nuclearity":"NS"},{"parent":259,"left":70,"right":258,"relation":"elaboration","nuclearity":"NS"},{"parent":258,"left":71,"right":72,"relation":"elaboration","nuclearity":"NS"},{"parent":262,"left":73,"right":261,"relation":"elaboration","nuclearity":"NS"},{"parent":261,"left":74,"right":75,"relation":"adversative","nuclearity":"NS"},{"parent":277,"left":266,"right":276,"relation":"joint","nuclearity":"NN"},{"parent":266,"left":264,"right":265,"relation":"causal","nuclearity":"SN"},{"parent":264,"left":76,"right":77,"relation":"mode","nuclearity":"NS"},{"parent":265,"left":78,"right":79,"relation":"elaboration","nuclearity":"NS"},{"parent":276,"left":273,"right":275,"relation":"elaboration","nuclearity":"NS"},{"parent":273,"left":267,"right":272,"relation":"elaboration","nuclearity":"NS"},{"parent":267,"left":80,"right":81,"relation":"elaboration","nuclearity":"NS"},{"parent":272,"left":269,"right":271,"relation":"evaluation","nuclearity":"NS"},{"parent":269,"left":268,"right":84,"relation":"attribution","nuclearity":"NS"},{"parent":268,"left":82,"right":83,"relation":"context","nuclearity":"SN"},{"parent":271,"left":270,"right":87,"relation":"purpose","nuclearity":"NS"},{"parent":270,"left":85,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":275,"left":274,"right":90,"relation":"evaluation","nuclearity":"NS"},{"parent":274,"left":88,"right":89,"relation":"purpose","nuclearity":"NS"},{"parent":378,"left":316,"right":377,"relation":"joint","nuclearity":"NN"},{"parent":316,"left":305,"right":315,"relation":"elaboration","nuclearity":"NS"},{"parent":305,"left":280,"right":304,"relation":"elaboration","nuclearity":"NS"},{"parent":280,"left":91,"right":92,"relation":"adversative","nuclearity":"SN"},{"parent":304,"left":300,"right":303,"relation":"adversative","nuclearity":"NN"},{"parent":300,"left":288,"right":299,"relation":"joint","nuclearity":"NN"},{"parent":288,"left":285,"right":287,"relation":"context","nuclearity":"SN"},{"parent":285,"left":282,"right":284,"relation":"joint","nuclearity":"NN"},{"parent":282,"left":281,"right":95,"relation":"adversative","nuclearity":"SN"},{"parent":281,"left":93,"right":94,"relation":"elaboration","nuclearit