ight":119,"relation":"same-unit","nuclearity":"NN"},{"parent":255,"left":117,"right":118,"relation":"elaboration","nuclearity":"NS"},{"parent":266,"left":260,"right":265,"relation":"attribution","nuclearity":"SN"},{"parent":260,"left":259,"right":123,"relation":"same-unit","nuclearity":"NN"},{"parent":259,"left":121,"right":122,"relation":"elaboration","nuclearity":"NS"},{"parent":265,"left":261,"right":264,"relation":"adversative","nuclearity":"SN"},{"parent":261,"left":124,"right":125,"relation":"elaboration","nuclearity":"NS"},{"parent":264,"left":263,"right":129,"relation":"attribution","nuclearity":"NS"},{"parent":263,"left":126,"right":262,"relation":"elaboration","nuclearity":"NS"},{"parent":262,"left":127,"right":128,"relation":"elaboration","nuclearity":"NS"},{"parent":277,"left":130,"right":276,"relation":"elaboration","nuclearity":"NS"},{"parent":276,"left":269,"right":275,"relation":"elaboration","nuclearity":"NS"},{"parent":269,"left":268,"right":133,"relation":"elaboration","nuclearity":"NS"},{"parent":268,"left":131,"right":132,"relation":"causal","nuclearity":"SN"},{"parent":275,"left":271,"right":274,"relation":"adversative","nuclearity":"SN"},{"parent":271,"left":270,"right":136,"relation":"attribution","nuclearity":"NS"},{"parent":270,"left":134,"right":135,"relation":"context","nuclearity":"SN"},{"parent":274,"left":272,"right":273,"relation":"evaluation","nuclearity":"NS"},{"parent":272,"left":137,"right":138,"relation":"joint","nuclearity":"NN"},{"parent":273,"left":139,"right":140,"relation":"elaboration","nuclearity":"NS"}]}