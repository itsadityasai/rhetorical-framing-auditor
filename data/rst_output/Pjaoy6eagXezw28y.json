{"article_id":"Pjaoy6eagXezw28y","edus":[{"id":0,"text":"U.S. Senate Majority Leader Mitch McConnell","depth":4},{"id":1,"text":"( R-KY )","depth":4},{"id":2,"text":"arrives at the U.S. Capitol in Washington , U.S. December 16 , 2019 .","depth":3},{"id":3,"text":"( Jonathan Ernst/Reuters )","depth":2},{"id":4,"text":"Senate Majority Leader Mitch McConnell","depth":9},{"id":5,"text":"( R. , Ky. )","depth":9},{"id":6,"text":"has whipped the 51 votes","depth":8},{"id":7,"text":"required","depth":8},{"id":8,"text":"to establish the rules for President Trump ' s impending impeachment trial","depth":9},{"id":9,"text":"without a concrete agreement on witnesses ,","depth":9},{"id":10,"text":"according to multiple reports .","depth":6},{"id":11,"text":"McConnell told colleagues during a closed-door lunch on Tuesday","depth":7},{"id":12,"text":"that he had secured the necessary backing","depth":8},{"id":13,"text":"to begin President Trump ' s impeachment trial ,","depth":8},{"id":14,"text":"according to the Washington Post .","depth":6},{"id":15,"text":"Politico first reported","depth":5},{"id":16,"text":"that Republicans were growing increasingly confident in their ability","depth":6},{"id":17,"text":"to set the trial parameters","depth":7},{"id":18,"text":"without input from Democrats .","depth":7},{"id":19,"text":"The decision comes","depth":5},{"id":20,"text":"despite protests from Senate Minority Leader Chuck Schumer","depth":8},{"id":21,"text":"( D. , N.Y. ) ,","depth":8},{"id":22,"text":"who said","depth":8},{"id":23,"text":"that \" Republicans may run","depth":10},{"id":24,"text":"but they can ' t hide \" from the question","depth":10},{"id":25,"text":"of whether witnesses and documents will be called in the trial .","depth":9},{"id":26,"text":"\" There will be votes at the beginning on whether to call the four witnesses","depth":9},{"id":27,"text":"we ' ve proposed","depth":9},{"id":28,"text":"and subpoena the documents","depth":9},{"id":29,"text":"we ' ve identified , \"","depth":9},{"id":30,"text":"Schumer declared .","depth":7},{"id":31,"text":"Democrats have argued continuously","depth":6},{"id":32,"text":"that White House officials","depth":8},{"id":33,"text":"who have first-hand knowledge of President Trump ' s dealings with Ukraine , such as former adviser John Bolton ,","depth":8},{"id":34,"text":"should be required to testify during the trial .","depth":7},{"id":35,"text":"Bolton said Monday","depth":6},{"id":36,"text":"that he would testify","depth":7},{"id":37,"text":"if subpoenaed .","depth":7},{"id":38,"text":"McConnell has been planning the trial in the same format as that of former President Bill Clinton ,","depth":4},{"id":39,"text":"with opening arguments being held before a vote","depth":5},{"id":40,"text":"to determine which witnesses ,","depth":7},{"id":41,"text":"if any ,","depth":7},{"id":42,"text":"would be called to testify .","depth":6},{"id":43,"text":"Senate Majority Whip John Thune","depth":9},{"id":44,"text":"( R. , S.D . )","depth":9},{"id":45,"text":"said before the lunch","depth":8},{"id":46,"text":"that Republican leadership was \" \" trying to get consensus among Republicans","depth":8},{"id":47,"text":"about how to go forward . \"","depth":8},{"id":48,"text":"\" We are taking the temperature of our members","depth":8},{"id":49,"text":"to see where they are","depth":8},{"id":50,"text":"but I ' m hoping","depth":9},{"id":51,"text":"our members will be prepared to move forward along the lines of the Clinton rules","depth":10},{"id":52,"text":"which is what we think","depth":11},{"id":53,"text":"makes sense , \"","depth":11},{"id":54,"text":"Thune said .","depth":8},{"id":55,"text":"\" What we ' re aspiring to do is to get this process moving forward","depth":6},{"id":56,"text":"and indicate to the Democrats","depth":7},{"id":57,"text":"that","depth":8},{"id":58,"text":"as soon as they send those articles over here ,","depth":9},{"id":59,"text":"we ' re ready to go . \"","depth":9},{"id":60,"text":"House Speaker Nancy Pelosi","depth":7},{"id":61,"text":"( D. , Calif. )","depth":7},{"id":62,"text":"has delayed sending the articles over to the Senate ,","depth":6},{"id":63,"text":"but Republicans have been ramping up pressure on her","depth":7},{"id":64,"text":"to deliver them ,","depth":7},{"id":65,"text":"with Senator Josh Hawley","depth":8},{"id":66,"text":"( R. , Mo . )","depth":8},{"id":67,"text":"introducing a resolution on Monday","depth":8},{"id":68,"text":"that would preemptively dismiss the articles","depth":9},{"id":69,"text":"if they ' re not sent over in a timely manner .","depth":9}],"relations":[{"parent":139,"left":73,"right":138,"relation":"context","nuclearity":"SN"},{"parent":73,"left":72,"right":3,"relation":"attribution","nuclearity":"NS"},{"parent":72,"left":71,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":71,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":138,"left":106,"right":137,"relation":"elaboration","nuclearity":"NS"},{"parent":106,"left":87,"right":105,"relation":"elaboration","nuclearity":"NS"},{"parent":87,"left":83,"right":86,"relation":"elaboration","nuclearity":"NS"},{"parent":83,"left":79,"right":82,"relation":"elaboration","nuclearity":"NS"},{"parent":79,"left":78,"right":10,"relation":"attribution","nuclearity":"NS"},{"parent":78,"left":75,"right":77,"relation":"elaboration","nuclearity":"NS"},{"parent":75,"left":74,"right":6,"relation":"same-unit","nuclearity":"NN"},{"parent":74,"left":4,"right":5,"relation":"elaboration","nuclearity":"NS"},{"parent":77,"left":7,"right":76,"relation":"purpose","nuclearity":"NS"},{"parent":76,"left":8,"right":9,"relation":"mode","nuclearity":"NS"},{"parent":82,"left":81,"right":14,"relation":"attribution","nuclearity":"NS"},{"parent":81,"left":11,"right":80,"relation":"attribution","nuclearity":"SN"},{"parent":80,"left":12,"right":13,"relation":"purpose","nuclearity":"NS"},{"parent":86,"left":15,"right":85,"relation":"attribution","nuclearity":"SN"