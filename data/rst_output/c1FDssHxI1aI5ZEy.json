rity":"SN"},{"parent":348,"left":340,"right":347,"relation":"elaboration","nuclearity":"NS"},{"parent":340,"left":335,"right":339,"relation":"elaboration","nuclearity":"NS"},{"parent":335,"left":332,"right":334,"relation":"adversative","nuclearity":"NN"},{"parent":332,"left":158,"right":159,"relation":"context","nuclearity":"NS"},{"parent":334,"left":333,"right":162,"relation":"same-unit","nuclearity":"NN"},{"parent":333,"left":160,"right":161,"relation":"elaboration","nuclearity":"NS"},{"parent":339,"left":336,"right":338,"relation":"adversative","nuclearity":"NN"},{"parent":336,"left":163,"right":164,"relation":"attribution","nuclearity":"SN"},{"parent":338,"left":165,"right":337,"relation":"attribution","nuclearity":"SN"},{"parent":337,"left":166,"right":167,"relation":"elaboration","nuclearity":"NS"},{"parent":347,"left":342,"right":346,"relation":"causal","nuclearity":"SN"},{"parent":342,"left":168,"right":341,"relation":"context","nuclearity":"SN"},{"parent":341,"left":169,"right":170,"relation":"attribution","nuclearity":"SN"},{"parent":346,"left":171,"right":345,"relation":"elaboration","nuclearity":"NS"},{"parent":345,"left":172,"right":344,"relation":"elaboration","nuclearity":"NS"},{"parent":344,"left":173,"right":343,"relation":"joint","nuclearity":"NN"},{"parent":343,"left":174,"right":175,"relation":"attribution","nuclearity":"SN"},{"parent":352,"left":176,"right":351,"relation":"attribution","nuclearity":"SN"},{"parent":351,"left":177,"right":350,"relation":"elaboration","nuclearity":"NS"},{"parent":350,"left":178,"right":179,"relation":"elaboration","nuclearity":"NS"}]}