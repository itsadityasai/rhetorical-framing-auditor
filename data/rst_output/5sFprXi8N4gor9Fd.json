"nuclearity":"SN"},{"parent":335,"left":332,"right":334,"relation":"attribution","nuclearity":"SN"},{"parent":332,"left":331,"right":156,"relation":"same-unit","nuclearity":"NN"},{"parent":331,"left":154,"right":155,"relation":"elaboration","nuclearity":"NS"},{"parent":334,"left":157,"right":333,"relation":"context","nuclearity":"NS"},{"parent":333,"left":158,"right":159,"relation":"elaboration","nuclearity":"NS"},{"parent":351,"left":340,"right":350,"relation":"joint","nuclearity":"NN"},{"parent":340,"left":160,"right":339,"relation":"explanation","nuclearity":"NS"},{"parent":339,"left":161,"right":338,"relation":"attribution","nuclearity":"SN"},{"parent":338,"left":162,"right":337,"relation":"same-unit","nuclearity":"NN"},{"parent":337,"left":163,"right":164,"relation":"context","nuclearity":"SN"},{"parent":350,"left":346,"right":349,"relation":"elaboration","nuclearity":"NS"},{"parent":346,"left":341,"right":345,"relation":"elaboration","nuclearity":"NS"},{"parent":341,"left":165,"right":166,"relation":"attribution","nuclearity":"SN"},{"parent":345,"left":343,"right":344,"relation":"adversative","nuclearity":"SN"},{"parent":343,"left":167,"right":342,"relation":"joint","nuclearity":"NN"},{"parent":342,"left":168,"right":169,"relation":"joint","nuclearity":"NN"},{"parent":344,"left":170,"right":171,"relation":"context","nuclearity":"NS"},{"parent":349,"left":347,"right":348,"relation":"attribution","nuclearity":"SN"},{"parent":347,"left":172,"right":173,"relation":"context","nuclearity":"SN"},{"parent":348,"left":174,"right":175,"relation":"joint","nuclearity":"NN"},{"parent":357,"left":355,"right":356,"relation":"joint","nuclearity":"NN"},{"parent":355,"left":176,"right":177,"relation":"purpose","nuclearity":"NS"},{"parent":356,"left":178,"right":179,"relation":"purpose","nuclearity":"NS"}]}