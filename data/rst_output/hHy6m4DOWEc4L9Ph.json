{"article_id":"hHy6m4DOWEc4L9Ph","edus":[{"id":0,"text":"Puerto Rico ' s decision","depth":4},{"id":1,"text":"to cancel its contract with Whitefish Energy Holdings LLC , a small Montana-based company with ties to the Trump administration ,","depth":4},{"id":2,"text":"has thrown the island ' s electricity restoration efforts into disarray .","depth":3},{"id":3,"text":"Puerto Rico Electric Power Authority","depth":7},{"id":4,"text":"( PREPA )","depth":7},{"id":5,"text":"CEO Ricardo Ramos said Sunday","depth":6},{"id":6,"text":"he would move to cancel the $ 300 million contract with Whitefish Energy ,","depth":6},{"id":7,"text":"which has drawn intense scrutiny .","depth":6},{"id":8,"text":"The cancellation comes on the heels of revelations","depth":6},{"id":9,"text":"that the contract was awarded to a company with deep ties to Trump donors and Interior Secretary Ryan Zinke .","depth":6},{"id":10,"text":"The contract included a clause","depth":6},{"id":11,"text":"that barred the government from reviewing the company ' s profits","depth":7},{"id":12,"text":"related to its electric grid work .","depth":7},{"id":13,"text":"While Puerto Rico Gov . Ricardo A. Rosselló contends","depth":5},{"id":14,"text":"power restoration efforts will remain on schedule ,","depth":5},{"id":15,"text":"PREPA Executive Director Ricardo Ramos warned","depth":5},{"id":16,"text":"that cancellation of the contract could cause up to 12-week delay","depth":6},{"id":17,"text":"in getting electricity turned on for residents across the island .","depth":6},{"id":18,"text":"Hurricane Maria devastated Puerto Rico more than 40 days ago ,","depth":7},{"id":19,"text":"yet only about 30 percent of utility customers on the island have had their power restored .","depth":7},{"id":20,"text":"New York Gov . Andrew Cuomo","depth":10},{"id":21,"text":"( D )","depth":10},{"id":22,"text":"said Sunday","depth":9},{"id":23,"text":"he plans to deploy additional utility crews and equipment","depth":9},{"id":24,"text":"to help Puerto Rico jump-start the repairs .","depth":9},{"id":25,"text":"\" It ' s very hard to get the society up and running","depth":9},{"id":26,"text":"until you have the power restored .","depth":9},{"id":27,"text":"And there ' s been very little progress on the power , \"","depth":9},{"id":28,"text":"Cuomo told CNN .","depth":9},{"id":29,"text":"New York previously deployed resources to Puerto Rico","depth":9},{"id":30,"text":"immediately following Hurricane Maria .","depth":9},{"id":31,"text":"New York is deploying additional utility crews and equipment","depth":9},{"id":32,"text":"to help restore power in Puerto Rico .","depth":9},{"id":33,"text":"- Andrew Cuomo","depth":8},{"id":34,"text":"( @ NYGovCuomo )","depth":8},{"id":35,"text":"October 29 , 2017","depth":6},{"id":36,"text":"Rosselló said in a press conference on Sunday","depth":6},{"id":37,"text":"that the island would coordinate with New York and Florida","depth":7},{"id":38,"text":"to reinforce electric power brigades .","depth":7},{"id":39,"text":"To further help with relief efforts ,","depth":7},{"id":40,"text":"Cuomo has organized a 28-person power restoration team","depth":8},{"id":41,"text":"consisting of engineers and supervisors","depth":9},{"id":42,"text":"that specialize in the supervision of transmission and distribution system recovery .","depth":9},{"id":43,"text":"The workers ,","depth":8},{"id":44,"text":"pulled from various utility companies across New York State ,","depth":8},{"id":45,"text":"reportedly will be deployed in early November .","depth":7},{"id":46,"text":"Sen. Maria Cantwell","depth":9},{"id":47,"text":"( D-WA ) ,","depth":9},{"id":48,"text":"the ranking member of the Senate Energy and Natural Resources Committee , welcomed the decision","depth":9},{"id":49,"text":"to cancel the Whitefish Energy contract","depth":9},{"id":50,"text":"and stressed","depth":8},{"id":51,"text":"that an investigation","depth":10},{"id":52,"text":"into how the contract came about","depth":10},{"id":53,"text":"should continue .","depth":9},{"id":54,"text":"\" Taxpayers should pay a fair rate for the emergency repairs","depth":9},{"id":55,"text":"Puerto Rico desperately needs","depth":9},{"id":56,"text":"- not be gouged by Whitefish Energy or anyone else , \"","depth":8},{"id":57,"text":"Cantwell said in a statement .","depth":7},{"id":58,"text":"PREPA ' s contract with Whitefish Energy raised red flags","depth":9},{"id":59,"text":"soon after it was signed .","depth":9},{"id":60,"text":"The company ,","depth":11},{"id":61,"text":"based in Whitefish , Montana ,","depth":11},{"id":62,"text":"was was tiny two-person operation with annual revenues of only $ 1 million .","depth":10},{"id":63,"text":"The company also appeared to have close ties to Zinke ,","depth":11},{"id":64,"text":"who lives in Whitefish .","depth":11},{"id":65,"text":"Zinke and Whitefish Energy CEO Andy Techmanski have denied any wrongdoing ,","depth":12},{"id":66,"text":"but both acknowledged","depth":13},{"id":67,"text":"that they have known each other for years .","depth":13},{"id":68,"text":"One of Zinke ' s sons worked as a flagger at construction sites","depth":12},{"id":69,"text":"where Whitefish Energy was operating .","depth":12},{"id":70,"text":"Among Whitefish Energy ' s investors is the Dallas-based HBC Investments LLC .","depth":8},{"id":71,"text":"Joseph Colonnetta , founding and general partner of HBC , donated $ 5,400 to Donald Trump ' s presidential campaign and $ 14,600 to the Republican National Committee through the Trump Victory fund ,","depth":9},{"id":72,"text":"set up","depth":10},{"id":73,"text":"to raise money from big donors .","depth":10},{"id":74,"text":"On Monday , the Wall Street Journal reported","depth":9},{"id":75,"text":"that the FBI is investigating PREPA ' s contract with Whitefish Energy .","depth":9},{"id":76,"text":"FBI agents from the San Juan field office are looking into the deal ,","depth":10},{"id":77,"text":"the newspaper said ,","depth":10},{"id":78,"text":"citing three people familiar with the matter .","depth":9},{"id":79,"text":"PREPA also has signed a $ 200 million contract with Cobra Acquisitions LLC","depth":12},{"id":80,"text":"to support the work on the island by Whitefish Energy","depth":13},{"id":81,"text":"to restore the main lines of transmission .","depth":13},{"id":82,"text":"Cobra , a subsidiary of Mammoth Energy Services , is based in Oklahoma .","depth":11},{"id":83,"text":"Mammoth executives said","depth":13},{"id":84,"text":"officials with FEMA were \" involved every step of the way","depth":14},{"id":85,"text":"to make sure","depth":15},{"id":86,"text":"the contract complies with their reimbursement requirements. \"","depth":15},{"id":87,"text":"Prior to beginning any work ,","depth":14},{"id":88,"text":"Mammoth received a $ 15 million up-front payment ,","depth":14},{"id":89,"text":"and billing will occur twice weekly .","depth":13},{"id":90,"text":"Mammoth spokesman Matt Wagner said","depth":12},{"id":91,"text":"the company is confident","depth":13},{"id":92,"text":"its contract with PREPA will withstand scrutiny .","depth":13},{"id":93,"text":"The subsidiary was formed last spring","depth":10},{"id":94,"text":"and currently has 275 employees .","depth":10},{"id":95,"text":"Arty Straehla , Mammoth ' s CEO , said on a October 20 conference call","depth":10},{"id":96,"text":"that Cobra ' s primary clients are electric utilities","depth":11},{"id":97,"text":"and that","depth":12},{"id":98,"text":"prior to winning the Puerto Rico contract ,","depth":13},{"id":99,"text":"the subsidiary had sent crews","depth":14},{"id":100,"text":"to help with recovery efforts in Texas","depth":16},{"id":101,"text":"following Hurricane Harvey","depth":16},{"id":102,"text":"and in Florida","depth":16},{"id":103,"text":"following Hurricane Irma .","depth":16},{"id":104,"text":"The contract was completed on October 20 ,","depth":11},{"id":105,"text":"and within days Cobra had a 60-person advance crew on the island","depth":12},{"id":106,"text":"starting to set up a base of operation .","depth":12},{"id":107,"text":"Over the coming weeks , more than 500 workers will be mobilized to the island","depth":12},{"id":108,"text":"to help restore the electric utility infrastructure ,","depth":12},{"id":109,"text":"Cobra said in a statement .","depth":11},{"id":110,"text":"Last week , Whitefish Energy reportedly hired a former House member","depth":10},{"id":111,"text":"to lobby on its behalf","depth":10},{"id":112,"text":"as lawmakers called for investigations into its contract with PREPA .","depth":9},{"id":113,"text":"Former Rep. Dennis Cardoza","depth":11},{"id":114,"text":"( D-CA )","depth":11},{"id":115,"text":"told Politico","depth":10},{"id":116,"text":"that he would \" meet people on the Hill \"","depth":10},{"id":117,"text":"to make the case","depth":11},{"id":118,"text":"that Whitefish Energy won the contract fairly .","depth":11},{"id":119,"text":"The Sierra Club described the Whitefish Energy contract as \" only the latest scandal \" for the Trump administration .","depth":8},{"id":120,"text":"\" Puerto Ricans need someone","depth":12},{"id":121,"text":"capable of turning on the lights","depth":12},{"id":122,"text":"which obtains its contract through an open and transparent process","depth":12},{"id":123,"text":"in order to transform the electric grid ,","depth":12},{"id":124,"text":"not one","depth":11},{"id":125,"text":"mired in controversy , \"","depth":11},{"id":126,"text":"Ramón Cruz , a member of the Sierra Club ' s national board and former member of the Puerto Rico Energy Commission , said in a statement .","depth":9},{"id":127,"text":"With power still out across three-quarters of Puerto Rico ,","depth":9},{"id":128,"text":"the need for electricity remains urgent .","depth":9},{"id":129,"text":"https : //t.co/gA8Lp3PFcK","depth":9},{"id":130,"text":"pic.twitter.com/QFSjtnycYq","depth":9},{"id":131,"text":"- Mark Hand","depth":9},{"id":132,"text":"( @ MarkFHand )","depth":9},{"id":133,"text":"October 26 , 2017","depth":8},{"id":134,"text":"Like Cantwell , Cruz said","depth":8},{"id":135,"text":"Congress must continue to investigate how a company with close ties to Zinke and Trump donors obtained the contract in the first place .","depth":8},{"id":136,"text":"\" The ongoing devastation in Puerto Rico should never have been used","depth":10},{"id":137,"text":"to profit friends of this administration ,","depth":10},{"id":138,"text":"and we the people deserve answers , \"","depth":9},{"id":139,"text":"he said .","depth":8},{"id":140,"text":"Rosselló had said","depth":8},{"id":141,"text":"the Whitefish Energy contract had become a \" distraction \"","depth":9},{"id":142,"text":"when the real focus should be restoring power to the island .","depth":9},{"id":143,"text":"In a statement Sunday , Whitefish Energy said","depth":10},{"id":144,"text":"the decision","depth":12},{"id":145,"text":"to cancel the contract","depth":12},{"id":146,"text":"will \" only delay what the people of Puerto Rico want and deserve","depth":12},{"id":147,"text":"- to have the power restored quickly in the same manner","depth":13},{"id":148,"text":"their fellow citizens on the mainland experience after a natural disaster . \"","depth":13},{"id":149,"text":"Nonetheless , Whitefish Energy said","depth":11},{"id":150,"text":"it plans to finish any work","depth":12},{"id":151,"text":"that PREPA wants the company to complete .","depth":12},{"id":152,"text":"The company said","depth":13},{"id":153,"text":"its ability","depth":15},{"id":154,"text":"to mobilize immediately","depth":15},{"id":155,"text":"\" exceeded all other efforts by other parties. \"","depth":14},{"id":156,"text":"In less than a month , the company brought 350 workers","depth":14},{"id":157,"text":"and was on track to have more than 500 workers on the island by this week ,","depth":14},{"id":158,"text":"it said .","depth":13},{"id":159,"text":"Whitefish Energy said","depth":12},{"id":160,"text":"it completed \" significant work \" on two major transmission lines","depth":14},{"id":161,"text":"that crossed over mountains","depth":14},{"id":162,"text":"and conducted \" critical work \" on remote parts of southern Puerto Rico ,","depth":14},{"id":163,"text":"which are accessible only by helicopter and heavy equipment .","depth":14},{"id":164,"text":"Despite the cancellation of the contract ,","depth":11},{"id":165,"text":"PREPA said","depth":13},{"id":166,"text":"it remains \" on track \"","depth":14},{"id":167,"text":"to reach the target of 95 percent of power restoration by December ,","depth":14},{"id":168,"text":"according to María Soledad , a reporter with Caribbean Business .","depth":12},{"id":169,"text":"In mid-October , Rosselló said","depth":13},{"id":170,"text":"his goal was to have 30 percent of the island ' s power restored by the end of the month .","depth":13},{"id":171,"text":"After that , the target would be to restore 50 percent by November 15 , 80 percent by December 1 , and 95 percent by December 15 .","depth":12},{"id":172,"text":"`` We are on track '' to reach the target of 95 % of energy generation by Dec.","depth":12},{"id":173,"text":"said Power Authority Dir @ CaribBusiness - María Soledad","depth":13},{"id":174,"text":"( @ Maria_Soledad7 )","depth":13},{"id":175,"text":"October 29 , 2017","depth":9},{"id":176,"text":"Why the government of Puerto Rico decided to forgo mutual aid agreements","depth":5},{"id":177,"text":"and instead signed the agreement with Whitefish Energy","depth":5},{"id":178,"text":"remains an unanswered question .","depth":4},{"id":179,"text":"\" No one in Puerto Rico , not Rosselló nor PREPA Executive Director Ricardo Ramos , has satisfactorily explained the decision","depth":6},{"id":180,"text":"to put off bringing in external crews and equipment","depth":8},{"id":181,"text":"and forego mutual aid agreements ,","depth":8},{"id":182,"text":"which raises suspicions","depth":8},{"id":183,"text":"that the job had been set aside from the outset for mainland private interests , \"","depth":8},{"id":184,"text":"Armando Valdés Prieto , former director of Puerto Rico ' s Office of Management and Budget , wrote in an op-ed","depth":6},{"id":185,"text":"published Monday in the Washington Post .","depth":6},{"id":186,"text":"The cancellation of the contract raises many questions ,","depth":6},{"id":187,"text":"Valdés Prieto wrote .","depth":6},{"id":188,"text":"How much more will Puerto Rico have to pay on top of the $ 8 million to $ 10 million","depth":8},{"id":189,"text":"PREPA said","depth":9},{"id":190,"text":"it has already been disbursed","depth":9},{"id":191,"text":"to demobilize work crews under the contract ' s cancellation clause ?","depth":7},{"id":192,"text":"How will PREPA make up for 10- to 12-week delay","depth":7},{"id":193,"text":"that","depth":9},{"id":194,"text":"Ramos predicted","depth":9},{"id":195,"text":"could result from the termination of the contract ?","depth":8}],"relations":[{"parent":391,"left":213,"right":390,"relation":"elaboration","nuclearity":"NS"},{"parent":213,"left":198,"right":212,"relation":"elaboration","nuclearity":"NS"},{"parent":198,"left":197,"right":2,"relation":"same-unit","nuclearity":"NN"},{"parent":197,"left":0,"right":1,"relation":"elaboration","nuclearity":"NS"},{"parent":212,"left":207,"right":211,"relation":"evaluation","nuclearity":"NS"},{"parent":207,"left":202,"right":206,"relation":"context","nuclearity":"NS"},{"parent":202,"left":200,"right":201,"relation":"attribution","nuclearity":"SN"},{"parent":200,"left":199,"right":5,"relation":"same-unit","nuclearity":"NN"},{"parent":199,"left":3,"right":4,"relation":"restatement","nuclearity":"NS"},{"parent":201,"left":6,"right":7,"relation":"elaboration","nuclearity":"NS"},{"parent":206,"left":203,"right":205,"relation":"elaboration","nuclearity":"NS"},{"parent":203,"left":8,"right":9,"relation":"elaboration","nuclearity":"NS"},{"parent":205,"left":10,"right":204,"relation":"elaboration","nuclearity":"NS"},{"parent":204,"left":11,"right":12,"relation":"elaboration","nuclearity":"NS"},{"parent":211,"left":208,"right":210,"relation":"adversative","nuclearity":"SN"},{"parent":208,"left":13,"right":14,"relation":"attribution","nuclearity":"SN"},{"parent":210,"left":15,"right":209,"relation":"attribution","nuclearity":"SN"},{"parent":209,"left":16,"right":17,"relation":"elaboration","nuclearity":"NS"},{"parent":390,"left":370,"right":389,"relation":"elaboration","nuclearity":"NS"},{"parent":370,"left":240,"right":369,"relation":"elaboration","nuclearity":"NS"},{"parent":240,"left":230,"right":239,"relation":"elaboration","nuclearity":"NS"},{"parent":230,"left":223,"right":229,"relation":"context","nuclearity":"NS"},{"parent":223,"left":214,"right":222,"relation":"context","nuclearity":"SN"},{"parent":214,"left":18,"right":19,"relation":"context","nuclearity":"SN"},{"parent":222,"left":218,"right":221,"relation":"explanation","nuclearity":"NS"},{"parent":218,"left":216,"right":217,"relation":"attribution","nuclearity":"SN"},{"parent":216,"left":215,"right":22,"relation":"same-unit","nuclearity":"NN"},{"parent":215,"left":20,"right":21,"relation":"elaboration","nuclearity":"NS"},{"parent":217,"left":23,"right":24,"relation":"purpose","nuclearity":"NS"},{"parent":221,"left":219,"right":220,"relation":"elaboration","nuclearity":"NS"},{"parent":219,"left":25,"right":26,"relation":"context","nuclearity":"NS"},{"parent":220,"left":27,"right":28,"relation":"attribution","nuclearity":"NS"},{"parent":229,"left":228,"right":35,"relation":"context","nuclearity":"NS"},{"parent":228,"left":226,"right":227,"relation":"attribution","nuclearity":"NS"},{"parent":226,"left":224,"right":225,"relation":"context","nuclearity":"SN"},{"parent":224,"left":29,"right":30,"relation":"context","nuclearity":"NS"},{"parent":225,"left":31,"right":32,"relation":"purpose","nuclearity":"NS"},{"parent":227,"left":33,"right":34,"relation":"elaboration","nuclearity":"NS"},{"parent